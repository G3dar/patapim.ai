---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, getLocalePath } from '../i18n';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);

const sidebarTitles: Record<string, Record<string, string>> = {
  en: {
    releaseNotes: 'Release Notes',
    gettingStarted: 'Getting Started',
    coreConcepts: 'Core Concepts',
    features: 'Features',
    reference: 'Reference',
  },
  ja: {
    releaseNotes: 'リリースノート',
    gettingStarted: 'はじめに',
    coreConcepts: 'コアコンセプト',
    features: '機能',
    reference: 'リファレンス',
  },
};
const titles = sidebarTitles[locale] || sidebarTitles.en;

const sidebarLinks: Record<string, Record<string, Record<string, string>>> = {
  en: {
    releaseNotes: {
      'releases': 'All Releases',
    },
    gettingStarted: {
      'getting-started/installation': 'Installation',
      'getting-started/quick-start': 'Quick Start',
      'getting-started/system-requirements': 'System Requirements',
    },
    coreConcepts: {
      'core-concepts/terminal-first-philosophy': 'Terminal-First Philosophy',
      'core-concepts/patapim-projects': 'PATAPIM Projects',
      'core-concepts/context-preservation': 'Context Preservation',
    },
    features: {
      'features/multi-terminal': 'Multi-Terminal',
      'features/remote-access': 'Remote Access',
      'features/voice-dictation': 'Voice Dictation',
      'features/project-management': 'Project Management',
      'features/task-management': 'Task Management',
      'features/github-integration': 'GitHub Integration',
      'features/plugin-system': 'Plugin System',
      'features/mcp-browser-control': 'MCP Browser Control',
      'features/file-editor': 'File Editor',
      'features/session-persistence': 'Session Persistence',
      'features/passkey-auth': 'PassKey Authentication',
      'features/auto-updates': 'Auto-Updates',
      'features/account-licensing': 'Account & Licensing',
      'features/referral-program': 'Referral Program',
    },
    reference: {
      'reference/keyboard-shortcuts': 'Keyboard Shortcuts',
      'reference/configuration': 'Configuration',
      'reference/claude-md-reference': 'CLAUDE.md Reference',
      'reference/structure-json-reference': 'STRUCTURE.json Reference',
      'reference/tasks-json-reference': 'tasks.json Reference',
    },
  },
  ja: {
    releaseNotes: {
      'releases': '全リリース',
    },
    gettingStarted: {
      'getting-started/installation': 'インストール',
      'getting-started/quick-start': 'クイックスタート',
      'getting-started/system-requirements': 'システム要件',
    },
    coreConcepts: {
      'core-concepts/terminal-first-philosophy': 'ターミナルファースト思想',
      'core-concepts/patapim-projects': 'PATAPIMプロジェクト',
      'core-concepts/context-preservation': 'コンテキスト保持',
    },
    features: {
      'features/multi-terminal': 'マルチターミナル',
      'features/remote-access': 'リモートアクセス',
      'features/voice-dictation': '音声入力',
      'features/project-management': 'プロジェクト管理',
      'features/task-management': 'タスク管理',
      'features/github-integration': 'GitHub連携',
      'features/plugin-system': 'プラグインシステム',
      'features/mcp-browser-control': 'MCPブラウザ操作',
      'features/file-editor': 'ファイルエディタ',
      'features/session-persistence': 'セッション永続化',
      'features/passkey-auth': 'PassKey認証',
      'features/auto-updates': '自動アップデート',
      'features/account-licensing': 'アカウントとライセンス',
      'features/referral-program': '紹介プログラム',
    },
    reference: {
      'reference/keyboard-shortcuts': 'キーボードショートカット',
      'reference/configuration': '設定',
      'reference/claude-md-reference': 'CLAUDE.mdリファレンス',
      'reference/structure-json-reference': 'STRUCTURE.jsonリファレンス',
      'reference/tasks-json-reference': 'tasks.jsonリファレンス',
    },
  },
};
const links = sidebarLinks[locale] || sidebarLinks.en;

const sidebar = [
  {
    title: titles.gettingStarted,
    items: Object.entries(links.gettingStarted).map(([slug, label]) => ({ title: label, slug })),
  },
  {
    title: titles.coreConcepts,
    items: Object.entries(links.coreConcepts).map(([slug, label]) => ({ title: label, slug })),
  },
  {
    title: titles.features,
    items: Object.entries(links.features).map(([slug, label]) => ({ title: label, slug })),
  },
  {
    title: titles.reference,
    items: Object.entries(links.reference).map(([slug, label]) => ({ title: label, slug })),
  },
];
---

<BaseLayout title={`${title} — PATAPIM Docs`} description={description}>
  <Navbar />

  <div class="docs-layout">
    <aside class="docs-sidebar" id="docs-sidebar">
      <nav class="docs-nav">
        {sidebar.map((group) => (
          <div class="nav-group">
            <h4 class="nav-group-title"><span class="nav-prompt">$</span> {group.title.toLowerCase().replace(/\s+/g, '-')}</h4>
            <ul class="nav-group-items">
              {group.items.map((item) => (
                <li>
                  <a
                    href={lp(`/docs/${item.slug}`)}
                    class={`nav-item ${currentPath.includes(item.slug) ? 'active' : ''}`}
                  >
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <main class="docs-content">
      <article class="docs-article">
        <h1>{title}</h1>
        <slot />
      </article>
    </main>
  </div>

  <Footer />
</BaseLayout>

<style>
  /* Fixed shared navbar is 56px tall (see terminal.css .tv-nav) */
  .docs-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: 100vh;
    padding-top: 56px;
  }

  /* ---------- sidebar rail ---------- */
  .docs-sidebar {
    position: sticky;
    top: 56px;
    height: calc(100vh - 56px);
    overflow-y: auto;
    background: var(--bg-primary);
    border-right: 1px solid var(--border-subtle);
    padding: var(--space-xl) 0;
  }

  .docs-nav {
    padding: 0 var(--space-lg);
  }

  .nav-group {
    margin-bottom: var(--space-xl);
  }

  .nav-group-title {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--text-tertiary);
    padding: 0 var(--space-md);
    margin-bottom: var(--space-sm);
  }
  .nav-prompt {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }

  .nav-group-items {
    list-style: none;
  }

  .nav-item {
    display: block;
    padding: 5px var(--space-md);
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--text-tertiary);
    text-decoration: none;
    border-radius: 0;
    transition: color var(--transition-fast);
  }
  .nav-item:hover {
    color: #ffffff;
  }
  .nav-item.active {
    font-weight: 600;
    background: linear-gradient(120deg, #c26bf0, #8b7cf8, #22d3ee);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ---------- article ---------- */
  .docs-content {
    padding: var(--space-3xl) var(--space-4xl);
    max-width: 820px;
    min-width: 0;
  }

  /* var(--font-sans) resolves to JetBrains Mono in en and Noto Sans JP
     under :lang(ja) — never hard-code mono on body copy here. */
  .docs-article {
    font-family: var(--font-sans);
    font-size: 14.5px;
    line-height: 1.9;
  }

  .docs-article :global(h1) {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border-subtle);
  }

  .docs-article :global(h2) {
    position: relative;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.01em;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
    padding-bottom: 10px;
    color: var(--text-primary);
  }
  .docs-article :global(h2::after) {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg,
      rgba(194, 107, 240, 0.55),
      rgba(139, 124, 248, 0.35) 40%,
      rgba(34, 211, 238, 0.18) 70%,
      transparent);
  }

  .docs-article :global(h3) {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    color: var(--text-secondary);
  }

  .docs-article :global(p) {
    margin-bottom: var(--space-lg);
    color: var(--text-secondary);
  }
  .docs-article :global(strong) {
    color: var(--text-primary);
  }

  .docs-article :global(a) {
    color: var(--cy);
    text-decoration: none;
  }
  .docs-article :global(a:hover) {
    color: var(--cy);
    text-decoration: underline;
  }

  .docs-article :global(ul), .docs-article :global(ol) {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
    color: var(--text-secondary);
  }
  .docs-article :global(li) {
    margin-bottom: var(--space-sm);
  }
  .docs-article :global(li::marker) {
    color: var(--text-muted);
  }

  .docs-article :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: rgba(255, 255, 255, 0.06);
    color: var(--cy);
    padding: 1px 6px;
    border-radius: 0;
  }

  /* !important: shiki writes background-color inline on <pre> */
  .docs-article :global(pre) {
    background: #050505 !important;
    border: 1px solid var(--border-default);
    border-radius: 0;
    padding: var(--space-lg) var(--space-xl);
    font-size: 13px;
    line-height: 1.7;
    overflow-x: auto;
    margin-bottom: var(--space-lg);
  }
  .docs-article :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text-secondary);
    font-size: inherit;
  }

  .docs-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-xl);
    font-size: 13px;
  }
  .docs-article :global(th) {
    text-align: left;
    padding: 9px 14px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }
  .docs-article :global(td) {
    padding: 9px 14px;
    border: 1px solid var(--border-default);
    color: var(--text-secondary);
  }

  .docs-article :global(blockquote) {
    border-left: 2px solid var(--vi);
    padding: var(--space-md) var(--space-lg);
    margin: var(--space-lg) 0;
    background: rgba(167, 139, 250, 0.05);
    border-radius: 0;
    color: var(--text-secondary);
  }
  .docs-article :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .docs-article :global(img) {
    max-width: 100%;
    border-radius: 0;
    border: 1px solid var(--border-default);
  }

  .docs-article :global(hr) {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: var(--space-2xl) 0;
  }

  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
    }
    .docs-sidebar {
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--border-subtle);
    }
    .docs-content {
      padding: var(--space-xl);
    }
  }
</style>
