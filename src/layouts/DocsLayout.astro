---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, getLocalePath } from '../i18n';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);

const sidebarTitles: Record<string, Record<string, string>> = {
  en: {
    gettingStarted: 'Getting Started',
    coreConcepts: 'Core Concepts',
    features: 'Features',
    reference: 'Reference',
  },
  ja: {
    gettingStarted: 'はじめに',
    coreConcepts: 'コアコンセプト',
    features: '機能',
    reference: 'リファレンス',
  },
};
const titles = sidebarTitles[locale] || sidebarTitles.en;

const sidebarLinks: Record<string, Record<string, Record<string, string>>> = {
  en: {
    gettingStarted: {
      'getting-started/installation': 'Installation',
      'getting-started/quick-start': 'Quick Start',
      'getting-started/system-requirements': 'System Requirements',
    },
    coreConcepts: {
      'core-concepts/terminal-first-philosophy': 'Terminal-First Philosophy',
      'core-concepts/patapim-projects': 'PATAPIM Projects',
      'core-concepts/context-preservation': 'Context Preservation',
    },
    features: {
      'features/multi-terminal': 'Multi-Terminal',
      'features/remote-access': 'Remote Access',
      'features/voice-dictation': 'Voice Dictation',
      'features/project-management': 'Project Management',
      'features/task-management': 'Task Management',
      'features/github-integration': 'GitHub Integration',
      'features/plugin-system': 'Plugin System',
      'features/mcp-browser-control': 'MCP Browser Control',
      'features/file-editor': 'File Editor',
      'features/session-persistence': 'Session Persistence',
      'features/passkey-auth': 'PassKey Authentication',
      'features/auto-updates': 'Auto-Updates',
      'features/account-licensing': 'Account & Licensing',
      'features/referral-program': 'Referral Program',
    },
    reference: {
      'reference/keyboard-shortcuts': 'Keyboard Shortcuts',
      'reference/configuration': 'Configuration',
      'reference/claude-md-reference': 'CLAUDE.md Reference',
      'reference/structure-json-reference': 'STRUCTURE.json Reference',
      'reference/tasks-json-reference': 'tasks.json Reference',
    },
  },
  ja: {
    gettingStarted: {
      'getting-started/installation': 'インストール',
      'getting-started/quick-start': 'クイックスタート',
      'getting-started/system-requirements': 'システム要件',
    },
    coreConcepts: {
      'core-concepts/terminal-first-philosophy': 'ターミナルファースト思想',
      'core-concepts/patapim-projects': 'PATAPIMプロジェクト',
      'core-concepts/context-preservation': 'コンテキスト保持',
    },
    features: {
      'features/multi-terminal': 'マルチターミナル',
      'features/remote-access': 'リモートアクセス',
      'features/voice-dictation': '音声入力',
      'features/project-management': 'プロジェクト管理',
      'features/task-management': 'タスク管理',
      'features/github-integration': 'GitHub連携',
      'features/plugin-system': 'プラグインシステム',
      'features/mcp-browser-control': 'MCPブラウザ操作',
      'features/file-editor': 'ファイルエディタ',
      'features/session-persistence': 'セッション永続化',
      'features/passkey-auth': 'PassKey認証',
      'features/auto-updates': '自動アップデート',
      'features/account-licensing': 'アカウントとライセンス',
      'features/referral-program': '紹介プログラム',
    },
    reference: {
      'reference/keyboard-shortcuts': 'キーボードショートカット',
      'reference/configuration': '設定',
      'reference/claude-md-reference': 'CLAUDE.mdリファレンス',
      'reference/structure-json-reference': 'STRUCTURE.jsonリファレンス',
      'reference/tasks-json-reference': 'tasks.jsonリファレンス',
    },
  },
};
const links = sidebarLinks[locale] || sidebarLinks.en;

const sidebar = [
  {
    title: titles.gettingStarted,
    items: Object.entries(links.gettingStarted).map(([slug, label]) => ({ title: label, slug })),
  },
  {
    title: titles.coreConcepts,
    items: Object.entries(links.coreConcepts).map(([slug, label]) => ({ title: label, slug })),
  },
  {
    title: titles.features,
    items: Object.entries(links.features).map(([slug, label]) => ({ title: label, slug })),
  },
  {
    title: titles.reference,
    items: Object.entries(links.reference).map(([slug, label]) => ({ title: label, slug })),
  },
];
---

<BaseLayout title={`${title} — PATAPIM Docs`} description={description}>
  <Navbar />

  <div class="docs-layout">
    <aside class="docs-sidebar" id="docs-sidebar">
      <nav class="docs-nav">
        {sidebar.map((group) => (
          <div class="nav-group">
            <h4 class="nav-group-title">{group.title}</h4>
            <ul class="nav-group-items">
              {group.items.map((item) => (
                <li>
                  <a
                    href={lp(`/docs/${item.slug}`)}
                    class={`nav-item ${currentPath.includes(item.slug) ? 'active' : ''}`}
                  >
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <main class="docs-content">
      <article class="docs-article">
        <slot />
      </article>
    </main>
  </div>

  <Footer />
</BaseLayout>

<style>
  .docs-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: 100vh;
    padding-top: 64px;
  }

  .docs-sidebar {
    position: sticky;
    top: 64px;
    height: calc(100vh - 64px);
    overflow-y: auto;
    background: var(--bg-primary);
    border-right: 1px solid var(--border-default);
    padding: var(--space-xl) 0;
  }

  .docs-nav {
    padding: 0 var(--space-lg);
  }

  .nav-group {
    margin-bottom: var(--space-xl);
  }

  .nav-group-title {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    padding: 0 var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .nav-group-items {
    list-style: none;
  }

  .nav-item {
    display: block;
    padding: 6px var(--space-md);
    font-size: 14px;
    color: var(--text-tertiary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }
  .nav-item:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }
  .nav-item.active {
    color: var(--accent-primary);
    background: var(--accent-subtle);
    font-weight: 500;
  }

  .docs-content {
    padding: var(--space-3xl) var(--space-4xl);
    max-width: 800px;
  }

  .docs-article {
    line-height: 1.8;
  }

  .docs-article :global(h1) {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border-default);
  }

  .docs-article :global(h2) {
    font-size: 24px;
    font-weight: 600;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
    color: var(--text-primary);
  }

  .docs-article :global(h3) {
    font-size: 18px;
    font-weight: 600;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    color: var(--text-primary);
  }

  .docs-article :global(p) {
    margin-bottom: var(--space-lg);
    color: var(--text-secondary);
  }

  .docs-article :global(ul), .docs-article :global(ol) {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
    color: var(--text-secondary);
  }
  .docs-article :global(li) {
    margin-bottom: var(--space-sm);
  }

  .docs-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-xl);
    font-size: 14px;
  }
  .docs-article :global(th) {
    text-align: left;
    padding: 10px 16px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    font-weight: 600;
    color: var(--text-primary);
  }
  .docs-article :global(td) {
    padding: 10px 16px;
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
  }

  .docs-article :global(blockquote) {
    border-left: 3px solid var(--accent-primary);
    padding: var(--space-md) var(--space-lg);
    margin: var(--space-lg) 0;
    background: var(--accent-subtle);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--text-secondary);
  }

  .docs-article :global(img) {
    max-width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-default);
  }

  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
    }
    .docs-sidebar {
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--border-default);
    }
    .docs-content {
      padding: var(--space-xl);
    }
  }
</style>
