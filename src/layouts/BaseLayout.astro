---
import { getLocaleFromUrl, t } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const locale = getLocaleFromUrl(Astro.url);
const {
  title = t(locale, 'meta.defaultTitle'),
  description = t(locale, 'meta.defaultDescription'),
  ogImage = '/og-image.png',
  noindex = false
} = Astro.props;

// Build hreflang alternate URLs
const currentPath = Astro.url.pathname;
const enPath = currentPath.replace(/^\/ja(\/|$)/, '/');
const jaPath = enPath === '/' ? '/ja/' : `/ja${enPath}`;
const siteUrl = 'https://patapim.ai';
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- critical trio against the white navigation flash:
       1. meta color-scheme dark — Chrome uses this for the DEFAULT canvas
          between documents (the CSS property alone is too late for that frame)
       2. inline black background — first paint is black before any stylesheet
       3. inline view-transition opt-in — the incoming page's opt-in must not
          wait for external CSS. is:inline keeps all of it verbatim in HTML. -->
  <meta name="color-scheme" content="dark" />
  <style is:inline>html{background:#000;color-scheme:dark}@view-transition{navigation:auto}::view-transition{background-color:#000}::view-transition-old(root),::view-transition-new(root){animation:none!important}.tv-authed .tv-nav-signin,.tv-authed #mobile-signin{display:none}</style>
  <!-- auth state resolved BEFORE first paint from the cached flag, so the
       Sign In link never pops in post-paint and reflows the header. The
       session fetch (Navbar/home) only reconciles the cache afterwards. -->
  <script is:inline>try{if(localStorage.getItem('ptpm-authed')==='1')document.documentElement.classList.add('tv-authed')}catch(e){}</script>
  <meta name="theme-color" content="#000000" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:type" content="website" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />

  <!-- hreflang -->
  <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
  <link rel="alternate" hreflang="ja" href={`${siteUrl}${jaPath}`} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${enPath}`} />

  <!-- Canonical -->
  <link rel="canonical" href={`${siteUrl}${currentPath}`} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Directory ownership verification -->
  <meta name="saashub-verification" content="87b3aasv9g0x" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  {locale === 'ja' && (
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  )}

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Patapim",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Windows, macOS",
    "url": siteUrl,
    "offers": [
      { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      { "@type": "Offer", "price": "6.99", "priceCurrency": "USD" },
      { "@type": "Offer", "price": "59.99", "priceCurrency": "USD" }
    ]
  })} />

  <!-- Global CSS -->
  <style is:global>
    @import '../styles/global.css';
  </style>

  <!-- Speculative prefetch: hovering a link warms the next page so
       navigation lands instantly. Prefetch (not prerender): prerender
       activation has its own rendering path with white-flash bugs. -->
  <script type="speculationrules" set:html={JSON.stringify({
    prefetch: [{ where: { and: [{ href_matches: '/*' }] }, eagerness: 'moderate' }]
  })} />
</head>
<body>
  <div class="tv-scanlines" aria-hidden="true"></div>
  <slot />

  <!-- Terminal entrance: page content types itself in a fast cascade.
       Synchronous at end-of-body so it splits before first paint. The nav,
       footer and anything below ~1.35 viewports appear instantly — the shell
       never rewrites, only the section you navigated to "assembles". -->
  <script is:inline>
    (function () {
      try {
        if (document.getElementById('tv-boot')) return; // the home runs its own ceremony
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var EXCL = '.tv-nav,.site-nav,nav,footer,.tvf-footer,script,style,noscript,#session-bar,[data-no-type]';
        var vh = window.innerHeight || 800;
        var LIMIT = vh * 1.35;
        // pages tagged [data-type-cascade] get a looser, more organic build:
        // stronger top-to-bottom stagger, per-block speed variation, stutter
        var casc = !!document.querySelector('[data-type-cascade]');
        var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null);
        var nodes = [];
        while (walker.nextNode()) {
          var n = walker.currentNode;
          if (!n.nodeValue || !n.nodeValue.trim()) continue;
          var pe = n.parentElement;
          if (!pe || pe.closest(EXCL)) continue;
          nodes.push(n);
        }
        var tops = nodes.map(function (n) { return n.parentElement.getBoundingClientRect().top; });
        var jobs = [];
        nodes.forEach(function (n, i) {
          if (tops[i] > LIMIT) return; // below the fold: instant
          var full = n.nodeValue;
          var shown = document.createElement('span');
          var hidden = document.createElement('span');
          hidden.style.visibility = 'hidden';
          hidden.textContent = full;
          n.parentNode.replaceChild(hidden, n);
          hidden.parentNode.insertBefore(shown, hidden);
          jobs.push({
            s: shown, h: hidden, f: full, i: 0, st: casc,
            rate: Math.max(1, Math.ceil(full.length / (casc ? 10 + Math.random() * 30 : 22))),
            delay: casc
              ? Math.floor(Math.random() * 24 + Math.max(0, Math.min(tops[i], 1600)) / 1600 * 85)
              : Math.floor(Math.random() * 4 + Math.max(0, Math.min(tops[i], 1200)) / 1200 * 26)
          });
        });
        if (!jobs.length) return;
        function step() {
          var active = false;
          for (var k = 0; k < jobs.length; k++) {
            var j = jobs[k];
            if (j.delay > 0) { j.delay--; active = true; continue; }
            if (j.i < j.f.length) {
              active = true;
              if (j.st && Math.random() < 0.25) continue; // organic stutter
              j.i = Math.min(j.f.length, j.i + j.rate);
              j.s.textContent = j.f.slice(0, j.i);
              j.h.textContent = j.f.slice(j.i);
            }
          }
          if (active) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      } catch (e) { /* the flourish must never block a page */ }
    })();
  </script>

  <!-- SF geo beacon: records page opens + dwell time for SF visitors only.
       The server drops non-SF traffic, and a tracked:false reply stops the
       client from sending any further beacons. -->
  <script is:inline>
    (function () {
      try {
        var visitId = (crypto && crypto.randomUUID)
          ? crypto.randomUUID()
          : String(Date.now()) + '-' + Math.random().toString(36).slice(2);
        var openedAt = Date.now();
        var activeMs = 0;
        var lastResume = document.visibilityState === 'visible' ? openedAt : 0;
        var timer = null;
        var stopped = false;

        function dwell() {
          // Accumulated visible time, plus the currently-open visible segment.
          var live = lastResume ? (Date.now() - lastResume) : 0;
          return activeMs + live;
        }

        function payload(event) {
          return JSON.stringify({
            visitId: visitId,
            event: event,
            path: location.pathname + location.search,
            ref: document.referrer || '',
            durationMs: dwell(),
          });
        }

        function send(event, useBeacon) {
          if (stopped && event !== 'open') return;
          var body = payload(event);
          if (useBeacon && navigator.sendBeacon) {
            navigator.sendBeacon('/api/sf/track', new Blob([body], { type: 'application/json' }));
            return;
          }
          fetch('/api/sf/track', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: body,
            keepalive: true,
          })
            .then(function (r) { return r.json(); })
            .then(function (res) {
              if (event === 'open' && (!res || !res.tracked)) {
                stopped = true; // Not an SF visitor — stop beaconing.
                if (timer) { clearInterval(timer); timer = null; }
              }
            })
            .catch(function () {});
        }

        document.addEventListener('visibilitychange', function () {
          if (document.visibilityState === 'visible') {
            lastResume = Date.now();
          } else {
            if (lastResume) { activeMs += Date.now() - lastResume; lastResume = 0; }
            send('ping', true);
          }
        });

        window.addEventListener('pagehide', function () { send('close', true); });

        send('open', false);
        timer = setInterval(function () { send('ping', false); }, 20000);
      } catch (e) { /* tracking is best-effort */ }
    })();
  </script>
</body>
</html>
