---
import { getLocaleFromUrl, t } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const {
  title = t(locale, 'meta.defaultTitle'),
  description = t(locale, 'meta.defaultDescription'),
  ogImage = '/og-image.png'
} = Astro.props;

// Build hreflang alternate URLs
const currentPath = Astro.url.pathname;
const enPath = currentPath.replace(/^\/ja(\/|$)/, '/');
const jaPath = enPath === '/' ? '/ja/' : `/ja${enPath}`;
const siteUrl = 'https://patapim.ai';
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:type" content="website" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- hreflang -->
  <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
  <link rel="alternate" hreflang="ja" href={`${siteUrl}${jaPath}`} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${enPath}`} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  {locale === 'ja' && (
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  )}

  <!-- Global CSS -->
  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body>
  <slot />
</body>
</html>
