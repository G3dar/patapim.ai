---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getLocaleFromUrl, t, getLocalePath } from '../../../i18n';
import en from '../../../i18n/translations/en';
import ja from '../../../i18n/translations/ja';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);
const translations = locale === 'ja' ? ja : en;

const { code } = Astro.params;
const env = Astro.locals.runtime.env;

let status: 'valid' | 'invalid' | 'claimed' | 'expired' = 'invalid';
let invite: any = null;

if (code) {
  try {
    const raw = await env.LICENSES.get(`beta-invite:${code}`);
    if (raw) {
      invite = JSON.parse(raw);
      if (invite.claimedBy) {
        status = 'claimed';
      } else if (new Date(invite.expiresAt) < new Date()) {
        status = 'expired';
      } else {
        status = 'valid';
      }
    }
  } catch {
    // KV lookup failed — treat as invalid
  }
}

// Set beta cookie if valid (same pattern as __patapim_ref in referral system)
if (status === 'valid' && code) {
  Astro.cookies.set('__patapim_beta', code, {
    path: '/',
    secure: true,
    sameSite: 'lax',
    maxAge: 60 * 60 * 24 * 7, // 7 days
  });
}
---

<BaseLayout title={t(locale, 'meta.betaTitle')} description={t(locale, 'meta.betaDescription')}>
  <Navbar />

  <main class="beta-page">
    <div class="container">
      {status === 'invalid' && (
        <div class="beta-card">
          <div class="beta-icon error-icon">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="15" y1="9" x2="9" y2="15"/>
              <line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
          </div>
          <h1 class="beta-title">{t(locale, 'beta.invalidTitle')}</h1>
          <p class="beta-desc">{t(locale, 'beta.invalidDesc')}</p>
          <div class="beta-cta">
            <a href={lp('/')} class="btn btn-secondary">{t(locale, 'common.goToHomepage')}</a>
          </div>
        </div>
      )}

      {status === 'claimed' && (
        <div class="beta-card">
          <div class="beta-icon warn-icon">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h1 class="beta-title">{t(locale, 'beta.claimedTitle')}</h1>
          <p class="beta-desc">{t(locale, 'beta.claimedDesc')}</p>
          <div class="beta-cta">
            <a href={lp('/')} class="btn btn-secondary">{t(locale, 'common.goToHomepage')}</a>
          </div>
        </div>
      )}

      {status === 'expired' && (
        <div class="beta-card">
          <div class="beta-icon warn-icon">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h1 class="beta-title">{t(locale, 'beta.expiredTitle')}</h1>
          <p class="beta-desc">{t(locale, 'beta.expiredDesc')}</p>
          <div class="beta-cta">
            <a href={lp('/')} class="btn btn-secondary">{t(locale, 'common.goToHomepage')}</a>
          </div>
        </div>
      )}

      {status === 'valid' && (
        <div class="beta-card beta-card-valid">
          <div class="beta-badge">{t(locale, 'beta.badge')}</div>
          <h1 class="beta-title">{t(locale, 'beta.title')}</h1>
          <p class="beta-value">{t(locale, 'beta.freeProLifetime')} <span class="beta-value-note">{t(locale, 'beta.value')}</span></p>

          <ul class="beta-features">
            {translations.beta.features.map((feature) => (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {feature}
              </li>
            ))}
          </ul>

          <a href={`/api/auth/google?beta=${code}`} class="btn btn-primary beta-cta-btn">
            {t(locale, 'beta.claimButton')}
          </a>

          <p class="beta-note">{t(locale, 'beta.claimHint')}</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .beta-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 0 80px;
  }

  .beta-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 520px;
    width: 90%;
    margin: 0 auto;
    padding: var(--space-4xl) var(--space-3xl);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
  }

  .beta-card-valid {
    border-color: var(--accent-primary);
    box-shadow: 0 0 60px rgba(212, 165, 116, 0.12);
  }

  .beta-icon {
    margin-bottom: var(--space-xl);
  }

  .error-icon {
    color: var(--error, #ef4444);
  }

  .warn-icon {
    color: var(--warning, #e0a458);
  }

  .beta-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--accent-primary);
    background: rgba(212, 165, 116, 0.12);
    padding: 4px 16px;
    border-radius: 100px;
    margin-bottom: var(--space-lg);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .beta-title {
    font-size: 28px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-lg);
    line-height: 1.3;
  }

  .beta-value {
    font-size: 18px;
    font-weight: 600;
    color: var(--accent-primary);
    margin-bottom: var(--space-2xl);
  }

  .beta-value-note {
    font-size: 14px;
    font-weight: 400;
    color: var(--text-tertiary);
  }

  .beta-desc {
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-2xl);
  }

  .beta-features {
    list-style: none;
    text-align: left;
    width: 100%;
    margin-bottom: var(--space-2xl);
  }

  .beta-features li {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    font-size: 15px;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-subtle);
  }

  .beta-features li:last-child {
    border-bottom: none;
  }

  .beta-features svg {
    color: var(--accent-primary);
    flex-shrink: 0;
  }

  .beta-cta-btn {
    width: 100%;
    justify-content: center;
    font-size: 16px;
    padding: 14px 32px;
  }

  .beta-note {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: var(--space-lg);
  }

  .beta-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  @media (max-width: 480px) {
    .beta-card {
      padding: var(--space-2xl) var(--space-xl);
    }
    .beta-title {
      font-size: 24px;
    }
  }
</style>
