---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import ValueProp from '../../components/ValueProp.astro';
import SecondaryFeatures from '../../components/SecondaryFeatures.astro';
import MoreFeatures from '../../components/MoreFeatures.astro';
import PricingPreview from '../../components/PricingPreview.astro';
import Footer from '../../components/Footer.astro';
import { getUserFromRequest } from '../../lib/auth';

const env = Astro.locals.runtime.env;
const user = await getUserFromRequest(env.SESSIONS, Astro.request);

if (user) {
  return Astro.redirect('/ja/go');
}
---

<BaseLayout>
  <Navbar />
  <Hero />
  <ValueProp />
  <SecondaryFeatures />
  <MoreFeatures />
  <PricingPreview />
  <Footer />
</BaseLayout>
