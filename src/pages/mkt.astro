        <div class="deep-panel">
          <div class="deep-panel-title">License Pools</div>
          <div style="margin-bottom:12px">
            <div class="stat-row"><span class="stat-label">Total distributed</span><span class="stat-value" style="color:var(--accent)">${b.totalDistributed}/${b.totalBudget}</span></div>
            <div class="progress-track" style="margin-top:4px"><div class="progress-fill" style="width:${pct(b.totalDistributed, b.totalBudget)}%"></div></div>
          </div>
          <div class="pool-grid">
            ${(b.pools || []).map(p => `
              <div class="pool-card">
                <div class="pool-name">${esc(p.pool)}</div>
                <div class="pool-numbers"><span class="distributed">${p.distributed}</span> <span class="remaining">/ ${p.budget}</span></div>
                <div class="progress-track" style="margin-top:4px"><div class="progress-fill ${p.remaining < 0 ? 'red' : ''}" style="width:${Math.min(pct(p.distributed, p.budget), 100)}%"></div></div>
              </div>`).join('')}
          </div>
        </div>

        <div class="deep-panel">
          <div class="deep-panel-title">Distribution by Platform</div>
          ${Object.keys(b.byPlatform || {}).length > 0 ?
            `<div class="bar-chart">
              ${Object.entries(b.byPlatform).sort((a,b) => b[1]-a[1]).map(([p, count]) => `
                <div class="bar-row">
                  <span class="bar-label">${esc(p)}</span>
                  <div class="bar-track"><div class="bar-fill" style="width:${pct(count, b.totalDistributed)}%;background:var(--accent)"></div></div>
                  <span class="bar-count">${count}</span>
                </div>`).join('')}
            </div>` :
            '<div style="color:var(--text-dim);font-size:12px">No distribution yet</div>'}

          <div style="margin-top:16px">
            <div class="stat-row"><span class="stat-label">Activation rate</span><span class="stat-value">${b.activationRate}</span></div>
            <div class="stat-row"><span class="stat-label">Total keys sent</span><span class="stat-value">${b.distributionCount}</span></div>
            <div class="stat-row"><span class="stat-label">Activated</span><span class="stat-value">${b.activated}</span></div>
          </div>
        </div>
      </div>`;
    }

    // ---- Helpers ----
    function pct(value, total) {
      if (!total || total === 0) return 0;
      return Math.round((value / total) * 100);
    }

    function esc(str) {
      if (!str) return '';
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function renderStackedBar(obj, colors) {
      const total = Object.values(obj).reduce((s, v) => s + v, 0);
      if (total === 0) return '<div class="stacked-bar"></div>';
      const segments = Object.entries(obj).map(([key, val]) =>
        `<div class="stacked-segment" style="width:${pct(val, total)}%;background:${colors[key] || 'var(--text-dim)'}"></div>`
      ).join('');
      const legend = Object.entries(obj).map(([key, val]) =>
        `<div class="legend-item"><div class="legend-dot" style="background:${colors[key] || 'var(--text-dim)'}"></div>${key}: ${val}</div>`
      ).join('');
      return `<div class="stacked-bar">${segments}</div><div class="stacked-legend">${legend}</div>`;
    }

    function renderGauge(label, current, max) {
      const ratio = pct(current, max);
      const color = ratio >= 80 ? 'var(--red)' : ratio >= 50 ? 'var(--orange)' : 'var(--green)';
      return `<div class="gauge-row">
        <span class="gauge-label">${label}</span>
        <div class="gauge-track">
          <div class="gauge-fill" style="width:${ratio}%;background:${color}"></div>
          <span class="gauge-text">${current}/${max}</span>
        </div>
      </div>`;
    }

    function getThisWeekCount(weeklyTrend) {
      if (!weeklyTrend?.length) return 0;
      return weeklyTrend[weeklyTrend.length - 1]?.count || 0;
    }

    // Init
    fetchData();
    connectSSE();
    setInterval(fetchData, 30000);
  </script>
</body>
</html>
