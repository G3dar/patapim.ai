---
export const prerender = false;

import { getUserFromRequest } from '../lib/auth';
import { isAdmin } from '../lib/admin';

const env = Astro.locals.runtime.env;
const user = await getUserFromRequest(env.SESSIONS, Astro.request);

if (!user) {
  return Astro.redirect('/api/auth/google');
}

if (!isAdmin(user)) {
  return Astro.redirect('/go');
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Stats — PATAPIM</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="topbar-brand">
          <span class="brand-icon">&#x276F;_</span>
          <span class="brand-text">PATAPIM</span>
        </a>
        <span class="topbar-sep"></span>
        <span class="topbar-label">Stats</span>
      </div>
      <div class="topbar-right">
        <img src={user.picture} alt="" class="topbar-avatar" referrerpolicy="no-referrer" />
        <a href="/admin" class="topbar-link">Admin</a>
        <a href="/go" class="topbar-link">Dashboard</a>
      </div>
    </div>
  </header>

  <main class="stats-main">
    <div class="stats-container">

      <!-- Month nav -->
      <div class="month-nav">
        <button class="nav-btn" id="prev-month" title="Previous month">&larr;</button>
        <span class="month-label" id="month-label">Loading...</span>
        <button class="nav-btn" id="next-month" title="Next month">&rarr;</button>
      </div>

      <!-- KPI row -->
      <div class="kpi-row" id="kpi-row">
        <div class="kpi kpi-dau"><div class="kpi-label">DAU (peak)</div><div class="kpi-value" id="kpi-dau">-</div></div>
        <div class="kpi kpi-views"><div class="kpi-label">Page Views</div><div class="kpi-value" id="kpi-pageviews">-</div></div>
        <div class="kpi"><div class="kpi-label">Downloads</div><div class="kpi-value" id="kpi-downloads">-</div></div>
        <div class="kpi"><div class="kpi-label">Signups</div><div class="kpi-value" id="kpi-signups">-</div></div>
        <div class="kpi kpi-pro"><div class="kpi-label">New Pro</div><div class="kpi-value" id="kpi-pro">-</div></div>
        <div class="kpi kpi-lifetime"><div class="kpi-label">New Lifetime</div><div class="kpi-value" id="kpi-lifetime">-</div></div>
      </div>

      <!-- Charts -->
      <div class="chart-section">
        <div class="chart-card">
          <div class="chart-title">Daily Active Users</div>
          <div class="chart-area" id="chart-dau"></div>
        </div>
      </div>

      <div class="chart-section">
        <div class="chart-card">
          <div class="chart-title">Page Views</div>
          <div class="chart-area" id="chart-pageviews"></div>
        </div>
      </div>

      <div class="chart-section">
        <div class="chart-card">
          <div class="chart-title">Downloads <span class="chart-legend-inline"><span class="swatch win-swatch"></span> Windows <span class="swatch mac-swatch"></span> Mac</span></div>
          <div class="chart-area" id="chart-downloads"></div>
        </div>
      </div>

      <div class="chart-section">
        <div class="chart-card">
          <div class="chart-title">Signups</div>
          <div class="chart-area" id="chart-signups"></div>
        </div>
      </div>

      <div class="chart-row">
        <div class="chart-card">
          <div class="chart-title">New Pro Subscriptions</div>
          <div class="chart-area" id="chart-pro"></div>
        </div>
        <div class="chart-card">
          <div class="chart-title">New Lifetime Purchases</div>
          <div class="chart-area" id="chart-lifetime"></div>
        </div>
      </div>

      <!-- Daily table -->
      <div class="table-section">
        <div class="section-heading">Daily Breakdown</div>
        <div class="tbl-wrap">
          <table class="tbl">
            <thead>
              <tr>
                <th>Date</th>
                <th>DAU</th>
                <th>Views</th>
                <th>DLs</th>
                <th>Win</th>
                <th>Mac</th>
                <th>Signups</th>
                <th>Pro</th>
                <th>Lifetime</th>
              </tr>
            </thead>
            <tbody id="daily-tbody"></tbody>
          </table>
        </div>
      </div>

      <!-- Referrers -->
      <div class="referrers-section">
        <div class="section-heading">Traffic Sources</div>
        <div id="referrers-content" class="referrers-empty">No referrer data yet</div>
      </div>

    </div>
  </main>

<style is:global>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --white: #ffffff;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-300: #d1d5db;
    --gray-400: #9ca3af;
    --gray-500: #6b7280;
    --gray-600: #4b5563;
    --gray-700: #374151;
    --gray-800: #1f2937;
    --gray-900: #111827;
    --blue-50: #eff6ff;
    --blue-100: #dbeafe;
    --blue-500: #3b82f6;
    --blue-600: #2563eb;
    --blue-700: #1d4ed8;
    --green-50: #f0fdf4;
    --green-100: #dcfce7;
    --green-500: #22c55e;
    --green-600: #16a34a;
    --green-700: #15803d;
    --amber-50: #fffbeb;
    --amber-100: #fef3c7;
    --amber-500: #f59e0b;
    --amber-600: #d97706;
    --amber-700: #b45309;
    --red-50: #fef2f2;
    --red-100: #fee2e2;
    --red-500: #ef4444;
    --red-600: #dc2626;
    --purple-50: #faf5ff;
    --purple-100: #f3e8ff;
    --purple-500: #a855f7;
    --purple-600: #9333ea;
    --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', 'Consolas', monospace;
    --radius: 10px;
    --radius-sm: 6px;
    --shadow-card: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
  }

  body {
    font-family: var(--font);
    background: var(--gray-50);
    color: var(--gray-800);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  /* Top Bar */
  .topbar {
    background: var(--white);
    border-bottom: 1px solid var(--gray-200);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .topbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .topbar-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .topbar-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--gray-900);
    font-weight: 700;
    font-size: 15px;
  }

  .brand-icon { font-family: var(--mono); color: var(--blue-600); }

  .topbar-sep { width: 1px; height: 20px; background: var(--gray-200); }

  .topbar-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--purple-600);
    background: var(--purple-50);
    padding: 2px 10px;
    border-radius: 100px;
    letter-spacing: 0.3px;
  }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .topbar-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid var(--gray-200);
  }

  .topbar-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--blue-600);
    text-decoration: none;
  }

  .topbar-link:hover { text-decoration: underline; }

  /* Main */
  .stats-main { padding: 32px 24px 64px; }
  .stats-container { max-width: 1200px; margin: 0 auto; }

  /* Month Nav */
  .month-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 28px;
  }

  .month-label {
    font-size: 20px;
    font-weight: 700;
    color: var(--gray-900);
    min-width: 200px;
    text-align: center;
  }

  .nav-btn {
    background: var(--white);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius-sm);
    width: 40px;
    height: 40px;
    font-size: 18px;
    color: var(--gray-600);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 150ms;
  }

  .nav-btn:hover { border-color: var(--blue-500); color: var(--blue-600); background: var(--blue-50); }
  .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; pointer-events: none; }

  /* KPI Row */
  .kpi-row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
    margin-bottom: 28px;
  }

  .kpi {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 20px 24px;
    box-shadow: var(--shadow-card);
    transition: box-shadow 150ms;
  }

  .kpi:hover { box-shadow: var(--shadow-md); }

  .kpi-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .kpi-value {
    font-family: var(--mono);
    font-size: 32px;
    font-weight: 700;
    color: var(--gray-900);
    line-height: 1;
  }

  .kpi-dau { border-left: 3px solid var(--amber-500); }
  .kpi-dau .kpi-value { color: var(--amber-700); }
  .kpi-views { border-left: 3px solid var(--green-500); }
  .kpi-views .kpi-value { color: var(--green-700); }
  .kpi-pro { border-left: 3px solid var(--blue-500); }
  .kpi-pro .kpi-value { color: var(--blue-700); }
  .kpi-lifetime { border-left: 3px solid var(--purple-500); }
  .kpi-lifetime .kpi-value { color: var(--purple-600); }

  /* Chart sections */
  .chart-section { margin-bottom: 20px; }

  .chart-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .chart-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 20px 24px 16px;
    box-shadow: var(--shadow-card);
  }

  .chart-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--gray-700);
    margin-bottom: 16px;
  }

  .chart-area {
    display: flex;
    align-items: flex-end;
    gap: 1px;
    height: 180px;
    padding-top: 20px;
  }

  .bar-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    justify-content: flex-end;
    min-width: 0;
  }

  .bar-val {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--gray-500);
    margin-bottom: 2px;
    line-height: 1;
  }

  .bar-val.zero { color: var(--gray-300); }

  .bar {
    width: 100%;
    min-height: 2px;
    border-radius: 3px 3px 0 0;
    transition: opacity 150ms;
    cursor: default;
  }

  .bar:hover { opacity: 0.75; }

  .bar.dau-bar { background: var(--amber-500); }
  .bar.pageviews-bar { background: var(--green-500); }
  .bar.downloads-bar { background: var(--amber-500); }
  .bar.win-bar { background: var(--blue-500); border-radius: 0; }
  .bar.mac-bar { background: var(--gray-400); border-radius: 3px 3px 0 0; }
  .bar.signups-bar { background: var(--blue-500); }
  .bar.pro-bar { background: var(--blue-500); }
  .bar.lifetime-bar { background: var(--purple-500); }

  .stacked-bars {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .chart-legend-inline {
    font-size: 12px;
    font-weight: 400;
    color: var(--gray-500);
    margin-left: 12px;
  }

  .swatch {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    margin-right: 3px;
    margin-left: 8px;
    vertical-align: middle;
  }

  .win-swatch { background: var(--blue-500); }
  .mac-swatch { background: var(--gray-400); }

  .bar-label {
    font-size: 10px;
    font-family: var(--mono);
    color: var(--gray-400);
    margin-top: 4px;
    line-height: 1;
  }

  /* Table */
  .table-section { margin-top: 8px; }

  .section-heading {
    font-size: 15px;
    font-weight: 600;
    color: var(--gray-800);
    margin-bottom: 14px;
  }

  .tbl-wrap {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    overflow-x: auto;
  }

  .tbl {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .tbl th {
    text-align: left;
    padding: 12px 16px;
    font-size: 11px;
    font-weight: 600;
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--gray-200);
    white-space: nowrap;
    background: var(--gray-50);
  }

  .tbl td {
    padding: 10px 16px;
    border-bottom: 1px solid var(--gray-100);
    color: var(--gray-600);
    font-family: var(--mono);
    font-size: 13px;
  }

  .tbl tr:last-child td { border-bottom: none; }
  .tbl tbody tr:hover td { background: var(--blue-50); }

  .tbl td.date-cell {
    font-weight: 600;
    color: var(--gray-800);
  }

  .tbl td.zero { color: var(--gray-300); }

  .tbl tfoot td {
    font-weight: 700;
    color: var(--gray-900);
    background: var(--gray-50);
    border-top: 2px solid var(--gray-200);
  }

  /* Referrers */
  .referrers-section { margin-top: 28px; }

  .referrers-empty {
    text-align: center;
    padding: 32px;
    color: var(--gray-400);
    font-size: 14px;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
  }

  .ref-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .ref-row {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    box-shadow: var(--shadow-card);
  }

  .ref-rank {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--gray-400);
    min-width: 20px;
    text-align: right;
  }

  .ref-domain {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-800);
    min-width: 180px;
  }

  .ref-bar-wrap {
    flex: 1;
    height: 8px;
    background: var(--gray-100);
    border-radius: 4px;
    overflow: hidden;
  }

  .ref-bar {
    height: 100%;
    border-radius: 4px;
    background: var(--green-500);
    transition: width 300ms ease;
  }

  .ref-count {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-700);
    min-width: 40px;
    text-align: right;
  }

  .ref-pct {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--gray-400);
    min-width: 44px;
    text-align: right;
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .kpi-row { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 900px) {
    .kpi-row { grid-template-columns: repeat(2, 1fr); }
    .chart-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .kpi-row { grid-template-columns: 1fr 1fr; }
    .kpi-value { font-size: 24px; }
    .month-label { font-size: 16px; min-width: 160px; }
    .chart-area { height: 120px; }
  }
</style>

<script is:inline>
  let currentMonth = '';

  const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
    'July', 'August', 'September', 'October', 'November', 'December'];

  function formatMonthLabel(m) {
    const [y, mo] = m.split('-').map(Number);
    return monthNames[mo - 1] + ' ' + y;
  }

  function fmtDay(dateStr) {
    const d = new Date(dateStr + 'T00:00:00');
    const day = d.getDate();
    const weekday = d.toLocaleDateString('en-US', { weekday: 'short' });
    return weekday + ' ' + day;
  }

  function buildBarChart(containerId, days, key, barClass) {
    const el = document.getElementById(containerId);
    if (!el) return;

    const values = days.map(function(d) { return d[key]; });
    const max = Math.max(1, ...values);

    el.innerHTML = days.map(function(d) {
      const val = d[key];
      const h = Math.max(2, (val / max) * 130);
      const day = parseInt(d.date.slice(8), 10);
      return '<div class="bar-col">' +
        '<span class="bar-val' + (val === 0 ? ' zero' : '') + '">' + val + '</span>' +
        '<div class="bar ' + barClass + '" style="height:' + h + 'px"></div>' +
        '<span class="bar-label">' + day + '</span>' +
        '</div>';
    }).join('');
  }

  function buildStackedChart(containerId, days) {
    var el = document.getElementById(containerId);
    if (!el) return;

    var maxTotal = Math.max(1, ...days.map(function(d) { return d.downloads; }));

    el.innerHTML = days.map(function(d) {
      var day = parseInt(d.date.slice(8), 10);
      var winH = Math.max(0, (d.win / maxTotal) * 130);
      var macH = Math.max(0, (d.mac / maxTotal) * 130);
      if (d.downloads > 0 && winH + macH < 2) winH = 2;
      var total = d.downloads;
      return '<div class="bar-col">' +
        '<span class="bar-val' + (total === 0 ? ' zero' : '') + '">' + total + '</span>' +
        '<div class="stacked-bars">' +
          (d.mac > 0 ? '<div class="bar mac-bar" style="height:' + macH + 'px" title="Mac: ' + d.mac + '"></div>' : '') +
          '<div class="bar win-bar" style="height:' + winH + 'px;border-radius:' + (d.mac > 0 ? '0' : '3px 3px 0 0') + '" title="Win: ' + d.win + '"></div>' +
        '</div>' +
        '<span class="bar-label">' + day + '</span>' +
        '</div>';
    }).join('');
  }

  async function loadMonth(month) {
    const params = month ? '?month=' + month : '';
    try {
      const res = await fetch('/api/admin/history' + params);
      const data = await res.json();

      currentMonth = data.month;

      document.getElementById('month-label').textContent = formatMonthLabel(data.month);

      document.getElementById('prev-month').disabled = false;
      var nextBtn = document.getElementById('next-month');
      nextBtn.disabled = !data.nextMonth;

      document.getElementById('kpi-dau').textContent = String(data.totals.dau);
      document.getElementById('kpi-pageviews').textContent = String(data.totals.pageviews);
      document.getElementById('kpi-downloads').textContent = String(data.totals.downloads);
      document.getElementById('kpi-signups').textContent = String(data.totals.signups);
      document.getElementById('kpi-pro').textContent = String(data.totals.newPro);
      document.getElementById('kpi-lifetime').textContent = String(data.totals.newLifetime);

      buildBarChart('chart-dau', data.days, 'dau', 'dau-bar');
      buildBarChart('chart-pageviews', data.days, 'pageviews', 'pageviews-bar');
      buildStackedChart('chart-downloads', data.days);
      buildBarChart('chart-signups', data.days, 'signups', 'signups-bar');
      buildBarChart('chart-pro', data.days, 'newPro', 'pro-bar');
      buildBarChart('chart-lifetime', data.days, 'newLifetime', 'lifetime-bar');

      var tbody = document.getElementById('daily-tbody');
      var reversed = data.days.slice().reverse();
      var ts = 'font-weight:700;color:var(--gray-900);background:var(--gray-50);border-top:2px solid var(--gray-200)';
      var zc = function(v) { return v === 0 ? ' zero' : ''; };
      tbody.innerHTML = reversed.map(function(d) {
        return '<tr>' +
          '<td class="date-cell">' + fmtDay(d.date) + '</td>' +
          '<td class="' + zc(d.dau) + '">' + d.dau + '</td>' +
          '<td class="' + zc(d.pageviews) + '">' + d.pageviews + '</td>' +
          '<td class="' + zc(d.downloads) + '">' + d.downloads + '</td>' +
          '<td class="' + zc(d.win) + '">' + d.win + '</td>' +
          '<td class="' + zc(d.mac) + '">' + d.mac + '</td>' +
          '<td class="' + zc(d.signups) + '">' + d.signups + '</td>' +
          '<td class="' + zc(d.newPro) + '">' + d.newPro + '</td>' +
          '<td class="' + zc(d.newLifetime) + '">' + d.newLifetime + '</td>' +
          '</tr>';
      }).join('') +
        '<tr>' +
          '<td style="' + ts + '">Total</td>' +
          '<td style="' + ts + '">' + data.totals.dau + '</td>' +
          '<td style="' + ts + '">' + data.totals.pageviews + '</td>' +
          '<td style="' + ts + '">' + data.totals.downloads + '</td>' +
          '<td style="' + ts + '">' + data.totals.win + '</td>' +
          '<td style="' + ts + '">' + data.totals.mac + '</td>' +
          '<td style="' + ts + '">' + data.totals.signups + '</td>' +
          '<td style="' + ts + '">' + data.totals.newPro + '</td>' +
          '<td style="' + ts + '">' + data.totals.newLifetime + '</td>' +
        '</tr>';

      // Referrers
      var refEl = document.getElementById('referrers-content');
      var refs = data.referrers || {};
      var refEntries = Object.entries(refs).sort(function(a, b) { return b[1] - a[1]; });
      if (refEntries.length === 0) {
        refEl.className = 'referrers-empty';
        refEl.innerHTML = 'No referrer data yet for this month';
      } else {
        refEl.className = 'ref-grid';
        var refMax = refEntries[0][1];
        var refTotal = refEntries.reduce(function(s, e) { return s + e[1]; }, 0);
        refEl.innerHTML = refEntries.map(function(e, i) {
          var domain = e[0];
          var count = e[1];
          var pct = refTotal > 0 ? ((count / refTotal) * 100).toFixed(1) : '0';
          var barW = Math.max(2, Math.round((count / refMax) * 100));
          return '<div class="ref-row">' +
            '<span class="ref-rank">' + (i + 1) + '.</span>' +
            '<span class="ref-domain">' + domain + '</span>' +
            '<div class="ref-bar-wrap"><div class="ref-bar" style="width:' + barW + '%"></div></div>' +
            '<span class="ref-count">' + count + '</span>' +
            '<span class="ref-pct">' + pct + '%</span>' +
            '</div>';
        }).join('');
      }

      document.getElementById('prev-month')._month = data.prevMonth;
      document.getElementById('next-month')._month = data.nextMonth;

    } catch(e) {
      document.getElementById('month-label').textContent = 'Failed to load';
    }
  }

  document.getElementById('prev-month').addEventListener('click', function() {
    var m = document.getElementById('prev-month')._month;
    if (m) loadMonth(m);
  });

  document.getElementById('next-month').addEventListener('click', function() {
    var m = document.getElementById('next-month')._month;
    if (m) loadMonth(m);
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft') {
      var m = document.getElementById('prev-month')._month;
      if (m) loadMonth(m);
    } else if (e.key === 'ArrowRight') {
      var btn = document.getElementById('next-month');
      if (btn._month && !btn.disabled) loadMonth(btn._month);
    }
  });

  loadMonth();
</script>

</body>
</html>
