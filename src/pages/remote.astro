---
export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PATAPIM Remote</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style is:inline>
    body { margin:0; background:#0a0a0b; color:#e4e4e7;
           font-family: -apple-system, system-ui, sans-serif;
           display:flex; align-items:center; justify-content:center; height:100vh; }
    .msg { opacity:.6; font-size:14px; }
  </style>
  <!-- Smart entry point. Computers get the full desktop UI (/remotedesk →
       the device's /desktop view); phones get the mobile terminal UI
       (/remote-mobile). Go straight to either URL to force that one, or use
       ?view=mobile / ?view=desktop to override. All query params (t/url/d/…)
       are forwarded untouched so the one-time connect token is consumed once
       by the final page. -->
  <script is:inline>
    (function () {
      var p = new URLSearchParams(location.search);
      var view = (p.get('view') || '').toLowerCase();
      p.delete('view');
      var qs = p.toString();

      function isMobile() {
        var ua = navigator.userAgent || '';
        if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini|Mobile/i.test(ua)) return true;
        if (navigator.userAgentData && typeof navigator.userAgentData.mobile === 'boolean')
          return navigator.userAgentData.mobile;
        return window.matchMedia('(pointer: coarse)').matches
            && window.matchMedia('(max-width: 1024px)').matches;
      }

      var target = view === 'mobile'  ? '/remote-mobile'
                 : view === 'desktop' ? '/remotedesk'
                 : isMobile()         ? '/remote-mobile'
                 :                      '/remotedesk';

      location.replace(target + (qs ? '?' + qs : ''));
    })();
  </script>
</head>
<body>
  <div class="msg">Opening PATAPIM Remote…</div>
</body>
</html>
