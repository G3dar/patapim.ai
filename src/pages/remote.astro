---
export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PATAPIM Remote</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style is:inline>
    body { margin:0; background:#0a0a0b; color:#e4e4e7;
           font-family: -apple-system, system-ui, sans-serif;
           display:flex; align-items:center; justify-content:center; height:100vh; }
    .msg { opacity:.6; font-size:14px; }
  </style>
  <!-- Smart entry point. Everyone — phones and computers — gets the full
       desktop UI (/remotedesk → the device's /desktop view), which now has a
       built-in mobile mode (full-screen projects drawer + swipe) on touch
       phones. The lean standalone client (/remote-mobile) is kept as a fallback,
       reachable with ?view=mobile. Use ?view=desktop to force /remotedesk. All
       query params (t/url/d/…) are forwarded untouched so the one-time connect
       token is consumed once by the final page. -->
  <script is:inline>
    (function () {
      var p = new URLSearchParams(location.search);
      var view = (p.get('view') || '').toLowerCase();
      p.delete('view');
      var qs = p.toString();

      // Default everyone to the rich /desktop experience; ?view=mobile opts
      // back into the legacy standalone client as a fallback.
      var target = view === 'mobile' ? '/remote-mobile' : '/remotedesk';

      location.replace(target + (qs ? '?' + qs : ''));
    })();
  </script>
</head>
<body>
  <div class="msg">Opening PATAPIM Remote…</div>
</body>
</html>
