---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import HeroMiniComputerControl from '../components/HeroMiniComputerControl.astro';
import V2MiniMultiTerminal from '../components/V2MiniMultiTerminal.astro';
import HeroMiniVoiceDictation from '../components/HeroMiniVoiceDictation.astro';
import HeroMiniRemoteAccess from '../components/HeroMiniRemoteAccess.astro';
import HeroMiniConnectedTabs from '../components/HeroMiniConnectedTabs.astro';
import V2MiniBrowserComms from '../components/V2MiniBrowserComms.astro';
import V2ComputerControlScene from '../components/V2ComputerControlScene.astro';
import V2MultiTerminalScene from '../components/V2MultiTerminalScene.astro';
import V2VoiceDictationScene from '../components/V2VoiceDictationScene.astro';
import V2RemoteAccessScene from '../components/V2RemoteAccessScene.astro';
import V2ConnectedTabsScene from '../components/V2ConnectedTabsScene.astro';
import V2BrowserCommsScene from '../components/V2BrowserCommsScene.astro';

const ASCII_LOGO = `██████╗  █████╗ ████████╗ █████╗ ██████╗ ██╗███╗   ███╗
██╔══██╗██╔══██╗╚══██╔══╝██╔══██╗██╔══██╗██║████╗ ████║
██████╔╝███████║   ██║   ███████║██████╔╝██║██╔████╔██║
██╔═══╝ ██╔══██║   ██║   ██╔══██║██╔═══╝ ██║██║╚██╔╝██║
██║     ██║  ██║   ██║   ██║  ██║██║     ██║██║ ╚═╝ ██║
╚═╝     ╚═╝  ╚═╝   ╚═╝   ╚═╝  ╚═╝╚═╝     ╚═╝╚═╝     ╚═╝`;

// solid blocks only — box-drawing shadow chars stripped (rendered as a dim layer behind)
const ASCII_SOLID = ASCII_LOGO.replace(/[╔╗╚╝═║]/g, ' ');

// the 9 hero demos, same lineup and order as the original home
const FEATURES = [
  { slug: 'computer-control',   name: 'full computer control', desc: 'Claude takes the wheel — it clicks, types and opens apps, driving your entire machine end to end. Your subscription, zero extra API costs.' },
  { slug: 'multi-terminal',     name: 'multi-terminal focus system', desc: 'Your projects live in folders, not chats — each with color-coded tasks and live notifications, so you can run many terminals at once without losing track.' },
  { slug: 'voice-dictation',    name: 'voice-dictation',       desc: 'Lightning fast, fully local speech-to-text. Talk to any terminal.' },
  { slug: 'remote-access',      name: 'remote-access done right',         desc: 'Nothing to enable, no remote mode to arm — if a machine is on, you can already reach it from any device running Patapim, phone or desktop. Instant.' },
  { slug: 'connected-tabs',     name: 'connected-persistent-tabs', desc: 'Tabs reference each other and know every project — ask one about another repo and it checks what that tab is doing, opens a tab there, and gets to work. Restart? Everything comes back exactly as you left it.' },
  { slug: 'integrated-browser', name: 'integrated browser automation', subname: 'whatsapp · telegram · gmail', desc: 'Every terminal gets its own built-in Chrome — no computer automation needed, and far more power than a plain browser MCP. “Get my groceries and WhatsApp me when it’s done” · “can I cover my card bill?” · “football tonight?” — it browses, does it, and reports back.' },
];

const FREE_FEATURES = [
  'Full computer control',
  'Up to 3 projects',
  'Up to 9 terminals',
  'A long 30 min dictation buffer',
  'Remote access',
  'Task management',
];
const PRO_FEATURES = [
  'Unlimited terminals',
  'Unlimited projects',
  'Unlimited dictation',
  'Everything in Free',
  'Priority support',
];
---

<BaseLayout title="PATAPIM — Superpower Suite for Claude Code" description="Patapim adds everything Claude Code is missing — multi-project workspaces, voice, remote control, live notifications — without taking the terminal away from you.">
<div class="tv" id="tv">
  <!-- the boot ceremony is for ARRIVALS: coming from inside patapim.ai skips
       it entirely. Synchronous so not even one frame of the beam leaks. -->
  <script is:inline>
    try {
      if (document.referrer && new URL(document.referrer).origin === location.origin) {
        document.documentElement.classList.add('tv-noboot');
      }
    } catch (e) { /* no referrer info — play the boot */ }
  </script>
  <!-- boot sequence overlay: CRT power-on → typed prompt → page prints in -->
  <div id="tv-boot" aria-hidden="true">
    <div class="tvb-crt"></div>
    <div class="tvb-line" id="tvb-line">
      <span class="tvb-prompt">❯_</span>
      <span class="tvb-sep">/</span>
      <span id="tvb-typed"></span><span class="tvb-cursor">█</span>
    </div>
  </div>
  <!-- ============ NAV ============ -->
  <nav class="tv-nav">
    <div class="tv-nav-inner">
      <a href="/" class="tv-brand">
        <span class="tv-brand-icon">❯_</span>
        <span class="tv-brand-sep">/</span>
        <span class="tv-brand-name">patapim</span>
      </a>
      <div class="tv-nav-links">
        <a href="#demos">Features</a>
        <a href="/download">Download</a>
        <a href="/docs/releases">Docs</a>
        <a href="/whats-new">What's new</a>
        <a href="/about">About</a>
        <a href="/signin" id="tv-home-signin" style="display:none;">Sign in</a>
        <a href="/go" class="tv-nav-cta">[ dashboard ]</a>
      </div>
    </div>
  </nav>

  <main class="tv-main">

    <!-- ============ HERO ============ -->
    <section class="tv-hero">
      <div class="tv-hero-left">
        <div class="tv-logo" id="tv-logo" aria-label="PATAPIM">
          <pre class="tv-logo-layer tv-logo-cy" aria-hidden="true">{ASCII_SOLID}</pre>
          <pre class="tv-logo-layer tv-logo-vi" aria-hidden="true">{ASCII_SOLID}</pre>
          <pre class="tv-logo-base">{ASCII_LOGO}</pre>
        </div>
        <div class="tv-tagline"><span id="tv-tagline" data-text="SUPERPOWER SUITE FOR CLAUDE CODE"></span><span class="tv-tagline-cursor">▌</span></div>
      </div>
      <div class="tv-hero-right">
        <p class="tv-hero-copy">
          Patapim adds everything Claude&nbsp;Code is missing —
          multi-project workspaces, voice, remote control, live
          notifications — without taking the terminal away from you.
        </p>
        <p class="tv-hero-copy tv-dim">
          It's still Claude Code. Still your terminal. Just with superpowers.
        </p>
      </div>
    </section>

    <!-- ============ TRY IT NOW + AGENTS ============ -->
    <section class="tv-tryrow">
      <div class="tv-try">
        <div class="tv-label"><span class="tv-label-prompt">$</span> patapim install</div>
        <div class="tv-install">
          <div class="tv-install-tabs">
            <button class="tvi-tab active" data-tvtab="cmd">cmd</button>
            <button class="tvi-tab" data-tvtab="ps">powershell</button>
            <button class="tvi-tab" data-tvtab="mac">macos</button>
          </div>
          <div class="tvi-panel active" data-tvpanel="cmd" data-copy='curl -fsSL https://raw.githubusercontent.com/G3dar/patapim-releases/main/install.cmd -o "%TEMP%\patapim-install.cmd" && "%TEMP%\patapim-install.cmd"'>
            <span class="tvi-prompt">C:\&gt;</span>
            <code>curl -fsSL …/install.cmd | run</code>
            <span class="tvi-copy" title="copy full command">⧉</span>
          </div>
          <div class="tvi-panel" data-tvpanel="ps" data-copy="irm https://raw.githubusercontent.com/G3dar/patapim-releases/main/install.ps1 | iex">
            <span class="tvi-prompt">PS&gt;</span>
            <code>irm patapim…/install.ps1 | iex</code>
            <span class="tvi-copy" title="copy full command">⧉</span>
          </div>
          <div class="tvi-panel" data-tvpanel="mac" data-copy="curl -fsSL https://raw.githubusercontent.com/G3dar/patapim-releases/main/install-mac.sh | bash">
            <span class="tvi-prompt">$</span>
            <code>curl -fsSL …/install-mac.sh | bash</code>
            <span class="tvi-copy" title="copy full command">⧉</span>
          </div>
          <div class="tv-install-meta">windows 10+ · macos 12+ · <a href="/download">download page</a></div>
        </div>
      </div>
      <div class="tv-agents">
        <div class="tv-agents-note">
          also supports
          <span class="tv-agent-chip"><img src="/v2/codex-color.svg" alt="" /> Codex</span>,
          <span class="tv-agent-chip"><img src="/v2/antigravity-color.svg" alt="" /> Antigravity</span>
          — or any custom CLI
        </div>
      </div>
    </section>

    <!-- ============ LIVE DEMOS (the animations, front and center) ============ -->
    <section class="tv-demos" id="demos">
      <div class="tv-demos-head">
        <div class="tv-label-core">CORE FEATURES</div>
        <div class="tv-demos-sub">six superpowers, running live below</div>
      </div>
      <div class="tv-demo-grid">
        <div class="tv-demo tv-demo-max" id="demo-computer-control" data-tvdemo data-maximize="cc" role="button" tabindex="0" aria-label="Expand full computer control demo">
          <div class="tv-demo-frame"><HeroMiniComputerControl /></div>
          <div class="tv-demo-name">{FEATURES[0].name}</div>
          <p class="tv-demo-desc">{FEATURES[0].desc}</p>
          <span class="tv-demo-expand" aria-hidden="true">⤢ click to expand</span>
        </div>
        <div class="tv-demo tv-demo-max" id="demo-multi-terminal" data-tvdemo data-maximize="mt" role="button" tabindex="0" aria-label="Expand multi-terminal demo">
          <div class="tv-demo-frame"><V2MiniMultiTerminal /></div>
          <div class="tv-demo-name">{FEATURES[1].name}</div>
          <p class="tv-demo-desc">{FEATURES[1].desc}</p>
          <span class="tv-demo-expand" aria-hidden="true">⤢ click to expand</span>
        </div>
        <div class="tv-demo tv-demo-max" id="demo-voice-dictation" data-tvdemo data-maximize="vd" role="button" tabindex="0" aria-label="Expand voice dictation demo">
          <div class="tv-demo-frame"><HeroMiniVoiceDictation /></div>
          <div class="tv-demo-name">{FEATURES[2].name}</div>
          <p class="tv-demo-desc">{FEATURES[2].desc}</p>
          <span class="tv-demo-expand" aria-hidden="true">⤢ click to expand</span>
        </div>
        <div class="tv-demo tv-demo-max" id="demo-remote-access" data-tvdemo data-maximize="ra" role="button" tabindex="0" aria-label="Expand remote access demo">
          <div class="tv-demo-frame"><HeroMiniRemoteAccess /></div>
          <div class="tv-demo-name">{FEATURES[3].name}</div>
          <p class="tv-demo-desc">{FEATURES[3].desc}</p>
          <span class="tv-demo-expand" aria-hidden="true">⤢ click to expand</span>
        </div>
        <div class="tv-demo tv-demo-max" id="demo-connected-tabs" data-tvdemo data-maximize="ct" role="button" tabindex="0" aria-label="Expand connected persistent tabs demo">
          <div class="tv-demo-frame"><HeroMiniConnectedTabs /></div>
          <div class="tv-demo-name">{FEATURES[4].name}</div>
          <p class="tv-demo-desc">{FEATURES[4].desc}</p>
          <span class="tv-demo-expand" aria-hidden="true">⤢ click to expand</span>
        </div>
        <div class="tv-demo tv-demo-max" id="demo-integrated-browser" data-tvdemo data-maximize="bc" role="button" tabindex="0" aria-label="Expand browser automation demo">
          <div class="tv-demo-frame"><V2MiniBrowserComms /></div>
          <div class="tv-demo-name">{FEATURES[5].name}</div>
          <div class="tv-demo-subname">
            <svg class="tv-svclogo" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="11" fill="#25d366"/><path d="M12 5.6a6.3 6.3 0 0 0-5.4 9.6L5.5 18l2.9-1a6.3 6.3 0 1 0 3.6-11.4zm3.4 8.6c-.2.5-.9.9-1.4.9-.4.1-.8.1-2.4-.5-2-.8-3.3-2.9-3.4-3-.1-.2-.8-1.1-.8-2.1s.5-1.5.7-1.7c.2-.2.4-.2.6-.2h.4c.1 0 .3 0 .4.4l.6 1.4c0 .1.1.3 0 .4l-.3.4-.3.4c-.1.1-.2.2-.1.4.1.2.6 1 1.2 1.6.9.8 1.6 1 1.8 1.1.2.1.3.1.5-.1l.6-.8c.2-.2.3-.2.5-.1l1.3.6c.2.1.3.2.4.3 0 .1 0 .5-.3.6z" fill="#fff"/></svg>
            <span>whatsapp</span>
            <span class="tv-svcdot">·</span>
            <svg class="tv-svclogo" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="11" fill="#2aabee"/><path d="M5.4 11.8l11.2-4.4c.5-.2 1 .1.8.9l-1.9 9c-.1.6-.5.8-1 .5l-2.9-2.1-1.4 1.3c-.2.2-.3.3-.6.3l.2-3 5.5-5c.2-.2 0-.3-.3-.1l-6.8 4.3-2.9-.9c-.6-.2-.6-.6.1-.8z" fill="#fff"/></svg>
            <span>telegram</span>
            <span class="tv-svcdot">·</span>
            <svg class="tv-svclogo" viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2" fill="#fff"/><path d="M2 7l10 7L22 7" fill="none" stroke="#ea4335" stroke-width="2.4"/><path d="M2 7v10h3V10.5L2 7zm17 3.5V17h3V7l-3 3.5z" fill="#ea4335" opacity="0.85"/></svg>
            <span>gmail</span>
          </div>
          <p class="tv-demo-desc">{FEATURES[5].desc}</p>
          <span class="tv-demo-expand" aria-hidden="true">⤢ click to expand</span>
        </div>
      </div>
      <div class="tv-cta-row">
        <a href="/download" class="tv-bigcta" id="tv-bigcta">
          <span class="tv-bigcta-txt">$ install patapim</span>
          <span class="tv-bigcta-cursor">█</span>
        </a>
      </div>
    </section>

    <!-- ============ SYSTEM FETCH (neofetch-style spec sheet) ============ -->
    <section class="tv-fetch" id="leaderboard">
      <div class="tv-label"><span class="tv-label-prompt">$</span> patapim fetch <span class="tv-dim">— why I built this.</span></div>
      <div class="tv-fetch-box">
        <pre class="tv-fetch-logo" aria-hidden="true">{`██████╗
██╔══██╗
██████╔╝
██╔═══╝
██║
╚═╝`}</pre>
        <div class="tv-fetch-info">
          <div class="tv-fetch-title">you<span class="tvf-at">@</span>patapim</div>
          <div class="tv-fetch-sep" aria-hidden="true">─────────────────────────</div>
          <div class="tv-fetch-note" data-fetch-note>
            <p class="tv-fetch-p">
              I've been using Claude&nbsp;Code nonstop — and I've been hitting
              the <span class="tv-hl-pain">same pain points</span>, over and over.
            </p>
            <p class="tv-fetch-p">
              I needed <b>dictation</b>. I needed to <b>follow my sessions
              remotely</b>. I wanted <b>computer control</b> without paying for
              an API key. I wanted <b>browser automation</b> that doesn't stop
              to ask trivial questions. And I wanted <b>folder-oriented
              context</b>.
            </p>
            <p class="tv-fetch-p">
              Patapim is what I built to fix that. Today <strong>my whole
              company runs on it</strong>, and we're already working with
              <strong>10+ partners</strong> implementing this technology.
            </p>
            <p class="tv-fetch-p">
              It gives Claude&nbsp;Code <span class="tv-fetch-grad">the
              superpowers it needs to be truly agentic</span> — practical,
              and focused. While I code.
            </p>
          </div>
          <div class="tv-palette" aria-hidden="true">
            <span style="background:#1c1c1c"></span><span style="background:#3a3a3a"></span><span style="background:#5c5c5c"></span><span style="background:#828282"></span><span style="background:#ababab"></span><span style="background:#dedede"></span><span style="background:var(--vi)"></span><span style="background:var(--cy)"></span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PRICING ============ -->
    <section class="tv-pricing" id="pricing">
      <div class="tv-label"><span class="tv-label-prompt">$</span> patapim upgrade <span class="tv-dim">— start free. upgrade when you're ready.</span></div>
      <div class="tv-price-grid">
        <div class="tv-pcard tv-pcard-hero">
          <div class="tv-pcard-tag">VERY POWERFUL</div>
          <div class="tv-pcard-head">
            <span class="tv-pcard-name">Free</span>
            <span class="tv-pcard-sub">the free plan is seriously powerful</span>
          </div>
          <div class="tv-pcard-pricebox">
            <span class="tv-pcard-amount tv-grad">$0</span>
            <span class="tv-pcard-period">forever</span>
          </div>
          <ul>
            {FREE_FEATURES.map((f) => <li><span class="tv-check">✓</span> {f}</li>)}
          </ul>
          <a href="/download" class="tv-pbtn tv-pbtn-accent">$ download free</a>
        </div>
        <div class="tv-pcard">
          <div class="tv-pcard-head">
            <span class="tv-pcard-name">Pro</span>
            <span class="tv-pcard-sub">full power, no limits</span>
          </div>
          <div class="tv-pcard-pricebox">
            <span class="tv-pcard-amount">$6.99</span>
            <span class="tv-pcard-period">/month</span>
          </div>
          <ul>
            {PRO_FEATURES.map((f) => <li><span class="tv-check">✓</span> {f}</li>)}
          </ul>
          <a href="/pricing" class="tv-pbtn">$ go pro</a>
        </div>
        <div class="tv-pcard tv-pcard-life">
          <div class="tv-pcard-head">
            <span class="tv-pcard-name">Lifetime</span>
            <span class="tv-pcard-sub">one payment. done.</span>
          </div>
          <div class="tv-pcard-pricebox">
            <span class="tv-pcard-amount">$59.99</span>
            <span class="tv-pcard-period">one-time</span>
          </div>
          <ul>
            <li><span class="tv-check">✓</span> Pro features for life</li>
            <li><span class="tv-check">✓</span> No subscriptions</li>
            <li><span class="tv-check">✓</span> No renewals</li>
            <li><span class="tv-check">✓</span> Yours. Forever.</li>
          </ul>
          <a href="/pricing" class="tv-pbtn">$ unlock forever</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />

  <!-- ============ MAXIMIZED DEMO (FLIP modal) ============ -->
  <div id="tv-max" aria-hidden="true">
    <div class="tv-max-backdrop" data-max-close></div>
    <div class="tv-max-frame" id="tv-max-frame">
      <button class="tv-max-close" data-max-close aria-label="close">✕</button>
      <div class="tv-max-scene" data-scene="cc">
        <V2ComputerControlScene />
        <div class="tv-max-caption">
          <span class="tv-max-caption-title">⬚ FULL COMPUTER CONTROL</span>
          <span class="tv-max-caption-text">claude drives your real mouse, keyboard and apps — end to end · control it from your phone via <b>remote</b> · no API keys, no per-token billing — <b>your claude subscription does the work</b></span>
        </div>
      </div>
      <div class="tv-max-scene" data-scene="mt">
        <V2MultiTerminalScene />
        <div class="tv-max-caption">
          <span class="tv-max-caption-title">▦ MULTI-TERMINAL</span>
          <span class="tv-max-caption-text">your projects live in <b>folders, not chats</b> — each folder runs its own terminals, context and history · <b>notifications</b> ping you the moment an agent finishes or needs you · run 10 things at once <b>without losing track</b></span>
        </div>
      </div>
      <div class="tv-max-scene" data-scene="ct">
        <V2ConnectedTabsScene />
        <div class="tv-max-caption">
          <span class="tv-max-caption-title">⇄ CONNECTED-PERSISTENT-TABS</span>
          <span class="tv-max-caption-text">tabs talk to each other — ask one terminal how <b>another project</b> is going and it checks, or tell it to <b>start a process in a different tab</b> · close patapim, reopen: <b>every tab comes back exactly as you left it</b></span>
        </div>
      </div>
      <div class="tv-max-scene" data-scene="bc">
        <V2BrowserCommsScene />
        <div class="tv-max-caption">
          <span class="tv-max-caption-title">◫ BROWSER + WHATSAPP · TELEGRAM · GMAIL</span>
          <span class="tv-max-caption-text">every terminal carries its <b>own embedded Chrome</b> — no computer automation needed, far more muscle than a plain browser MCP · it shops, checks your bank, rallies your friends — then <b>reports back where you live</b></span>
        </div>
      </div>
      <div class="tv-max-scene" data-scene="vd">
        <V2VoiceDictationScene />
        <div class="tv-max-caption">
          <span class="tv-max-caption-title">▮▮▮ VOICE DICTATION</span>
          <span class="tv-max-caption-text">hold <b>two keys</b> and just talk — <b>instant, 100% local</b> transcription straight into any terminal · auto-mutes your audio while you speak · full <b>dictation history</b> · dictate from <b>your phone</b> too — you really talk to your computer</span>
        </div>
      </div>
      <div class="tv-max-scene" data-scene="ra">
        <V2RemoteAccessScene />
        <div class="tv-max-caption">
          <span class="tv-max-caption-title">⇄ REMOTE-ACCESS, DONE RIGHT</span>
          <span class="tv-max-caption-text">no remote mode to enable, nothing to type — <b>if the machine is on, you're in</b> · reach every session instantly from <b>any device</b> running patapim, phone or desktop · your agents, connected everywhere</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* ==================== HOME-ONLY THEME OVERRIDES ====================
     Tokens live in global.css now. The .tv wrapper keeps ONLY the
     desaturation overrides that keep the mini demo widgets monochrome. */
  .tv {
    --success: #cfcfcf;
    --success-subtle: rgba(255, 255, 255, 0.08);
    --warning: #bdbdbd;
    --error: #9e9e9e;
    --error-subtle: rgba(255, 255, 255, 0.08);
    --info: #b5b5b5;

    font-family: var(--font-mono);
    background: #000;
    color: var(--text-primary);
    min-height: 100vh;
    position: relative;
  }

  .tv a { color: inherit; }

  /* ==================== BOOT SEQUENCE ==================== */
  #tv-boot {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000;
    /* CSS failsafe: even if JS dies, the overlay self-destructs at 4s */
    animation: tvb-failsafe 0.01s linear 4s forwards;
  }
  #tv-boot.done {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  /* internal navigation: no ceremony, no flash — the overlay never paints */
  .tv-noboot #tv-boot { display: none; }
  @keyframes tvb-failsafe {
    to { opacity: 0; visibility: hidden; pointer-events: none; }
  }

  /* CRT power-on beam: an instant — line flashes across, blips, gone */
  .tvb-crt {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(194,107,240,0.9), rgba(255,255,255,1) 50%, rgba(34,211,238,0.9));
    transform: scale(0, 0.004);
    animation: tvb-poweron 140ms cubic-bezier(0.2, 0.7, 0.3, 1) forwards;
    pointer-events: none;
  }
  @keyframes tvb-poweron {
    0%   { transform: scale(0, 0.004); opacity: 1; }
    35%  { transform: scale(1, 0.004); opacity: 1; }
    70%  { transform: scale(1, 1); opacity: 0.3; }
    100% { transform: scale(1, 1); opacity: 0; }
  }

  /* the boot prompt IS the navbar brand: same position, same metrics.
     what gets typed here stays — the brand is excluded from the mass re-type. */
  .tvb-line {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(1120px, 100%);
    padding: 0 24px;
    box-sizing: border-box;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    opacity: 0;
  }
  .tvb-line.on { opacity: 1; }
  .tvb-prompt {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .tvb-sep { color: var(--text-muted); }
  #tvb-typed {
    color: var(--text-primary);
    letter-spacing: 0.05em;
  }
  #tvb-typed:empty { margin-left: -10px; }  /* no gap ghost before typing starts */
  .tvb-cursor { color: var(--cy); animation: tv-blink 0.7s steps(1, end) infinite; }

  .tv-main {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px 40px;
  }

  .tv-label {
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 18px;
  }
  .tv-label-prompt {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .tv-label-core {
    font-weight: 700;
    letter-spacing: 0.14em;
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  /* centered display heading for the demos section */
  .tv-demos-head { text-align: center; margin-bottom: 44px; }
  .tv-demos-head .tv-label-core { font-size: 19px; letter-spacing: 0.22em; }
  .tv-demos-sub { margin-top: 6px; font-size: 12.5px; color: var(--text-muted); letter-spacing: 0.06em; }
  .tv-dim { color: var(--text-muted); text-transform: none; letter-spacing: 0; }
  .tv-dim a { color: var(--text-tertiary); text-decoration: underline; }

  /* ==================== NAV ==================== */
  .tv-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border-subtle);
  }
  .tv-nav-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 13px;
  }
  .tv-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .tv-brand-icon {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .tv-brand-sep { color: var(--text-muted); }
  .tv-brand-name { color: var(--text-primary); letter-spacing: 0.05em; }
  .tv-nav-links { display: flex; gap: 26px; align-items: center; }
  .tv-nav-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 13px;
    transition: color 120ms;
  }
  .tv-nav-links a:hover { color: var(--text-primary); }
  .tv-nav-cta { color: var(--text-primary) !important; }
  .tv-nav-cta:hover {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ==================== HERO ==================== */
  .tv-hero {
    display: grid;
    grid-template-columns: minmax(0, auto) minmax(260px, 380px);
    gap: 48px;
    align-items: start;
    padding: 38px 0 22px;
  }
  .tv-logo { position: relative; display: inline-block; }
  .tv-logo pre {
    /* terminal fonts with FULL block/box-drawing coverage — one font for every
       glyph means columns can't drift (Google's JetBrains subset lacks █ ╔ ═,
       and mixed fallback metrics were what deformed the letters) */
    font-family: 'Cascadia Mono', Consolas, Menlo, 'DejaVu Sans Mono', 'JetBrains Mono', monospace;
    font-variant-ligatures: none;
    font-size: clamp(8px, 1.45vw, 15px);
    line-height: 1.16;
    margin: 0;
    user-select: none;
    border: none;
    background: none;
    padding: 0;
    border-radius: 0;
    overflow: visible;
  }
  .tv-logo pre.tv-logo-base {
    position: relative;
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .tv-logo-layer { position: absolute; inset: 0; pointer-events: none; }
  .tv-logo-cy { color: var(--cy); transform: translate(-3px, 1px); opacity: 0; }
  .tv-logo-vi { color: var(--vi); transform: translate(3px, -1px); opacity: 0; }

  /* occasional chromatic glitch */
  .tv-logo.glitch .tv-logo-cy { animation: tv-glitch-a 260ms steps(2, end) 1; opacity: 0.85; }
  .tv-logo.glitch .tv-logo-vi { animation: tv-glitch-b 260ms steps(2, end) 1; opacity: 0.85; }
  .tv-logo.glitch .tv-logo-base { animation: tv-glitch-c 260ms steps(3, end) 1; }
  @keyframes tv-glitch-a {
    0% { transform: translate(-2px, 0); clip-path: inset(0 0 60% 0); }
    50% { transform: translate(-6px, 2px); clip-path: inset(20% 0 30% 0); }
    100% { transform: translate(-2px, 0); clip-path: none; }
  }
  @keyframes tv-glitch-b {
    0% { transform: translate(2px, 0); clip-path: inset(55% 0 0 0); }
    50% { transform: translate(7px, -2px); clip-path: inset(35% 0 15% 0); }
    100% { transform: translate(2px, 0); clip-path: none; }
  }
  @keyframes tv-glitch-c {
    0%, 100% { transform: none; }
    40% { transform: translate(1px, 0) skewX(0.6deg); }
    70% { transform: translate(-1px, 0); }
  }

  /* rare MALFUNCTION: slice glitch — clones of the wordmark clipped into
     bands, desynced sideways, stacked over the (hidden) original */
  .tv-logo pre.tv-malf-slice {
    position: absolute;
    top: 0;
    left: 0;
    margin: 0;
    visibility: visible !important;
    will-change: transform;
    pointer-events: none;
  }

  .tv-tagline {
    margin-top: 16px;
    font-size: 13px;
    letter-spacing: 0.28em;
    color: var(--text-primary);
    min-height: 20px;
  }
  .tv-tagline-cursor { color: var(--cy); animation: tv-blink 1s steps(1, end) infinite; }
  .tv-hero-right { padding-top: 8px; }
  .tv-hero-copy {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-secondary);
    margin: 0 0 16px;
  }
  .tv-hero-copy.tv-dim { color: var(--text-tertiary); font-size: 14px; }

  /* ==================== TRY IT NOW ==================== */
  .tv-tryrow {
    display: grid;
    grid-template-columns: minmax(0, 560px) 1fr;
    gap: 48px;
    align-items: end;
    padding: 10px 0 40px;
  }
  .tv-install { max-width: 560px; }
  .tv-install-tabs { display: flex; gap: 14px; margin-bottom: 10px; }
  .tvi-tab {
    background: none;
    border: none;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
    cursor: pointer;
    padding: 2px 0;
    border-bottom: 1px solid transparent;
  }
  .tvi-tab:hover { color: var(--text-secondary); }
  .tvi-tab.active { color: var(--text-primary); border-bottom-color: var(--cy); }

  .tvi-panel {
    display: none;
    align-items: center;
    gap: 10px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    padding: 13px 16px;
    font-size: 13px;
    cursor: pointer;
    position: relative;
  }
  .tvi-panel.active { display: flex; }
  .tvi-panel:hover { border-color: var(--border-strong); }
  .tvi-panel.copied { border-color: var(--cy); }
  .tvi-panel.copied::after {
    content: 'copied ✓';
    position: absolute;
    right: 40px;
    color: var(--cy);
    font-size: 11px;
  }
  .tvi-prompt {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    flex-shrink: 0;
  }
  .tvi-panel code { color: var(--text-secondary); background: none; padding: 0; flex: 1; }
  .tvi-copy { color: var(--text-muted); margin-left: auto; }
  .tvi-panel:hover .tvi-copy { color: var(--text-primary); }
  .tv-install-meta { margin-top: 10px; font-size: 12px; color: var(--text-muted); }
  .tv-install-meta a { color: var(--text-tertiary); text-decoration: underline; }

  .tv-agents { align-self: end; }
  .tv-agents-note {
    font-size: 13px;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    padding-bottom: 34px;
  }
  .tv-agent-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--text-secondary);
  }
  .tv-agent-chip img { width: 16px; height: 16px; }

  /* ==================== BIG CTA ==================== */
  @keyframes tv-blink { 50% { opacity: 0; } }

  .tv-cta-row {
    display: flex;
    justify-content: center;
    margin-top: 52px;
  }

  .tv-bigcta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border-strong);
    padding: 14px 30px;
    font-size: 15px;
    color: var(--text-primary);
    text-decoration: none;
    position: relative;
    transition: border-color 150ms, box-shadow 150ms;
  }
  .tv-bigcta:hover {
    border-color: var(--cy);
    box-shadow: 0 0 24px rgba(34, 211, 238, 0.15), inset 0 0 24px rgba(139, 124, 248, 0.06);
    color: #fff;
  }
  .tv-bigcta-cursor { color: var(--cy); animation: tv-blink 1s steps(1, end) infinite; }

  /* ==================== SYSTEM FETCH ($ patapim fetch) ==================== */
  .tv-fetch { padding: 8px 0 72px; }
  .tv-fetch-box {
    display: flex;
    gap: 64px;
    align-items: center;
    padding: 12px 0;
  }
  .tv-fetch-logo {
    font-family: var(--font-mono);
    font-size: clamp(18px, 3vw, 30px);
    line-height: 1.15;
    margin: 0;
    border: none;
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    padding: 0;
    overflow: visible;
    user-select: none;
    flex-shrink: 0;
  }
  .tv-fetch-info { font-size: 13.5px; line-height: 1.9; min-width: 0; }
  .tv-fetch-title { color: var(--text-primary); font-weight: 700; }
  .tv-fetch-title .tvf-at {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .tv-fetch-sep { color: var(--text-muted); }
  .tv-fetch-row { display: flex; gap: 12px; min-width: 0; }
  /* the founder note — prose that types itself at reading speed */
  .tv-fetch-info { flex: 1; min-width: 0; }
  .tv-fetch-note { margin-top: 16px; }
  .tv-fetch-p {
    max-width: 820px;
    margin: 0 0 26px;
    font-size: 15px;
    line-height: 2.05;
    color: var(--text-secondary);
  }
  .tv-fetch-p b { color: var(--cy); font-weight: 600; }
  .tv-fetch-p strong { color: #fff; font-weight: 600; }
  .tv-hl-pain { color: var(--vi); font-weight: 700; }
  .tv-fetch-grad {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .tvf-key { color: var(--text-tertiary); width: 92px; flex-shrink: 0; }
  .tvf-key::after { content: ' →'; color: var(--text-muted); }
  .tvf-val { color: var(--text-secondary); text-decoration: none; }
  a.tvf-val:hover {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .tv-palette { display: flex; gap: 6px; margin-top: 16px; }
  .tv-palette span { width: 18px; height: 18px; display: inline-block; }

  /* ==================== LIVE DEMOS ==================== */
  .tv-demos { padding: 8px 0 72px; }
  .tv-demo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 60px 48px;
    justify-items: center;
    max-width: 980px;
    margin: 0 auto;
  }
  /* the animated widgets, a notch bigger (zoom scales layout too) */
  .tv-demo-frame { zoom: 1.18; }
  .tv-demo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    width: 100%;
    max-width: 464px;
    padding: 26px 24px 24px;
    /* the panel: quiet gradient + hairline + deep shadow, DOS-editor calm */
    background: linear-gradient(180deg, #0b0b0e 0%, #070708 100%);
    border: 1px solid rgba(255, 255, 255, 0.09);
    box-shadow:
      0 18px 48px rgba(0, 0, 0, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 500ms ease, transform 500ms ease, border-color 200ms ease, box-shadow 200ms ease;
    scroll-margin-top: 90px;
  }
  .tv-demo.vis { opacity: 1; transform: none; }
  .tv-demo { overflow: hidden; position: relative; }
  /* hover: the panel comes alive — color, glow, volume. no movement. */
  .tv-demo:hover {
    border-color: rgba(139, 124, 248, 0.45);
    box-shadow:
      0 0 0 1px rgba(139, 124, 248, 0.22),
      0 0 28px rgba(139, 124, 248, 0.22),
      0 0 72px rgba(34, 211, 238, 0.12),
      0 26px 60px rgba(0, 0, 0, 0.7),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }
  /* a band of violet→cyan light sweeps across the panel while hovered */
  .tv-demo::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(115deg,
      transparent 32%,
      rgba(194, 107, 240, 0.11) 45%,
      rgba(255, 255, 255, 0.06) 50%,
      rgba(34, 211, 238, 0.13) 55%,
      transparent 68%);
    background-size: 260% 100%;
    background-position: 130% 0;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 250ms;
  }
  .tv-demo:hover::after {
    opacity: 1;
    animation: tv-card-sheen 2s ease-in-out infinite;
  }
  @keyframes tv-card-sheen {
    0% { background-position: 130% 0; }
    65%, 100% { background-position: -130% 0; }
  }
  .tv-demo-frame {
    filter: saturate(0) contrast(1.04);
    transition: filter 300ms ease;
  }
  .tv-demo:hover .tv-demo-frame { filter: saturate(0.6) contrast(1.02); }
  .tv-demo-name {
    font-size: 14.5px;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-top: 4px;
    transition: transform 180ms cubic-bezier(0.34, 1.56, 0.64, 1);
    transform-origin: center;
  }
  .tv-demo-name::before { content: '▸ '; color: var(--vi); }
  .tv-demo:hover .tv-demo-name {
    transform: scale(1.12);
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .tv-demo:hover .tv-demo-name::before {
    color: var(--cy);
    -webkit-text-fill-color: var(--cy);
  }
  /* second tier of the title lockup (service names, deliberately smaller) */
  .tv-demo-subname {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    font-size: 10.5px;
    font-weight: 700;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.28em;
    margin-top: -8px;
  }
  .tv-demo:hover .tv-demo-subname { color: var(--cy); }
  .tv-svclogo {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    filter: saturate(0) brightness(0.85);
    transition: filter 250ms ease;
  }
  .tv-demo:hover .tv-svclogo { filter: none; }
  .tv-svcdot { color: var(--text-muted); }
  .tv-demo-desc {
    font-size: 10.5px;
    line-height: 1.75;
    color: var(--text-tertiary);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
    max-width: 360px;
  }

  /* ==================== MAXIMIZED DEMO MODAL ==================== */
  .tv-demo-max { cursor: pointer; position: relative; }
  .tv-demo-expand {
    font-size: 10.5px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    opacity: 0;
    transition: opacity 150ms, color 150ms;
  }
  .tv-demo-max:hover .tv-demo-expand { opacity: 1; color: var(--cy); }

  #tv-max {
    position: fixed;
    inset: 0;
    z-index: 800;
    display: none;
  }
  #tv-max.open { display: block; }
  .tv-max-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(3px);
    opacity: 0;
    transition: opacity 260ms ease;
  }
  #tv-max.in .tv-max-backdrop { opacity: 1; }
  .tv-max-frame {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(1000px, 93vw);
    height: min(620px, 85vh);
    margin: calc(min(620px, 85vh) / -2) 0 0 calc(min(1000px, 93vw) / -2);
    background: #050505;
    border: 1px solid var(--border-strong);
    box-shadow: 0 0 80px rgba(139, 124, 248, 0.12), 0 40px 120px rgba(0, 0, 0, 0.8);
    transform-origin: top left;
    will-change: transform, opacity;
    display: flex;
    flex-direction: column;
  }
  .tv-max-scene {
    display: none;
    flex: 1;
    min-height: 0;
    flex-direction: column;
    opacity: 0;
    transition: opacity 200ms ease 120ms;
  }
  .tv-max-scene.active { display: flex; }
  #tv-max.in .tv-max-scene.active { opacity: 1; }
  .tv-max-scene > :global(.ccs),
  .tv-max-scene > :global(.mts),
  .tv-max-scene > :global(.vds),
  .tv-max-scene > :global(.ras),
  .tv-max-scene > :global(.cts),
  .tv-max-scene > :global(.bcs) { flex: 1; min-height: 0; }

  .tv-max-caption {
    display: flex;
    align-items: baseline;
    gap: 18px;
    padding: 14px 20px;
    border-top: 1px solid var(--border-default);
    background: #070708;
    font-size: 14px;
    line-height: 1.65;
  }
  .tv-max-caption-title {
    flex-shrink: 0;
    font-weight: 700;
    letter-spacing: 0.1em;
    font-size: 13px;
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .tv-max-caption-text { color: #c9c9c9; }
  .tv-max-caption-text b { color: var(--cy); font-weight: 600; }
  @media (max-width: 700px) {
    .tv-max-caption { flex-direction: column; gap: 4px; }
  }
  .tv-max-close {
    position: absolute;
    top: 10px;
    right: 12px;
    z-index: 20;
    background: none;
    border: 1px solid var(--border-default);
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 4px 9px;
    cursor: pointer;
    transition: color 120ms, border-color 120ms;
  }
  .tv-max-close:hover { color: #fff; border-color: var(--cy); }

  /* ==================== PRICING ==================== */
  .tv-pricing { padding: 8px 0 72px; }
  .tv-price-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
  }
  .tv-pcard {
    border: 1px solid var(--border-default);
    border-top: none;
    padding: 26px 26px 28px;
    position: relative;
    background: linear-gradient(180deg, #0c0c0e 0%, #060607 100%);
    display: flex;
    flex-direction: column;
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
  }
  /* gradient hairline across the top of every card */
  .tv-pcard::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, rgba(255,255,255,0.25), rgba(255,255,255,0.06));
  }
  .tv-pcard:hover { transform: translateY(-3px); border-color: var(--border-strong); }

  /* PRO — the hero card */
  .tv-pcard-hero {
    border: 1px solid transparent;
    border-top: none;
    background:
      linear-gradient(180deg, #0e0d14 0%, #07070b 100%) padding-box,
      linear-gradient(180deg, #c26bf0, #8b7cf8 50%, #22d3ee) border-box;
    box-shadow:
      0 0 44px rgba(139, 124, 248, 0.13),
      0 0 90px rgba(34, 211, 238, 0.07);
  }
  .tv-pcard-hero::before { background: var(--p-gradient); opacity: 0.9; height: 2px; background: linear-gradient(90deg, #c26bf0, #8b7cf8, #22d3ee); }
  .tv-pcard-hero { transform: scale(1.04); }
  .tv-pcard-hero .tv-pcard-amount { font-size: 40px; }
  .tv-pcard-hero:hover {
    transform: scale(1.04) translateY(-4px);
    box-shadow:
      0 0 60px rgba(139, 124, 248, 0.2),
      0 0 120px rgba(34, 211, 238, 0.1);
  }
  /* faint radial glow inside the pro card */
  .tv-pcard-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(80% 45% at 50% 0%, rgba(139, 124, 248, 0.12), transparent);
  }

  .tv-pcard-tag {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    padding: 3px 12px;
    font-size: 10px;
    letter-spacing: 0.2em;
    font-weight: 700;
    color: #000;
    background: linear-gradient(90deg, #c26bf0, #8b7cf8, #22d3ee);
    z-index: 2;
  }

  .tv-pcard-head { margin-bottom: 20px; }
  .tv-pcard-name {
    display: block;
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }
  .tv-pcard-sub {
    display: block;
    margin-top: 4px;
    font-size: 12px;
    color: var(--text-tertiary);
  }
  .tv-pcard-pricebox {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding-bottom: 18px;
    margin-bottom: 18px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .tv-pcard-amount {
    font-size: 34px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }
  .tv-grad {
    background: linear-gradient(120deg, #c26bf0, #8b7cf8, #22d3ee);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .tv-pcard-period { font-size: 12px; color: var(--text-muted); }
  .tv-pcard ul { list-style: none; margin: 0 0 24px; padding: 0; flex: 1; }
  .tv-pcard li {
    font-size: 13px;
    color: var(--text-secondary);
    padding: 5px 0;
  }
  .tv-check { color: var(--text-muted); margin-right: 8px; }
  .tv-pcard-hero .tv-check { color: var(--cy); }
  .tv-pbtn {
    display: block;
    text-align: center;
    border: 1px solid var(--border-strong);
    padding: 12px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
    transition: border-color 150ms, background 150ms, color 150ms;
  }
  .tv-pbtn:hover { border-color: #fff; background: rgba(255,255,255,0.05); color: #fff; }
  .tv-pbtn-accent {
    border: none;
    background: linear-gradient(90deg, #c26bf0, #8b7cf8, #22d3ee);
    color: #000;
  }
  .tv-pbtn-accent:hover {
    background: linear-gradient(90deg, #d187ff, #9c8dff, #4ae0f7);
    color: #000;
    box-shadow: 0 0 28px rgba(139, 124, 248, 0.35);
  }

  /* ==================== FOOTER ==================== */
  .tv-footer {
    border-top: 1px solid var(--border-default);
    padding: 28px 0 8px;
    font-size: 12px;
    color: var(--text-tertiary);
  }
  .tv-footer-top {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }
  .tv-footer-links { display: flex; gap: 18px; }
  .tv-footer-links a { color: var(--text-tertiary); text-decoration: none; }
  .tv-footer-links a:hover { color: var(--text-primary); }
  .tv-footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    color: var(--text-muted);
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 900px) {
    .tv-hero { grid-template-columns: 1fr; gap: 28px; padding-top: 48px; }
    .tv-tryrow { grid-template-columns: 1fr; gap: 32px; }
    .tv-demo-grid { grid-template-columns: repeat(2, 1fr); }
    .tv-price-grid { grid-template-columns: 1fr; max-width: 480px; }
    .tv-fetch-box { flex-direction: column; align-items: flex-start; gap: 28px; }
    .tv-nav-links { gap: 16px; }
    .tv-nav-links a:not(.tv-nav-cta) { display: none; }
  }
  @media (max-width: 560px) {
    .tv-demo-grid { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tv * { animation: none !important; transition: none !important; }
    .tv-row, .tv-demo { opacity: 1; transform: none; }
    .tvb-spark polyline { stroke-dashoffset: 0; }
  }
</style>

<script>
  // ---------- install tabs + copy ----------
  const tabs = document.querySelectorAll('[data-tvtab]');
  const panels = document.querySelectorAll('[data-tvpanel]');
  function activate(id: string) {
    tabs.forEach(t => t.classList.toggle('active', (t as HTMLElement).dataset.tvtab === id));
    panels.forEach(p => p.classList.toggle('active', (p as HTMLElement).dataset.tvpanel === id));
  }
  tabs.forEach(t => t.addEventListener('click', () => activate((t as HTMLElement).dataset.tvtab!)));
  if (/Mac|iPhone|iPad/.test(navigator.userAgent)) activate('mac');

  panels.forEach(p => {
    p.addEventListener('click', () => {
      const text = (p as HTMLElement).dataset.copy;
      if (!text) return;
      navigator.clipboard?.writeText(text).catch(() => {});
      p.classList.add('copied');
      setTimeout(() => p.classList.remove('copied'), 1400);
    });
  });

  // ---------- tagline typewriter (started by the boot sequence) ----------
  const tag = document.getElementById('tv-tagline');
  function startTagline() {
    if (!tag) return;
    const full = tag.dataset.text || '';
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
      tag.textContent = full;
      return;
    }
    let i = 0;
    const tick = () => {
      tag.textContent = full.slice(0, ++i);
      if (i < full.length) setTimeout(tick, 40 + Math.random() * 45);
    };
    tick();
  }

  // ---------- reveal Sign in for anonymous visitors ----------
  (async () => {
    const show = () => document.getElementById('tv-home-signin')?.style.setProperty('display', '');
    try {
      const res = await fetch('/api/auth/session');
      const data = await res.json();
      if (!data.authenticated) show();
    } catch {
      show();
    }
  })();

  // ---------- logo glitch + rare malfunction ----------
  const logo = document.getElementById('tv-logo');
  if (logo && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    setInterval(() => {
      if (logo.classList.contains('malf')) return;
      logo.classList.add('glitch');
      setTimeout(() => logo.classList.remove('glitch'), 280);
    }, 3800);

    // every 8–16s: SLICE GLITCH — the wordmark splits into horizontal bands
    // that desync sideways with hard steps and chromatic echoes, then realign.
    // no noise characters: the logo stays the logo, just badly synced for a beat
    const basePre = logo.querySelector('.tv-logo-base') as HTMLElement | null;
    const scheduleMalf = () => {
      setTimeout(() => {
        if (!basePre || logo.classList.contains('glitch')) { scheduleMalf(); return; }
        const cuts = [0, 16 + Math.random() * 16, 44 + Math.random() * 14, 70 + Math.random() * 14, 100];
        const clones: HTMLElement[] = [];
        basePre.style.visibility = 'hidden';
        for (let i = 0; i < cuts.length - 1; i++) {
          const clip = `inset(${cuts[i]}% -6px ${100 - cuts[i + 1]}% -6px)`;
          const dx = (Math.random() < 0.5 ? -1 : 1) * (4 + Math.random() * 9);
          const dur = 380 + Math.random() * 140;
          const mk = (color: string | null, amp: number) => {
            const c = basePre.cloneNode(true) as HTMLElement;
            c.classList.add('tv-malf-slice');
            c.style.clipPath = clip;
            if (color) {
              c.style.background = 'none';
              c.style.webkitTextFillColor = color;
              c.style.opacity = '0.7';
            }
            logo.appendChild(c);
            clones.push(c);
            c.animate(
              [
                { transform: 'translateX(0)', ...(color ? { opacity: 0 } : {}) },
                { transform: `translateX(${dx * amp}px)`, ...(color ? { opacity: 0.7 } : {}), offset: 0.2 },
                { transform: `translateX(${-dx * amp * 0.6}px)`, offset: 0.55 },
                { transform: `translateX(${dx * amp * 0.25}px)`, ...(color ? { opacity: 0.4 } : {}), offset: 0.8 },
                { transform: 'translateX(0)', ...(color ? { opacity: 0 } : {}) },
              ],
              { duration: dur, easing: 'steps(4, end)' }
            );
          };
          mk(null, 1);
          // two slices get a chromatic echo trailing the opposite way
          if (i === 1) mk('var(--cy)', -1.7);
          if (i === 2) mk('var(--vi)', -1.7);
        }
        setTimeout(() => {
          clones.forEach(c => c.remove());
          basePre.style.visibility = '';
          scheduleMalf();
        }, 560);
      }, 3500 + Math.random() * 4500);
    };
    scheduleMalf();
  }

  // ---------- founder note: types itself at reading speed on arrival ----------
  (function fetchTyper() {
    const note = document.querySelector('[data-fetch-note]');
    if (!note) return;
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // split every text node into [shown][hidden] up front — layout is fixed,
    // the text is just invisible until it gets "written"
    type Job = { shown: HTMLElement; hidden: HTMLElement; full: string };
    const jobs: Job[] = [];
    const walker = document.createTreeWalker(note, NodeFilter.SHOW_TEXT);
    const nodes: Text[] = [];
    while (walker.nextNode()) nodes.push(walker.currentNode as Text);
    nodes.forEach(n => {
      const full = n.nodeValue || '';
      if (!full.trim()) return;
      const shown = document.createElement('span');
      const hidden = document.createElement('span');
      hidden.style.visibility = 'hidden';
      hidden.textContent = full;
      (n as ChildNode).replaceWith(shown, hidden);
      jobs.push({ shown, hidden, full });
    });

    let started = false;
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting || started) return;
        started = true;
        io.disconnect();
        let j = 0, i = 0;
        const step = () => {
          if (j >= jobs.length) return;
          const job = jobs[j];
          i++;
          job.shown.textContent = job.full.slice(0, i);
          job.hidden.textContent = job.full.slice(i);
          // reading pace: brisk chars, real pauses at punctuation
          const ch = job.full[i - 1];
          let delay = 14;
          if (ch === '.') delay = 300;
          else if (ch === ',' || ch === '—') delay = 140;
          if (i >= job.full.length) { j++; i = 0; }
          setTimeout(step, delay);
        };
        step();
      });
    }, { threshold: 0.3 });
    io.observe(note);
  })();

  // ---------- $ patapim fetch — live uptime ----------
  const uptimeEl = document.getElementById('tv-uptime');
  if (uptimeEl) {
    const t0 = Date.now();
    setInterval(() => {
      const s = Math.floor((Date.now() - t0) / 1000);
      uptimeEl.textContent = s < 60 ? `${s}s` : `${Math.floor(s / 60)}m ${String(s % 60).padStart(2, '0')}s`;
    }, 1000);
  }

  // ---------- reveal on scroll (armed by the boot sequence) ----------
  function startObserving() {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('vis');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('[data-tvrow], [data-tvdemo]').forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${(i % 9) * 55}ms`;
      io.observe(el);
    });
  }

  // ---------- maximized demos: FLIP from a card to a big app window ----------
  (function maximize() {
    const modal = document.getElementById('tv-max');
    const frame = document.getElementById('tv-max-frame');
    if (!modal || !frame) return;

    const wrappers = new Map<string, HTMLElement>();
    modal.querySelectorAll('.tv-max-scene').forEach(w => {
      wrappers.set((w as HTMLElement).dataset.scene!, w as HTMLElement);
    });

    let open = false;
    let activeCardFrame: HTMLElement | null = null;
    let activeWrapper: HTMLElement | null = null;

    function flipFrom(): string {
      if (!activeCardFrame) return 'none';
      const from = activeCardFrame.getBoundingClientRect();
      const to = frame!.getBoundingClientRect();
      return `translate(${from.left - to.left}px, ${from.top - to.top}px) scale(${from.width / to.width}, ${from.height / to.height})`;
    }

    function openModal(card: HTMLElement, key: string) {
      if (open) return;
      const wrapper = wrappers.get(key);
      if (!wrapper) return;
      open = true;
      activeCardFrame = card.querySelector('.tv-demo-frame');
      activeWrapper = wrapper;
      wrappers.forEach(w => w.classList.toggle('active', w === wrapper));
      modal!.classList.add('open');
      modal!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      // start collapsed onto the card, expand to center
      frame!.style.transition = 'none';
      frame!.style.transform = flipFrom();
      frame!.style.opacity = '0.4';
      void frame!.offsetWidth;
      frame!.style.transition = 'transform 380ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 240ms ease';
      frame!.style.transform = 'none';
      frame!.style.opacity = '1';
      modal!.classList.add('in');
      wrapper.firstElementChild?.dispatchEvent(new Event('scene:start'));
    }

    function closeModal() {
      if (!open) return;
      open = false;
      activeWrapper?.firstElementChild?.dispatchEvent(new Event('scene:stop'));
      modal!.classList.remove('in');
      frame!.style.transform = flipFrom();
      frame!.style.opacity = '0.3';
      setTimeout(() => {
        modal!.classList.remove('open');
        modal!.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }, 330);
    }

    document.querySelectorAll('[data-maximize]').forEach(card => {
      const key = (card as HTMLElement).dataset.maximize!;
      card.addEventListener('click', () => openModal(card as HTMLElement, key));
      card.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          openModal(card as HTMLElement, key);
        }
      });
    });
    modal.querySelectorAll('[data-max-close]').forEach(el => el.addEventListener('click', closeModal));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  })();

  // ---------- boot sequence: CRT power-on → typed prompt → page prints in ----------
  (function boot() {
    const overlay = document.getElementById('tv-boot');
    const line = document.getElementById('tvb-line');
    const typed = document.getElementById('tvb-typed');
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    const finish = () => {
      overlay?.classList.add('done');
      startTagline();
      startObserving();
    };

    const internalNav = document.documentElement.classList.contains('tv-noboot');
    if (!overlay || !typed || reduced || internalNav) { finish(); return; }

    // timeline: flash (140ms) → cursor cuts in → beat → type → beat → page prints
    const T_CURSOR = 170;   // cursor appears by cut, right after the flash
    const T_TYPE = 560;     // a beat of blinking cursor, then typing starts
    const CHAR_MS = 34;     // typing speed
    const text = 'patapim';
    const T_TYPED = T_TYPE + text.length * CHAR_MS;  // ≈ 830ms
    const T_LIFT = T_TYPED + 380;                    // another beat ≈ 1.2s

    // 1. cursor cuts in, blinks alone for a beat
    setTimeout(() => line?.classList.add('on'), T_CURSOR);

    // 2. the prompt types itself
    setTimeout(() => {
      let i = 0;
      const type = () => {
        typed.textContent = text.slice(0, ++i);
        if (i < text.length) setTimeout(type, CHAR_MS);
      };
      type();
    }, T_TYPE);

    // every text on the page types itself left → right, all at once.
    // each text node is split into [visible span][hidden span] so nothing reflows.
    function prepareMassType() {
      const EXCLUDE = 'script,style,.tv-demo-frame,.tv-tagline,.tv-logo-layer,#tv-uptime,#tv-boot,#tv-max,.tv-brand,.tv-fetch-note';
      const scopes = [document.querySelector('.tv-nav'), document.querySelector('.tv-main')].filter(Boolean);
      const jobs: { shown: HTMLElement; hidden: HTMLElement; full: string; i: number; rate: number; delay: number }[] = [];
      // pass 1: collect nodes + measure (reads only, no layout thrash)
      const nodes: { node: Text; top: number }[] = [];
      for (const scope of scopes) {
        const walker = document.createTreeWalker(scope as Node, NodeFilter.SHOW_TEXT, {
          acceptNode(n) {
            if (!n.nodeValue || !n.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
            if ((n.parentElement as HTMLElement)?.closest(EXCLUDE)) return NodeFilter.FILTER_REJECT;
            return NodeFilter.FILTER_ACCEPT;
          },
        });
        while (walker.nextNode()) {
          const node = walker.currentNode as Text;
          nodes.push({ node, top: node.parentElement?.getBoundingClientRect().top ?? 0 });
        }
      }
      // pass 2: split (writes only)
      for (const { node, top } of nodes) {
        const full = node.nodeValue || '';
        const shown = document.createElement('span');
        const hidden = document.createElement('span');
        hidden.style.visibility = 'hidden';
        hidden.textContent = full;
        (node as ChildNode).replaceWith(shown, hidden);
        // cascade: texts lower on the screen clearly wait their turn
        const cascade = (Math.max(0, Math.min(top, 1600)) / 1600) * 42;
        jobs.push({
          shown, hidden, full, i: 0,
          rate: Math.max(1, Math.ceil(full.length / 28)),  // every text finishes in ~28 frames
          delay: Math.floor(Math.random() * 5 + cascade),  // jitter + vertical offset
        });
      }
      return jobs;
    }

    function runMassType(jobs: ReturnType<typeof prepareMassType>) {
      const step = () => {
        let active = false;
        for (const j of jobs) {
          if (j.delay > 0) { j.delay--; active = true; continue; }
          if (j.i < j.full.length) {
            j.i = Math.min(j.full.length, j.i + j.rate);
            j.shown.textContent = j.full.slice(0, j.i);
            j.hidden.textContent = j.full.slice(j.i);
            active = true;
          }
        }
        if (active) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    }

    // 3. beat, then: overlay cuts away and the whole page TYPES itself in
    setTimeout(() => {
      const jobs = prepareMassType();                          // split while still covered
      overlay.classList.add('done');                           // hard cut, no fade
      runMassType(jobs);
      setTimeout(startTagline, 260);
      setTimeout(startObserving, 420);                         // widgets join once the top has loaded
    }, T_LIFT);
  })();
</script>
</BaseLayout>
