---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';

const url = new URL(Astro.request.url);
const token = url.searchParams.get('token') || '';
const intent = url.searchParams.get('intent') || '';
---
<BaseLayout title="Verify email — PATAPIM" description="Verify your PATAPIM email address.">
  <main class="auth-page">
    <div class="auth-card">
      <a href="/" class="brand">PATAPIM</a>
      <h1>Verifying your email…</h1>

      <div id="state-pending">
        <p class="lead">Hold on a second while we confirm your link.</p>
      </div>

      <div id="state-success" hidden>
        <p class="lead success">Your email has been verified. You're all set.</p>
        <p class="lead" id="next-action">
          <a href="/go" class="btn primary">Go to your dashboard</a>
        </p>
      </div>

      <div id="state-error" hidden>
        <p class="lead error">This verification link is invalid or has expired.</p>
        <p class="lead">If you signed in already, you can request a new link from your dashboard.</p>
        <p>
          <a href="/go" class="btn primary">Go to my dashboard</a>
        </p>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .auth-page {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    padding: 32px 16px;
    background:
      radial-gradient(circle at 20% 10%, rgba(212,165,116,0.06), transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(120,165,212,0.04), transparent 40%),
      var(--bg-deep);
  }
  .auth-card {
    width: 100%; max-width: 440px;
    background: var(--bg-primary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    padding: 36px 32px;
    box-shadow: var(--shadow-lg);
  }
  .brand {
    display: block; font-family: var(--font-sans); font-weight: 700;
    color: var(--text-secondary); letter-spacing: 1.5px; text-decoration: none;
    font-size: 13px; margin-bottom: 24px;
  }
  .brand:hover { color: var(--accent-primary); }
  h1 {
    font-family: var(--font-sans); color: var(--text-primary);
    font-size: 22px; font-weight: 600; margin: 0 0 14px;
  }
  .lead { color: var(--text-secondary); font-size: 14px; line-height: 1.5; margin-bottom: 14px; }
  .lead.success { color: var(--success); }
  .lead.error { color: var(--error); }
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    padding: 12px 18px; border-radius: var(--radius-md);
    font-size: 14px; font-weight: 600; font-family: var(--font-sans);
    cursor: pointer; border: 1px solid transparent; text-decoration: none;
    transition: all var(--transition-fast); margin-top: 8px;
  }
  .btn.primary { background: var(--accent-primary); color: var(--bg-deep); }
  .btn.primary:hover { background: var(--accent-secondary); }
</style>

<script define:vars={{ token, intent }}>
  (async () => {
    const pending = document.getElementById('state-pending');
    const success = document.getElementById('state-success');
    const error = document.getElementById('state-error');
    const nextAction = document.getElementById('next-action');

    if (!token) {
      pending.hidden = true;
      error.hidden = false;
      return;
    }

    try {
      const res = await fetch('/api/auth/verify-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ token }),
      });
      pending.hidden = true;
      if (res.ok) {
        success.hidden = false;
        // If the user clicked through from a "verify before reset" flow, push
        // them to the reset-password page next.
        if (intent === 'reset' && nextAction) {
          nextAction.innerHTML = '<a href="/reset-password" class="btn primary">Continue to reset password</a>';
        }
      } else {
        error.hidden = false;
      }
    } catch {
      pending.hidden = true;
      error.hidden = false;
    }
  })();
</script>
