---
export const prerender = false;

import { getUserFromRequest } from '../../lib/auth';
import { isAdmin } from '../../lib/admin';

const env = Astro.locals.runtime.env;
const user = await getUserFromRequest(env.SESSIONS, Astro.request);

if (!user) {
  return Astro.redirect('/api/auth/google');
}
if (!isAdmin(user)) {
  return Astro.redirect('/go');
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SF Tracking — PATAPIM Admin</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg-deep: #0f0f10; --bg-primary: #151516; --bg-secondary: #1a1a1c;
      --bg-tertiary: #222225; --bg-elevated: #28282c; --bg-hover: #2e2e33;
      --text-primary: #e8e6e3; --text-secondary: #a09b94; --text-tertiary: #6b6660;
      --accent: #d4a574; --accent-subtle: rgba(212,165,116,0.14);
      --mission: #d47878; --mission-subtle: rgba(212,120,120,0.16);
      --success: #7cb382; --info: #78a5d4;
      --border: rgba(255,255,255,0.08); --border-strong: rgba(255,255,255,0.12);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg-deep); color: var(--text-primary); font-family: 'Inter', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }
    .mono { font-family: 'JetBrains Mono', monospace; }

    .topbar { border-bottom: 1px solid var(--border); background: var(--bg-primary); }
    .topbar-inner { max-width: 1200px; margin: 0 auto; padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; }
    .brand { display: flex; align-items: center; gap: 10px; font-weight: 600; }
    .brand-icon { color: var(--accent); font-family: 'JetBrains Mono', monospace; }
    .topbar-sep { width: 1px; height: 18px; background: var(--border-strong); margin: 0 4px; }
    .topbar-label { color: var(--text-secondary); font-size: 13px; }
    .topbar-right { display: flex; align-items: center; gap: 16px; font-size: 13px; }
    .topbar-link { color: var(--accent); }

    .wrap { max-width: 1200px; margin: 0 auto; padding: 28px 24px 80px; }
    .page-title { font-size: 24px; font-weight: 700; letter-spacing: -0.01em; }
    .page-sub { color: var(--text-secondary); font-size: 14px; margin-top: 6px; max-width: 720px; line-height: 1.5; }
    .page-sub code { background: var(--bg-tertiary); padding: 1px 6px; border-radius: 4px; font-family: 'JetBrains Mono', monospace; font-size: 12px; }

    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; margin: 24px 0; }
    .kpi { background: var(--bg-primary); border: 1px solid var(--border); border-radius: 12px; padding: 18px; }
    .kpi.mission { border-color: var(--mission-subtle); background: linear-gradient(180deg, var(--mission-subtle), var(--bg-primary) 60%); }
    .kpi-label { color: var(--text-secondary); font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em; }
    .kpi-value { font-size: 30px; font-weight: 700; margin-top: 8px; font-family: 'JetBrains Mono', monospace; }
    .kpi-sub { color: var(--text-tertiary); font-size: 12px; margin-top: 6px; }
    .kpi.mission .kpi-value { color: var(--mission); }

    .panel { background: var(--bg-primary); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 20px; }
    .panel h2 { font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-secondary); margin-bottom: 16px; }

    .chart { display: flex; align-items: flex-end; gap: 6px; height: 140px; }
    .bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; min-width: 0; }
    .bar-stack { width: 100%; max-width: 26px; display: flex; flex-direction: column-reverse; height: 110px; justify-content: flex-start; }
    .bar { width: 100%; border-radius: 3px 3px 0 0; }
    .bar.v { background: var(--info); }
    .bar.d { background: var(--accent); }
    .bar-label { font-size: 9px; color: var(--text-tertiary); font-family: 'JetBrains Mono', monospace; white-space: nowrap; transform: rotate(-45deg); transform-origin: center; margin-top: 6px; }
    .legend { display: flex; gap: 18px; margin-top: 14px; font-size: 12px; color: var(--text-secondary); }
    .legend span { display: inline-flex; align-items: center; gap: 6px; }
    .dot { width: 10px; height: 10px; border-radius: 3px; display: inline-block; }

    .cols { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @media (max-width: 760px) { .cols { grid-template-columns: 1fr; } }
    .rank { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .rank li { display: flex; justify-content: space-between; font-size: 13px; gap: 12px; }
    .rank .name { color: var(--text-primary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .rank .count { color: var(--text-secondary); font-family: 'JetBrains Mono', monospace; }

    .filters { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
    .chip { background: var(--bg-tertiary); border: 1px solid var(--border); color: var(--text-secondary); padding: 6px 12px; border-radius: 999px; font-size: 12px; cursor: pointer; }
    .chip.active { background: var(--accent-subtle); border-color: var(--accent); color: var(--accent); }

    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { text-align: left; color: var(--text-tertiary); font-weight: 500; font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; padding: 8px 10px; border-bottom: 1px solid var(--border); }
    td { padding: 9px 10px; border-bottom: 1px solid var(--border); vertical-align: top; }
    tr:hover td { background: var(--bg-secondary); }
    .tag { font-size: 11px; padding: 2px 8px; border-radius: 6px; font-weight: 500; }
    .tag.visit { background: rgba(120,165,212,0.16); color: var(--info); }
    .tag.download { background: var(--accent-subtle); color: var(--accent); }
    .pin { color: var(--mission); font-weight: 600; }
    .muted { color: var(--text-tertiary); }
    .loader { color: var(--text-secondary); padding: 40px; text-align: center; }
    .note { font-size: 12px; color: var(--text-tertiary); margin-top: 10px; line-height: 1.5; }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <a href="/" class="brand"><span class="brand-icon">&#x276F;_</span> PATAPIM</a>
      <div class="topbar-right">
        <span class="topbar-label">SF Tracking</span>
        <span class="topbar-sep"></span>
        <a href="/admin" class="topbar-link">&larr; Admin</a>
      </div>
    </div>
  </header>

  <main class="wrap">
    <h1 class="page-title">San Francisco activity</h1>
    <p class="page-sub">
      Page opens (with dwell time) and downloads originating from the SF Bay, with the
      downtown / Mission St corridor highlighted in <span class="pin">red</span>.
      "Near Mission St" means within <span id="near-km" class="mono"></span> km of the
      downtown Mission St anchor. Location comes from Cloudflare edge geo — it is
      city-level and approximate, so treat distances as a coarse signal, not GPS.
    </p>

    <div id="content"><div class="loader">Loading…</div></div>
  </main>

  <script>
    const fmtDur = (ms) => {
      if (!ms || ms < 1000) return '—';
      const s = Math.round(ms / 1000);
      if (s < 60) return s + 's';
      const m = Math.floor(s / 60), rs = s % 60;
      if (m < 60) return m + 'm ' + rs + 's';
      const h = Math.floor(m / 60);
      return h + 'h ' + (m % 60) + 'm';
    };
    const fmtTime = (ms) => {
      const d = new Date(ms);
      return d.toLocaleString('en-US', { timeZone: 'America/Los_Angeles', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
    };
    const esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const host = (ref) => { try { return new URL(ref).hostname.replace(/^www\./, ''); } catch { return ref || 'direct'; } };

    let DATA = null;
    let filter = 'all';

    function rankList(entries) {
      if (!entries || !entries.length) return '<li class="muted">No data yet</li>';
      return entries.map(([name, count]) => `<li><span class="name">${esc(name)}</span><span class="count">${count}</span></li>`).join('');
    }

    function renderChart(byDay) {
      const days = Object.keys(byDay).sort();
      const last = days.slice(-30);
      if (!last.length) return '<div class="muted">No activity recorded yet.</div>';
      let max = 1;
      for (const d of last) max = Math.max(max, byDay[d].visits + byDay[d].downloads);
      const cols = last.map((d) => {
        const b = byDay[d];
        const vh = Math.round((b.visits / max) * 110);
        const dh = Math.round((b.downloads / max) * 110);
        const label = d.slice(5);
        return `<div class="bar-col" title="${d}: ${b.visits} visits, ${b.downloads} downloads">
          <div class="bar-stack">
            <div class="bar v" style="height:${vh}px"></div>
            <div class="bar d" style="height:${dh}px"></div>
          </div>
          <div class="bar-label">${label}</div>
        </div>`;
      }).join('');
      return `<div class="chart">${cols}</div>
        <div class="legend">
          <span><i class="dot" style="background:var(--info)"></i> Visits</span>
          <span><i class="dot" style="background:var(--accent)"></i> Downloads</span>
        </div>`;
    }

    function renderTable() {
      let evts = DATA.events;
      if (filter === 'mission') evts = evts.filter((e) => e.nearMission);
      else if (filter === 'visit') evts = evts.filter((e) => e.type === 'visit');
      else if (filter === 'download') evts = evts.filter((e) => e.type === 'download');

      if (!evts.length) return '<div class="loader">No matching events.</div>';

      const rows = evts.map((e) => {
        const loc = [e.city, e.region].filter(Boolean).join(', ') || 'Unknown';
        const dist = e.distanceKm == null ? '—' : e.distanceKm.toFixed(2) + ' km';
        const what = e.type === 'download'
          ? `<span class="tag download">download</span> <span class="muted">${esc(e.asset || '')}</span>`
          : `<span class="tag visit">visit</span> <span class="muted">${esc(e.path || '/')}</span>`;
        return `<tr>
          <td class="mono">${fmtTime(e.time)}</td>
          <td>${what}</td>
          <td>${e.nearMission ? '<span class="pin">&#9679; Mission St</span>' : esc(loc)}</td>
          <td class="mono">${dist}</td>
          <td class="mono">${e.type === 'visit' ? fmtDur(e.durationMs) : '—'}</td>
          <td class="muted">${esc(e.type === 'visit' ? host(e.ref) : (e.asOrg || ''))}</td>
        </tr>`;
      }).join('');

      return `<table><thead><tr>
        <th>When (PT)</th><th>Event</th><th>Location</th><th>Dist. to Mission St</th><th>Dwell</th><th>Source</th>
      </tr></thead><tbody>${rows}</tbody></table>`;
    }

    function render() {
      const s = DATA.summary;
      document.getElementById('near-km').textContent = DATA.nearKm;
      const html = `
        <div class="kpis">
          <div class="kpi"><div class="kpi-label">SF page opens</div><div class="kpi-value">${s.visits.total}</div><div class="kpi-sub">unique page loads tracked</div></div>
          <div class="kpi mission"><div class="kpi-label">Near Mission St</div><div class="kpi-value">${s.visits.mission}</div><div class="kpi-sub">opens in downtown corridor</div></div>
          <div class="kpi"><div class="kpi-label">Avg dwell</div><div class="kpi-value">${fmtDur(s.visits.avgDwellMs)}</div><div class="kpi-sub">median ${fmtDur(s.visits.medianDwellMs)}</div></div>
          <div class="kpi"><div class="kpi-label">SF downloads</div><div class="kpi-value">${s.downloads.total}</div><div class="kpi-sub">${s.downloads.mission} near Mission St</div></div>
        </div>

        <div class="panel">
          <h2>Activity — last 30 days</h2>
          ${renderChart(DATA.byDay)}
        </div>

        <div class="cols">
          <div class="panel"><h2>Top cities</h2><ul class="rank">${rankList(s.topCities)}</ul></div>
          <div class="panel"><h2>Networks / ISPs</h2><ul class="rank">${rankList(s.topNetworks)}</ul></div>
          <div class="panel"><h2>Top pages</h2><ul class="rank">${rankList(s.topPaths)}</ul></div>
          <div class="panel"><h2>Referrers</h2><ul class="rank">${rankList(s.topReferrers)}</ul></div>
        </div>

        <div class="panel">
          <h2>Event log</h2>
          <div class="filters">
            <button class="chip" data-f="all">All</button>
            <button class="chip" data-f="mission">Near Mission St</button>
            <button class="chip" data-f="visit">Visits</button>
            <button class="chip" data-f="download">Downloads</button>
          </div>
          <div id="table-host">${renderTable()}</div>
          <p class="note">Showing up to 500 most recent events. Times in Pacific. Records are retained ~180 days.</p>
        </div>`;
      document.getElementById('content').innerHTML = html;
      bindFilters();
    }

    function bindFilters() {
      document.querySelectorAll('.chip').forEach((c) => {
        c.classList.toggle('active', c.dataset.f === filter);
        c.addEventListener('click', () => {
          filter = c.dataset.f;
          document.querySelectorAll('.chip').forEach((x) => x.classList.toggle('active', x.dataset.f === filter));
          document.getElementById('table-host').innerHTML = renderTable();
        });
      });
    }

    fetch('/api/admin/sf')
      .then((r) => r.json())
      .then((d) => { DATA = d; render(); })
      .catch(() => { document.getElementById('content').innerHTML = '<div class="loader">Failed to load.</div>'; });
  </script>
</body>
</html>
