---
// Deep Test — the test sheet for one run (?id=<runId>).
// Static page; everything client-side: plan + run results fetched on load,
// edits queued in localStorage and flushed (debounced) to the results API.
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Test Sheet — PATAPIM Deep Test</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="topbar">
    <div class="topbar-inner">
      <a href="/deep-test" class="brand">← Deep Test</a>
      <span class="sep"></span>
      <span id="run-title" class="label">Loading…</span>
      <span id="save-state" class="save-state" title="Autosave state"></span>
      <nav class="nav">
        <button id="export" class="btn-ghost">Finish & export report</button>
      </nav>
    </div>
    <div class="overall"><span id="overall-bar" class="bar wide"></span><span id="overall-text" class="mini"></span></div>
  </header>

  <div class="layout">
    <aside class="side">
      <div class="filters">
        <input id="search" type="search" placeholder="Search items…" />
        <div class="filter-row">
          <select id="f-mode"><option value="">mode: all</option><option>human</option><option>agent</option><option>both</option></select>
          <select id="f-priority"><option value="">prio: all</option><option>P0</option><option>P1</option><option>P2</option></select>
        </div>
        <div class="filter-row">
          <select id="f-status">
            <option value="">status: all</option><option value="untested">untested</option>
            <option value="pass">pass</option><option value="fail">fail</option>
            <option value="blocked">blocked</option><option value="skipped">skipped</option>
          </select>
        </div>
      </div>
      <div class="legend">
        <div class="legend-row"><span class="st st-pass on">✓</span> pass — worked as expected</div>
        <div class="legend-row"><span class="st st-fail on">✗</span> fail — misbehaved (add a note!)</div>
        <div class="legend-row"><span class="st st-blocked on">⊘</span> blocked — couldn't test it</div>
        <div class="legend-row"><span class="st st-skipped on">▸</span> skip — deliberately not tested</div>
        <div class="legend-row dim">Click ▸ on an item for steps & expected result. Notes autosave.</div>
      </div>
      <nav id="section-nav"></nav>
    </aside>

    <main id="sheet"><p class="hint">Loading plan…</p></main>
  </div>

  <script is:inline>
    const $ = (s) => document.querySelector(s);
    const esc = (s) => String(s ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
    const runId = new URLSearchParams(location.search).get('id');
    if (!runId) location.replace('/deep-test');

    const STATUSES = ['pass', 'fail', 'blocked', 'skipped'];
    const QKEY = 'deep-test-queue-' + runId;

    let plan = null, run = null;
    const state = new Map();        // itemId -> {s, note, ev, at, by}
    const itemsById = new Map();
    const sectionsRendered = new Set();
    let testerName = localStorage.getItem('deep-test-name') || 'anonymous';

    // ---------- autosave queue (localStorage-backed, survives reload/offline) ----------
    const queue = new Map(Object.entries(JSON.parse(localStorage.getItem(QKEY) || '{}')));
    let flushTimer = null, flushing = false;

    function persistQueue() { localStorage.setItem(QKEY, JSON.stringify(Object.fromEntries(queue))); }
    function setSaveState(txt, cls) { const el = $('#save-state'); el.textContent = txt; el.className = 'save-state ' + (cls || ''); }

    function enqueue(itemId) {
      const r = state.get(itemId);
      if (!r || !r.s) return;
      queue.set(itemId, { itemId, status: r.s, note: r.note || undefined, at: r.at });
      persistQueue();
      setSaveState('● unsaved', 'dirty');
      clearTimeout(flushTimer);
      flushTimer = setTimeout(flush, 1500);
    }

    async function flush(useBeacon) {
      if (!queue.size || flushing) return;
      const batch = [...queue.values()].slice(0, 100);
      const payload = JSON.stringify({ by: testerName, results: batch });
      if (useBeacon && navigator.sendBeacon) {
        const blob = new Blob([payload], { type: 'application/json' });
        if (navigator.sendBeacon(`/api/deep-test/runs/${runId}/results`, blob)) {
          batch.forEach(b => queue.delete(b.itemId)); persistQueue();
        }
        return;
      }
      flushing = true;
      setSaveState('saving…', 'saving');
      try {
        const r = await fetch(`/api/deep-test/runs/${runId}/results`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload,
        });
        if (!r.ok) throw new Error((await r.json().catch(() => ({}))).error || r.status);
        const { counts } = await r.json();
        batch.forEach(b => queue.delete(b.itemId));
        persistQueue();
        if (counts) { run.counts = counts; renderProgress(); }
        setSaveState(queue.size ? '● unsaved' : '✓ saved', queue.size ? 'dirty' : 'saved');
        if (queue.size) { flushTimer = setTimeout(flush, 1500); }
      } catch (e) {
        setSaveState('⚠ save failed — retrying', 'error');
        flushTimer = setTimeout(flush, 5000);
      } finally { flushing = false; }
    }
    addEventListener('pagehide', () => flush(true));

    // ---------- rendering ----------
    function countsForSection(secId) {
      const c = { pass: 0, fail: 0, blocked: 0, skipped: 0, total: 0 };
      for (const it of plan.items) {
        if (it.section !== secId) continue;
        c.total++;
        const r = state.get(it.id);
        if (r && r.s) c[r.s]++;
      }
      return c;
    }
    function barHtml(c, cls) {
      const seg = (n, k) => c.total && n ? `<span class="seg ${k}" style="width:${(n / c.total) * 100}%"></span>` : '';
      return `<span class="bar ${cls || ''}">${seg(c.pass, 'p')}${seg(c.fail, 'f')}${seg(c.blocked, 'b')}${seg(c.skipped, 's')}</span>`;
    }

    function renderProgress() {
      // overall
      const c = { pass: 0, fail: 0, blocked: 0, skipped: 0, total: plan.items.length };
      for (const r of state.values()) if (r.s) c[r.s]++;
      const tested = c.pass + c.fail + c.blocked + c.skipped;
      $('#overall-bar').outerHTML = barHtml(c, 'wide').replace('class="bar', 'id="overall-bar" class="bar');
      $('#overall-text').textContent = `${tested}/${c.total} · ✓${c.pass} ✗${c.fail} ⊘${c.blocked} ▸${c.skipped}`;
      // per-section nav
      for (const sec of plan.sections) {
        const el = document.getElementById('nav-' + sec.id);
        if (el) el.querySelector('.nav-bar-slot').innerHTML = barHtml(countsForSection(sec.id));
      }
    }

    function itemRow(it) {
      const r = state.get(it.id) || {};
      const badges = [
        `<span class="badge bd-${it.mode}">${it.mode}</span>`,
        `<span class="badge bd-prio">${it.priority}</span>`,
        it.destructive ? '<span class="badge bd-destr">destructive</span>' : '',
        ...(it.requiresExternal || []).map(x => `<span class="badge bd-ext">${esc(x)}</span>`),
        it.seedResult ? `<span class="badge bd-seed" title="Result in the 2026-06-08 integral test">prev: ${esc(it.seedResult)}</span>` : '',
      ].join('');
      const detail = `
        ${it.preconditions?.length ? `<div class="kv"><span>Preconditions</span><ul>${it.preconditions.map(p => `<li>${esc(p)}</li>`).join('')}</ul></div>` : ''}
        ${it.steps?.length ? `<div class="kv"><span>Steps</span><ol>${it.steps.map(s => `<li>${esc(s)}</li>`).join('')}</ol></div>` : ''}
        ${it.expected ? `<div class="kv"><span>Expected</span><p>${esc(it.expected)}</p></div>` : ''}
        ${it.automationHints ? `<div class="kv dim"><span>Automation</span><p>${esc([it.automationHints.selectors?.join(' '), it.automationHints.mcpTools?.join(' '), it.automationHints.notes].filter(Boolean).join(' · '))}</p></div>` : ''}`;
      return `<div class="item" id="item-${esc(it.id)}" data-id="${esc(it.id)}" data-mode="${it.mode}" data-priority="${it.priority}" data-status="${r.s || 'untested'}" data-text="${esc((it.id + ' ' + it.title + ' ' + (it.subsection || '')).toLowerCase())}">
        <div class="item-head">
          <button class="expander" title="Show steps">▸</button>
          <span class="item-id mono">${esc(it.id)}</span>
          <span class="item-title">${esc(it.title)}</span>
          ${badges}
          <span class="spacer"></span>
          <span class="st-btns">${STATUSES.map(s => `<button class="st st-${s} ${r.s === s ? 'on' : ''}" data-s="${s}">${s === 'pass' ? '✓' : s === 'fail' ? '✗' : s === 'blocked' ? '⊘' : '▸'}</button>`).join('')}</span>
        </div>
        <div class="item-detail" hidden>${detail}</div>
        <textarea class="note" placeholder="Notes…" rows="1">${esc(r.note || '')}</textarea>
        ${r.ev ? `<details class="evidence"><summary>Evidence (${esc(r.by || '?')})</summary><pre>${esc(r.ev)}</pre></details>` : ''}
      </div>`;
    }

    function renderSection(sec) {
      if (sectionsRendered.has(sec.id)) return;
      sectionsRendered.add(sec.id);
      const host = document.getElementById('items-' + sec.id);
      host.innerHTML = plan.items.filter(i => i.section === sec.id).map(itemRow).join('');
      applyFilters(host);
    }

    function renderSheet() {
      $('#sheet').innerHTML = plan.sections
        .sort((a, b) => (a.order || 0) - (b.order || 0))
        .map(sec => `<details class="section" id="sec-${esc(sec.id)}" data-sec="${esc(sec.id)}">
            <summary><span class="sec-title">${esc(sec.title)}</span>
              <span class="mini">${plan.items.filter(i => i.section === sec.id).length} items</span></summary>
            ${sec.description ? `<p class="sec-desc">${esc(sec.description)}</p>` : ''}
            <div class="items" id="items-${esc(sec.id)}"></div>
          </details>`).join('');
      $('#section-nav').innerHTML = plan.sections.map(sec =>
        `<a id="nav-${esc(sec.id)}" href="#sec-${esc(sec.id)}"><span class="nav-title">${esc(sec.title)}</span><span class="nav-bar-slot"></span></a>`).join('');

      document.querySelectorAll('details.section').forEach(d => {
        d.addEventListener('toggle', () => { if (d.open) renderSection(plan.sections.find(s => s.id === d.dataset.sec)); });
      });
      document.querySelectorAll('#section-nav a').forEach(a => a.addEventListener('click', () => {
        const sec = document.getElementById(a.getAttribute('href').slice(1));
        if (sec && !sec.open) sec.open = true;
      }));

      // Event delegation for the whole sheet
      $('#sheet').addEventListener('click', (e) => {
        const stBtn = e.target.closest('.st');
        if (stBtn) {
          const itemEl = stBtn.closest('.item');
          const id = itemEl.dataset.id;
          const cur = state.get(id) || {};
          const s = stBtn.dataset.s === cur.s ? null : stBtn.dataset.s; // toggle off = clear locally (stays last-saved server-side)
          if (s) {
            state.set(id, { ...cur, s, at: Date.now(), by: testerName });
            enqueue(id);
          } else {
            state.set(id, { ...cur, s: cur.s }); // no clear API — keep as-is
          }
          itemEl.dataset.status = (state.get(id) || {}).s || 'untested';
          itemEl.querySelectorAll('.st').forEach(b => b.classList.toggle('on', b.dataset.s === (state.get(id) || {}).s));
          renderProgress();
          return;
        }
        const exp = e.target.closest('.expander');
        if (exp) {
          const det = exp.closest('.item').querySelector('.item-detail');
          det.hidden = !det.hidden;
          exp.textContent = det.hidden ? '▸' : '▾';
        }
      });
      $('#sheet').addEventListener('input', (e) => {
        const ta = e.target.closest('textarea.note');
        if (!ta) return;
        ta.style.height = 'auto'; ta.style.height = ta.scrollHeight + 'px';
        const itemEl = ta.closest('.item');
        const id = itemEl.dataset.id;
        const cur = state.get(id) || {};
        state.set(id, { ...cur, note: ta.value, at: Date.now(), by: testerName });
        if ((state.get(id) || {}).s) enqueue(id);  // notes ride along once a status exists
      });
    }

    // ---------- filters ----------
    function applyFilters(scope) {
      const q = $('#search').value.trim().toLowerCase();
      const fm = $('#f-mode').value, fp = $('#f-priority').value, fs = $('#f-status').value;
      (scope || document).querySelectorAll('.item').forEach(el => {
        const live = state.get(el.dataset.id);
        el.dataset.status = (live && live.s) || 'untested';
        const ok = (!q || el.dataset.text.includes(q))
          && (!fm || el.dataset.mode === fm)
          && (!fp || el.dataset.priority === fp)
          && (!fs || el.dataset.status === fs);
        el.style.display = ok ? '' : 'none';
      });
    }
    ['#search', '#f-mode', '#f-priority', '#f-status'].forEach(s => $(s).addEventListener('input', () => {
      // ensure filtered sections are rendered so matches are findable
      if ($('#search').value || $('#f-mode').value || $('#f-priority').value || $('#f-status').value) {
        plan.sections.forEach(sec => { renderSection(sec); document.getElementById('sec-' + sec.id).open = true; });
      }
      applyFilters();
    }));

    // ---------- report export ----------
    $('#export').addEventListener('click', async () => {
      await flush();
      const lines = [`# PATAPIM Deep Test — ${run.name} (${run.environment})`, '',
        `- Run: \`${runId}\` · plan \`${run.planVersion}\` · app ${run.appVersion || 'n/a'}`,
        `- Date: ${new Date().toISOString().slice(0, 16)}Z`, ''];
      const c = { pass: 0, fail: 0, blocked: 0, skipped: 0 };
      for (const r of state.values()) if (r.s) c[r.s]++;
      const tested = c.pass + c.fail + c.blocked + c.skipped;
      lines.push(`**${tested}/${plan.items.length} executed — ${c.pass} PASS · ${c.fail} FAIL · ${c.blocked} BLOCKED · ${c.skipped} SKIPPED**`, '');
      const failed = plan.items.filter(i => state.get(i.id)?.s === 'fail');
      if (failed.length) {
        lines.push('## Failures', '');
        for (const it of failed) {
          const r = state.get(it.id);
          lines.push(`### ${it.id} — ${it.title}`, r.note ? `> ${r.note.replace(/\n/g, '\n> ')}` : '_(no note)_', '');
        }
      }
      lines.push('## Per-section results', '', '| Section | ✓ | ✗ | ⊘ | ▸ | untested |', '|---|---|---|---|---|---|');
      for (const sec of plan.sections) {
        const sc = countsForSection(sec.id);
        const t = sc.pass + sc.fail + sc.blocked + sc.skipped;
        lines.push(`| ${sec.title} | ${sc.pass} | ${sc.fail} | ${sc.blocked} | ${sc.skipped} | ${sc.total - t} |`);
      }
      const noted = plan.items.filter(i => state.get(i.id)?.note && state.get(i.id)?.s !== 'fail');
      if (noted.length) {
        lines.push('', '## Notes on non-failures', '');
        for (const it of noted) lines.push(`- **${it.id}** (${state.get(it.id).s}): ${state.get(it.id).note}`);
      }
      const markdown = lines.join('\n');
      try {
        const r = await fetch(`/api/deep-test/runs/${runId}/report`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ markdown, by: testerName }),
        });
        if (!r.ok) throw new Error((await r.json().catch(() => ({}))).error || r.status);
        location.href = '/deep-test/reports?id=' + runId;
      } catch (e) { alert('Report upload failed: ' + e.message); }
    });

    // ---------- boot ----------
    (async () => {
      const [planRes, runRes] = await Promise.all([
        fetch('/api/deep-test/plan'),
        fetch(`/api/deep-test/runs/${runId}`),
      ]);
      plan = await planRes.json();
      if (!runRes.ok) { $('#sheet').innerHTML = '<p class="hint">Run not found. <a href="/deep-test">Back</a></p>'; return; }
      const data = await runRes.json();
      run = data.run;
      testerName = localStorage.getItem('deep-test-name') || run.name || 'anonymous';
      plan.items.forEach(i => itemsById.set(i.id, i));

      // server results → state
      for (const sec of Object.values(data.results || {})) {
        for (const [itemId, r] of Object.entries(sec.items || {})) state.set(itemId, r);
      }
      // local unsent queue wins over server (it's newer by construction)
      for (const [itemId, q] of queue) {
        state.set(itemId, { s: q.status, note: q.note, at: q.at, by: testerName });
      }

      document.title = `${run.name} — PATAPIM Deep Test`;
      $('#run-title').textContent = `${run.name} · ${run.environment}${run.label ? ' · ' + run.label : ''}`;
      renderSheet();
      renderProgress();
      if (queue.size) flush();

      // open first section with untested items
      const first = plan.sections.find(s => countsForSection(s.id).total > 0);
      if (first) document.getElementById('sec-' + first.id).open = true;
    })();
  </script>

  <style is:global>
    :root {
      --bg: #0d1117; --panel: #161b22; --border: #30363d;
      --text: #e6edf3; --dim: #8b949e; --accent: #2f81f7;
      --pass: #3fb950; --fail: #f85149; --blocked: #d29922; --skip: #6e7681;
    }
    * { box-sizing: border-box; margin: 0; }
    body { background: var(--bg); color: var(--text); font-family: Inter, system-ui, sans-serif; }
    .mono, code, pre { font-family: 'JetBrains Mono', monospace; }
    a { color: var(--accent); text-decoration: none; }
    .hint { color: var(--dim); padding: 20px; }
    .mini { color: var(--dim); font-size: 12px; }
    .topbar { position: sticky; top: 0; z-index: 10; background: var(--panel); border-bottom: 1px solid var(--border); }
    .topbar-inner { display: flex; align-items: center; gap: 12px; padding: 10px 16px; }
    .brand { color: var(--text); font-weight: 600; font-size: 14px; }
    .sep { width: 1px; height: 16px; background: var(--border); }
    .label { font-size: 14px; color: var(--dim); }
    .nav { margin-left: auto; }
    .btn-ghost { background: transparent; border: 1px solid var(--border); color: var(--text); border-radius: 6px; padding: 6px 14px; font: inherit; font-size: 13px; cursor: pointer; }
    .btn-ghost:hover { border-color: var(--accent); }
    .save-state { font-size: 12px; color: var(--dim); }
    .save-state.dirty { color: var(--blocked); } .save-state.saved { color: var(--pass); }
    .save-state.saving { color: var(--accent); } .save-state.error { color: var(--fail); }
    .overall { display: flex; align-items: center; gap: 10px; padding: 0 16px 8px; }
    .bar { display: inline-flex; width: 140px; height: 8px; background: var(--bg); border-radius: 4px; overflow: hidden; }
    .bar.wide { flex: 1; height: 6px; }
    .seg.p { background: var(--pass); } .seg.f { background: var(--fail); }
    .seg.b { background: var(--blocked); } .seg.s { background: var(--skip); }
    .layout { display: grid; grid-template-columns: 280px 1fr; max-width: 1500px; margin: 0 auto; }
    .side { position: sticky; top: 64px; height: calc(100vh - 64px); overflow-y: auto; padding: 14px; border-right: 1px solid var(--border); }
    .filters input, .filters select { width: 100%; background: var(--bg); border: 1px solid var(--border); color: var(--text); border-radius: 6px; padding: 7px 10px; font: inherit; font-size: 13px; margin-bottom: 8px; }
    .filter-row { display: flex; gap: 8px; } .filter-row select { flex: 1; }
    .legend { border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; margin-top: 4px; display: flex; flex-direction: column; gap: 6px; }
    .legend-row { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text); }
    .legend-row .st { pointer-events: none; width: 24px; height: 20px; font-size: 11px; }
    .legend-row.dim { color: var(--dim); font-size: 11.5px; line-height: 1.4; }
    #section-nav { display: flex; flex-direction: column; margin-top: 10px; }
    #section-nav a { display: flex; flex-direction: column; gap: 4px; padding: 8px 10px; border-radius: 6px; color: var(--text); font-size: 13px; }
    #section-nav a:hover { background: rgba(47,129,247,0.08); }
    #section-nav .bar { width: 100%; height: 4px; }
    main#sheet { padding: 16px 20px 120px; min-width: 0; }
    details.section { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; margin-bottom: 12px; }
    details.section > summary { cursor: pointer; padding: 12px 16px; display: flex; align-items: baseline; gap: 12px; list-style: none; }
    details.section > summary::before { content: '▸'; color: var(--dim); }
    details.section[open] > summary::before { content: '▾'; }
    .sec-title { font-weight: 600; }
    .sec-desc { color: var(--dim); font-size: 13px; padding: 0 16px 10px; }
    .items { padding: 0 10px 10px; }
    .item { border-top: 1px solid var(--border); padding: 8px 6px; }
    .item-head { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .expander { background: none; border: 0; color: var(--dim); cursor: pointer; font-size: 12px; padding: 2px; }
    .item-id { color: var(--dim); font-size: 11.5px; }
    .item-title { font-size: 14px; }
    .spacer { flex: 1; }
    .badge { font-size: 10.5px; padding: 1px 7px; border-radius: 9px; border: 1px solid var(--border); color: var(--dim); }
    .bd-agent { color: #58a6ff; } .bd-both { color: #bc8cff; } .bd-human { color: #7ee787; }
    .bd-destr { color: var(--fail); border-color: rgba(248,81,73,0.4); }
    .bd-ext { color: var(--blocked); }
    .st-btns { display: inline-flex; gap: 4px; }
    .st { width: 30px; height: 26px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg); color: var(--dim); cursor: pointer; font-size: 13px; }
    .st-pass.on { background: rgba(63,185,80,0.2); color: var(--pass); border-color: var(--pass); }
    .st-fail.on { background: rgba(248,81,73,0.2); color: var(--fail); border-color: var(--fail); }
    .st-blocked.on { background: rgba(210,153,34,0.2); color: var(--blocked); border-color: var(--blocked); }
    .st-skipped.on { background: rgba(110,118,129,0.25); color: var(--text); border-color: var(--skip); }
    .item-detail { padding: 8px 8px 4px 30px; }
    .kv { display: flex; gap: 10px; font-size: 13px; margin-bottom: 6px; }
    .kv > span { color: var(--dim); min-width: 110px; font-size: 12px; }
    .kv ul, .kv ol { padding-left: 18px; } .kv.dim p { color: var(--dim); font-size: 12px; }
    .note { width: calc(100% - 30px); margin: 6px 0 2px 30px; background: var(--bg); border: 1px solid var(--border); color: var(--text); border-radius: 6px; padding: 6px 10px; font: inherit; font-size: 13px; resize: none; overflow: hidden; }
    .note:placeholder-shown { opacity: 0.6; }
    .evidence { margin: 4px 0 4px 30px; font-size: 12px; color: var(--dim); }
    .evidence pre { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 8px; overflow-x: auto; white-space: pre-wrap; }
    .item[data-status="pass"] .item-title { opacity: 0.55; }
    @media (max-width: 900px) { .layout { grid-template-columns: 1fr; } .side { position: static; height: auto; border-right: 0; border-bottom: 1px solid var(--border); } }
  </style>
