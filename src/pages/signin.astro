---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getUserFromRequest } from '../lib/auth';
import { createReferralAssociation, activateReferral } from '../lib/referral';
import { completePairingIfPresent } from '../lib/pairing';

const env = Astro.locals.runtime.env;
const url = new URL(Astro.request.url);
const pairingSessionId = url.searchParams.get('s');
const errorParam = url.searchParams.get('error');
const rawReturnTo = url.searchParams.get('returnTo') || '';
// Only accept relative paths (open-redirect protection).
const returnTo = rawReturnTo.startsWith('/') ? rawReturnTo : '';

const user = await getUserFromRequest(env.SESSIONS, Astro.request);

// If pairing was just initiated, set the cookie so any sign-in path (Google
// or email/password) can complete it via completePairingIfPresent.
if (!user && pairingSessionId) {
  Astro.response.headers.append(
    'Set-Cookie',
    `__patapim_pair=${pairingSessionId}; Secure; SameSite=Lax; Path=/; Max-Age=600`,
  );
}

if (user) {
  // Already signed in — just complete pairing/referral and bounce away.
  const cookies = Astro.request.headers.get('cookie') || '';
  const refCookieMatch = cookies.match(/(?:^|;\s*)__patapim_ref=([^;]+)/);
  if (refCookieMatch) {
    try {
      const referrerEmail = decodeURIComponent(refCookieMatch[1]);
      await createReferralAssociation(env.LICENSES, referrerEmail, user.email);
      await activateReferral(env.LICENSES, user.email);
    } catch (e) {
      console.error('Referral activation error (signin fast path):', e);
    }
  }

  if (pairingSessionId) {
    // Inject the pair cookie temporarily so completePairingIfPresent picks it
    // up. We pass a synthetic Request that the helper can read.
    const reqWithPair = new Request(Astro.request.url, {
      headers: { cookie: `__patapim_pair=${pairingSessionId}` },
    });
    await completePairingIfPresent(env, reqWithPair, {
      googleId: user.googleId,
      email: user.email,
    });

    const headers = new Headers({ Location: '/go?paired=1' });
    if (refCookieMatch) headers.append('Set-Cookie', '__patapim_ref=; Secure; SameSite=Lax; Path=/; Max-Age=0');
    return new Response(null, { status: 302, headers });
  }

  if (refCookieMatch) {
    return new Response(null, {
      status: 302,
      headers: {
        Location: '/go',
        'Set-Cookie': '__patapim_ref=; Secure; SameSite=Lax; Path=/; Max-Age=0',
      },
    });
  }
  return Astro.redirect(returnTo || '/go');
}

// Carry both pairing (?s) and returnTo across all sub-flows so signup,
// forgot-password and Google sign-in all land back where the user started.
const params = new URLSearchParams();
if (pairingSessionId) params.set('s', pairingSessionId);
if (returnTo) params.set('returnTo', returnTo);
const sigParam = params.toString() ? `?${params.toString()}` : '';
---
<BaseLayout title="Sign in — PATAPIM" description="Sign in to your PATAPIM account.">
  <main class="auth-page">
    <div class="auth-wrap">
      <a href="/" class="auth-brand"><span class="auth-brand-icon">❯_</span><span class="auth-brand-sep">/</span><span class="auth-brand-name">patapim</span></a>
      <div class="auth-card tv-auth-card">
        <div class="tv-label"><span class="tv-label-prompt">$</span> patapim signin <span class="tv-dim">— welcome back</span></div>
        <h1 class="tv-auth-title">Sign in</h1>

        {errorParam === 'google_only' && (
          <div class="alert">This email was created with Google. Sign in with Google below — or use "Forgot password?" to set a password.</div>
        )}

        <a href={`/api/auth/google${sigParam}`} class="google-btn tv-pbtn">
          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
            <path fill="#4285F4" d="M17.64 9.205c0-.639-.057-1.252-.164-1.841H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/>
            <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
            <path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.997 8.997 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/>
            <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.581C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/>
          </svg>
          Sign in with Google
        </a>

        <div class="tv-divider">or sign in with email</div>

        <form id="signin-form" novalidate>
          <label class="field">
            <span class="tv-form-label">Email</span>
            <input class="tv-input" type="email" name="email" autocomplete="email" required />
          </label>

          <label class="field">
            <span class="tv-form-label">Password</span>
            <input class="tv-input" type="password" name="password" autocomplete="current-password" required minlength="10" />
          </label>

          <div class="row-end">
            <a class="muted-link" href={`/reset-password${sigParam}`}>Forgot password?</a>
          </div>

          <button type="submit" class="tv-pbtn tv-pbtn-accent">Sign in</button>
          <p id="signin-error" class="form-error" hidden></p>
        </form>

        <p class="signup-prompt">Don't have an account? <a href={`/signup${sigParam}`}>Sign up</a></p>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
    background: var(--bg-deep);
  }
  .auth-wrap { width: 100%; max-width: 400px; }
  .auth-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
    margin: 0 0 14px 2px;
  }
  .auth-brand:hover .auth-brand-name { color: var(--text-primary); }
  .auth-brand-icon {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .auth-brand-sep { color: var(--text-muted); }
  .auth-brand-name { letter-spacing: 0.05em; transition: color 120ms; }

  .alert {
    border: 1px solid rgba(34, 211, 238, 0.4);
    background: rgba(34, 211, 238, 0.06);
    color: var(--text-secondary);
    font-size: 12.5px;
    line-height: 1.5;
    padding: 10px 12px;
    margin-bottom: 16px;
  }

  .google-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    margin-top: 4px;
  }
  .google-btn svg { flex-shrink: 0; }

  .field { display: block; }
  .row-end { display: flex; justify-content: flex-end; margin: 8px 0 14px; }
  .muted-link {
    color: var(--text-tertiary);
    font-size: 12px;
    text-decoration: none;
  }
  .muted-link:hover { color: var(--cy); }

  button.tv-pbtn { width: 100%; }
  button.tv-pbtn:disabled { opacity: 0.6; cursor: wait; }

  .form-error { color: var(--error); font-size: 12px; margin: 10px 0 0; }

  .signup-prompt {
    text-align: center;
    color: var(--text-tertiary);
    font-size: 12.5px;
    margin-top: 20px;
  }
  .signup-prompt a { color: var(--text-primary); text-decoration: underline; }
  .signup-prompt a:hover { color: var(--cy); }
</style>

<script>
  const form = document.getElementById('signin-form') as HTMLFormElement | null;
  const errEl = document.getElementById('signin-error') as HTMLParagraphElement | null;
  if (form && errEl) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errEl.hidden = true;
      errEl.textContent = '';
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;

      const data = new FormData(form);
      const email = String(data.get('email') || '').trim();
      const password = String(data.get('password') || '');

      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ email, password }),
        });
        const body = await res.json().catch(() => ({}));
        if (res.ok && body.ok) {
          const params = new URLSearchParams(window.location.search);
          const rt = params.get('returnTo') || '';
          const safeReturnTo = rt.startsWith('/') ? rt : '';
          window.location.href = body.paired ? '/go?paired=1' : (safeReturnTo || '/go');
          return;
        }
        if (res.status === 429) {
          errEl.textContent = `Too many attempts. Try again in ${body.retryAfter || 60}s.`;
        } else if (body.hint === 'google_only') {
          errEl.textContent = "We couldn't sign you in. This email may have been created with Google — try the Google button below.";
        } else {
          errEl.textContent = "Wrong email or password.";
        }
        errEl.hidden = false;
      } catch (e) {
        errEl.textContent = 'Network error. Please try again.';
        errEl.hidden = false;
      } finally {
        submitBtn.disabled = false;
      }
    });
  }
</script>
