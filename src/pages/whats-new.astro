---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

type Card = {
  version: string;
  title: string;
  desc: string;
};

type Section = {
  label: string;
  title: string;
  cards: Card[];
};

const sections: Section[] = [
  {
    label: 'extensibility',
    title: 'Extensibility & API',
    cards: [
      {
        version: 'v1.6',
        title: 'Local API & TypeScript SDK',
        desc: 'A scoped-token HTTP + WebSocket API on localhost, wrapped by @patapim/sdk — drive terminals, tasks and notifications from your own scripts.',
      },
      {
        version: 'v1.6',
        title: 'Plugin system',
        desc: 'Build isolated plugins that add MCP tools to every Claude Code session, plus UI panels, toolbar buttons, scheduled tasks and instruction blocks.',
      },
      {
        version: 'v1.6',
        title: 'Plugin marketplace',
        desc: 'Browse and install community plugins from Preferences, or from any repo URL. Publish yours to the open community index.',
      },
    ],
  },
  {
    label: 'stability',
    title: 'Reliability & infra',
    cards: [
      {
        version: 'v1.2.106',
        title: 'Sessions survive updates',
        desc: 'Terminal state is now preserved across auto-updates, with anti-clobber logic and a safety net for edge cases.',
      },
      {
        version: 'v1.2.94',
        title: 'Security audit remediation',
        desc: 'Tier 0/1/2 fixes from a 10-domain security review — about 30 hardening changes across the app.',
      },
      {
        version: 'v1.2.89',
        title: 'iOS connection recovery',
        desc: 'Silent re-auth plus WebView reload on long background resume, so the mobile app reconnects cleanly after sleep.',
      },
    ],
  },
  {
    label: 'dev-workflow',
    title: 'Dev workflow',
    cards: [
      {
        version: 'v1.2.91 / 92',
        title: 'SSH remote projects',
        desc: 'Connect, browse, and run terminals over SSH. Saved connection profiles and a dropdown mode picker on the project list.',
      },
      {
        version: 'v1.2.96',
        title: 'Layout presets & custom tab icons',
        desc: 'Terminal grid presets (2×1, 2×2, 3×3), per-tab icon customization, dashboard redesign, detachable browser chrome.',
      },
      {
        version: 'v1.2.105',
        title: 'Customizable toolbar',
        desc: 'Toolbar buttons are now hideable per user. New Terminal / Tasks / Toolbar / Remote / Report bug are off by default.',
      },
      {
        version: 'v1.2.90',
        title: 'MCP schedule_command',
        desc: 'New MCP tool to queue terminal commands from external automations, with an in-app overlay while a scheduled run is active.',
      },
    ],
  },
  {
    label: 'ai-voice',
    title: 'AI & voice',
    cards: [
      {
        version: 'v1.2.96',
        title: 'Push-to-talk dictation',
        desc: 'Hold Ctrl+Alt+Shift to dictate and auto-submit, system-wide — no need to focus the app window first.',
      },
      {
        version: 'v1.2.94',
        title: 'Preferences → Integrations',
        desc: 'Unified settings panel for Telegram, Ollama, mic device selection, and audio mute.',
      },
      {
        version: 'v1.2.90',
        title: 'Local Ollama agent',
        desc: 'Gemma runs locally via a tray-launched setup wizard. Focus is restored to your previous app when the dialog closes.',
      },
    ],
  },
  {
    label: 'terminals-ux',
    title: 'Terminals & UX',
    cards: [
      {
        version: 'v1.2.94',
        title: 'Paste images into terminals',
        desc: 'Cmd/Ctrl+V drops clipboard images straight into the active terminal, ready for Claude to read.',
      },
      {
        version: 'v1.2.93',
        title: 'Beginner-mode polish',
        desc: 'Telegram /new launches Claude directly. Notifications can pop out into a detached window. Dev tutorial reworked.',
      },
      {
        version: 'v1.2.89',
        title: 'Beginner mode',
        desc: 'Big new-terminal button on first launch. The Git panel only appears when you are inside a Git repository.',
      },
    ],
  },
  {
    label: 'mobile-remote',
    title: 'Mobile & remote',
    cards: [
      {
        version: 'v1.2.89',
        title: 'iOS cloud/local toggle',
        desc: 'The login screen now offers cloud or local UI mode. Session restore is faster and more reliable on resume.',
      },
      {
        version: 'v1.2.89',
        title: 'Tray, autostart, native installer',
        desc: 'System tray with close-to-tray, autostart-on-login enabled by default, and a polished Windows installer flow.',
      },
    ],
  },
];

const totalCards = sections.reduce((n, s) => n + s.cards.length, 0);
---

<BaseLayout
  title="What's new — PATAPIM"
  description="A changelog-style recap of PATAPIM features shipped in May 2026 (v1.2.85 → v1.2.106)."
>
  <Navbar />

  <main class="recap-main">
    <section class="recap-hero">
      <div class="recap-container">
        <div class="tv-label"><span class="tv-label-prompt">$</span> git log v1.2.85..v1.2.106 <span class="tv-dim">— may 2026</span></div>
        <h1 class="recap-title tv-heading">WHAT'S NEW IN PATAPIM</h1>
        <p class="recap-subtitle tv-heading-sub">
          {totalCards} features shipped over 12 days. The objective list, grouped by area.
        </p>
      </div>
    </section>

    {sections.map((section) => (
      <section class="recap-section">
        <div class="recap-container">
          <div class="recap-section-header">
            <div class="tv-label"><span class="tv-label-prompt">$</span> git log --grep="{section.label}" <span class="tv-dim">— {section.title.toLowerCase()}</span></div>
          </div>
          <div class="recap-grid">
            {section.cards.map((card) => (
              <article class="tv-panel recap-card">
                <span class="version-chip tv-grad">{card.version}</span>
                <h3 class="recap-card-title">{card.title}</h3>
                <p class="recap-card-desc">{card.desc}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))}

    <section class="recap-footer-cta">
      <div class="recap-container">
        <p class="recap-footer-text">
          Want the full commit-level changelog? See <a href="/docs/releases">documentation → releases</a>.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .recap-main {
    padding-top: 64px;
    font-family: var(--font-mono);
    background: var(--bg-deep);
  }

  .recap-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .recap-hero {
    padding: 64px 0 32px;
  }

  .recap-hero .tv-label {
    text-align: center;
  }

  .recap-title {
    margin-top: 22px;
    font-size: clamp(17px, 2.6vw, 24px);
  }

  .recap-subtitle {
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .recap-section {
    padding: 44px 0;
  }

  .recap-section-header {
    margin-bottom: 6px;
  }

  .recap-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .recap-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .version-chip {
    align-self: flex-start;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .recap-card-title {
    font-size: 14.5px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.03em;
    line-height: 1.4;
    margin: 0;
  }

  .recap-card-desc {
    font-size: 12.5px;
    color: var(--text-tertiary);
    line-height: 1.75;
    margin: 0;
  }

  .recap-footer-cta {
    padding: 48px 0 96px;
    text-align: center;
  }

  .recap-footer-text {
    color: var(--text-tertiary);
    font-size: 13px;
  }

  .recap-footer-text a {
    color: var(--text-secondary);
    text-decoration: underline;
  }
  .recap-footer-text a:hover {
    color: var(--cy);
  }

  @media (max-width: 960px) {
    .recap-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .recap-grid {
      grid-template-columns: 1fr;
    }
    .recap-hero {
      padding: 48px 0 24px;
    }
    .recap-section {
      padding: 32px 0;
    }
  }
</style>
