---
export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PATAPIM Desktop — connecting…</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style is:inline>
    :root { --accent:#c9a227; --border:#2a2a30; --surface:#131316; }
    body { margin:0; background:#0a0a0b; color:#e4e4e7;
           font-family: -apple-system, system-ui, sans-serif;
           display:flex; align-items:center; justify-content:center; min-height:100vh; }
    .box { text-align:center; width:min(420px, 90vw); padding:24px; }
    .title { font-size:16px; font-weight:600; }
    .msg { opacity:.7; font-size:14px; margin-top:8px; }
    .err { color:#f87171; opacity:1; }
    .pick-label { font-size:13px; opacity:.7; margin:18px 0 10px; }
    .device {
      display:flex; align-items:center; justify-content:space-between; gap:10px;
      width:100%; text-align:left; box-sizing:border-box;
      background:var(--surface); border:1px solid var(--border); border-radius:10px;
      padding:12px 14px; margin-bottom:8px; color:#e4e4e7; font-size:14px;
      cursor:pointer; transition:border-color .15s, background .15s;
    }
    .device:hover { border-color:var(--accent); background:#191920; }
    .device .meta { font-size:11px; opacity:.55; }
    .device .dot { width:8px; height:8px; border-radius:50%; background:#22c55e; flex:0 0 auto; }
    .device .dot.heartbeat { background:#f59e0b; }
    .device .name { display:flex; align-items:center; gap:8px; font-weight:600; }
    /* Full-screen frame that hosts the desktop UI without exposing the tunnel
       URL in the address bar (stays on patapim.ai/remotedesk). */
    #frame { position:fixed; inset:0; width:100%; height:100%; border:0; display:none; background:#0a0a0b; }
    #frame.visible { display:block; }
    body.framed .box { display:none; }
  </style>
</head>
<body>
  <div class="box">
    <div class="title">PATAPIM Desktop</div>
    <div id="msg" class="msg">Connecting…</div>
    <div id="picker"></div>
  </div>
  <iframe id="frame"
          allow="microphone; clipboard-read; clipboard-write; fullscreen; display-capture"
          allowfullscreen></iframe>
  <script is:inline>
    (function () {
      var p = new URLSearchParams(location.search);
      var t = p.get('t'), url = p.get('url'), d = p.get('d'), n = p.get('n');
      var msg = document.getElementById('msg');
      var picker = document.getElementById('picker');
      function fail(text) { msg.textContent = text; msg.className = 'msg err'; }
      function set(text) { msg.textContent = text; }

      // Which device the embedded /desktop view is currently showing, and the
      // origin it's served from. Tracked so the iframe's "Connected" dropdown
      // can list the OTHER devices (the desktop view is cross-origin and can't
      // reach our authenticated APIs itself — see the message broker below).
      var currentDeviceToken = d || null;
      var currentTunnelOrigin = null;
      function originOf(u) { try { return new URL(u).origin; } catch (e) { return null; } }

      // Open the device's full desktop web UI (served by the user's own PATAPIM
      // at <tunnelUrl>/desktop) inside a full-screen iframe, so the address bar
      // stays on patapim.ai/remotedesk instead of exposing the raw tunnel URL.
      function go(tunnel, ct, name) {
        var dest = tunnel.replace(/\/+$/, '') + '/desktop?connectToken=' + encodeURIComponent(ct);
        var host = name || n;
        if (host) dest += '&host=' + encodeURIComponent(host); // cosmetic device label
        currentTunnelOrigin = originOf(tunnel); // origin the iframe posts from
        var frame = document.getElementById('frame');
        frame.src = dest;
        frame.classList.add('visible');
        document.body.classList.add('framed');
        if (host) { try { document.title = 'PATAPIM · ' + host; } catch (e) {} }
      }

      // Mint a fresh one-time connect token for a device (session cookie auth),
      // then redirect to its /desktop view. The token is consumed by /desktop.
      function connectByToken(deviceToken, name) {
        currentDeviceToken = deviceToken;
        set('Connecting to ' + (name || 'your device') + '…');
        return fetch('/api/device/connect-token', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ deviceToken: deviceToken }),
        })
          .then(function (r) {
            if (r.status === 401) { fail('Session expired — open patapim.ai/go and sign in.'); return null; }
            return r.ok ? r.json() : null;
          })
          .then(function (j) {
            if (j && j.connectToken && j.tunnelUrl) { go(j.tunnelUrl, j.connectToken, name); return true; }
            if (j !== null) fail((j && j.error) || 'Device offline or not found.');
            return false;
          })
          .catch(function () { fail('Failed to connect.'); return false; });
      }

      // Several machines online → let the user choose instead of silently
      // guessing (picking the wrong one would connect to the wrong computer).
      function showPicker(devices) {
        set('Choose a computer to open:');
        msg.className = 'msg';
        devices.forEach(function (dev) {
          var btn = document.createElement('button');
          btn.className = 'device';
          var heartbeat = dev.status === 'heartbeat';
          btn.innerHTML =
            '<span class="name"><span class="dot' + (heartbeat ? ' heartbeat' : '') + '"></span>' +
            (dev.deviceName || 'PATAPIM') + '</span>' +
            '<span class="meta">' + (dev.platform || '') + (heartbeat ? ' · connecting' : '') + '</span>';
          btn.addEventListener('click', function () {
            picker.innerHTML = '';
            connectByToken(dev.token, dev.deviceName);
          });
          picker.appendChild(btn);
        });
      }

      // Broker for the embedded /desktop view's "Connected" dropdown. That view
      // is cross-origin (served from the device's tunnel), so it can't call our
      // authenticated device APIs — it asks us via postMessage and we answer
      // with the session cookie we hold.
      window.addEventListener('message', function (event) {
        // Only trust messages from the iframe we actually embedded.
        if (!currentTunnelOrigin || event.origin !== currentTunnelOrigin) return;
        var data = event.data;
        if (!data || data.source !== 'patapim-desktop') return;
        var frame = document.getElementById('frame');
        function reply(payload) {
          if (frame && frame.contentWindow) {
            frame.contentWindow.postMessage(payload, currentTunnelOrigin);
          }
        }

        if (data.type === 'request-devices') {
          fetch('/api/device/list', { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (j) {
              var devices = ((j && j.devices) || [])
                .filter(function (x) {
                  return (x.status === 'online' || x.status === 'heartbeat') && x.tunnelUrl;
                })
                .map(function (x) {
                  return {
                    token: x.token,
                    deviceName: x.deviceName,
                    status: x.status,
                    current: x.token === currentDeviceToken,
                  };
                });
              reply({ source: 'patapim-remotedesk', type: 'devices', devices: devices });
            })
            .catch(function () {
              reply({ source: 'patapim-remotedesk', type: 'devices', devices: [] });
            });
        } else if (data.type === 'switch-device' && data.token) {
          document.body.classList.remove('framed');
          var f = document.getElementById('frame');
          if (f) { f.classList.remove('visible'); f.src = 'about:blank'; }
          connectByToken(data.token, data.name);
        } else if (data.type === 'disconnect') {
          location.href = '/go';
        }
      });

      // 1. Direct: connectToken + tunnelUrl already supplied.
      if (t && url) { go(url, t); return; }

      // 2. Explicit device token supplied (e.g. cross-link from the mobile UI).
      if (d) { connectByToken(d); return; }

      // 3. Automatic discovery. One online machine → connect straight away.
      //    Several online → show a picker so we never open the wrong computer.
      set('Looking for your devices…');
      fetch('/api/device/list', { credentials: 'same-origin' })
        .then(function (r) {
          if (r.status === 401) { fail('Please sign in at patapim.ai first.'); return null; }
          return r.ok ? r.json() : null;
        })
        .then(function (data) {
          if (!data) return;
          var devices = (data && data.devices) || [];
          var avail = devices.filter(function (x) {
            return (x.status === 'online' || x.status === 'heartbeat') && x.tunnelUrl;
          });
          // Online first, then heartbeat — and within each, the picker keeps list order.
          avail.sort(function (a, b) {
            var rank = function (s) { return s === 'online' ? 0 : 1; };
            return rank(a.status) - rank(b.status);
          });
          if (!avail.length) { fail('No device is online right now. Open PATAPIM on the computer you want to reach.'); return; }
          if (avail.length === 1) { connectByToken(avail[0].token, avail[0].deviceName); return; }
          showPicker(avail);
        })
        .catch(function () { fail('Failed to reach the server.'); });
    })();
  </script>
</body>
</html>
