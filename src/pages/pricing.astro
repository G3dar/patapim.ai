---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import SessionBar from '../components/SessionBar.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, t, getLocalePath } from '../i18n';
import en from '../i18n/translations/en';
import ja from '../i18n/translations/ja';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);
const translations = locale === 'ja' ? ja : en;

const featuresCompare = translations.pricing.featuresCompare;
const faq = translations.pricing.faq;
---

<BaseLayout title={t(locale, 'meta.pricingTitle')} description={t(locale, 'meta.pricingDescription')}>
  <Navbar />
  <SessionBar />

  <main class="pricing-page">
    <div class="container">
      <div class="section-header" style="padding-top: 120px;">
        <span class="section-label">{t(locale, 'pricing.label')}</span>
        <h1 class="section-title">{t(locale, 'pricing.title')}</h1>
        <p class="section-subtitle">
          {t(locale, 'pricing.subtitle')}
        </p>
      </div>

      <!-- Pricing Cards -->
      <div class="pricing-cards">
        <div class="p-card">
          <h2>{t(locale, 'pricing.freeTitle')}</h2>
          <div class="p-price"><span class="p-amount">{t(locale, 'pricing.freePrice')}</span> <span class="p-period">{t(locale, 'pricing.freePeriod')}</span></div>
          <p class="p-desc">{t(locale, 'pricing.freeDesc')}</p>
          <a href={lp('/download')} class="btn btn-secondary" style="width:100%; justify-content:center;">{t(locale, 'common.downloadFree')}</a>
          <ul class="p-list">
            {featuresCompare.map((f) => (
              <li>
                <span class="p-label">{f.name}</span>
                <span class={`p-value ${f.free === 'No' ? 'dim' : ''}`}>{f.free}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="p-card featured">
          <h2>{t(locale, 'pricing.proTitle')}</h2>
          <div class="p-price">
            <span class="p-amount">{t(locale, 'pricing.proPrice')}</span>
            <span class="p-period">{t(locale, 'pricing.proPeriod')}</span>
          </div>
          <p class="p-desc">{t(locale, 'pricing.proDesc')}</p>
          <a href="#" class="btn btn-primary" id="checkout-monthly" style="width:100%; justify-content:center;">{t(locale, 'common.goPro')}</a>
          <ul class="p-list">
            {featuresCompare.map((f) => (
              <li>
                <span class="p-label">{f.name}</span>
                <span class={`p-value ${f.pro !== f.free ? 'highlight' : ''}`}>{f.pro}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Unlock Forever Banner -->
      <div class="unlock-section">
        <div class="unlock-card">
          <span class="unlock-badge">{t(locale, 'pricing.unlockBadge')}</span>
          <h2 class="unlock-title">{t(locale, 'pricing.unlockTitle')}</h2>
          <p class="unlock-desc" set:html={t(locale, 'pricing.unlockDesc').replace(/\n/g, '<br/>')} />
          <div class="unlock-price-row">
            <div class="unlock-price-area">
              <span class="unlock-price">{t(locale, 'pricing.unlockPrice')}</span>
              <span class="unlock-once">{t(locale, 'pricing.unlockNote')}</span>
            </div>
            <a href="#" class="btn btn-primary" id="checkout-lifetime">{t(locale, 'pricing.unlockButton')}</a>
          </div>
        </div>
      </div>

      <!-- Enterprise / Business -->
      <div class="enterprise-section">
        <div class="enterprise-card">
          <div class="enterprise-grid">
            <div class="enterprise-copy">
              <span class="enterprise-badge">{t(locale, 'pricing.enterpriseBadge')}</span>
              <h2 class="enterprise-title">{t(locale, 'pricing.enterpriseTitle')}</h2>
              <p class="enterprise-desc" set:html={t(locale, 'pricing.enterpriseDesc').replace(/\n/g, '<br/>')} />
            </div>
            <div class="enterprise-action">
              <a href="mailto:info@patapim.ai?subject=PATAPIM%20for%20Business" class="btn btn-secondary enterprise-btn">{t(locale, 'pricing.enterpriseCta')}</a>
              <span class="enterprise-note">{t(locale, 'pricing.enterpriseNote')}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Already purchased? Associate license key -->
      <div class="claim-section">
        <div class="claim-card">
          <div class="claim-grid">
            <div class="claim-copy">
              <span class="claim-badge">Already purchased</span>
              <h2 class="claim-title">Have a license key?</h2>
              <p class="claim-desc">
                Link an existing PATAPIM license to your account. You can associate the same key with up to <strong>2 accounts</strong> — handy if you bought with one email and use PATAPIM with another, or if you share a lifetime license with a partner.
              </p>
            </div>
            <div class="claim-action">
              <form id="claim-form" novalidate>
                <input
                  type="text"
                  name="licenseKey"
                  placeholder="License key"
                  autocomplete="off"
                  spellcheck="false"
                  required
                />
                <button type="submit" class="btn btn-secondary claim-btn">Associate to my account</button>
              </form>
              <p id="claim-msg" class="claim-msg" hidden></p>
            </div>
          </div>
        </div>
      </div>

      <!-- FAQ -->
      <div class="faq-section section">
        <h2 class="section-title" style="font-size: 28px;">{t(locale, 'pricing.faqTitle')}</h2>
        <div class="faq-grid">
          {faq.map((item) => (
            <div class="faq-item">
              <h3>{item.q}</h3>
              <p set:html={item.a} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .pricing-page {
    min-height: 100vh;
  }

  .pricing-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    max-width: 800px;
    margin: 0 auto;
  }

  .p-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl);
    position: relative;
  }

  .p-card.featured {
    border-color: var(--accent-primary);
    box-shadow: 0 0 40px rgba(212, 165, 116, 0.1);
  }

  .p-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent-primary);
    color: var(--bg-deep);
    font-size: 12px;
    font-weight: 600;
    padding: 4px 16px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .p-card h2 {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .p-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: var(--space-xs);
  }
  .p-amount {
    font-size: 48px;
    font-weight: 700;
    font-family: var(--font-mono);
  }
  .p-period {
    font-size: 16px;
    color: var(--text-tertiary);
  }
  .p-desc {
    font-size: 14px;
    color: var(--text-tertiary);
    margin-bottom: var(--space-xl);
  }

  .p-list {
    list-style: none;
    margin-top: var(--space-xl);
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-lg);
  }
  .p-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 14px;
  }
  .p-label { color: var(--text-secondary); }
  .p-value { color: var(--text-primary); font-weight: 500; }
  .p-value.dim { color: var(--text-muted); font-weight: 400; }
  .p-value.highlight { color: var(--accent-primary); }

  /* Unlock Forever */
  .unlock-section {
    max-width: 800px;
    margin: var(--space-2xl) auto 0;
  }

  .unlock-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl);
    text-align: center;
  }

  .unlock-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--warning);
    background: rgba(224, 164, 88, 0.12);
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: var(--space-md);
  }

  .unlock-title {
    font-size: 24px;
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .unlock-desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto var(--space-xl);
  }

  .unlock-price-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xl);
  }

  .unlock-price-area {
    text-align: center;
  }

  .unlock-price {
    display: block;
    font-size: 42px;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--text-primary);
  }

  .unlock-once {
    display: block;
    font-size: 13px;
    color: var(--text-tertiary);
    margin-top: 2px;
  }

  /* Enterprise / Business */
  .enterprise-section {
    max-width: 800px;
    margin: var(--space-xl) auto 0;
  }

  .enterprise-card {
    background: linear-gradient(135deg, var(--bg-secondary), var(--bg-tertiary, var(--bg-secondary)));
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-xl) var(--space-2xl);
    position: relative;
    overflow: hidden;
  }

  .enterprise-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, var(--accent-glow), transparent 60%);
    pointer-events: none;
  }

  .enterprise-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-xl);
    align-items: center;
    position: relative;
  }

  .enterprise-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent-primary);
    background: var(--accent-subtle);
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: var(--space-sm);
    letter-spacing: 0.02em;
  }

  .enterprise-title {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .enterprise-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .enterprise-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .enterprise-btn {
    white-space: nowrap;
  }

  .enterprise-note {
    font-size: 12px;
    color: var(--text-tertiary);
  }

  /* Already-purchased / claim license key */
  .claim-section {
    max-width: 800px;
    margin: var(--space-xl) auto 0;
  }
  .claim-card {
    background: linear-gradient(135deg, var(--bg-secondary), var(--bg-tertiary, var(--bg-secondary)));
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-xl) var(--space-2xl);
    position: relative;
    overflow: hidden;
  }
  .claim-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top left, var(--accent-glow), transparent 60%);
    pointer-events: none;
  }
  .claim-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
    position: relative;
  }
  .claim-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent-primary);
    background: var(--accent-subtle);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-sm);
    letter-spacing: 0.02em;
  }
  .claim-title {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }
  .claim-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }
  .claim-desc strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  .claim-action { display: flex; flex-direction: column; gap: 10px; }
  #claim-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  #claim-form input {
    background: var(--bg-primary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    padding: 11px 14px;
    font-size: 14px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    transition: border-color var(--transition-fast);
  }
  #claim-form input:focus {
    outline: none;
    border-color: var(--accent-primary);
  }
  .claim-btn { width: 100%; justify-content: center; }
  .claim-msg {
    font-size: 13px;
    padding: 10px 12px;
    border-radius: var(--radius-md);
    margin: 0;
  }
  .claim-msg.success {
    background: var(--success-subtle);
    color: var(--success);
    border: 1px solid var(--success);
  }
  .claim-msg.error {
    background: var(--error-subtle);
    color: var(--error);
    border: 1px solid var(--error);
  }

  /* FAQ */
  .faq-section {
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
  }

  .faq-item h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }
  .faq-item p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .pricing-cards { grid-template-columns: 1fr; }
    .claim-grid { grid-template-columns: 1fr; }
    .faq-grid { grid-template-columns: 1fr; }
    .unlock-price-row {
      flex-direction: column;
      gap: var(--space-lg);
    }
    .enterprise-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .enterprise-action {
      align-items: center;
    }
  }
</style>

<script>
  async function handleCheckout(plan: 'pro' | 'lifetime') {
    const btn = document.getElementById(plan === 'pro' ? 'checkout-monthly' : 'checkout-lifetime');
    if (btn) btn.setAttribute('disabled', '');
    try {
      // Best-effort: include authenticated email if signed in
      let email: string | undefined;
      try {
        const sessionRes = await fetch('/api/auth/session');
        if (sessionRes.ok) {
          const sessionData = await sessionRes.json();
          if (sessionData.authenticated) email = sessionData.user.email;
        }
      } catch {}

      const res = await fetch('/api/stripe/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plan, email }),
      });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        console.error('Checkout error:', data.error);
        if (btn) btn.removeAttribute('disabled');
      }
    } catch (err) {
      console.error('Checkout error:', err);
      if (btn) btn.removeAttribute('disabled');
    }
  }

  document.getElementById('checkout-monthly')?.addEventListener('click', (e) => {
    e.preventDefault();
    handleCheckout('pro');
  });

  document.getElementById('checkout-lifetime')?.addEventListener('click', (e) => {
    e.preventDefault();
    handleCheckout('lifetime');
  });

  // Already-purchased license-key claim flow
  const claimForm = document.getElementById('claim-form') as HTMLFormElement | null;
  const claimMsg = document.getElementById('claim-msg') as HTMLParagraphElement | null;
  if (claimForm && claimMsg) {
    claimForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      claimMsg.hidden = true;
      claimMsg.className = 'claim-msg';
      const submitBtn = claimForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;

      const licenseKey = String((new FormData(claimForm)).get('licenseKey') || '').trim();
      if (!licenseKey) {
        claimMsg.classList.add('error');
        claimMsg.textContent = 'Enter your license key.';
        claimMsg.hidden = false;
        submitBtn.disabled = false;
        return;
      }

      try {
        const res = await fetch('/api/license/claim', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ licenseKey }),
        });

        if (res.status === 401) {
          // Not signed in — bounce through /signin and come back to /pricing.
          window.location.href = '/signin?returnTo=' + encodeURIComponent('/pricing#claim-section');
          return;
        }

        const body = await res.json().catch(() => ({}));
        if (res.ok && body.ok) {
          claimMsg.classList.add('success');
          if (body.alreadyAssociated) {
            claimMsg.textContent = 'This license is already linked to your account.';
          } else if (body.remainingSlots === 0) {
            claimMsg.textContent = 'License linked. This key is now at its 2-account limit.';
          } else {
            claimMsg.textContent = 'License linked to your account. You can also link it to one more email.';
          }
          claimMsg.hidden = false;
          claimForm.reset();
          return;
        }

        claimMsg.classList.add('error');
        switch (body.error) {
          case 'invalid_license_key':
            claimMsg.textContent = 'Enter a valid license key.'; break;
          case 'license_not_found':
          case 'license_data_missing':
          case 'license_mismatch':
            claimMsg.textContent = 'License key not recognized. Double-check the value from your purchase email.'; break;
          case 'license_inactive':
            claimMsg.textContent = 'This license is inactive (' + (body.status || 'unknown') + '). Contact support if this is unexpected.'; break;
          case 'max_accounts_reached':
            claimMsg.textContent = 'This license is already linked to ' + (body.max || 2) + ' accounts. Each key can only be associated with up to 2.'; break;
          default:
            if (res.status === 429) {
              claimMsg.textContent = 'Too many attempts. Try again in a bit.';
            } else {
              claimMsg.textContent = 'Could not link the license. Please try again.';
            }
        }
        claimMsg.hidden = false;
      } catch {
        claimMsg.classList.add('error');
        claimMsg.textContent = 'Network error. Please try again.';
        claimMsg.hidden = false;
      } finally {
        submitBtn.disabled = false;
      }
    });
  }
</script>
