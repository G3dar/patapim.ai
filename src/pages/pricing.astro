---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import SessionBar from '../components/SessionBar.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, t, getLocalePath } from '../i18n';
import en from '../i18n/translations/en';
import ja from '../i18n/translations/ja';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);
const translations = locale === 'ja' ? ja : en;

const featuresCompare = translations.pricing.featuresCompare;
const faq = translations.pricing.faq;

// terminal-aesthetic tier features (mirrors the v2 home lineup)
const FREE_FEATURES = [
  'Full computer control',
  'Up to 3 projects',
  'Up to 9 terminals',
  'A long 30 min dictation buffer',
  'Remote access',
  'Task management',
];
const PRO_FEATURES = [
  'Unlimited terminals',
  'Unlimited projects',
  'Unlimited dictation',
  'Everything in Free',
  'Priority support',
];
const LIFETIME_FEATURES = [
  'Pro features for life',
  'No subscriptions',
  'No renewals',
  'Yours. Forever.',
];
---

<BaseLayout title={t(locale, 'meta.pricingTitle')} description={t(locale, 'meta.pricingDescription')}>
  <Navbar />
  <SessionBar />

  <main class="pricing-page">
    <div class="pp-main">

      <!-- Header -->
      <div class="pp-head">
        <div class="tv-label"><span class="tv-label-prompt">$</span> patapim upgrade <span class="tv-dim">— start free. upgrade when you're ready.</span></div>
        <h1 class="tv-heading pp-title">{t(locale, 'pricing.title')}</h1>
        <p class="tv-heading-sub">{t(locale, 'pricing.subtitle')}</p>
      </div>

      <!-- Pricing Cards -->
      <div class="tv-price-grid pp-grid">
        <div class="tv-pcard tv-pcard-hero">
          <div class="tv-pcard-tag">INCLUDES ALL FEATURES</div>
          <div class="tv-pcard-head">
            <span class="tv-pcard-name">{t(locale, 'pricing.freeTitle')}</span>
            <span class="tv-pcard-sub">{t(locale, 'pricing.freeDesc')}</span>
          </div>
          <div class="tv-pcard-pricebox">
            <span class="tv-pcard-amount tv-grad">{t(locale, 'pricing.freePrice')}</span>
            <span class="tv-pcard-period">{t(locale, 'pricing.freePeriod')}</span>
          </div>
          <ul>
            {FREE_FEATURES.map((f) => <li><span class="tv-check">✓</span> {f}</li>)}
          </ul>
          <a href={lp('/download')} class="tv-pbtn tv-pbtn-accent">$ {t(locale, 'common.downloadFree').toLowerCase()}</a>
        </div>

        <div class="tv-pcard">
          <div class="tv-pcard-head">
            <span class="tv-pcard-name">{t(locale, 'pricing.proTitle')}</span>
            <span class="tv-pcard-sub">{t(locale, 'pricing.proDesc')}</span>
          </div>
          <div class="tv-pcard-pricebox">
            <span class="tv-pcard-amount">{t(locale, 'pricing.proPrice')}</span>
            <span class="tv-pcard-period">{t(locale, 'pricing.proPeriod')}</span>
          </div>
          <ul>
            {PRO_FEATURES.map((f) => <li><span class="tv-check">✓</span> {f}</li>)}
          </ul>
          <a href="#" class="tv-pbtn" id="checkout-monthly">$ {t(locale, 'common.goPro').toLowerCase()}</a>
        </div>

        <div class="tv-pcard">
          <div class="tv-pcard-head">
            <span class="tv-pcard-name">Lifetime</span>
            <span class="tv-pcard-sub">one payment. done.</span>
          </div>
          <div class="tv-pcard-pricebox">
            <span class="tv-pcard-amount">{t(locale, 'pricing.unlockPrice')}</span>
            <span class="tv-pcard-period">{t(locale, 'pricing.unlockNote')}</span>
          </div>
          <ul>
            {LIFETIME_FEATURES.map((f) => <li><span class="tv-check">✓</span> {f}</li>)}
          </ul>
          <a href="#" class="tv-pbtn" id="checkout-lifetime">$ {t(locale, 'pricing.unlockButton').toLowerCase()}</a>
        </div>
      </div>

      <!-- Compare: free vs pro -->
      <div class="pp-section">
        <div class="tv-label"><span class="tv-label-prompt">$</span> diff free pro <span class="tv-dim">— feature by feature</span></div>
        <div class="pp-compare tv-panel tv-panel-static">
          <div class="pp-compare-row pp-compare-header">
            <span class="pp-compare-name">FEATURE</span>
            <span class="pp-compare-free">FREE</span>
            <span class="pp-compare-pro">PRO</span>
          </div>
          {featuresCompare.map((f) => (
            <div class="pp-compare-row">
              <span class="pp-compare-name">{f.name}</span>
              <span class={`pp-compare-free ${f.free === 'No' ? 'dim' : ''}`}>{f.free}</span>
              <span class={`pp-compare-pro ${f.pro !== f.free ? 'highlight' : ''}`}>{f.pro}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Enterprise / Business -->
      <div class="pp-section">
        <div class="tv-label"><span class="tv-label-prompt">$</span> patapim enterprise <span class="tv-dim">— for teams</span></div>
        <div class="enterprise-card tv-panel tv-panel-static">
          <div class="enterprise-grid">
            <div class="enterprise-copy">
              <span class="pp-microlabel">{t(locale, 'pricing.enterpriseBadge')}</span>
              <h2 class="enterprise-title">{t(locale, 'pricing.enterpriseTitle')}</h2>
              <p class="enterprise-desc" set:html={t(locale, 'pricing.enterpriseDesc').replace(/\n/g, '<br/>')} />
            </div>
            <div class="enterprise-action">
              <a href="mailto:info@patapim.ai?subject=PATAPIM%20for%20Business" class="tv-pbtn enterprise-btn">$ {t(locale, 'pricing.enterpriseCta').toLowerCase()}</a>
              <span class="enterprise-note">{t(locale, 'pricing.enterpriseNote')}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Already purchased? Associate license key -->
      <div class="pp-section" id="claim-section">
        <div class="tv-label"><span class="tv-label-prompt">$</span> patapim license --claim <span class="tv-dim">— already purchased?</span></div>
        <div class="claim-card tv-panel tv-panel-static">
          <div class="claim-grid">
            <div class="claim-copy">
              <span class="pp-microlabel">Already purchased</span>
              <h2 class="claim-title">Have a license key?</h2>
              <p class="claim-desc">
                Link an existing PATAPIM license to your account. You can associate the same key with up to <strong>2 accounts</strong> — handy if you bought with one email and use PATAPIM with another, or if you share a lifetime license with a partner.
              </p>
            </div>
            <div class="claim-action">
              <form id="claim-form" novalidate>
                <input
                  type="text"
                  name="licenseKey"
                  placeholder="License key"
                  autocomplete="off"
                  spellcheck="false"
                  required
                />
                <button type="submit" class="tv-pbtn claim-btn">$ associate to my account</button>
              </form>
              <p id="claim-msg" class="claim-msg" hidden></p>
            </div>
          </div>
        </div>
      </div>

      <!-- FAQ -->
      <div class="pp-section faq-section">
        <div class="tv-label"><span class="tv-label-prompt">$</span> faq <span class="tv-dim">— {t(locale, 'pricing.faqTitle').toLowerCase()}</span></div>
        <div class="faq-grid">
          {faq.map((item) => (
            <div class="faq-item">
              <h3><span class="faq-q-mark">?</span> {item.q}</h3>
              <p set:html={item.a} />
            </div>
          ))}
        </div>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .pricing-page {
    min-height: 100vh;
    font-family: var(--font-mono);
    background: var(--bg-deep);
  }

  .pp-main {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px 72px;
  }

  .pp-head {
    padding-top: 120px;
    margin-bottom: 44px;
  }

  .pp-title {
    margin-top: 26px;
    font-size: clamp(17px, 2.4vw, 22px);
    text-transform: uppercase;
  }

  .pp-grid {
    max-width: 980px;
    margin: 0 auto;
  }

  .pp-section {
    max-width: 860px;
    margin: 88px auto 0;
  }

  .pp-microlabel {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cy);
    margin-bottom: 10px;
  }

  /* Compare: free vs pro */
  .pp-compare {
    padding: 8px 24px 12px;
  }
  .pp-compare-row {
    display: grid;
    grid-template-columns: 1fr 130px 130px;
    gap: 16px;
    align-items: baseline;
    padding: 10px 0;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 13px;
  }
  .pp-compare-row:last-child { border-bottom: none; }
  .pp-compare-header {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--text-muted);
  }
  .pp-compare-name { color: var(--text-secondary); }
  .pp-compare-free { color: var(--text-tertiary); }
  .pp-compare-free.dim { color: var(--text-muted); }
  .pp-compare-pro { color: var(--text-primary); }
  .pp-compare-pro.highlight {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }

  /* Enterprise / Business */
  .enterprise-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: center;
    position: relative;
  }

  .enterprise-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.02em;
    margin: 0 0 8px;
  }

  .enterprise-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.8;
    margin: 0;
  }

  .enterprise-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .enterprise-btn {
    white-space: nowrap;
    padding: 12px 22px;
  }

  .enterprise-note {
    font-size: 11px;
    color: var(--text-muted);
  }

  /* Already-purchased / claim license key */
  .claim-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: center;
    position: relative;
  }
  .claim-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.02em;
    margin: 0 0 8px;
  }
  .claim-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.8;
    margin: 0;
  }
  .claim-desc strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  .claim-action { display: flex; flex-direction: column; gap: 10px; }
  #claim-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  #claim-form input {
    width: 100%;
    box-sizing: border-box;
    background: var(--bg-deep);
    border: 1px solid var(--border-default);
    border-radius: 0;
    color: var(--text-primary);
    padding: 11px 14px;
    font-size: 13.5px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    transition: border-color 150ms, box-shadow 150ms;
  }
  #claim-form input::placeholder { color: var(--text-muted); }
  #claim-form input:focus {
    outline: none;
    border-color: rgba(34, 211, 238, 0.55);
    box-shadow: 0 0 0 1px rgba(34, 211, 238, 0.25);
  }
  .claim-btn { width: 100%; }
  .claim-msg {
    font-size: 13px;
    padding: 10px 12px;
    border-radius: 0;
    margin: 0;
  }
  .claim-msg.success {
    background: var(--success-subtle);
    color: var(--success);
    border: 1px solid var(--success);
  }
  .claim-msg.error {
    background: var(--error-subtle);
    color: var(--error);
    border: 1px solid var(--error);
  }

  /* FAQ */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 40px;
  }

  .faq-item {
    padding: 20px 4px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .faq-item h3 {
    font-size: 13.5px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.02em;
    margin: 0 0 10px;
  }
  .faq-q-mark {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
    margin-right: 4px;
  }
  .faq-item p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.8;
    margin: 0;
  }

  @media (max-width: 900px) {
    .pp-grid {
      grid-template-columns: 1fr;
      max-width: 440px;
    }
  }

  @media (max-width: 640px) {
    .claim-grid { grid-template-columns: 1fr; }
    .faq-grid { grid-template-columns: 1fr; }
    .pp-compare-row { grid-template-columns: 1fr 80px 80px; gap: 10px; }
    .enterprise-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .enterprise-action {
      align-items: center;
    }
    .pp-section { margin-top: 64px; }
  }
</style>

<script>
  async function handleCheckout(plan: 'pro' | 'lifetime') {
    const btn = document.getElementById(plan === 'pro' ? 'checkout-monthly' : 'checkout-lifetime');
    if (btn) btn.setAttribute('disabled', '');
    try {
      // Best-effort: include authenticated email if signed in
      let email: string | undefined;
      try {
        const sessionRes = await fetch('/api/auth/session');
        if (sessionRes.ok) {
          const sessionData = await sessionRes.json();
          if (sessionData.authenticated) email = sessionData.user.email;
        }
      } catch {}

      const res = await fetch('/api/stripe/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plan, email }),
      });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        console.error('Checkout error:', data.error);
        if (btn) btn.removeAttribute('disabled');
      }
    } catch (err) {
      console.error('Checkout error:', err);
      if (btn) btn.removeAttribute('disabled');
    }
  }

  document.getElementById('checkout-monthly')?.addEventListener('click', (e) => {
    e.preventDefault();
    handleCheckout('pro');
  });

  document.getElementById('checkout-lifetime')?.addEventListener('click', (e) => {
    e.preventDefault();
    handleCheckout('lifetime');
  });

  // Already-purchased license-key claim flow
  const claimForm = document.getElementById('claim-form') as HTMLFormElement | null;
  const claimMsg = document.getElementById('claim-msg') as HTMLParagraphElement | null;
  if (claimForm && claimMsg) {
    claimForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      claimMsg.hidden = true;
      claimMsg.className = 'claim-msg';
      const submitBtn = claimForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;

      const licenseKey = String((new FormData(claimForm)).get('licenseKey') || '').trim();
      if (!licenseKey) {
        claimMsg.classList.add('error');
        claimMsg.textContent = 'Enter your license key.';
        claimMsg.hidden = false;
        submitBtn.disabled = false;
        return;
      }

      try {
        const res = await fetch('/api/license/claim', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ licenseKey }),
        });

        if (res.status === 401) {
          // Not signed in — bounce through /signin and come back to /pricing.
          window.location.href = '/signin?returnTo=' + encodeURIComponent('/pricing#claim-section');
          return;
        }

        const body = await res.json().catch(() => ({}));
        if (res.ok && body.ok) {
          claimMsg.classList.add('success');
          if (body.alreadyAssociated) {
            claimMsg.textContent = 'This license is already linked to your account.';
          } else if (body.remainingSlots === 0) {
            claimMsg.textContent = 'License linked. This key is now at its 2-account limit.';
          } else {
            claimMsg.textContent = 'License linked to your account. You can also link it to one more email.';
          }
          claimMsg.hidden = false;
          claimForm.reset();
          return;
        }

        claimMsg.classList.add('error');
        switch (body.error) {
          case 'invalid_license_key':
            claimMsg.textContent = 'Enter a valid license key.'; break;
          case 'license_not_found':
          case 'license_data_missing':
          case 'license_mismatch':
            claimMsg.textContent = 'License key not recognized. Double-check the value from your purchase email.'; break;
          case 'license_inactive':
            claimMsg.textContent = 'This license is inactive (' + (body.status || 'unknown') + '). Contact support if this is unexpected.'; break;
          case 'max_accounts_reached':
            claimMsg.textContent = 'This license is already linked to ' + (body.max || 2) + ' accounts. Each key can only be associated with up to 2.'; break;
          default:
            if (res.status === 429) {
              claimMsg.textContent = 'Too many attempts. Try again in a bit.';
            } else {
              claimMsg.textContent = 'Could not link the license. Please try again.';
            }
        }
        claimMsg.hidden = false;
      } catch {
        claimMsg.classList.add('error');
        claimMsg.textContent = 'Network error. Please try again.';
        claimMsg.hidden = false;
      } finally {
        submitBtn.disabled = false;
      }
    });
  }
</script>
