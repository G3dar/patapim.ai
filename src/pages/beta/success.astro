---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getLocaleFromUrl, t, getLocalePath } from '../../i18n';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);

---

<BaseLayout title={t(locale, 'meta.betaSuccessTitle')} description={t(locale, 'meta.betaSuccessDescription')}>
  <Navbar />

  <main class="ea-page">
    <div class="ea-container">

      <div class="ea-confetti" aria-hidden="true">
        <span class="dot dot-1"></span><span class="dot dot-2"></span><span class="dot dot-3"></span>
        <span class="dot dot-4"></span><span class="dot dot-5"></span><span class="dot dot-6"></span>
        <span class="dot dot-7"></span><span class="dot dot-8"></span>
      </div>

      <span class="ea-badge">{t(locale, 'betaSuccess.badge')}</span>
      <h1 class="ea-title">{t(locale, 'betaSuccess.title')}</h1>
      <p class="ea-sub">{t(locale, 'betaSuccess.subtitle')}</p>

      <a href={lp('/download')} class="ea-dl-btn">{t(locale, 'betaSuccess.downloadButton')}</a>
      <span class="ea-platform">{t(locale, 'betaSuccess.platformNote')}</span>

      <!-- Personal note -->
      <div class="ea-divider"></div>

      <div class="ea-personal">
        <p>{t(locale, 'betaSuccess.personalNote')}</p>
        <p set:html={t(locale, 'betaSuccess.voiceTip').replace('voice dictation', '<strong>voice dictation</strong>')} />
        <p>{t(locale, 'betaSuccess.feedbackNote')}</p>
        <span class="ea-signature">{t(locale, 'betaSuccess.signoff')}</span>
      </div>

      <!-- Quick start cards -->
      <div class="ea-cards">
        <div class="ea-card ea-card-voice">
          <span class="ea-card-icon">🎙️</span>
          <h3>{t(locale, 'betaSuccess.tipTalk')}</h3>
          <p>{t(locale, 'betaSuccess.tipTalkDesc')}</p>
        </div>
        <div class="ea-card ea-card-grid">
          <span class="ea-card-icon">⚡</span>
          <h3>{t(locale, 'betaSuccess.tipParallel')}</h3>
          <p>{t(locale, 'betaSuccess.tipParallelDesc')}</p>
        </div>
        <div class="ea-card ea-card-phone">
          <span class="ea-card-icon">📱</span>
          <h3>{t(locale, 'betaSuccess.tipPhone')}</h3>
          <p>{t(locale, 'betaSuccess.tipPhoneDesc')}</p>
        </div>
      </div>

      <!-- Reach me -->
      <div class="ea-channels">
        <a href="mailto:g@3dar.com" class="ea-channel">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          g@3dar.com
        </a>
        <a href="https://reddit.com/r/ClaudeCode" target="_blank" rel="noopener" class="ea-channel">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
          Reddit
        </a>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .ea-page {
    padding: 140px 0 80px;
    overflow: hidden;
  }

  .ea-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 var(--space-xl);
    text-align: center;
    position: relative;
  }

  /* ── Confetti dots ── */
  .ea-confetti {
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 120px;
    pointer-events: none;
  }

  .dot {
    position: absolute;
    width: 8px;
    height: 8px;
    animation: confetti-fall 1.8s ease-out forwards;
    opacity: 0;
  }

  .dot-1 { background: #c26bf0; left: 15%; animation-delay: 0.1s; }
  .dot-2 { background: #4ade80; left: 30%; animation-delay: 0.2s; }
  .dot-3 { background: #22d3ee; left: 45%; animation-delay: 0.05s; }
  .dot-4 { background: #8b7cf8; left: 60%; animation-delay: 0.25s; }
  .dot-5 { background: #c26bf0; left: 75%; animation-delay: 0.15s; }
  .dot-6 { background: #a78bfa; left: 85%; animation-delay: 0.3s; }
  .dot-7 { background: #4ade80; left: 10%; animation-delay: 0.35s; }
  .dot-8 { background: #22d3ee; left: 55%; animation-delay: 0.4s; }

  @keyframes confetti-fall {
    0% { transform: translateY(-30px) scale(0); opacity: 0; }
    30% { opacity: 1; transform: translateY(20px) scale(1.2); }
    100% { transform: translateY(80px) scale(0.6); opacity: 0; }
  }

  /* ── Hero ── */
  .ea-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--success);
    background: var(--success-subtle);
    border: 1px solid rgba(74, 222, 128, 0.3);
    padding: 6px 20px;
    border-radius: 0;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: var(--space-xl);
  }

  .ea-title {
    font-size: 44px;
    font-weight: 800;
    margin-bottom: var(--space-md);
    line-height: 1.15;
    letter-spacing: -0.01em;
    background: linear-gradient(120deg, #ededed 0%, #c26bf0 55%, #22d3ee 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ea-sub {
    font-size: 16px;
    color: var(--text-secondary);
    margin-bottom: var(--space-2xl);
    line-height: 1.6;
  }

  /* ── Download button ── */
  .ea-dl-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 340px;
    padding: 15px 32px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    color: #000;
    background: linear-gradient(90deg, #c26bf0, #8b7cf8, #22d3ee);
    border: none;
    border-radius: 0;
    text-decoration: none;
    transition: background 0.15s, box-shadow 0.15s;
    box-shadow: 0 0 28px rgba(139, 124, 248, 0.25);
  }

  .ea-dl-btn:hover {
    background: linear-gradient(90deg, #d187ff, #9c8dff, #4ae0f7);
    color: #000;
    box-shadow: 0 0 40px rgba(139, 124, 248, 0.4);
  }

  .ea-platform {
    display: block;
    font-size: 12px;
    color: var(--text-muted);
    margin-top: var(--space-md);
  }

  /* ── Divider ── */
  .ea-divider {
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, #c26bf0, #8b7cf8, #22d3ee);
    margin: var(--space-4xl) auto;
  }

  /* ── Personal note ── */
  .ea-personal {
    text-align: left;
    margin-bottom: var(--space-3xl);
  }

  .ea-personal p {
    font-size: 14.5px;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .ea-personal strong {
    color: var(--cy);
    font-weight: 600;
  }

  .ea-signature {
    display: block;
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: var(--space-md);
  }

  /* ── Feature cards ── */
  .ea-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    text-align: left;
    margin-bottom: 0;
  }

  .ea-card {
    padding: var(--space-xl);
    background: linear-gradient(180deg, #0b0b0e 0%, #070708 100%);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 0;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition: border-color 0.2s, transform 0.2s;
  }

  .ea-card:hover {
    transform: translateY(-2px);
    border-color: rgba(139, 124, 248, 0.35);
  }

  .ea-card-voice { border-bottom: 2px solid var(--vi); }
  .ea-card-grid { border-bottom: 2px solid var(--success); }
  .ea-card-phone { border-bottom: 2px solid var(--cy); }

  .ea-card-icon {
    font-size: 26px;
    display: block;
    margin-bottom: var(--space-md);
  }

  .ea-card h3 {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }

  .ea-card p {
    font-size: 12.5px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .ea-channels {
    margin-top: var(--space-3xl);
    display: flex;
    justify-content: center;
    gap: var(--space-2xl);
  }

  .ea-channel {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--cy);
    text-decoration: none;
    padding: 10px 20px;
    background: rgba(34, 211, 238, 0.05);
    border: 1px solid rgba(34, 211, 238, 0.2);
    border-radius: 0;
    transition: background 0.2s, border-color 0.2s;
  }

  .ea-channel:hover {
    background: rgba(34, 211, 238, 0.1);
    border-color: rgba(34, 211, 238, 0.4);
    color: var(--cy);
  }

  .ea-channel svg { flex-shrink: 0; }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .ea-title { font-size: 34px; }
    .ea-sub { font-size: 15px; }
    .ea-key code { font-size: 14px; }
    .ea-cards { grid-template-columns: 1fr; }
    .ea-channels { flex-direction: column; align-items: center; gap: var(--space-md); }
    .ea-confetti { width: 300px; }
  }
</style>
