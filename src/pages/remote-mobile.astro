            const initDone = () => {
              if (!isWritingBuffer) return; // guard against double-fire
              const _bA1 = term.buffer.active;
              dbgLog('INIT post tid=' + msg.terminalId + ' rows=' + term.rows + ' baseY=' + _bA1.baseY + ' viewY=' + _bA1.viewportY + ' bufLen=' + _bA1.length);
              drainTimerId = null;
              isWritingBuffer = false;
              applyPtyDims({ syncServer: true, forceRefresh: true });
              requestAnimationFrame(() => term.scrollToBottom());
              // Suspend horizontal auto-scroll until the user types. Without this,
              // the first render after load can land userIsTyping=true (carried
              // from a prior terminal) and yank hOffset to wherever the cursor
              // happens to be in the loaded buffer — usually the far right.
              userIsTyping = false;
              autoScrollDisabled = true;
              setHOffset(0);
              updatePlanModeButtons();
              // Re-lock textarea on mobile so the next tap gets a clean
              // blur → removeAttribute → focus cycle (same as switchDone).
              // Skip if user just tapped the keyboard button (grace period)
              // OR is actively typing — yanking readonly mid-type makes the
              // soft keyboard's spacebar scroll the page instead of typing.
              if (isMobileClient && xtermTextarea
                  && !(keyboardOpenTime && Date.now() - keyboardOpenTime < 1200)
                  && document.activeElement !== xtermTextarea) {
