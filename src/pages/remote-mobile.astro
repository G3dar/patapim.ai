          <button class="key-btn" data-key="ArrowRight">&rarr;</button>
          <button class="key-btn" data-key="Enter">↵</button>
          <button class="key-btn" id="key-zoom-out" title="Zoom out">A−</button>
          <button class="key-btn" id="key-zoom-in" title="Zoom in">A+</button>
          <button class="key-btn" id="key-kbd" title="Toggle keyboard" style="padding:4px 20px; font-size:16px;">⌨</button>
          <button class="key-btn" id="key-select" style="border-color:var(--accent); color:var(--accent);">Select</button>
          <button class="key-btn" id="key-telegram" title="Toggle Telegram notifications">✈ TG</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Debug overlay: activate with ?debug=1 in URL -->
  <div id="dbg-panel" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:9999;background:rgba(0,0,0,0.92);color:#0f0;font-family:monospace;font-size:11px;padding:8px;max-height:45vh;overflow-y:auto;border-top:2px solid #0f0;touch-action:pan-y;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
      <strong style="color:#d4a574;">PATAPIM debug</strong>
      <span>
        <button id="dbg-copy" style="font-family:monospace;font-size:10px;background:#1a1918;color:#0f0;border:1px solid #0f0;padding:2px 8px;cursor:pointer;margin-right:4px;">COPY</button>
        <button id="dbg-clear" style="font-family:monospace;font-size:10px;background:#1a1918;color:#888;border:1px solid #444;padding:2px 8px;cursor:pointer;margin-right:4px;">CLEAR</button>
        <button id="dbg-close" style="font-family:monospace;font-size:10px;background:#1a1918;color:#e05252;border:1px solid #e05252;padding:2px 8px;cursor:pointer;">X</button>
      </span>
    </div>
    <div id="dbg-state" style="color:#adf;margin-bottom:6px;line-height:1.6;"></div>
    <div id="dbg-log" style="line-height:1.5;"></div>
  </div>

  <script is:inline type="module">
    import { Terminal } from 'https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/+esm';
    import { FitAddon } from 'https://cdn.jsdelivr.net/npm/@xterm/addon-fit@0.10.0/+esm';

    // Parse URL params
    const params = new URLSearchParams(location.search);
    const deviceToken = params.get('d');

    // Active connection variables (mutable — refreshed on reconnect)
    let activeConnectToken = params.get('t');
    let activeTunnelUrl = params.get('url');
    let activeDeviceToken = deviceToken;

    // Deep-link from a Telegram notification: open this terminal and (if
    // `keys` is set) auto-press the chosen menu option. Cleared the moment
    // we successfully fire so a refresh doesn't re-trigger.
    let pendingTerminalId = params.get('terminal');
    let pendingProject = params.get('project');
    let pendingKeys = params.get('keys');
    if (pendingTerminalId || pendingProject || pendingKeys) {
      // Strip the deep-link params from the URL bar immediately. Connection
      // params (d/t/url) are preserved.
      const keep = new URLSearchParams();
      for (const k of ['d', 't', 'url']) {
        const v = params.get(k);
        if (v) keep.set(k, v);
      }
      const qs = keep.toString();
      try {
        history.replaceState(null, '', location.pathname + (qs ? '?' + qs : ''));
      } catch {}
    }

    // DOM
    const statusEl = document.getElementById('status');
    const statusDropdown = document.getElementById('status-dropdown');
    const tabsEl = document.getElementById('tabs');
    const loadingEl = document.getElementById('loading');
    const loadingText = document.getElementById('loading-text');
    const terminalWrap = document.getElementById('terminal-wrap');
    const scrollBottomBtn = document.getElementById('scroll-bottom');
    const sidebarEl = document.getElementById('sidebar');
    const sidebarOverlay = document.getElementById('sidebar-overlay');
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebarClose = document.getElementById('sidebar-close');
    const projectsList = document.getElementById('projects-list');
    const topbarProject = document.getElementById('topbar-project');
    const topbarSwitcher = document.getElementById('topbar-switcher');
    const btnStartClaude = document.getElementById('btn-start-claude');
    const btnStartGemini = document.getElementById('btn-start-gemini');
    const btnStartCodex = document.getElementById('btn-start-codex');
    const btnNewTerminal = document.getElementById('btn-new-terminal');
    const fabTrigger = document.getElementById('fab-trigger');
    const fabMenu = document.getElementById('fab-menu');
    const fabPlanMode = document.getElementById('fab-plan-mode');
    const fabSkipPerms = document.getElementById('fab-skip-perms');
    const fabPaste = document.getElementById('fab-paste');
    const fabImage = document.getElementById('fab-image');
    const fabCompact = document.getElementById('fab-compact');
    const fabToast = document.getElementById('fab-toast');
    const fabMic = document.getElementById('fab-mic');
    const fabKbd = document.getElementById('fab-kbd');
    const imagePicker = document.getElementById('image-picker');
    const keySelect = document.getElementById('key-select');
    const keyShiftTab = document.getElementById('key-shift-tab');
    const keyMic = document.getElementById('key-mic');
    const voicePreview = document.getElementById('voice-preview');
    const voiceText = document.getElementById('voice-text');
    const voiceSend = document.getElementById('voice-send');
    const voiceCancel = document.getElementById('voice-cancel');

    // State
    let ws = null;
    let term = null;
    let fitAddon = null;
    let currentTerminalId = null;
    let terminals = [];
    let isSwitching = false;
    let switchOutputQueue = [];
    let ptyDims = null;
    let isWritingBuffer = false;
    let drainTimerId = null;   // current checkDrain setTimeout id
    let drainDeadline = 0;     // hard fallback: fire initDone/switchDone after this timestamp
    let lastBufferSeq = 0;
    let isApplyingServerResize = false;
    let lastSentResize = { terminalId: null, cols: 0, rows: 0 };
    let lastFocusSync = { terminalId: null, focused: null };
    let lastVisualViewportHeight = 0;
    let fontSize = 14;
    let fontManuallySet = false;
    let reconnectAttempts = 0;
    let reconnectTimer = null;
    let wsConnectTimeout = null;
    let isAuthenticated = false;
    const modifiers = { ctrl: false, alt: false };
    let fabOpen = false;
    let isPlanMode = false;
    let isCompactView = false;
    let selectMode = false;
    let pendingAIStart = false;

    // ---- DEBUG OVERLAY ----
    const dbgPanel = document.getElementById('dbg-panel');
    const dbgState = document.getElementById('dbg-state');
    const dbgLogEl = document.getElementById('dbg-log');
    const dbgEvents = [];
    const isDebugMode = new URLSearchParams(location.search).has('debug');
    if (isDebugMode && dbgPanel) {
      dbgPanel.style.display = 'block';
      document.getElementById('dbg-close')?.addEventListener('click', () => dbgPanel.style.display = 'none');
      document.getElementById('dbg-clear')?.addEventListener('click', () => { dbgEvents.length = 0; if(dbgLogEl) dbgLogEl.innerHTML=''; });
      document.getElementById('dbg-copy')?.addEventListener('click', () => {
        const state = dbgState ? dbgState.textContent : '';
        const log = dbgEvents.join('\n');
        navigator.clipboard?.writeText(state + '\n---\n' + log).then(() => alert('Copiado!')).catch(() => alert('Error al copiar'));
      });
    }
    function dbgLog(msg) {
      if (!isDebugMode) return;
      const t = new Date().toISOString().slice(11,23);
      dbgEvents.push(t + ' ' + msg);
      if (dbgEvents.length > 40) dbgEvents.shift();
      if (dbgLogEl) dbgLogEl.innerHTML = dbgEvents.map(e => '<div>' + e + '</div>').join('');
    }
    function dbgUpdate() {
      if (!isDebugMode || !dbgState) return;
      const wrap = terminalWrap;
      const screen = wrap ? wrap.querySelector('.xterm-screen') : null;
      const viewport = wrap ? wrap.querySelector('.xterm-viewport') : null;
      const xtermEls = document.querySelectorAll('.xterm').length;
      const canvases = document.querySelectorAll('.xterm canvas').length;
      dbgState.innerHTML = [
        'build=r57  isMobile=' + (isMobileResizeMode ? isMobileResizeMode() : '?'),
        'ptyDims=' + (ptyDims ? ptyDims.cols+'×'+ptyDims.rows : 'null'),
        'term: rows=' + (term ? term.rows : '?') + ' cols=' + (term ? term.cols : '?') + ' font=' + (term ? term.options.fontSize : '?') + 'px',
        'containerH=' + (wrap ? wrap.clientHeight : '?') + ' screenH=' + (screen ? screen.clientHeight : '?') + ' screenW=' + (screen ? screen.clientWidth : '?'),
        'vp.scrollTop=' + (viewport ? Math.round(viewport.scrollTop) : '?') + ' vp.scrollH=' + (viewport ? viewport.scrollHeight : '?'),
        'xterm elements=' + xtermEls + '  canvases=' + canvases,
        'ws.state=' + (ws ? ['CONNECTING','OPEN','CLOSING','CLOSED'][ws.readyState] : 'null'),
      ].join('<br>');
    }
    if (isDebugMode) setInterval(dbgUpdate, 500);
    // ---- END DEBUG OVERLAY ----
    let mediaRecorder = null;
    let audioChunks = [];
    let recordingTimeout = null;
    let transcriptionTimeout = null;
    let isRecording = false;
    let selectionOverlay = null;
    let mobileKeyboardOpen = false;
    let keyboardOpenTime = 0; // timestamp of last keyboard-open tap (grace period for snapshots)
    let keyboardWasUp = false; // tracks the open→closed transition for the viewport pin

    function detectMobileClient() {
      const userAgent = navigator.userAgent || '';
      const uaMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini|Mobile/i.test(userAgent);
      // Check UA string first — userAgentData.mobile can be wrong under device emulation
      if (uaMobile) return true;
      if (navigator.userAgentData && typeof navigator.userAgentData.mobile === 'boolean') {
        return navigator.userAgentData.mobile;
      }
      const coarsePointer = window.matchMedia('(pointer: coarse)').matches;
      const narrowViewport = window.matchMedia('(max-width: 1024px)').matches;
      return coarsePointer && narrowViewport;
    }

    const isMobileClient = detectMobileClient();

    // Balanced default density on phones: a slightly smaller font fits ~55-60 cols
    // on a typical handset while staying readable. Desktop browsers keep 14.
    // The +/- font buttons remain the readability knob and recompute cols from here.
    if (isMobileClient) fontSize = 12;

    // Sidebar state
    let sidebarData = { projects: [], currentProject: null, currentSubfolder: null };
    let laterExpanded = false;

    // Helper to fetch a fresh connectToken from the server
    async function fetchConnectToken(devToken) {
      const res = await fetch('/api/device/connect-token', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ deviceToken: devToken }),
      });
      if (res.status === 401) return { error: 'session_expired' };
      if (!res.ok) return { error: 'fetch_failed' };
      return res.json();
    }

    // Device switcher (inside the status dropdown). Lists the account's
    // other PATAPIMs so the user can hop between machines from the phone
    // without going back to /go. Online devices are clickable; offline are
    // shown greyed for context. The current device is labelled "this one".
    let deviceListCache = null;
    let deviceListLoadInFlight = null;
    async function loadDeviceList(force = false) {
      if (deviceListLoadInFlight) return deviceListLoadInFlight;
      if (!force && deviceListCache) { renderDeviceList(deviceListCache); return deviceListCache; }
      deviceListLoadInFlight = (async () => {
        try {
          const res = await fetch('/api/device/list', { credentials: 'same-origin' });
          if (!res.ok) return [];
          const data = await res.json();
          deviceListCache = Array.isArray(data.devices) ? data.devices : [];
          renderDeviceList(deviceListCache);
          return deviceListCache;
        } catch {
          return [];
        } finally {
          deviceListLoadInFlight = null;
        }
      })();
      return deviceListLoadInFlight;
    }

    function renderDeviceList(devices) {
      const host = document.getElementById('device-pick-list');
      if (!host) return;
      if (!devices || devices.length === 0) {
        host.innerHTML = '<div class="device-pick-empty">No other devices</div>';
        return;
      }
      // Sort: current first, then online, then heartbeat, then offline.
      const ranked = devices.slice().sort((a, b) => {
        const ra = a.token === activeDeviceToken ? 0 : (a.status === 'online' ? 1 : (a.status === 'heartbeat' ? 2 : 3));
        const rb = b.token === activeDeviceToken ? 0 : (b.status === 'online' ? 1 : (b.status === 'heartbeat' ? 2 : 3));
        return ra - rb;
      });
      host.innerHTML = '';
      for (const d of ranked) {
        const isCurrent = d.token === activeDeviceToken;
        const status = d.status || (d.online ? 'online' : 'offline');
        const cls = ['device-pick-item', status];
        if (isCurrent) cls.push('current');
        if (status === 'offline') cls.push('offline');
        const btn = document.createElement('button');
        btn.className = cls.join(' ');
        btn.dataset.token = d.token;
        const safeName = (d.deviceName || 'Unnamed').replace(/[<>&]/g, s => ({ '<':'&lt;','>':'&gt;','&':'&amp;' }[s]));
        const badge = isCurrent ? 'this one' : (status === 'online' ? '' : status);
        btn.innerHTML = '<span class="dot"></span><span class="name">' + safeName + '</span>'
          + (badge ? '<span class="badge">' + badge + '</span>' : '');
        if (!isCurrent && status !== 'offline') {
          btn.addEventListener('click', () => switchToDevice(d.token));
        }
        host.appendChild(btn);
      }
    }

    async function switchToDevice(targetToken) {
      const host = document.getElementById('device-pick-list');
      if (host) {
        // Visual feedback — disable buttons + show "switching"
        host.querySelectorAll('.device-pick-item').forEach(b => { b.style.pointerEvents = 'none'; b.style.opacity = '0.5'; });
      }
      const r = await fetchConnectToken(targetToken);
      if (!r || !r.connectToken || !r.tunnelUrl) {
        if (host) host.innerHTML = '<div class="device-pick-empty">Failed to switch (' + ((r && r.error) || 'unknown') + ')</div>';
        return;
      }
      // Persist target so auto-reconnect picks the right device after we land.
      try {
        localStorage.setItem('patapim_device', JSON.stringify({ deviceToken: targetToken, ts: Date.now() }));
      } catch {}
      // Navigate with the same URL shape the dashboard uses.
      const qs = new URLSearchParams({ d: targetToken, t: r.connectToken, url: r.tunnelUrl });
      window.location.href = '/remote-mobile?' + qs.toString();
    }

    // Init: connect from URL params or auto-reconnect from localStorage
    if (activeConnectToken && activeTunnelUrl) {
      // Normal flow from dashboard — store deviceToken for future reconnects
      if (activeDeviceToken) {
        localStorage.setItem('patapim_device', JSON.stringify({
          deviceToken: activeDeviceToken, ts: Date.now()
        }));
      }
      initTerminal();
      connect();
    } else {
      // Try auto-reconnect from localStorage
      tryAutoReconnect();
    }

    async function tryAutoReconnect() {
      const stored = JSON.parse(localStorage.getItem('patapim_device') || 'null');
      if (!stored?.deviceToken) {
        showError('Missing connection parameters. <a href="/go">Go back to dashboard</a>');
        return;
      }
      loadingText && (loadingText.textContent = 'Reconnecting...');
      const result = await fetchConnectToken(stored.deviceToken);
      if (result.error === 'session_expired') {
        localStorage.removeItem('patapim_device');
        window.location.href = '/go';
        return;
      }
      if (!result.connectToken || !result.tunnelUrl) {
        showError((result.error || 'Device offline') + '. <a href="/go">Go back to dashboard</a>');
        return;
      }
      activeConnectToken = result.connectToken;
      activeTunnelUrl = result.tunnelUrl;
      activeDeviceToken = stored.deviceToken;
      initTerminal();
      connect();
    }

    function showError(html) {
      loadingEl.classList.remove('hidden');
      loadingText.remove();
      const spinner = loadingEl.querySelector('.loading-spinner');
      if (spinner) spinner.remove();
      const err = document.createElement('div');
      err.className = 'loading-error';
      err.innerHTML = html;
      loadingEl.appendChild(err);
    }

    function setStatus(state, text) {
      statusEl.textContent = text;
      statusEl.className = 'topbar-status ' + state;
    }

    function isMobileResizeMode() {
      const coarsePointer = window.matchMedia('(pointer: coarse)').matches;
      const narrowViewport = window.matchMedia('(max-width: 1024px)').matches;
      const hasTouch = typeof navigator.maxTouchPoints === 'number' && navigator.maxTouchPoints > 0;
      return isMobileClient || (coarsePointer && narrowViewport) || (hasTouch && narrowViewport);
    }

    function getVisualViewportWidthRatio() {
      const vp = window.visualViewport;
      if (!vp) return 1;

      const visualWidth = Math.round(Number(vp.width) || 0);
      const layoutWidth = Math.round(Number(window.innerWidth || document.documentElement.clientWidth) || 0);
      if (!visualWidth || !layoutWidth || visualWidth >= layoutWidth) {
        return 1;
      }

      const ratio = visualWidth / layoutWidth;
      return Number.isFinite(ratio) && ratio > 0 ? ratio : 1;
    }

    // Push a mobile-driven resize to the server. The backend grants mobile
    // clients ownership of the terminal (claimTerminalControl), resizes the PTY,
    // and mirrors the width onto the desktop. Deduped against lastSentResize so an
    // echoed pty_dimensions can't bounce back and loop us.
    function sendMobileResize(cols, rows) {
      if (!ws || ws.readyState !== WebSocket.OPEN) return;
      if (!isAuthenticated || !currentTerminalId) return;
      if (!(cols > 0) || !(rows > 0)) return;
      if (isWritingBuffer) return;          // never resize mid buffer write (init/switch)
      if (isApplyingServerResize) return;   // don't echo a server-driven resize back
      if (lastSentResize.terminalId === currentTerminalId
          && lastSentResize.cols === cols && lastSentResize.rows === rows) return;
      ws.send(JSON.stringify({ type: 'resize', terminalId: currentTerminalId, cols, rows, mobile: true }));
      lastSentResize = { terminalId: currentTerminalId, cols, rows };
      dbgLog('sent mobile resize ' + cols + '×' + rows);
    }

    // Apply terminal dimensions.
    // Mobile: fit cols+rows to the phone at the readable font, resize PTY to match.
    // Desktop: force PTY cols for correct cursor positioning.
    function applyPtyDims(options = {}) {
      if (!fitAddon || !term) return;
      if (isWritingBuffer) return;
      const { syncServer = true, forceRefresh = false } = options;
      const isMobile = isMobileResizeMode();
      // Stick-to-bottom guard: only re-snap to the bottom after a relayout if the
      // user was ALREADY at the bottom. applyPtyDims fires on every layout change
      // (ResizeObserver, window resize, and the visualViewport resize that the
      // mobile URL bar triggers while scrolling) — unconditionally scrolling here
      // (explicitly via scrollToBottom OR implicitly via term.resize, which xterm
      // snaps to ybase) yanked the user out of the scrollback every time they
      // tried to read history.
      const _buf = term.buffer.active;
      const wasAtBottom = _buf.viewportY >= _buf.baseY;
      const _linesFromBottom = wasAtBottom ? 0 : (_buf.baseY - _buf.viewportY);
      const _restoreScrollAfterResize = () => {
        if (wasAtBottom || _linesFromBottom <= 0) return;
        const nb = term.buffer.active;
        const targetY = Math.max(0, nb.baseY - _linesFromBottom);
        const delta = targetY - nb.viewportY;
        if (delta !== 0) term.scrollLines(delta);
      };
      dbgLog('applyPtyDims isMobile=' + isMobile + ' ptyDims=' + (ptyDims ? ptyDims.cols+'×'+ptyDims.rows : 'null') + ' syncServer=' + syncServer);

      if (isMobile) {
        const hasRemoteDims = ptyDims && Number.isFinite(ptyDims.cols) && Number.isFinite(ptyDims.rows);

        if (isCompactView && hasRemoteDims) {
          // OPT-OUT (compact view): show the full desktop width with the font
          // shrunk to fit. Preserves the previous mobile behavior and never
          // resizes the PTY.
          // CRITICAL: do NOT call fitAddon.fit() here — fit() would resize to
          // narrow mobile cols BEFORE we force ptyDims.cols, reflowing the whole
          // scrollback at the wrong width and corrupting TUI content. Use
          // proposeDimensions() to get the row count, then a single resize.
          if (!fontManuallySet) {
            const containerH = terminalWrap.clientHeight;
            if (containerH > 0 && ptyDims.rows > 0) {
              const targetFont = Math.max(11, Math.floor(containerH / ptyDims.rows));
              if (term.options.fontSize !== targetFont) term.options.fontSize = targetFont;
            }
          } else if (term.options.fontSize !== fontSize) {
            term.options.fontSize = fontSize;
          }
          const dims = fitAddon.proposeDimensions();
          const fitRows = (dims && dims.rows > 0) ? dims.rows : term.rows;
          if (term.cols !== ptyDims.cols || term.rows !== fitRows) {
            term.resize(ptyDims.cols, fitRows);
          }
          if (forceRefresh) term.refresh(0, term.rows - 1);
          if (wasAtBottom) requestAnimationFrame(() => term.scrollToBottom());
          else _restoreScrollAfterResize();
          // Compact view never resizes the PTY.
        } else {
          // PRIMARY mobile mode: the readable font is the knob; fit cols+rows to
          // the phone and push that width to the PTY (and, via the backend, the PC).
          if (term.options.fontSize !== fontSize) term.options.fontSize = fontSize;
          // proposeDimensions() reads the container + cell size to compute the
          // cols/rows that fit WITHOUT resizing. We resize exactly once to the
          // final target — no intermediate narrow-col reflow that corrupts TUIs.
          const dims = fitAddon.proposeDimensions();
          if (dims && dims.cols > 0 && dims.rows > 0) {
            const _oldRows = term.rows, _oldCols = term.cols;
            const _oldBase = term.buffer.active.baseY, _oldView = term.buffer.active.viewportY;
            if (term.cols !== dims.cols || term.rows !== dims.rows) {
              term.resize(dims.cols, dims.rows);
              const _nb = term.buffer.active;
              dbgLog('RESIZE ' + _oldCols + 'x' + _oldRows + '→' + dims.cols + 'x' + dims.rows + ' baseY ' + _oldBase + '→' + _nb.baseY + ' viewY ' + _oldView + '→' + _nb.viewportY + ' bufLen=' + _nb.length + ' wasBot=' + wasAtBottom);
            }
            if (forceRefresh) term.refresh(0, term.rows - 1);
            if (wasAtBottom) requestAnimationFrame(() => term.scrollToBottom());
            else _restoreScrollAfterResize();
            if (syncServer) {
              // Width changes (orientation flip / font +/-) always propagate.
              // While the soft keyboard is animating in/out, only the height
              // changes — suppress those rows-only resizes so we don't churn the
              // PTY/TUI mid-type. The local view still resizes either way.
              const colsChanged = !(lastSentResize.terminalId === currentTerminalId
                                    && lastSentResize.cols === dims.cols);
              const inKbGrace = isMobileClient && keyboardOpenTime
                                && (Date.now() - keyboardOpenTime < 1500);
              if (colsChanged || !inKbGrace) sendMobileResize(dims.cols, dims.rows);
            }
          } else if (!hasRemoteDims) {
            // Nothing measurable yet and no server dims — fit locally and wait
            // for terminal_init. Do not send a resize.
            fitAddon.fit();
            if (forceRefresh) term.refresh(0, term.rows - 1);
          }
        }
      } else if (ptyDims) {
        const dims = fitAddon.proposeDimensions();
        if (dims && dims.rows > 0) {
          term.resize(ptyDims.cols, dims.rows);
          if (forceRefresh) {
            term.refresh(0, term.rows - 1);
          }
        }
      } else {
        fitAddon.fit();
        if (forceRefresh) {
          term.refresh(0, term.rows - 1);
        }
      }
    }

    // Pin .app to the VISUAL viewport so the soft keyboard shrinks the app
    // instead of overlaying the terminal/input. On iOS/WebKit the layout viewport
    // (and 100dvh) does NOT shrink for the keyboard, so this JS is the only
    // mechanism. .app is a normal-flow flex column, so setting its height to the
    // visual-viewport height lets the flex chain reflow and lift the bottom bar +
    // prompt above the keyboard. Verified in the iOS 26.5 Simulator (real soft
    // keyboard): app 714→377, keys-bar + prompt stay visible above the keyboard.
    // Deliberately does NOT depend on `term` — layout must pin even mid-(re)connect.
    function pinAppToVisualViewport() {
      if (!isMobileResizeMode()) return;
      const appEl = document.querySelector('.app');
      const vp = window.visualViewport;
      if (!appEl || !vp) return;
      const h = Math.round(vp.height) + 'px';
      if (appEl.style.height !== h) appEl.style.height = h;
      if (vp.offsetTop > 0) window.scrollTo(0, 0); // keep page from panning under kb
    }

    function scrollToBottomIfKeyboard() {
      // Layout pin already ran (called directly from the listeners, term-independent).
      if (!isMobileResizeMode() || !term) return;
      const vp = window.visualViewport;
      if (!vp) return;

      // Absolute keyboard up/down detection — used ONLY for the readonly/fab-kbd
      // UX and prompt scroll, NOT for layout (layout is pinned unconditionally).
      const layoutH = window.innerHeight || document.documentElement.clientHeight;
      const keyboardUp = (layoutH - vp.height) > 120;
      const justOpened = keyboardUp && !keyboardWasUp;
      keyboardWasUp = keyboardUp;

      if (keyboardUp) {
        requestAnimationFrame(() => {
          applyPtyDims();
          // Only yank to the bottom on the open transition — re-doing it on every
          // animation tick would fight a user scrolling back through scrollback.
          if (justOpened) term.scrollToBottom();
        });
      } else {
        // Keyboard dismissed — re-lock textarea so taps reopen the keyboard.
        if (isMobileClient && mobileKeyboardOpen) {
          const ta = terminalWrap?.querySelector('.xterm-helper-textarea');
          // Skip re-lock if the textarea still has focus — visualViewport can
          // fire spurious shrink events (orientation, status bar) while the
          // keyboard is genuinely still up. Re-applying readonly mid-type
          // makes space/keys scroll the page instead of typing.
          if (ta && document.activeElement !== ta) {
            mobileKeyboardOpen = false;
            ta.setAttribute('readonly', 'readonly');
            fabKbd.classList.remove('hidden');
          }
        }
        requestAnimationFrame(() => {
          applyPtyDims();
        });
      }
    }

    function getCellWidth() {
      try {
        return term._core._renderService.dimensions.css.cell.width;
      } catch (e) {
        const screen = terminalWrap.querySelector('.xterm-screen');
        if (screen && term.cols > 0) return screen.offsetWidth / term.cols;
        return 0;
      }
    }

    function getCellHeight() {
      try {
        return term._core._renderService.dimensions.css.cell.height || 16;
      } catch (e) {
        const screen = terminalWrap.querySelector('.xterm-screen');
        if (screen && term.rows > 0) return screen.offsetHeight / term.rows;
        return 16;
      }
    }

    // Alt-screen TUIs (Claude Code, vim…) keep xterm in the alternate buffer,
    // which has NO scrollback by design — the app owns scrolling. Scrolling
    // them means asking the HOST app to scroll: dispatch wheel events on the
    // xterm screen so xterm (in the TUI's mouse-tracking mode, restored by the
    // snapshot's serialized modes) converts them into wheel reports that flow
    // through term.onData → ws input → host PTY. One event per line so slow
    // drags never get rounded away.
    function forwardWheelToTui(lines, clientX, clientY) {
      if (!term || !lines) return;
      const screen = terminalWrap.querySelector('.xterm-screen');
      if (!screen) return;
      const cellH = getCellHeight();
      const opts = { bubbles: true, cancelable: true, view: window, clientX, clientY,
                     deltaMode: 0, deltaY: lines > 0 ? cellH : -cellH };
      const n = Math.min(Math.abs(lines), 40); // clamp a single burst
      for (let i = 0; i < n; i++) screen.dispatchEvent(new WheelEvent('wheel', opts));
    }

    function isAltScreen() {
      return !!(term && term.buffer && term.buffer.active.type === 'alternate');
    }

    let isUserTouchScrolling = false;
    let autoScrollDisabled = false;
    let userIsTyping = false;
    let typingTimer = null;

    // Horizontal offset via CSS transform
    let hOffset = 0;

    function markTyping() {
      userIsTyping = true;
      if (typingTimer) clearTimeout(typingTimer);
      typingTimer = setTimeout(() => {
        userIsTyping = false;
      }, 2000);
    }

    function setHOffset(px) {
      // Fit-to-width (primary mobile) mode sizes the terminal to the phone, so
      // there is nothing to the right to reveal — any horizontal offset is just
      // useless drift. Only the compact view (full desktop width) keeps it.
      if (!isCompactView) px = 0;
      hOffset = px;
      const xtermEl = terminalWrap.querySelector('.xterm');
      if (xtermEl) {
        xtermEl.style.transition = 'transform 120ms ease-out';
        xtermEl.style.transform = px ? `translateX(-${px}px)` : '';
      }
    }

    function setHOffsetImmediate(px) {
      if (!isCompactView) px = 0;
      hOffset = px;
      const xtermEl = terminalWrap.querySelector('.xterm');
      if (xtermEl) {
        xtermEl.style.transition = 'none';
        xtermEl.style.transform = px ? `translateX(-${px}px)` : '';
      }
    }

    function isClaudeActive() {
      const cur = terminals.find(t => t.id === currentTerminalId);
      return cur && cur.isProcessing;
    }

    // Never auto-scroll while the user is reading scrollback (desktop AND mobile).
    // Snapshot writes (\x1b[2J\x1b[H + viewport-data) and cursor positioning
    // in live output can yank viewportY back to baseY. We capture the scroll
    // position before the write and restore it after xterm processes the data.
    // Mobile previously passed through unchanged, which forced the viewport back
    // to the bottom every time new output arrived while the user was scrolled up.
    function writePreservingScroll(data) {
      if (!term) return;
      const buf = term.buffer.active;
      const targetY = buf.viewportY;
      const isScrolledUp = targetY < buf.baseY;
      term.write(data);
      if (!isScrolledUp) return;
      requestAnimationFrame(() => {
        const newBuf = term.buffer.active;
        const clampedY = Math.min(targetY, newBuf.baseY);
        const delta = clampedY - newBuf.viewportY;
        if (delta !== 0) term.scrollLines(delta);
      });
    }

    function isClientFocused() {
      return !document.hidden && document.visibilityState === 'visible';
    }

    function sendTerminalFocus(focused, terminalId = currentTerminalId) {
      if (!ws || ws.readyState !== WebSocket.OPEN || !isAuthenticated || !terminalId) return;
      const normalized = !!focused;
      if (lastFocusSync.terminalId === terminalId && lastFocusSync.focused === normalized) return;

      ws.send(JSON.stringify({
        type: 'terminal_focus',
        terminalId,
        focused: normalized,
        mobile: isMobileResizeMode(),
      }));
      lastFocusSync = { terminalId, focused: normalized };
    }

    function syncTerminalFocus(terminalId = currentTerminalId) {
      if (!terminalId) return;
      sendTerminalFocus(isClientFocused(), terminalId);
    }

    function resetTerminalView() {
      if (!term) return;
      term.clear();
      term.write('\x1b[2J\x1b[3J\x1b[H');
    }

    function debounce(fn, delay) {
      let timer = null;
      return (...args) => {
        if (timer) clearTimeout(timer);
        timer = setTimeout(() => fn(...args), delay);
      };
    }

    // ── Plan Mode detection & toggle ──────────────────────────────

    function detectPlanMode() {
      if (!term) return false;
      const buffer = term.buffer.active;
      const start = Math.max(0, buffer.length - 15);
      let text = '';
      for (let i = start; i < buffer.length; i++) {
        const line = buffer.getLine(i);
        if (line) text += line.translateToString(false) + '\n';
      }
      return /plan\s*mode/i.test(text);
    }

    function updatePlanModeButtons() {
      applyPlanModeUI(detectPlanMode());
    }

    const debouncedUpdatePlanMode = debounce(updatePlanModeButtons, 500);

    function togglePlanMode() {
      if (!ws || ws.readyState !== WebSocket.OPEN || !currentTerminalId) return;

      // Send exactly one Shift+Tab — it's a toggle at the Claude Code level
      ws.send(JSON.stringify({ type: 'input', terminalId: currentTerminalId, data: '\x1b[Z' }));

      // Optimistically flip local state so the button responds immediately
      const targetState = !isPlanMode;
      isPlanMode = targetState;
      fabPlanMode.classList.toggle('plan-active', isPlanMode);
      const fabLabel = fabPlanMode.querySelector('span');
      if (fabLabel) fabLabel.textContent = isPlanMode ? 'Exit Plan Mode' : 'Toggle Plan Mode';
      keyShiftTab.classList.toggle('active', isPlanMode);

      // Reconcile with actual terminal state after snapshots arrive.
      // Use multiple checks: remote snapshots have variable latency.
      // Keep optimistic state for at least 2s before allowing revert.
      const toggledAt = Date.now();
      const reconcile = () => {
        const detected = detectPlanMode();
        // Within the grace window, only update if detection CONFIRMS the target state.
        // After the grace window, always reconcile with actual state.
        if (Date.now() - toggledAt < 2000) {
          if (detected === targetState) applyPlanModeUI(detected);
          // else: keep optimistic state, wait for next check
        } else {
          applyPlanModeUI(detected);
        }
      };
      setTimeout(reconcile, 800);
      setTimeout(reconcile, 1500);
      setTimeout(reconcile, 3000);

      term.focus();
      syncTerminalFocus();
    }

    function applyPlanModeUI(mode) {
      isPlanMode = mode;
      fabPlanMode.classList.toggle('plan-active', isPlanMode);
      const fabLabel = fabPlanMode.querySelector('span');
      if (fabLabel) fabLabel.textContent = isPlanMode ? 'Exit Plan Mode' : 'Toggle Plan Mode';
      keyShiftTab.classList.toggle('active', isPlanMode);
    }

    function initTerminal() {
      if (term) {
        term.dispose();
        term = null;
      }
      // Debug: expose key variables for live inspection
      window._d = () => ({ term, ws, currentTerminalId, isSwitching, isWritingBuffer, ptyDims, lastBufferSeq, switchOutputQueue, mobileKeyboardOpen, keyboardOpenTime });
      window._switchLog = [];
      // Debug state indicator — shows live flags in the topbar
      let _dbgSnapCount = 0;
      let _dbgOutCount = 0;
      window._dbgSnap = () => _dbgSnapCount++;
      window._dbgOut = () => _dbgOutCount++;
      const _dbgEl = document.getElementById('dbg-state');
      if (_dbgEl) {
        setInterval(() => {
          const grace = keyboardOpenTime ? Math.max(0, 600 - (Date.now() - keyboardOpenTime)) : 0;
          _dbgEl.textContent = (isSwitching ? 'SW ' : '') + (isWritingBuffer ? 'WB ' : '') + (mobileKeyboardOpen ? 'KB ' : '') + (grace > 0 ? 'G' + grace + ' ' : '') + 'S' + _dbgSnapCount + ' O' + _dbgOutCount;
        }, 200);
      }
      term = new Terminal({
        fontFamily: "'JetBrains Mono', monospace",
        fontSize,
        theme: {
          background: '#0a0a0b',
          foreground: '#e4e4e7',
          cursor: '#c9a227',
          cursorAccent: '#0a0a0b',
          selectionBackground: 'rgba(201, 162, 39, 0.3)',
          black: '#27272a',
          red: '#d47878',
          green: '#7cb382',
          yellow: '#c9a227',
          blue: '#6b9bd2',
          magenta: '#b07eb5',
          cyan: '#6bbfb8',
          white: '#e4e4e7',
          brightBlack: '#52525b',
          brightRed: '#e89090',
          brightGreen: '#96c99b',
          brightYellow: '#d4b84a',
          brightBlue: '#87b3e0',
          brightMagenta: '#c89bcb',
          brightCyan: '#88d3cd',
          brightWhite: '#fafafa',
        },
        cursorBlink: true,
        scrollback: 5000,
        allowProposedApi: true,
      });

      fitAddon = new FitAddon();
      term.loadAddon(fitAddon);
      term.open(terminalWrap);

      // On mobile, prevent the keyboard from appearing on every touch.
      // We mark the xterm textarea readonly so taps don't auto-open the keyboard;
      // our touchend handler removes readonly on quick taps to show the keyboard,
      // and we re-apply it only when the keyboard is dismissed (detected via visualViewport).
      const xtermTextarea = terminalWrap.querySelector('.xterm-helper-textarea');
      if (isMobileClient && xtermTextarea) {
        xtermTextarea.setAttribute('readonly', 'readonly');
        // Prevent iOS keyboard-switch from triggering xterm text selection.
        // iOS fires a `select` event on the textarea when switching keyboard
        // layouts (e.g. letters → numbers); clear the unwanted selection.
        xtermTextarea.addEventListener('select', () => {
          if (!selectMode) term.clearSelection();
        });
      }

      fitAddon.fit();

      // Handle user input
      term.onData(data => {
        if (!ws || ws.readyState !== WebSocket.OPEN || !isAuthenticated) return;

        // Mouse reports (wheel scroll forwarded to an alt-screen TUI) are not
        // typing: send verbatim — no modifier rewriting, no h-autoscroll
        // re-enable, no markTyping (which would yank hOffset mid-scroll).
        if (data.startsWith('\x1b[<') || data.startsWith('\x1b[M')) {
          ws.send(JSON.stringify({ type: 'input', terminalId: currentTerminalId, data }));
          return;
        }

        // Any key press re-enables auto horizontal scroll (suspended by manual touch scroll)
        autoScrollDisabled = false;

        // Apply modifiers
        let sendData = data;
        if (modifiers.ctrl && data.length === 1) {
          const code = data.toUpperCase().charCodeAt(0) - 64;
          if (code > 0 && code < 32) {
            sendData = String.fromCharCode(code);
          }
          modifiers.ctrl = false;
          updateModifierButtons();
        }
        if (modifiers.alt) {
          sendData = '\x1b' + data;
          modifiers.alt = false;
          updateModifierButtons();
        }

        ws.send(JSON.stringify({
          type: 'input',
          terminalId: currentTerminalId,
          data: sendData,
        }));
        // Enter/Return → reset to left immediately (only when Claude is idle)
        if (sendData === '\r' || sendData === '\n') {
          if (!isClaudeActive()) setHOffset(0);
          userIsTyping = false;
          if (typingTimer) clearTimeout(typingTimer);
        } else {
          markTyping();
        }
      });

      const updateScrollButton = () => {
        const viewport = terminalWrap.querySelector('.xterm-viewport');
        if (!viewport) return;
        const distanceFromBottom = viewport.scrollHeight - viewport.clientHeight - viewport.scrollTop;
        const isAtBottom = distanceFromBottom < 10;
        const hasScrollback = viewport.scrollHeight > viewport.clientHeight + 10;
        const isScrolledUp = !isAtBottom && hasScrollback;
        const isScrolledRight = hOffset > 10;
        scrollBottomBtn.classList.toggle('visible', isScrolledUp || isScrolledRight);

        const svg = scrollBottomBtn.querySelector('svg');
        if (svg) {
          if (isScrolledUp && isScrolledRight) {
            svg.style.transform = 'rotate(45deg)';
          } else if (isScrolledRight) {
            svg.style.transform = 'rotate(90deg)';
          } else {
            svg.style.transform = 'rotate(0deg)';
          }
        }
      };

      // Track scroll position
      term.onScroll(updateScrollButton);
      term.onRender(() => {
        // Don't adjust horizontal scrolling while Claude is active
        if (!isClaudeActive()) {
          // Kill any browser/xterm native auto-scroll (we manage scroll via CSS transform)
          if (terminalWrap.scrollLeft !== 0) terminalWrap.scrollLeft = 0;
          const vp = terminalWrap.querySelector('.xterm-viewport');
          if (vp && vp.scrollLeft !== 0) vp.scrollLeft = 0;
        }

        if (isMobileResizeMode() && !isClaudeActive() && !autoScrollDisabled) {
          const cellWidth = getCellWidth();
          if (cellWidth) {
            const buf = term.buffer.active;
            const cursorX = buf.cursorX;
            const cursorY = buf.cursorY;

            // Skip phantom cursor on the last row — that's Claude's footer/status bar,
            // not a real typing position. The actual prompt is always above it.
            if (cursorY >= term.rows - 1) {
              // don't auto-scroll for this phantom position
            } else if (userIsTyping) {
              // Active typing: keep cursor visible with left/right margin thresholds
              const cursorPx = cursorX * cellWidth;
              const vw = terminalWrap.clientWidth;
              const visualPos = cursorPx - hOffset;

              if (visualPos > vw * 0.80) {
                setHOffset(Math.max(0, cursorPx - vw * 0.33));
              } else if (visualPos < vw * 0.15 && hOffset > 0) {
                setHOffset(Math.max(0, cursorPx - vw * 0.33));
              }
            } else if (!isUserTouchScrolling && hOffset > 0) {
              // Not typing, not touch-scrolling: if cursor fits in viewport, reset offset.
              // This prevents stale hOffset from causing jumps when the prompt redraws
              // or the cursor moves back to column 0 (e.g. after command finishes).
              const cursorPx = cursorX * cellWidth;
              const vw = terminalWrap.clientWidth;
              if (cursorPx < vw * 0.85) {
                setHOffset(0);
              }
            }
          }
        }
        setTimeout(updateScrollButton, 50);
      });

      const viewport = terminalWrap.querySelector('.xterm-viewport');
      if (viewport) {
        viewport.addEventListener('scroll', debounce(updateScrollButton, 16), { passive: true });
      }
      terminalWrap.addEventListener('scroll', debounce(updateScrollButton, 16), { passive: true });

      // overflow-x: hidden prevents xterm auto-scroll. Touch-drag uses transform.

      terminalWrap.addEventListener('click', () => {
        term.focus();
        syncTerminalFocus();
      });
      // Mobile: only show keyboard on quick tap, not on hold/drag (which should scroll)
      if (isMobileClient) {
        let touchInfo = null;
        let longPressTimer = null;

        const cancelLongPress = () => {
          if (longPressTimer) { clearTimeout(longPressTimer); longPressTimer = null; }
        };

        terminalWrap.addEventListener('touchstart', (e) => {
          const t = e.touches[0];
          touchInfo = { x: t.clientX, y: t.clientY, time: Date.now() };
          // Long-press: hold ~500ms without moving → enter selection mode
          longPressTimer = setTimeout(() => {
            longPressTimer = null;
            touchInfo = null; // prevent tap-to-keyboard on touchend
            if (navigator.vibrate) navigator.vibrate(40);
            if (!selectMode) {
              selectMode = true;
              keySelect.classList.add('active');
              enterSelectionMode();
            }
          }, 500);
        }, { passive: true });

        terminalWrap.addEventListener('touchend', () => {
          cancelLongPress();
          if (!touchInfo) {
            window._kbLog = window._kbLog || [];
            window._kbLog.push({ t: Date.now(), ev: 'touchend-no-info' });
            return;
          }
          const elapsed = Date.now() - touchInfo.time;
          if (elapsed < 300) {
            // Quick tap — remove readonly so the keyboard opens.
            // readonly is re-applied when the keyboard is dismissed (visualViewport resize).
            // Blur first: if the textarea already has focus (e.g. from selectProject),
            // iOS treats focus() as a no-op and won't show the keyboard. Blurring
            // first ensures a fresh focus event that iOS honors.
            if (xtermTextarea) {
              xtermTextarea.blur();
              xtermTextarea.removeAttribute('readonly');
              // Force synchronous reflow so the attribute removal is committed
              // to the DOM before we re-focus. Without this, the browser may
              // still see the element as readonly when processing focus().
              void xtermTextarea.offsetHeight;
            }
            mobileKeyboardOpen = true;
            keyboardOpenTime = Date.now();
            fabKbd.classList.add('hidden');
            term.focus();
            syncTerminalFocus();
            window._kbLog = window._kbLog || [];
            window._kbLog.push({ t: Date.now(), ev: 'tap-focus', elapsed, hadFocus: document.activeElement === xtermTextarea, readonly: xtermTextarea?.hasAttribute('readonly') });
          } else {
            window._kbLog = window._kbLog || [];
            window._kbLog.push({ t: Date.now(), ev: 'tap-too-slow', elapsed });
          }
          touchInfo = null;
        });
        terminalWrap.addEventListener('touchcancel', () => {
          cancelLongPress();
          touchInfo = null;
        }, { passive: true });
        // Track last touch X for manual horizontal scroll
        // (xterm-viewport captures vertical scroll, blocking terminal-wrap's horizontal scroll)
        let lastTouchX = 0;
        let lastTouchY = 0;
        let tuiScrollAccum = 0;
        terminalWrap.addEventListener('touchstart', (e2) => {
          lastTouchX = e2.touches[0].clientX;
          lastTouchY = e2.touches[0].clientY;
          tuiScrollAccum = 0;
        }, { passive: true, capture: true });

        terminalWrap.addEventListener('touchmove', (e) => {
          const t = e.touches[0];
          // Cancel tap/long-press if dragged
          if (touchInfo) {
            const dx = Math.abs(t.clientX - touchInfo.x);
            const dy = Math.abs(t.clientY - touchInfo.y);
            if (dx > 10 || dy > 10) {
              touchInfo = null;
              cancelLongPress();
            }
          }
          // Manually apply horizontal scroll via transform — only in compact
          // view, where the terminal is wider than the screen. In fit-to-width
          // mode the terminal matches the phone width, so horizontal panning is
          // useless drift and is disabled (vertical scroll only).
          if (isCompactView) {
            const hDelta = lastTouchX - t.clientX;
            if (Math.abs(hDelta) > 1) {
              setHOffsetImmediate(Math.max(0, hOffset + hDelta));
              isUserTouchScrolling = true;
              // Suspend auto horizontal scroll until the next key press
              autoScrollDisabled = true;
            }
          }
          // Vertical drag over an alt-screen TUI (Claude Code, vim…) → forward
          // to the host app as wheel reports. The alt buffer has no scrollback,
          // so the native .xterm-viewport scroll (which handles normal-buffer
          // terminals) is a no-op there and the drag previously did nothing.
          if (isAltScreen()) {
            const cellH = getCellHeight();
            tuiScrollAccum += (lastTouchY - t.clientY); // finger up → toward newer output
            const lines = Math.trunc(tuiScrollAccum / cellH);
            if (lines !== 0) {
              tuiScrollAccum -= lines * cellH;
              isUserTouchScrolling = true;
              forwardWheelToTui(lines, t.clientX, t.clientY);
            }
          }
          lastTouchX = t.clientX;
          lastTouchY = t.clientY;
        }, { passive: true });
        terminalWrap.addEventListener('touchend', () => {
          setTimeout(() => { isUserTouchScrolling = false; }, 300);
        }, { passive: true });
      } else {
        terminalWrap.addEventListener('touchstart', () => {
          term.focus();
          syncTerminalFocus();
        }, { passive: true });

        // Desktop: bypass xterm's mouse-mode wheel forwarding. TUIs like
        // Claude enable mouse reporting, which makes xterm send wheel as
        // mouse buttons to the PTY instead of scrolling the scrollback.
        // We capture wheel before xterm sees it and call term.scrollLines()
        // directly (xterm's own API for scrollback navigation).
        terminalWrap.addEventListener('wheel', (e) => {
          if (!term) return;
          // Alt-screen TUIs (Claude Code, vim…) have no scrollback to scroll
          // locally — fall through to xterm's own wheel handling, which (with
          // the TUI's mouse mode active) forwards wheel reports the host app
          // scrolls by. The scrollLines bypass below is only for plain-shell
          // (normal-buffer) terminals, where mouse reporting would otherwise
          // eat the wheel and block scrollback navigation.
          if (isAltScreen()) return;
          e.preventDefault();
          e.stopPropagation();
          const dims = term._core && term._core._renderService && term._core._renderService.dimensions;
          const cellHeight = (dims && dims.css && dims.css.cell && dims.css.cell.height) || 16;
          const deltaPx = e.deltaMode === 1 ? e.deltaY * cellHeight : e.deltaY;
          const lines = Math.round(deltaPx / cellHeight);
          if (lines !== 0) {
            term.scrollLines(lines);
            dbgLog('wheel scrollLines=' + lines + ' deltaY=' + e.deltaY);
          }
        }, { capture: true, passive: false });
      }

      // Log xterm-viewport scroll events for debugging ghost issue
      const xtermVP = terminalWrap.querySelector('.xterm-viewport');
      if (xtermVP) {
        xtermVP.addEventListener('scroll', () => {
          dbgLog('vp.scroll scrollTop=' + Math.round(xtermVP.scrollTop) + ' scrollH=' + xtermVP.scrollHeight + ' clientH=' + xtermVP.clientHeight);
        }, { passive: true });
      }

      // Resize delegates to applyPtyDims
      const ro = new ResizeObserver(debounce(() => {
        applyPtyDims({ forceRefresh: true });
      }, 80));
      ro.observe(terminalWrap);

      const viewportResize = debounce(() => {
        applyPtyDims({ forceRefresh: true });
        // Crossing the mobile/desktop breakpoint flips where terminals are
        // listed (panel vs. horizontal bar) — keep the panel list in sync.
        renderSidebarTerminals();
      }, 80);
      window.addEventListener('resize', viewportResize);
      window.addEventListener('orientationchange', () => {
        setTimeout(() => {
          pinAppToVisualViewport();
          applyPtyDims({ forceRefresh: true });
        }, 120);
      });
      if (window.visualViewport) {
        lastVisualViewportHeight = window.visualViewport.height;

        // The layout pin runs FIRST and UNCONDITIONALLY (term-independent), coalesced
        // to one rAF per event burst so .app tracks the keyboard animation smoothly.
        // Undebounced — the old 80ms debounce could land mid-animation and miss the
        // final viewport height. scrollToBottomIfKeyboard handles only the term-side UX.
        let vpRafScheduled = false;
        const onViewportChange = () => {
          if (!vpRafScheduled) {
            vpRafScheduled = true;
            requestAnimationFrame(() => { vpRafScheduled = false; pinAppToVisualViewport(); });
          }
          scrollToBottomIfKeyboard();
          syncSidebarViewport();
        };
        window.visualViewport.addEventListener('resize', () => {
          lastVisualViewportHeight = window.visualViewport.height;
          onViewportChange();
        });
        window.visualViewport.addEventListener('scroll', onViewportChange);
      }
    }

    function connect() {
      if (!activeTunnelUrl) return;

      // Build WebSocket URL from tunnel URL
      const wsUrl = activeTunnelUrl.replace(/^https?:/, 'wss:');
      setStatus('connecting', 'Connecting...');
      loadingEl.classList.remove('hidden');
      loadingText && (loadingText.textContent = 'Connecting to device...');

      try {
        ws = new WebSocket(wsUrl);
      } catch (e) {
        showError('Failed to connect. <a href="/go">Go back</a>');
        return;
      }

      // Guard against a zombie tunnel URL: if the WS handshake doesn't
      // complete in ~8s the server's tunnel is likely dead and the browser
      // would otherwise hang in "connecting" for minutes. Force-close and
      // let onclose schedule a reconnect with a fresh token.
      if (wsConnectTimeout) clearTimeout(wsConnectTimeout);
      wsConnectTimeout = setTimeout(() => {
        if (ws && ws.readyState === WebSocket.CONNECTING) {
          try { ws.close(); } catch {}
        }
      }, 8000);

      ws.onopen = () => {
        if (wsConnectTimeout) { clearTimeout(wsConnectTimeout); wsConnectTimeout = null; }
        setStatus('connecting', 'Authenticating...');
        loadingText && (loadingText.textContent = 'Authenticating...');
        reconnectAttempts = 0;
        lastFocusSync = { terminalId: null, focused: null };
        // Auth is sent after receiving 'welcome' message to avoid double-auth
      };

      ws.onmessage = (e) => {
        try {
          handleMessage(JSON.parse(e.data));
        } catch (err) {
          console.error('[WS] Parse error:', err);
        }
      };

      ws.onclose = () => {
        if (wsConnectTimeout) { clearTimeout(wsConnectTimeout); wsConnectTimeout = null; }
        setStatus('disconnected', 'Disconnected');
        loadingEl.classList.remove('hidden');
        enableActions(false);
        lastFocusSync = { terminalId: null, focused: null };
        // Reset switch state so output isn't queued forever on reconnect
        isSwitching = false;
        switchOutputQueue = [];
        scheduleReconnect();
      };

      ws.onerror = () => {
        setStatus('disconnected', 'Connection error');
      };
    }

    function scheduleReconnect() {
      if (!isAuthenticated || !activeDeviceToken) return;
      if (reconnectAttempts >= 10) return;
      if (reconnectTimer) return;
      // Exponential-ish backoff capped at 10s so a temporarily unavailable
      // tunnel URL doesn't burn through all retries in 20s.
      const delay = Math.min(2000 * Math.pow(1.5, reconnectAttempts), 10000);
      reconnectTimer = setTimeout(async () => {
        reconnectTimer = null;
        reconnectAttempts++;
        setStatus('connecting', 'Reconnecting...');
        const result = await fetchConnectToken(activeDeviceToken);
        if (result.connectToken && result.tunnelUrl) {
          activeConnectToken = result.connectToken;
          activeTunnelUrl = result.tunnelUrl;
          connect();
        } else {
          // Token/tunnel not ready yet — keep trying instead of silently giving up.
          scheduleReconnect();
        }
      }, delay);
    }

    function handleMessage(msg) {
      switch (msg.type) {
        case 'welcome':
          // Server sent welcome, now authenticate with connect token
          ws.send(JSON.stringify({
            type: 'auth',
            connectToken: activeConnectToken,
          }));
          break;

        case 'auth_result':
          if (msg.success) {
            isAuthenticated = true;
            setStatus('connected', 'Connected');
            loadingEl.classList.add('hidden');
            enableActions(true);

