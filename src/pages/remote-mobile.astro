              initDone();
            }
          }
          break;

        case 'terminals':
        case 'switched':
          if (msg.terminals) {
            terminals = msg.terminals;
            renderTabs();
            // Deep-link target arrived with the list — switch to it. Project
            // mismatch (terminal belongs to another project) is handled below
            // in the sidebar_data branch where we kick off project selection.
            if (msg.type === 'terminals' && pendingTerminalId) {
              const found = terminals.find(t => t.id === pendingTerminalId);
              if (found) {
                const target = pendingTerminalId;
                pendingTerminalId = null;
                if (target !== currentTerminalId) {
                  switchTerminal(target);
                } else if (pendingKeys) {
                  // Already on the right terminal — fire the keys now.
                  ws.send(JSON.stringify({ type: 'input', terminalId: target, data: pendingKeys + '\r' }));
                  pendingKeys = null;
                }
              }
            }
          }
          if (msg.currentTerminal || msg.terminalId) {
            const previousTerminalId = currentTerminalId;
            const newId = msg.currentTerminal || msg.terminalId;
            if (newId !== currentTerminalId && term) {
              ptyDims = null;
              lastSentResize = { terminalId: null, cols: 0, rows: 0 };
              if (previousTerminalId) {
                sendTerminalFocus(false, previousTerminalId);
              }
              // Don't resetTerminalView here — the 'switched' block below
              // will clear and write. Calling reset here queues a write, and
              // the subsequent resize() in applyPtyDims kills xterm's write
              // processor, causing the buffer write to never complete.
            }
            currentTerminalId = newId;
            syncTerminalFocus(currentTerminalId);
            highlightTab(currentTerminalId);
          }
