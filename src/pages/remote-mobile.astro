              pendingAIStart = false;
              const newTermId = msg.terminalId || currentTerminalId;
              setTimeout(() => {
                const aiCommands = {
                  claude: 'claude --dangerously-skip-permissions',
                  gemini: 'gemini --yolo',
                  codex: 'codex --dangerously-bypass-approvals-and-sandbox',
                };
                const selectedAI = localStorage.getItem('patapim-remote-last-ai') || 'claude';
