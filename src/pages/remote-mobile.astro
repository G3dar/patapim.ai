            term.write('\x1b[?1049l\x1b[?2026h\x1b[0m\x1b[2J\x1b[3J\x1b[H' + (msg.buffer || '') + '\x1b[?2026l');
            const switchDone = () => {
              if (!isWritingBuffer) return; // guard against double-fire
              drainTimerId = null;
              isWritingBuffer = false;
              applyPtyDims({ syncServer: false, forceRefresh: true });
              requestAnimationFrame(() => term.scrollToBottom());
              isSwitching = false;
              // Telegram deep-link: now that the target terminal is rendered
              // and active, fire the queued option key once and clear it.
