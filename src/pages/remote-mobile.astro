              // soft keyboard's spacebar scroll the page instead of typing.
              if (isMobileClient && xtermTextarea
                  && !(keyboardOpenTime && Date.now() - keyboardOpenTime < 1200)
                  && document.activeElement !== xtermTextarea) {
                mobileKeyboardOpen = false;
                xtermTextarea.setAttribute('readonly', 'readonly');
                fabKbd.classList.remove('hidden');
              }
