            const _bA0 = term.buffer.active;
            const _data = msg.data || '';
            // Count \n and \r\n in the wire payload, and detect specific markers
            // so we can tell the difference between "desktop sent scrollback that
            // xterm refused to materialize" vs "desktop sent viewport only".
            const _nlCount = (_data.match(/\n/g) || []).length;
            const _crlfCount = (_data.match(/\r\n/g) || []).length;
            const _hasScrollMark = /scrollback line|plain-shell-line/.test(_data) ? 'YES' : 'no';
            dbgLog('INIT pre tid=' + msg.terminalId + ' dataLen=' + _data.length + ' nl=' + _nlCount + ' crlf=' + _crlfCount + ' rows=' + term.rows + ' hasMark=' + _hasScrollMark + ' baseY=' + _bA0.baseY);
            // CRITICAL: exit alt-screen (`\x1b[?1049l`) BEFORE writing the new
            // buffer. Without this, switching from a TUI tab (Claude, vim, etc.
            // which puts xterm in the alt buffer) to a plain shell tab keeps
            // xterm in the alt buffer — which has NO scrollback by xterm.js
            // design — so the 200+ lines of plain-shell scrollback in the wire
            // payload get scrolled past and immediately discarded, leaving only
            // the last `rows` lines visible and zero vertical scroll. If the
            // new buffer is itself a TUI, its data will re-enter alt mode via
            // its own `\x1b[?1049h`, so this exit is a no-op visually.
