    }

    // -- Sidebar: projects --

    function renderProjects() {
      projectsList.innerHTML = '';

      const allProjects = sidebarData.projects || [];
      const sortByTime = (a, b) => {
        const ta = a.lastOpenedAt || a.addedAt || '';
        const tb = b.lastOpenedAt || b.addedAt || '';
        return tb.localeCompare(ta);
      };

      const quickTasks = allProjects.filter(p => p.isQuickTasks);
      const active = allProjects.filter(p => !p.archived && !p.isQuickTasks).sort(sortByTime);
      const archived = allProjects.filter(p => p.archived && !p.isQuickTasks).sort(sortByTime);

      if (active.length === 0 && archived.length === 0 && quickTasks.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'no-projects';
        empty.textContent = 'No projects found';
        projectsList.appendChild(empty);
        return;
      }

      // Pin Quick Tasks to the top, above regular projects
      quickTasks.forEach(p => projectsList.appendChild(createProjectItem(p, false)));
      active.forEach(p => projectsList.appendChild(createProjectItem(p, false)));

      if (archived.length > 0) {
        const header = document.createElement('div');
        header.className = 'later-header' + (laterExpanded ? ' expanded' : '');

        const arrow = document.createElement('span');
        arrow.className = 'later-arrow';
        arrow.textContent = '\u25B8';
        header.appendChild(arrow);

        const label = document.createElement('span');
        label.textContent = 'Later';
        header.appendChild(label);

        const count = document.createElement('span');
        count.className = 'later-count';
        count.textContent = archived.length;
        header.appendChild(count);

        const container = document.createElement('div');
        container.className = 'later-projects' + (laterExpanded ? ' open' : '');
        archived.forEach(p => container.appendChild(createProjectItem(p, true)));

        header.addEventListener('click', () => {
          laterExpanded = !laterExpanded;
          header.classList.toggle('expanded', laterExpanded);
          container.classList.toggle('open', laterExpanded);
        });

        projectsList.appendChild(header);
        projectsList.appendChild(container);
      }
    }

    function createProjectItem(p, isArchived) {
      const wrapper = document.createElement('div');
      wrapper.className = 'project-entry';
      wrapper.dataset.path = p.path;

      const item = document.createElement('div');
      // Project is the active scope only when the phone is on this project AND
      // no subfolder is currently selected for it.
      const isProjectActive = p.path === sidebarData.currentProject && !sidebarData.currentSubfolder;
      item.className = 'project-item' + (isProjectActive ? ' active' : '');
      if (p.isQuickTasks) item.classList.add('quick-tasks');
      item.dataset.path = p.path;

      const icon = document.createElement('span');
      icon.className = 'project-icon';
      icon.textContent = p.isQuickTasks ? '\u26A1' : '\uD83D\uDCC1';
      item.appendChild(icon);

      const name = document.createElement('span');
      name.className = 'project-name';
      if (p.isQuickTasks) {
        name.textContent = p.name || 'Quick Tasks';
        name.title = p.name || 'Quick Tasks';
      } else {
        name.textContent = p.name || p.path.split(/[/\\]/).filter(Boolean).pop() || p.path;
        name.title = p.path;
      }
      item.appendChild(name);

      const counts = p.terminalCounts;
      if (counts && (counts.attention > 0 || counts.busy > 0 || counts.planMode > 0 || counts.idle > 0)) {
        const badges = document.createElement('div');
        badges.className = 'project-badges';

        if (counts.attention > 0) {
          const b = document.createElement('span');
          b.className = 'tbadge attention';
          b.textContent = counts.attention;
          b.title = counts.attention + ' finished';
          badges.appendChild(b);
        }
        if (counts.busy > 0) {
          const b = document.createElement('span');
          b.className = 'tbadge busy';
          b.textContent = counts.busy;
          b.title = counts.busy + ' processing';
          badges.appendChild(b);
        }
        if (counts.planMode > 0) {
          const b = document.createElement('span');
          b.className = 'tbadge plan';
          b.textContent = counts.planMode;
          b.title = counts.planMode + ' plan mode';
          badges.appendChild(b);
        }
        if (counts.idle > 0) {
          const b = document.createElement('span');
          b.className = 'tbadge idle';
          b.textContent = counts.idle;
          b.title = counts.idle + ' idle';
          badges.appendChild(b);
        }

        item.appendChild(badges);
      }

      // Archive/unarchive button — not applicable to the synthetic Quick Tasks entry
      if (!p.isQuickTasks) {
        const archBtn = document.createElement('button');
        archBtn.className = 'project-archive-btn';
        if (isArchived) {
          archBtn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>';
          archBtn.title = 'Move back to projects';
        } else {
          archBtn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>';
          archBtn.title = 'Move to Later';
        }
        archBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (!ws || ws.readyState !== WebSocket.OPEN) return;
          ws.send(JSON.stringify({
            type: 'set_project_archived',
            path: p.path,
            archived: !isArchived,
          }));
          // Optimistic update
          p.archived = !isArchived;
          renderProjects();
          // Also request fresh data from backend
          ws.send(JSON.stringify({ type: 'get_sidebar_data' }));
        });
        item.appendChild(archBtn);
      }

      item.addEventListener('click', () => selectProject(p.path));
      wrapper.appendChild(item);

      // Render subfolders nested under the project. Always shown — the user
      // can tap one to scope the terminal list to that subfolder, or tap the
      // project name to clear back to the project root.
      const subfolders = Array.isArray(p.subfolders) ? p.subfolders : [];
      for (const sf of subfolders) {
        wrapper.appendChild(createSubfolderItem(p.path, sf));
      }

      return wrapper;
    }

    function createSubfolderItem(projectPath, sf) {
      const item = document.createElement('div');
      const isActive = projectPath === sidebarData.currentProject
        && sf.path === sidebarData.currentSubfolder;
      item.className = 'subfolder-item' + (isActive ? ' active' : '');
      item.dataset.path = sf.path;

      const icon = document.createElement('span');
      icon.className = 'subfolder-icon';
      icon.textContent = '⤷'; // arrow into folder
      item.appendChild(icon);

      const name = document.createElement('span');
      name.className = 'subfolder-name';
      name.textContent = sf.name || sf.path.split(/[/\\]/).filter(Boolean).pop() || sf.path;
      name.title = sf.path;
      item.appendChild(name);

      const counts = sf.terminalCounts;
      if (counts && (counts.attention > 0 || counts.busy > 0 || counts.planMode > 0 || counts.idle > 0)) {
        const badges = document.createElement('div');
        badges.className = 'subfolder-badges';
        if (counts.attention > 0) {
          const b = document.createElement('span');
          b.className = 'tbadge attention';
          b.textContent = counts.attention;
          badges.appendChild(b);
        }
        if (counts.busy > 0) {
          const b = document.createElement('span');
          b.className = 'tbadge busy';
          b.textContent = counts.busy;
          badges.appendChild(b);
        }
        if (counts.planMode > 0) {
          const b = document.createElement('span');
          b.className = 'tbadge plan';
          b.textContent = counts.planMode;
          badges.appendChild(b);
        }
        if (counts.idle > 0) {
          const b = document.createElement('span');
          b.className = 'tbadge idle';
          b.textContent = counts.idle;
          badges.appendChild(b);
        }
        item.appendChild(badges);
      }

      item.addEventListener('click', (e) => {
        e.stopPropagation();
        selectSubfolder(projectPath, sf.path);
      });
      return item;
    }

    function selectProject(path) {
      if (!ws || ws.readyState !== WebSocket.OPEN) return;

      sidebarData.currentProject = path;
      sidebarData.currentSubfolder = null; // tapping the project always clears subfolder scope
      renderProjects();
      updateTopbarProject();

      // Queue output during the switch to prevent old terminal's output from
      // bleeding into the new project's terminal view (same pattern as switchTerminal)
      isSwitching = true;
      switchOutputQueue = [];
      resetTerminalView();

      ws.send(JSON.stringify({ type: 'select_project', path }));
      // Pass subfolderPath: null explicitly so the server clears its tracked
      // subfolder context on this client and returns project-root terminals.
      ws.send(JSON.stringify({ type: 'get_terminals', projectPath: path, subfolderPath: null }));

      // Close sidebar on mobile
      closeSidebar();

      // On mobile, don't auto-focus — focusing a readonly textarea prevents
      // the next tap from showing the keyboard (iOS treats re-focus as no-op).
      if (!isMobileClient) {
        term.focus();
      }
      syncTerminalFocus();
    }

    function selectSubfolder(projectPath, subfolderPath) {
      if (!ws || ws.readyState !== WebSocket.OPEN) return;

      sidebarData.currentProject = projectPath;
      sidebarData.currentSubfolder = subfolderPath;
      renderProjects();
      updateTopbarProject();

      isSwitching = true;
      switchOutputQueue = [];
      resetTerminalView();

      ws.send(JSON.stringify({ type: 'select_subfolder', projectPath, subfolderPath }));

      closeSidebar();
      if (!isMobileClient) term.focus();
      syncTerminalFocus();
    }

    function updateTopbarProject() {
      if (!sidebarData.currentProject) {
        topbarProject.textContent = '';
        return;
      }
      // Use friendly name for synthetic projects (e.g. Quick Tasks).
      const match = (sidebarData.projects || []).find(p => p.path === sidebarData.currentProject);
      if (match && match.isQuickTasks) {
        topbarProject.textContent = match.name || 'Quick Tasks';
        return;
      }
      const projectName = match?.name
        || sidebarData.currentProject.split(/[/\\]/).filter(Boolean).pop()
        || '';
      if (sidebarData.currentSubfolder) {
        const sf = (match?.subfolders || []).find(s => s.path === sidebarData.currentSubfolder);
        const sfName = sf?.name
          || sidebarData.currentSubfolder.split(/[/\\]/).filter(Boolean).pop()
          || '';
        topbarProject.textContent = projectName + ' / ' + sfName;
      } else {
        topbarProject.textContent = projectName;
      }
    }

    // -- Tabs --

    function extractTerminalNumber(id) {
      const match = id && id.match(/(\d+)/);
      return match ? match[1] : '?';
    }

    function makeTabEl(t) {
      const stateClass = t.needsAttention ? ' state-attention'
        : t.isProcessing ? ' state-busy'
        : t.isPlanMode ? ' state-plan'
        : '';
      const tab = document.createElement('div');
      tab.className = 'tab' + (t.id === currentTerminalId ? ' active' : '') + stateClass;
      tab.dataset.terminalId = t.id;
      const dot = document.createElement('span');
      dot.className = 'tab-state';
      tab.appendChild(dot);
      const label = document.createElement('span');
      label.textContent = t.name || ('Terminal ' + extractTerminalNumber(t.id));
      tab.appendChild(label);
      const closeBtn = document.createElement('button');
      closeBtn.className = 'tab-close';
      closeBtn.title = 'Close terminal';
      closeBtn.textContent = '×';
      closeBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (ws && ws.readyState === WebSocket.OPEN) {
          ws.send(JSON.stringify({ type: 'close_terminal', terminalId: t.id }));
        }
      });
      tab.appendChild(closeBtn);
      tab.addEventListener('click', () => switchTerminal(t.id));
      return tab;
    }

    function renderTabs() {
      // Incremental update — never wipe innerHTML, only mutate what changed.
      // Full innerHTML = '' forces the browser to re-rasterize the shared
      // tabs+terminal compositing layer, producing a ghost over the canvas.
      const existing = {};
      tabsEl.querySelectorAll('.tab[data-terminal-id]').forEach(el => {
        existing[el.dataset.terminalId] = el;
      });

      // Remove stale tabs
      Object.keys(existing).forEach(id => {
        if (!terminals.find(t => t.id === id)) existing[id].remove();
      });

      // Add or update tabs in order
      let addBtn = tabsEl.querySelector('.tab-add');
      terminals.forEach(t => {
        const stateClass = t.needsAttention ? ' state-attention'
          : t.isProcessing ? ' state-busy'
          : t.isPlanMode ? ' state-plan'
          : '';
        const newClass = 'tab' + (t.id === currentTerminalId ? ' active' : '') + stateClass;
        if (existing[t.id]) {
          existing[t.id].className = newClass;
        } else {
          const tab = makeTabEl(t);
          tabsEl.insertBefore(tab, tabsEl.querySelector('.tab-add-ai') || addBtn || null);
        }
      });

      // Ensure AI + button exists (creates terminal + starts selected LLM) — green, on the left
      if (!tabsEl.querySelector('.tab-add-ai')) {
        const aiBtn = document.createElement('button');
        aiBtn.className = 'tab-add-ai';
        aiBtn.textContent = '+';
        aiBtn.title = 'New AI terminal';
        aiBtn.addEventListener('click', () => {
          if (ws && ws.readyState === WebSocket.OPEN) {
            pendingAIStart = true;
            ws.send(JSON.stringify({ type: 'new_terminal' }));
            showToast('Creating AI terminal...');
          }
        });
        tabsEl.appendChild(aiBtn);
      }

      // Ensure plain + button exists — gray, after AI button
      if (!addBtn) {
        addBtn = document.createElement('button');
        addBtn.className = 'tab-add';
        addBtn.textContent = '+';
        addBtn.title = 'New terminal';
        addBtn.addEventListener('click', () => {
          if (ws && ws.readyState === WebSocket.OPEN) {
            ws.send(JSON.stringify({ type: 'new_terminal' }));
          }
        });
        tabsEl.appendChild(addBtn);
      }

      // Mirror the same terminal list inside the full-screen projects panel
      // (mobile only — desktop keeps the horizontal .tabs-bar above).
      renderSidebarTerminals();
    }

    // Mobile: the horizontal tab bar is hidden, so the selected project's
    // terminals are listed inside the panel. Reuses makeTabEl() so state/colors
    // stay in sync with the desktop tabs — a single source of truth.
    function renderSidebarTerminals() {
      const list = document.getElementById('sidebar-terms-list');
      if (!list) return;
      if (!isMobileResizeMode()) { list.innerHTML = ''; return; }
      list.innerHTML = '';
      if (!terminals.length) {
        const empty = document.createElement('div');
        empty.className = 'no-terms';
        empty.textContent = 'No terminals yet';
        list.appendChild(empty);
        return;
      }
      terminals.forEach(t => {
        const el = makeTabEl(t);
        // Any tap on the row (the × close button stops propagation) switches to
        // the terminal and slides the panel away to reveal it full-screen.
        el.addEventListener('click', closeSidebar);
        list.appendChild(el);
      });
    }

    function highlightTab(id) {
      tabsEl.querySelectorAll('.tab').forEach(tab => {
        tab.classList.toggle('active', tab.dataset.terminalId === id);
      });
      const list = document.getElementById('sidebar-terms-list');
      if (list) list.querySelectorAll('.tab').forEach(tab => {
        tab.classList.toggle('active', tab.dataset.terminalId === id);
      });
    }

    function switchTerminal(id) {
      if (id === currentTerminalId || !ws || ws.readyState !== WebSocket.OPEN) return;
      isSwitching = true;
      switchOutputQueue = [];
      resetTerminalView();
      ws.send(JSON.stringify({ type: 'switch', terminalId: id }));
    }

    // -- Sidebar toggle (mobile) --

    // Force the soft keyboard down. The full-screen projects panel is fixed to
    // the layout viewport (top:40px; bottom:0); while the keyboard is up the
    // visual viewport shrinks, so the bottom of the panel hides behind the
    // keyboard and that part of the scroll region is unreachable. Blurring the
    // xterm textarea + re-locking it (readonly) dismisses the keyboard and lets
    // the project list scroll normally. Mirrors the dismiss path in
    // scrollToBottomIfKeyboard().
    function dismissMobileKeyboard() {
      if (!isMobileClient) return;
      const ta = terminalWrap?.querySelector('.xterm-helper-textarea');
      if (ta) {
        ta.blur();
        ta.setAttribute('readonly', 'readonly');
      }
      if (document.activeElement && document.activeElement.blur) {
        document.activeElement.blur();
      }
      if (mobileKeyboardOpen) {
        mobileKeyboardOpen = false;
        if (fabKbd) fabKbd.classList.remove('hidden');
      }
      keyboardWasUp = false;
      // Re-pin to the full viewport (height back to full, top→0). A direct call
      // (not just style.height='') guarantees restore even when the blur fires no
      // visualViewport event, and keeps height/top managed by one code path.
      requestAnimationFrame(pinAppToVisualViewport);
    }

    // The panel is position:fixed (top:40px; bottom:0), anchored to the LAYOUT
    // viewport — which does not shrink for the soft keyboard on iOS. So even
    // after dismissMobileKeyboard() runs, if the keyboard lingers a frame the
    // bottom of the panel (the Terminals list + actions) sits behind it and you
    // can't pick another terminal. Lift the panel's bottom above the keyboard
    // so its whole content stays reachable. No-op once the keyboard is fully
    // down (gap collapses to ~0).
    function syncSidebarViewport() {
      if (!sidebarEl.classList.contains('open') || !isMobileResizeMode()) {
        sidebarEl.style.bottom = '';
        return;
      }
      const vp = window.visualViewport;
      if (!vp) return;
      const layoutH = window.innerHeight || document.documentElement.clientHeight;
      const kb = Math.max(0, layoutH - vp.height);
      sidebarEl.style.bottom = kb > 120 ? kb + 'px' : '';
    }

    function openSidebar() {
      dismissMobileKeyboard();
      sidebarEl.classList.add('open');
      sidebarOverlay.classList.add('visible');
      // Land at the top of the list, then keep the panel above the keyboard for
      // the few frames iOS takes to animate it away.
      if (projectsList) projectsList.scrollTop = 0;
      syncSidebarViewport();
      requestAnimationFrame(syncSidebarViewport);
    }

    function closeSidebar() {
      sidebarEl.classList.remove('open');
      sidebarOverlay.classList.remove('visible');
      sidebarEl.style.bottom = '';
    }

    function toggleSidebar() {
      if (sidebarEl.classList.contains('open')) {
        closeSidebar();
      } else {
        openSidebar();
      }
    }

    sidebarToggle.addEventListener('click', toggleSidebar);
    // Tapping the terminal name in the topbar is the natural way to switch
    // terminals — wire it to the same panel as the hamburger.
    if (topbarSwitcher) topbarSwitcher.addEventListener('click', toggleSidebar);

    sidebarClose.addEventListener('click', closeSidebar);
    sidebarOverlay.addEventListener('click', closeSidebar);

    // -- Swipe gestures (mobile) --
    // Swipe-right from the left edge opens the full-screen projects panel;
    // swipe-left on the open panel closes it. Anchoring the open-gesture to the
    // left edge keeps it from fighting the terminal's own horizontal pan in
    // compact view (see the terminalWrap touch handlers above).
    (function setupSwipeGestures() {
      const EDGE = 24;       // px from the left edge that arms an open-swipe
      const THRESHOLD = 50;  // min horizontal travel to trigger
      let sx = 0, sy = 0, armedOpen = false, tracking = false;

      document.addEventListener('touchstart', (e) => {
        if (!isMobileResizeMode() || !e.touches[0]) { tracking = false; return; }
        const t = e.touches[0];
        sx = t.clientX; sy = t.clientY;
        tracking = true;
        // Arm an open-gesture only when the panel is closed and the touch began
        // near the left edge; otherwise the gesture can only ever close.
        armedOpen = !sidebarEl.classList.contains('open') && t.clientX <= EDGE;
      }, { passive: true });

      document.addEventListener('touchend', (e) => {
        if (!tracking) return;
        tracking = false;
        if (!isMobileResizeMode()) return;
        const t = (e.changedTouches && e.changedTouches[0]) || null;
        if (!t) return;
        const dx = t.clientX - sx;
        const dy = t.clientY - sy;
        // Ignore taps and mostly-vertical drags (those are scrolls/keyboard taps).
        if (Math.abs(dx) < THRESHOLD || Math.abs(dy) > Math.abs(dx)) return;
        const open = sidebarEl.classList.contains('open');
        if (dx > 0 && armedOpen && !open) openSidebar();
        else if (dx < 0 && open) closeSidebar();
      }, { passive: true });
    })();

    // -- Action buttons --

    function enableActions(enabled) {
      btnStartClaude.disabled = !enabled;
      btnStartGemini.disabled = !enabled;
      btnStartCodex.disabled = !enabled;
      btnNewTerminal.disabled = !enabled;
    }

    // Send AI command to current terminal (same as desktop startAICommand)
    function sendAICommand(command) {
      if (!ws || ws.readyState !== WebSocket.OPEN || !currentTerminalId) return;
      syncTerminalFocus();
      ws.send(JSON.stringify({ type: 'input', terminalId: currentTerminalId, data: command + '\r' }));
    }

    btnStartClaude.addEventListener('click', () => {
      localStorage.setItem('patapim-remote-last-ai', 'claude');
      sendAICommand('claude --dangerously-skip-permissions');
    });

    btnStartGemini.addEventListener('click', () => {
      localStorage.setItem('patapim-remote-last-ai', 'gemini');
      sendAICommand('gemini --yolo');
    });

    btnStartCodex.addEventListener('click', () => {
      localStorage.setItem('patapim-remote-last-ai', 'codex');
      sendAICommand('codex --dangerously-bypass-approvals-and-sandbox');
    });

    btnNewTerminal.addEventListener('click', () => {
      if (!ws || ws.readyState !== WebSocket.OPEN) return;
      ws.send(JSON.stringify({ type: 'new_terminal' }));
    });

    // -- Settings gear dropdown + font size controls --

    const settingsToggle = document.getElementById('settings-toggle');
    const settingsDropdown = document.getElementById('settings-dropdown');
    const settingsFontValue = document.getElementById('settings-font-value');

    function closeSettings() { settingsDropdown.classList.remove('visible'); }

    function updateFontDisplay() { settingsFontValue.textContent = fontSize; }

    settingsToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      settingsDropdown.classList.toggle('visible');
    });

    settingsDropdown.addEventListener('click', (e) => e.stopPropagation());
    document.addEventListener('click', closeSettings);

    // Cross-link to the full desktop UI. Carry the current device so /remotedesk
    // reconnects to the same machine (it mints a fresh connect token there).
    const switchToDesktop = document.getElementById('switch-to-desktop');
    if (switchToDesktop) {
      switchToDesktop.addEventListener('click', (e) => {
        e.preventDefault();
        const dev = activeDeviceToken || params.get('d');
        window.location.href = '/remotedesk' + (dev ? '?d=' + encodeURIComponent(dev) : '');
      });
    }

    document.getElementById('settings-font-dec').addEventListener('click', () => {
      fontSize = Math.max(8, fontSize - 1);
      fontManuallySet = true;
      term.options.fontSize = fontSize;
      updateFontDisplay();
      applyPtyDims({ forceRefresh: true });
    });

    document.getElementById('settings-font-inc').addEventListener('click', () => {
      fontSize = Math.min(28, fontSize + 1);
      fontManuallySet = true;
      term.options.fontSize = fontSize;
      updateFontDisplay();
      applyPtyDims({ forceRefresh: true });
    });

    // Zoom buttons in keys bar
    document.getElementById('key-zoom-out').addEventListener('click', () => {
      fontSize = Math.max(8, fontSize - 1);
      fontManuallySet = true;
      term.options.fontSize = fontSize;
      updateFontDisplay();
      applyPtyDims({ forceRefresh: true });
    });
    document.getElementById('key-zoom-in').addEventListener('click', () => {
      fontSize = Math.min(28, fontSize + 1);
      fontManuallySet = true;
      term.options.fontSize = fontSize;
      updateFontDisplay();
      applyPtyDims({ forceRefresh: true });
    });

    // Status pill → dropdown toggle (only when connected)
    function closeStatusDropdown() {
      statusDropdown.classList.remove('visible');
    }
    statusEl.addEventListener('click', (e) => {
      e.stopPropagation();
      if (!statusEl.classList.contains('connected')) return;
      const willOpen = !statusDropdown.classList.contains('visible');
      statusDropdown.classList.toggle('visible');
      // Refresh the device list each time the dropdown opens so online/offline
      // status stays current without the user having to reload the page.
      if (willOpen) loadDeviceList(true);
    });
    // Don't let clicks inside the dropdown bubble up to the document handler
    // (which would close the dropdown immediately).
    statusDropdown.addEventListener('click', (e) => e.stopPropagation());
    document.addEventListener('click', closeStatusDropdown);

    // Disconnect (inside status dropdown)
    document.getElementById('btn-disconnect').addEventListener('click', () => {
      closeStatusDropdown();
      sendTerminalFocus(false);
      isAuthenticated = false;
      if (reconnectTimer) clearTimeout(reconnectTimer);
      if (ws) ws.close();
      location.href = '/go';
    });

    // Scroll to bottom + left
    scrollBottomBtn.addEventListener('click', () => {
      term.scrollToBottom();
      terminalWrap.scrollLeft = 0;
      setHOffset(0);
      scrollBottomBtn.classList.remove('visible');
    });

    // Special keys bar
    document.querySelectorAll('.key-btn[data-modifier]').forEach(btn => {
      btn.addEventListener('click', () => {
        const mod = btn.dataset.modifier;
        modifiers[mod] = !modifiers[mod];
        updateModifierButtons();
        term.focus();
        syncTerminalFocus();
      });
    });

    document.querySelectorAll('.key-btn[data-key]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!ws || ws.readyState !== WebSocket.OPEN) return;
        const key = btn.dataset.key;
        const keyMap = {
          Tab: '\t',
          Escape: '\x1b',
          ArrowUp: '\x1b[A',
          ArrowDown: '\x1b[B',
          ArrowRight: '\x1b[C',
          ArrowLeft: '\x1b[D',
          Enter: '\r',
        };
        const data = keyMap[key] || '';
        if (data) {
          ws.send(JSON.stringify({
            type: 'input',
            terminalId: currentTerminalId,
            data,
          }));
        }
        term.focus();
        syncTerminalFocus();
      });
    });

    document.querySelectorAll('.key-btn[data-seq]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!ws || ws.readyState !== WebSocket.OPEN) return;
        ws.send(JSON.stringify({
          type: 'input',
          terminalId: currentTerminalId,
          data: btn.dataset.seq,
        }));
        term.focus();
        syncTerminalFocus();
      });
    });

    // ⇧Tab — smart Plan Mode toggle with state detection
    keyShiftTab.addEventListener('click', () => {
      if (!isAuthenticated) return;
      togglePlanMode();
    });

    function updateModifierButtons() {
      document.querySelectorAll('.key-btn[data-modifier]').forEach(btn => {
        const mod = btn.dataset.modifier;
        btn.classList.toggle('active', modifiers[mod]);
      });
    }

    window.addEventListener('focus', () => {
      syncTerminalFocus();
    });

    // Mobile browsers can emit transient blur events while still visible/active.
    // We only release focus on visibilitychange (hidden) to avoid losing control.

    document.addEventListener('visibilitychange', () => {
      if (document.hidden || document.visibilityState !== 'visible') {
        sendTerminalFocus(false);
      } else {
        syncTerminalFocus();
        // Re-apply PTY dims so mobile gets correct cols (not a raw fitAddon.fit
        // which would reset to narrow mobile cols while PTY uses desktop cols).
        // forceRefresh repaints the canvas to clear stale ghost layers.
        if (term) {
          requestAnimationFrame(() => {
            applyPtyDims({ forceRefresh: true });
          });
        }
      }
    });

    // iOS bfcache: page restored from freeze — show loading overlay immediately
    // so the stale canvas is hidden until the WS reconnect completes.
    window.addEventListener('pageshow', (e) => {
      if (e.persisted) {
        loadingEl.classList.remove('hidden');
        // Re-apply PTY dims so terminal is correct when overlay clears
        if (term) {
          applyPtyDims({ forceRefresh: true });
        }
      }
    });

    // ── FAB: toggle menu ────────────────────────────────────────────
    function closeFab() {
      fabOpen = false;
      fabMenu.classList.remove('visible');
      fabTrigger.classList.remove('open');
    }

    fabTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      fabOpen = !fabOpen;
      fabMenu.classList.toggle('visible', fabOpen);
      fabTrigger.classList.toggle('open', fabOpen);
    });

    document.addEventListener('click', () => { if (fabOpen) closeFab(); });
    fabMenu.addEventListener('click', (e) => e.stopPropagation());

    // ── Toast helper ──────────────────────────────────────────────
    let toastTimer = null;
    function showToast(message, duration = 2000) {
      clearTimeout(toastTimer);
      fabToast.textContent = message;
      fabToast.classList.add('visible');
      toastTimer = setTimeout(() => fabToast.classList.remove('visible'), duration);
    }

    // ── FAB: Toggle Plan Mode (Shift+Tab with state detection) ───
    fabPlanMode.addEventListener('click', () => {
      closeFab();
      if (!ws || ws.readyState !== WebSocket.OPEN || !isAuthenticated || !currentTerminalId) {
        showToast('Not connected');
        return;
      }
      togglePlanMode();
    });

    // ── FAB: Toggle Compact View ────────────────────────────────────
    fabCompact.addEventListener('click', () => {
      closeFab();
      isCompactView = !isCompactView;
      fabCompact.classList.toggle('compact-active', isCompactView);
      const label = fabCompact.querySelector('span');
      if (label) label.textContent = isCompactView ? 'Full View' : 'Compact View';
      applyPtyDims({ syncServer: false, forceRefresh: true });
      if (term) {
        term.scrollToBottom();
        term.focus();
      }
    });

    // ── FAB: Start Claude (dangerously skip permissions) ──────────
    fabSkipPerms.addEventListener('click', () => {
      closeFab();
      if (!ws || ws.readyState !== WebSocket.OPEN || !currentTerminalId) {
        showToast('Not connected');
        return;
      }
      sendAICommand('claude --dangerously-skip-permissions');
    });

    // Base64-encode an image blob and stream it over the file_upload channel.
    // The server writes it into the terminal's CWD and types the path in, so
    // CLI tools (Claude Code, Codex) read the image from the remote disk.
    function sendImageBlob(blob, fileName) {
      if (blob.size > 10 * 1024 * 1024) {
        showToast('Image too large (max 10 MB)');
        return;
      }
      const reader = new FileReader();
      reader.onload = () => {
        const base64 = reader.result.split(',')[1];
        ws.send(JSON.stringify({
          type: 'file_upload',
          terminalId: currentTerminalId,
          fileName,
          mimeType: blob.type || 'image/png',
          size: blob.size,
          data: base64,
        }));
        showToast('Sent: ' + fileName);
        term.focus();
        syncTerminalFocus();
      };
      reader.onerror = () => showToast('Failed to read image');
      reader.readAsDataURL(blob);
    }

    // ── FAB: Paste from clipboard (text or image) ─────────────────
    fabPaste.addEventListener('click', async () => {
      closeFab();
      if (!ws || ws.readyState !== WebSocket.OPEN || !isAuthenticated || !currentTerminalId) {
        showToast('Not connected');
        return;
      }
      try {
        let text = null;
        // clipboard.read() sees image items (copied screenshots, photos) that
        // readText() can't. Grab the text from the same call when there's no
        // image — a second clipboard call can lose Safari's user activation.
        if (navigator.clipboard.read) {
          try {
            const items = await navigator.clipboard.read();
            for (const item of items) {
              const imgType = item.types.find((t) => t.startsWith('image/'));
              if (imgType) {
                const blob = await item.getType(imgType);
                const ext = imgType === 'image/jpeg' ? 'jpg' : (imgType.split('/')[1] || 'png');
                sendImageBlob(blob, 'clipboard-' + Date.now() + '.' + ext);
                return;
              }
              if (!text && item.types.includes('text/plain')) {
                text = await (await item.getType('text/plain')).text();
              }
            }
          } catch (_) { /* permission/format quirk — fall through to readText */ }
        }
        if (!text) text = await navigator.clipboard.readText();
        if (!text) { showToast('Clipboard is empty'); return; }
        // Bracketed paste mode prevents auto-execution of multi-line pastes
        const data = '\x1b[200~' + text + '\x1b[201~';
        ws.send(JSON.stringify({ type: 'input', terminalId: currentTerminalId, data }));
        showToast('Pasted ' + text.length + ' chars');
      } catch (err) {
        showToast('Clipboard access denied');
        console.warn('[FAB] Clipboard read failed:', err);
      }
      term.focus();
      syncTerminalFocus();
    });

    // ── FAB: Insert image ─────────────────────────────────────────
    fabImage.addEventListener('click', () => {
      closeFab();
      if (!ws || ws.readyState !== WebSocket.OPEN || !isAuthenticated || !currentTerminalId) {
        showToast('Not connected');
        return;
      }
      imagePicker.click();
    });

    imagePicker.addEventListener('change', () => {
      const file = imagePicker.files[0];
      if (!file) return;
      sendImageBlob(file, file.name);
      imagePicker.value = '';
    });

    // Native paste (Cmd/Ctrl+V on a desktop browser, iOS "Paste" callout):
    // when the clipboard carries an image, upload it instead of letting the
    // browser drop it — the terminal can't accept raw image data.
    document.addEventListener('paste', (e) => {
      if (!ws || ws.readyState !== WebSocket.OPEN || !isAuthenticated || !currentTerminalId) return;
      const items = e.clipboardData && e.clipboardData.items;
      if (!items) return;
      for (const item of items) {
        if (item.kind === 'file' && item.type.startsWith('image/')) {
          e.preventDefault();
          const blob = item.getAsFile();
          if (blob) sendImageBlob(blob, blob.name || ('clipboard-' + Date.now() + '.png'));
          return;
        }
      }
    });

    // ── Voice dictation (MediaRecorder → local transcription) ─────────────────

    function pickMimeType() {
      const types = [
        'audio/webm;codecs=opus',
        'audio/webm',
        'audio/mp4',
        'audio/ogg;codecs=opus',
        'audio/ogg',
      ];
      for (const t of types) {
        if (typeof MediaRecorder !== 'undefined' && MediaRecorder.isTypeSupported(t)) return t;
      }
      return ''; // let browser pick default
    }

    async function startRecording() {
      if (typeof MediaRecorder === 'undefined') {
        showToast('Your browser does not support audio recording');
        return;
      }
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        const mimeType = pickMimeType();
        audioChunks = [];
        mediaRecorder = new MediaRecorder(stream, mimeType ? { mimeType } : undefined);
        mediaRecorder.ondataavailable = (e) => {
          if (e.data.size > 0) audioChunks.push(e.data);
        };
        const recorderMimeType = mediaRecorder.mimeType || mimeType || 'audio/webm';
        mediaRecorder.onstop = async () => {
          // Release mic
          stream.getTracks().forEach(t => t.stop());
          if (audioChunks.length === 0) {
            showToast('No audio recorded');
            return;
          }
          const blob = new Blob(audioChunks, { type: recorderMimeType });
          if (blob.size > 20 * 1024 * 1024) {
            showToast('Recording too long (max 5 min)');
            return;
          }
          // Convert audio to 16kHz mono Float32 PCM using Web Audio API (no ffmpeg needed server-side)
          try {
            const arrayBuffer = await blob.arrayBuffer();
            const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            let float32Data;
            try {
              const decoded = await audioCtx.decodeAudioData(arrayBuffer);
              const offlineCtx = new OfflineAudioContext(1, Math.ceil(decoded.duration * 16000), 16000);
              const source = offlineCtx.createBufferSource();
              source.buffer = decoded;
              source.connect(offlineCtx.destination);
              source.start(0);
              const resampled = await offlineCtx.startRendering();
              float32Data = resampled.getChannelData(0);
            } finally {
              audioCtx.close();
            }

            // Convert Float32Array to base64 for JSON transport
            const uint8 = new Uint8Array(float32Data.buffer, float32Data.byteOffset, float32Data.byteLength);
            let binary = '';
            for (let i = 0; i < uint8.length; i++) binary += String.fromCharCode(uint8[i]);
            const base64Pcm = btoa(binary);

            if (ws && ws.readyState === WebSocket.OPEN && currentTerminalId) {
              ws.send(JSON.stringify({
                type: 'voice_audio',
                terminalId: currentTerminalId,
                data: base64Pcm,
                format: 'float32_16k',
                samples: float32Data.length,
              }));
              // Show preview with placeholder
              voiceText.value = '';
              voiceText.placeholder = 'Transcribing...';
              showVoicePreview();
              // Timeout for transcription (120s — 5-min recordings produce larger audio)
              if (transcriptionTimeout) clearTimeout(transcriptionTimeout);
              transcriptionTimeout = setTimeout(() => {
                if (voiceText.placeholder === 'Transcribing...') {
                  voiceText.placeholder = 'Speak now...';
                  hideVoicePreview();
                  showToast('Transcription timed out');
                }
              }, 120000);
            } else {
              showToast('No active connection');
            }
          } catch (err) {
            console.error('Audio conversion failed:', err);
            showToast('Failed to convert audio');
          }
        };
        mediaRecorder.start();
        isRecording = true;
        if (keyMic) keyMic.classList.add('recording');
        fabMic.classList.add('recording');
        // Auto-stop after 5 minutes
        recordingTimeout = setTimeout(() => {
          if (isRecording) stopRecording();
        }, 300000);
      } catch (e) {
        if (e.name === 'NotAllowedError') showToast('Microphone permission denied');
        else showToast('Failed to start microphone');
      }
    }

    function stopRecording() {
      isRecording = false;
      if (keyMic) keyMic.classList.remove('recording');
      fabMic.classList.remove('recording');
      if (recordingTimeout) { clearTimeout(recordingTimeout); recordingTimeout = null; }
      if (mediaRecorder && mediaRecorder.state !== 'inactive') {
        try { mediaRecorder.stop(); } catch (_) {}
      }
      mediaRecorder = null;
    }

    function showVoicePreview() {
      voicePreview.classList.add('visible');
      voiceText.focus();
    }

    function hideVoicePreview() {
      voicePreview.classList.remove('visible');
      voiceText.value = '';
      voiceText.placeholder = 'Speak now...';
    }

    // Mic button: toggle recording (both keys-bar and floating)
    function toggleRecording() {
      if (!isAuthenticated) return;
      if (isRecording) stopRecording();
      else startRecording();
    }
    if (keyMic) keyMic.addEventListener('click', toggleRecording);
    fabMic.addEventListener('click', toggleRecording);

    // Toggle native keyboard on mobile
    function openMobileKeyboard() {
      if (!isMobileClient) return;
      mobileKeyboardOpen = true;
      keyboardOpenTime = Date.now();
      fabKbd.classList.add('hidden');
      const ta = terminalWrap.querySelector('.xterm-helper-textarea');
      if (ta) {
        ta.blur();
        ta.removeAttribute('readonly');
        void ta.offsetHeight;
        ta.focus();
      }
      syncTerminalFocus();
    }
    fabKbd.addEventListener('click', openMobileKeyboard);
    document.getElementById('key-kbd').addEventListener('click', openMobileKeyboard);

    // Send: write transcribed text to terminal — user decides Enter
    voiceSend.addEventListener('click', () => {
      const text = voiceText.value.trim();
      if (text && ws && ws.readyState === WebSocket.OPEN && currentTerminalId) {
        ws.send(JSON.stringify({ type: 'input', terminalId: currentTerminalId, data: text }));
      }
      hideVoicePreview();
      term.focus();
      syncTerminalFocus();
    });

    // Cancel: discard
    voiceCancel.addEventListener('click', () => {
      if (isRecording) stopRecording();
      hideVoicePreview();
    });

    // ── Text selection mode ───────────────────────────────────────
    keySelect.addEventListener('click', () => {
      selectMode = !selectMode;
      keySelect.classList.toggle('active', selectMode);
      if (selectMode) enterSelectionMode();
      else exitSelectionMode();
    });

    // ── Telegram notifications toggle ──────────────────────────────
    const keyTelegram = document.getElementById('key-telegram');
    if (keyTelegram) {
      // Restore last choice (default: on)
      let telegramOn = localStorage.getItem('patapim_telegram_notifs') !== '0';
      const renderTelegram = () => keyTelegram.classList.toggle('tg-active', telegramOn);
      renderTelegram();
      keyTelegram.addEventListener('click', () => {
        telegramOn = !telegramOn;
        localStorage.setItem('patapim_telegram_notifs', telegramOn ? '1' : '0');
        renderTelegram();
        if (ws && ws.readyState === WebSocket.OPEN) {
          ws.send(JSON.stringify({ type: 'set_telegram_notifications', enabled: telegramOn }));
        }
        showToast(telegramOn ? 'Telegram notifications on' : 'Telegram notifications off');
      });
    }

    function enterSelectionMode() {
      if (selectionOverlay) return;
      const buffer = term.buffer.active;
      let text = '';
      for (let i = 0; i < buffer.length; i++) {
        const line = buffer.getLine(i);
        if (line) text += line.translateToString(true) + '\n';
      }
      selectionOverlay = document.createElement('div');
      selectionOverlay.className = 'selection-overlay';
      selectionOverlay.textContent = text;
      selectionOverlay.style.fontSize = fontSize + 'px';
      terminalWrap.appendChild(selectionOverlay);
      // Scroll to bottom to match terminal viewport
      selectionOverlay.scrollTop = selectionOverlay.scrollHeight;
      keySelect.textContent = 'Done';
    }

    function exitSelectionMode() {
      const selection = window.getSelection();
      if (selection && selection.toString().trim()) {
        navigator.clipboard.writeText(selection.toString()).then(() => {
          showToast('Copied to clipboard');
        }).catch(() => {});
      }
      if (selectionOverlay) {
        selectionOverlay.remove();
        selectionOverlay = null;
      }
      keySelect.textContent = 'Select';
      keySelect.classList.remove('active');
      selectMode = false;
      term.focus();
      syncTerminalFocus();
    }

    // Keepalive ping
    setInterval(() => {
      if (ws && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify({ type: 'ping' }));
      }
    }, 30000);
  </script>
</body>
</html>
