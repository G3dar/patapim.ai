            // preserve `?debug` so the diagnostic overlay survives the post-auth
            // URL scrub (otherwise turning on ?debug only buys you ~1 second of
            // visibility before the param is wiped).
            history.replaceState(null, '', '/remote-mobile' + (isDebugMode ? '?debug' : ''));

            // Preload the device list so the switcher is ready the first
            // time the user opens the status dropdown.
            loadDeviceList();

            // Don't render tabs from auth_result — wait for sidebar_data + get_terminals
            // Request sidebar data first, which will trigger get_terminals with correct project
            ws.send(JSON.stringify({ type: 'get_sidebar_data' }));

            term.focus();
            syncTerminalFocus();
            // Re-apply dims after reconnect so terminal cols match PTY
            if (term && ptyDims) {
              applyPtyDims({ forceRefresh: true });
            }
          } else {
