---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import SessionBar from '../components/SessionBar.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, t } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);

// terminal-aesthetic tier features (mirrors the v2 home lineup)
const FREE_FEATURES = [
  'Full computer control',
  'Unlimited projects',
  'Up to 3 terminals',
  'A long 30 min dictation buffer',
  'Full remote access',
  'Task management',
];
const PRO_FEATURES = [
  'Unlimited terminals',
  'Unlimited dictation',
  'Everything in Free',
  'Priority support',
];
const LIFETIME_FEATURES = [
  'Everything in Pro',
  'Pay once, own forever',
  'All future updates',
  'No subscriptions',
];
---

<BaseLayout title={t(locale, 'meta.downloadTitle')} description={t(locale, 'meta.downloadDescription')}>
  <Navbar />
  <SessionBar />

  <main class="download-page">
    <div class="dlp-main">

      <!-- Header -->
      <div class="dlp-head">
        <div class="tv-label"><span class="tv-label-prompt">$</span> patapim install <span class="tv-dim">— {t(locale, 'download.subtitle').toLowerCase()}</span></div>
        <h1 class="tv-heading dlp-title">{t(locale, 'download.title')}</h1>
        <p class="tv-heading-sub">windows 10+ · macos 12+</p>
      </div>

      <!-- Platform cards grid -->
      <div class="dl-grid">

        <!-- Windows -->
        <div class="dl-card tv-panel">
          <div class="dl-card-top">
            <div class="dl-icon">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
                <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>
              </svg>
            </div>
            <h2>{t(locale, 'download.windows')}</h2>
            <p class="dl-version">{t(locale, 'download.windowsNote')}</p>
            <a href="/api/download/latest" class="tv-pbtn tv-pbtn-accent dl-btn">
              $ {t(locale, 'download.downloadInstaller').toLowerCase()}
            </a>
          </div>
          <div class="dl-install-cmds">
            <div class="dl-cmd-block">
              <span class="dl-cmd-label">PowerShell</span>
              <div class="dl-cmd-line" data-dl-copy="irm https://raw.githubusercontent.com/G3dar/patapim-releases/main/install.ps1 | iex">
                <span class="dl-tooltip">Click to copy</span>
                <span class="tvi-prompt">PS&gt;</span>
                <code>irm https://raw.githubusercontent.com/G3dar/patapim-releases/main/install.ps1 | iex</code>
                <span class="dl-copy-btn" aria-label="Copy">⧉</span>
              </div>
            </div>
            <div class="dl-cmd-block">
              <span class="dl-cmd-label">CMD</span>
              <div class="dl-cmd-line" data-dl-copy='curl -fsSL https://raw.githubusercontent.com/G3dar/patapim-releases/main/install.cmd -o "%TEMP%\patapim-install.cmd" && "%TEMP%\patapim-install.cmd"'>
                <span class="dl-tooltip">Click to copy</span>
                <span class="tvi-prompt">C:\&gt;</span>
                <code>curl -fsSL https://raw.githubusercontent.com/G3dar/patapim-releases/main/install.cmd -o "%TEMP%\patapim-install.cmd" &amp;&amp; "%TEMP%\patapim-install.cmd"</code>
                <span class="dl-copy-btn" aria-label="Copy">⧉</span>
              </div>
            </div>
          </div>
        </div>

        <!-- macOS -->
        <div class="dl-card tv-panel">
          <div class="dl-card-top">
            <div class="dl-icon">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
            </div>
            <h2>{t(locale, 'download.macos')}</h2>
            <p class="dl-version" set:html={t(locale, 'download.macosNote')} />
            <div class="dl-mac-buttons">
              <a href="/api/download/latest-mac-arm64" class="tv-pbtn tv-pbtn-accent dl-btn">
                $ {t(locale, 'download.downloadAppleSilicon').toLowerCase()}
              </a>
              <a href="/api/download/latest-mac-x64" class="tv-pbtn dl-btn dl-btn-alt">
                $ {t(locale, 'download.downloadIntel').toLowerCase()}
              </a>
            </div>
          </div>
          <div class="dl-install-cmds">
            <div class="dl-cmd-block">
              <span class="dl-cmd-label">Terminal</span>
              <div class="dl-cmd-line" data-dl-copy="curl -fsSL https://raw.githubusercontent.com/G3dar/patapim-releases/main/install-mac.sh | bash">
                <span class="dl-tooltip">Click to copy</span>
                <span class="tvi-prompt">$</span>
                <code>curl -fsSL https://raw.githubusercontent.com/G3dar/patapim-releases/main/install-mac.sh | bash</code>
                <span class="dl-copy-btn" aria-label="Copy">⧉</span>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Plans -->
      <div class="upgrade-section">
        <div class="tv-label"><span class="tv-label-prompt">$</span> patapim upgrade <span class="tv-dim">— choose your plan</span></div>
        <div class="tv-price-grid upgrade-cards">

          <div class="tv-pcard tv-pcard-hero">
            <div class="tv-pcard-tag">INCLUDES ALL FEATURES</div>
            <div class="tv-pcard-head">
              <span class="tv-pcard-name">{t(locale, 'pricing.freeTitle')}</span>
              <span class="tv-pcard-sub">{t(locale, 'pricing.freeDesc')}</span>
            </div>
            <div class="tv-pcard-pricebox">
              <span class="tv-pcard-amount tv-grad">{t(locale, 'pricing.freePrice')}</span>
              <span class="tv-pcard-period">{t(locale, 'pricing.freePeriod')}</span>
            </div>
            <ul>
              {FREE_FEATURES.map((f) => <li><span class="tv-check">✓</span> {f}</li>)}
            </ul>
            <span class="plan-tag-free">✓ included with download</span>
          </div>

          <div class="tv-pcard plan-hoverable">
            <span class="plan-trace" aria-hidden="true"></span>
            <div class="plan-hover-tag">CANCEL ANYTIME</div>
            <div class="tv-pcard-head">
              <span class="tv-pcard-name">{t(locale, 'pricing.proTitle')}</span>
              <span class="tv-pcard-sub">{t(locale, 'pricing.proDesc')}</span>
            </div>
            <div class="tv-pcard-pricebox">
              <span class="tv-pcard-amount">{t(locale, 'pricing.proPrice')}</span>
              <span class="tv-pcard-period">{t(locale, 'pricing.proPeriod')}</span>
            </div>
            <ul>
              {PRO_FEATURES.map((f) => <li><span class="tv-check">✓</span> {f}</li>)}
            </ul>
            <a href="#" class="tv-pbtn" id="checkout-monthly">$ {t(locale, 'common.goPro').toLowerCase()}</a>
          </div>

          <div class="tv-pcard plan-hoverable">
            <span class="plan-trace" aria-hidden="true"></span>
            <div class="plan-hover-tag">PERMANENT ACCESS</div>
            <div class="tv-pcard-head">
              <span class="tv-pcard-name">Lifetime</span>
              <span class="tv-pcard-sub">one payment. done.</span>
            </div>
            <div class="tv-pcard-pricebox">
              <span class="tv-pcard-amount">{t(locale, 'pricing.unlockPrice')}</span>
              <span class="tv-pcard-period">{t(locale, 'pricing.unlockNote')}</span>
            </div>
            <ul>
              {LIFETIME_FEATURES.map((f) => <li><span class="tv-check">✓</span> {f}</li>)}
            </ul>
            <a href="#" class="tv-pbtn" id="checkout-lifetime">$ {t(locale, 'pricing.unlockButton').toLowerCase()}</a>
          </div>

        </div>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .download-page {
    min-height: 100vh;
    font-family: var(--font-mono);
    background: var(--bg-deep);
  }

  .dlp-main {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px 72px;
  }

  .dlp-head {
    padding-top: 120px;
    margin-bottom: 44px;
  }

  .dlp-title {
    margin-top: 26px;
    font-size: clamp(17px, 2.4vw, 22px);
    text-transform: uppercase;
  }

  .dl-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 24px;
  }

  .dl-card {
    display: flex;
    flex-direction: column;
  }

  .dl-card-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 26px;
  }

  .dl-card h2 {
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0 0 4px;
  }

  .dl-icon {
    color: var(--text-primary);
    margin-bottom: 16px;
  }
  .dl-card:hover .dl-icon {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .dl-version {
    font-size: 12px;
    color: var(--text-tertiary);
    margin: 0 0 22px;
  }

  .dl-btn {
    max-width: 320px;
    width: 100%;
  }

  .dl-mac-buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
    width: 100%;
  }

  .dl-btn-alt {
    font-size: 12px;
    padding: 9px 12px;
  }

  /* Install commands — .tvi-panel look, page-local hooks for the copy JS */
  .dl-install-cmds {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-align: left;
    position: relative;
    z-index: 1;
  }
  .dl-cmd-block {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .dl-cmd-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
  .dl-cmd-line {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: 0;
    padding: 11px 14px;
    font-size: 12px;
    cursor: pointer;
    position: relative;
    transition: border-color 0.2s;
  }
  .dl-cmd-line:hover {
    border-color: var(--border-strong);
  }
  .dl-cmd-line:hover .dl-copy-btn {
    color: var(--text-primary);
  }
  .dl-cmd-line.copied {
    border-color: var(--cy);
  }
  .dl-cmd-line .dl-tooltip {
    position: absolute;
    top: -30px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    color: var(--text-secondary);
    font-size: 11px;
    font-family: var(--font-mono);
    padding: 3px 10px;
    border-radius: 0;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .dl-cmd-line:hover .dl-tooltip {
    opacity: 1;
  }
  .dl-cmd-line.copied .dl-tooltip {
    border-color: var(--cy);
    color: var(--cy);
  }
  .dl-cmd-line code {
    flex: 1;
    font-size: 12px;
    background: none;
    padding: 0;
    color: var(--text-secondary);
    word-break: break-all;
    line-height: 1.5;
  }
  .dl-copy-btn {
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 2px;
    transition: color 0.2s;
  }
  .dl-copy-btn.copied {
    color: var(--cy);
  }

  /* Upgrade section */
  .upgrade-section {
    max-width: 980px;
    margin: 88px auto 0;
  }

  .upgrade-cards {
    margin-top: 30px;
  }

  .plan-tag-free {
    display: block;
    text-align: center;
    padding: 12px;
    font-size: 13px;
    font-weight: 600;
    color: var(--cy);
    border: 1px solid rgba(34, 211, 238, 0.35);
    background: rgba(34, 211, 238, 0.06);
  }

  /* Pro / Lifetime hover: a cyan box traces itself clockwise around the
     card, then the plan promise tag pops in at the top edge */
  .plan-trace {
    position: absolute;
    inset: -1px;
    pointer-events: none;
    z-index: 2;
  }
  .plan-trace::before,
  .plan-trace::after {
    content: '';
    position: absolute;
    width: 0;
    height: 0;
    opacity: 0;
    box-sizing: border-box;
    /* un-hover: fade out, then collapse instantly */
    transition: opacity 0.12s, width 0s 0.12s, height 0s 0.12s;
  }
  .plan-trace::before {
    top: 0;
    left: 0;
    border-top: 1px solid var(--cy);
    border-right: 1px solid var(--cy);
  }
  .plan-trace::after {
    bottom: 0;
    right: 0;
    border-bottom: 1px solid var(--cy);
    border-left: 1px solid var(--cy);
  }
  .plan-hoverable:hover .plan-trace::before {
    width: 100%;
    height: 100%;
    opacity: 1;
    transition: opacity 0s, width 0.14s ease-out, height 0.14s ease-out 0.14s;
  }
  .plan-hoverable:hover .plan-trace::after {
    width: 100%;
    height: 100%;
    opacity: 1;
    transition: opacity 0s 0.28s, width 0.14s ease-out 0.28s, height 0.14s ease-out 0.42s;
  }
  .plan-hover-tag {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%) translateY(5px);
    padding: 3px 12px;
    font-size: 10px;
    letter-spacing: 0.2em;
    font-weight: 700;
    color: var(--cy);
    background: #000;
    border: 1px solid var(--cy);
    opacity: 0;
    z-index: 3;
    pointer-events: none;
    white-space: nowrap;
    transition: opacity 0.12s, transform 0.12s;
  }
  .plan-hoverable:hover .plan-hover-tag {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    transition: opacity 0.16s 0.5s, transform 0.16s 0.5s;
  }

  @media (max-width: 900px) {
    .upgrade-cards {
      grid-template-columns: 1fr;
      max-width: 440px;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 768px) {
    .dl-grid { grid-template-columns: 1fr; }
    .upgrade-section { margin-top: 64px; }
  }
</style>

<script>
  // Checkout
  async function handleCheckout(plan: 'pro' | 'lifetime') {
    const btn = document.getElementById(plan === 'pro' ? 'checkout-monthly' : 'checkout-lifetime');
    if (btn) btn.setAttribute('disabled', '');
    try {
      let email: string | undefined;
      try {
        const sessionRes = await fetch('/api/auth/session');
        if (sessionRes.ok) {
          const sessionData = await sessionRes.json();
          if (sessionData.authenticated) email = sessionData.user.email;
        }
      } catch {}

      const res = await fetch('/api/stripe/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plan, email }),
      });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        console.error('Checkout error:', data.error);
        if (btn) btn.removeAttribute('disabled');
      }
    } catch (err) {
      console.error('Checkout error:', err);
      if (btn) btn.removeAttribute('disabled');
    }
  }

  document.getElementById('checkout-monthly')?.addEventListener('click', (e) => {
    e.preventDefault();
    handleCheckout('pro');
  });

  document.getElementById('checkout-lifetime')?.addEventListener('click', (e) => {
    e.preventDefault();
    handleCheckout('lifetime');
  });

  // Copy command - clicking anywhere on the line
  document.querySelectorAll<HTMLElement>('[data-dl-copy]').forEach(line => {
    line.addEventListener('click', () => {
      const text = line.dataset.dlCopy;
      if (!text) return;
      navigator.clipboard.writeText(text).then(() => {
        const tooltip = line.querySelector('.dl-tooltip');
        const icon = line.querySelector('.dl-copy-btn');
        line.classList.add('copied');
        if (tooltip) tooltip.textContent = 'Copied!';
        if (icon) icon.classList.add('copied');
        setTimeout(() => {
          line.classList.remove('copied');
          if (tooltip) tooltip.textContent = 'Click to copy';
          if (icon) icon.classList.remove('copied');
        }, 1500);
      });
    });
  });
</script>
