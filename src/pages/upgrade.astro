---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, t, getLocalePath } from '../i18n';
import en from '../i18n/translations/en';
import ja from '../i18n/translations/ja';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);
const translations = locale === 'ja' ? ja : en;

const features = translations.upgrade.features;
---

<BaseLayout title={t(locale, 'meta.upgradeTitle')} description={t(locale, 'meta.upgradeDescription')}>
  <Navbar />

  <main class="upgrade-page">
    <div class="container">
      <div class="upgrade-header">
        <div class="tv-label"><span class="tv-label-prompt">$</span> patapim upgrade <span class="tv-dim">— start free. upgrade when you're ready.</span></div>
        <h1 class="upgrade-title">{t(locale, 'upgrade.title')}</h1>
        <p class="upgrade-subtitle">
          {t(locale, 'upgrade.subtitle')}
        </p>
      </div>

      <div class="upgrade-cards">
        <!-- Pro Monthly -->
        <div class="u-card featured tv-pcard tv-pcard-hero">
          <div class="tv-pcard-tag">{t(locale, 'upgrade.proBadge')}</div>
          <div class="tv-pcard-head">
            <span class="tv-pcard-name">{t(locale, 'pricing.proTitle')}</span>
          </div>
          <div class="tv-pcard-pricebox">
            <span class="tv-pcard-amount">{t(locale, 'upgrade.proPrice')}</span>
            <span class="tv-pcard-period">{t(locale, 'upgrade.proPeriod')}</span>
          </div>
          <p class="u-desc">{t(locale, 'upgrade.proDesc')}</p>
          <a href="#" class="tv-pbtn tv-pbtn-accent" id="checkout-pro">{t(locale, 'upgrade.proButton')}</a>
        </div>

        <!-- Unlock Forever -->
        <div class="u-card lifetime tv-pcard">
          <div class="tv-pcard-tag u-tag-lifetime">{t(locale, 'upgrade.unlockBadge')}</div>
          <div class="tv-pcard-head">
            <span class="tv-pcard-name">{t(locale, 'pricing.unlockTitle')}</span>
          </div>
          <div class="tv-pcard-pricebox">
            <span class="tv-pcard-amount">{t(locale, 'upgrade.unlockPrice')}</span>
            <span class="tv-pcard-period">{t(locale, 'upgrade.unlockPeriod')}</span>
          </div>
          <p class="u-desc">{t(locale, 'upgrade.unlockDesc')}</p>
          <a href="#" class="tv-pbtn" id="checkout-lifetime">{t(locale, 'upgrade.unlockButton')}</a>
        </div>
      </div>

      <!-- Referral section -->
      <div class="referral-section">
        <button class="referral-toggle" id="referral-toggle" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          <span>{t(locale, 'upgrade.referralToggle')}</span>
          <svg class="referral-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="referral-form-container" id="referral-form">
          <p class="referral-hint">{t(locale, 'upgrade.referralHint')}</p>
          <input type="email" class="referral-input tv-input" id="referral-email" placeholder={t(locale, 'upgrade.referralPlaceholder')} autocomplete="email" />
          <p class="referral-error" id="referral-error"></p>
        </div>
      </div>

      <!-- Shared feature list -->
      <div class="features-section">
        <h4 class="features-heading">{t(locale, 'upgrade.includedTitle')}</h4>
        <ul class="features-list">
          {features.map((f) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
              {f}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .upgrade-page {
    min-height: 100vh;
  }

  .upgrade-header {
    text-align: center;
    padding-top: 130px;
    margin-bottom: 56px;
  }

  .upgrade-header .tv-label { margin-bottom: 22px; }

  .upgrade-title {
    font-size: clamp(24px, 4vw, 34px);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin: 0 0 12px;
    line-height: 1.25;
  }

  .upgrade-subtitle {
    font-size: 13.5px;
    color: var(--text-tertiary);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .upgrade-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    max-width: 680px;
    margin: 0 auto;
    align-items: stretch;
  }

  .upgrade-cards .u-desc {
    font-size: 12.5px;
    color: var(--text-tertiary);
    line-height: 1.7;
    margin: 0 0 24px;
    flex: 1;
  }

  .upgrade-cards .tv-pcard-tag.u-tag-lifetime {
    background: #0a0a0a;
    border: 1px solid rgba(34, 211, 238, 0.45);
    color: var(--cy);
  }

  .upgrade-cards a[disabled] {
    opacity: 0.55;
    pointer-events: none;
  }

  /* Features section */
  .features-section {
    max-width: 560px;
    margin: 56px auto 0;
    text-align: center;
  }

  .features-heading {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: var(--space-xl);
  }

  .features-heading::before { content: '$ '; color: var(--vi); }

  .features-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm) var(--space-xl);
    text-align: left;
    margin: 0;
    padding: 0;
  }

  .features-list li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 13px;
    color: var(--text-secondary);
  }

  .features-list li svg {
    color: var(--cy);
    flex-shrink: 0;
  }

  /* Referral section */
  .referral-section {
    max-width: 680px;
    margin: 44px auto 0;
    text-align: center;
  }

  .referral-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    background: transparent;
    border: 1px solid var(--border-default);
    border-radius: 0;
    padding: 8px 16px;
    color: var(--text-tertiary);
    font-size: 12.5px;
    font-family: var(--font-mono);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }

  .referral-toggle:hover {
    color: var(--text-secondary);
    border-color: var(--border-strong);
  }

  .referral-chevron {
    transition: transform 0.2s;
  }

  .referral-toggle.open .referral-chevron {
    transform: rotate(180deg);
  }

  .referral-form-container {
    display: none;
    margin-top: var(--space-md);
    background: linear-gradient(180deg, #0b0b0e 0%, #070708 100%);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 0;
    padding: var(--space-lg);
  }

  .referral-form-container.open {
    display: block;
  }

  .referral-hint {
    font-size: 12.5px;
    color: var(--text-tertiary);
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .referral-error {
    font-size: 12px;
    color: var(--error);
    margin-top: var(--space-xs);
    min-height: 18px;
  }

  @media (max-width: 640px) {
    .upgrade-cards {
      grid-template-columns: 1fr;
    }
    .features-list {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Referral toggle
  const toggleBtn = document.getElementById('referral-toggle')!;
  const formContainer = document.getElementById('referral-form')!;

  toggleBtn.addEventListener('click', () => {
    const isOpen = toggleBtn.classList.toggle('open');
    formContainer.classList.toggle('open', isOpen);
  });

  // Pre-fill from ?ref= URL param
  const urlParams = new URLSearchParams(window.location.search);
  const refParam = urlParams.get('ref');
  if (refParam) {
    (document.getElementById('referral-email') as HTMLInputElement).value = refParam;
    toggleBtn.classList.add('open');
    formContainer.classList.add('open');
  }

  async function handleCheckout(plan: 'pro' | 'lifetime') {
    const btn = document.getElementById(plan === 'pro' ? 'checkout-pro' : 'checkout-lifetime');
    const errorEl = document.getElementById('referral-error')!;
    errorEl.textContent = '';

    if (btn) btn.setAttribute('disabled', '');
    try {
      // Try to get email from URL query param (passed from PATAPIM app)
      const params = new URLSearchParams(window.location.search);
      let email: string | undefined = params.get('email') || undefined;

      // Fallback: try authenticated session
      if (!email) {
        try {
          const sessionRes = await fetch('/api/auth/session');
          if (sessionRes.ok) {
            const sessionData = await sessionRes.json();
            if (sessionData.authenticated) email = sessionData.user.email;
          }
        } catch {}
      }

      // Get referrer email if entered
      const referralInput = document.getElementById('referral-email') as HTMLInputElement;
      const referrerEmail = referralInput.value.trim() || undefined;

      // Client-side self-referral check
      if (referrerEmail && email && referrerEmail.toLowerCase() === email.toLowerCase()) {
        errorEl.textContent = 'You cannot refer yourself.';
        if (btn) btn.removeAttribute('disabled');
        return;
      }

      const res = await fetch('/api/stripe/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plan, email, referrerEmail }),
      });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        console.error('Checkout error:', data.error);
        if (data.error === 'Cannot refer yourself') {
          errorEl.textContent = 'You cannot refer yourself.';
        }
        if (btn) btn.removeAttribute('disabled');
      }
    } catch (err) {
      console.error('Checkout error:', err);
      if (btn) btn.removeAttribute('disabled');
    }
  }

  document.getElementById('checkout-pro')?.addEventListener('click', (e) => {
    e.preventDefault();
    handleCheckout('pro');
  });

  document.getElementById('checkout-lifetime')?.addEventListener('click', (e) => {
    e.preventDefault();
    handleCheckout('lifetime');
  });
</script>
