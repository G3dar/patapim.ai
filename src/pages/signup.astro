---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getUserFromRequest } from '../lib/auth';

const env = Astro.locals.runtime.env;
const url = new URL(Astro.request.url);
const pairingSessionId = url.searchParams.get('s');
const rawReturnTo = url.searchParams.get('returnTo') || '';
const returnTo = rawReturnTo.startsWith('/') ? rawReturnTo : '';

// If signed in already, send to returnTo (or /go).
const user = await getUserFromRequest(env.SESSIONS, Astro.request);
if (user) {
  return Astro.redirect(pairingSessionId ? '/go?paired=1' : (returnTo || '/go'));
}

// Set the pair cookie so signup can complete the desktop handoff.
if (pairingSessionId) {
  Astro.response.headers.append(
    'Set-Cookie',
    `__patapim_pair=${pairingSessionId}; Secure; SameSite=Lax; Path=/; Max-Age=600`,
  );
}

const params = new URLSearchParams();
if (pairingSessionId) params.set('s', pairingSessionId);
if (returnTo) params.set('returnTo', returnTo);
const sigParam = params.toString() ? `?${params.toString()}` : '';
---
<BaseLayout title="Sign up — PATAPIM" description="Create your PATAPIM account.">
  <main class="auth-page">
    <div class="auth-wrap">
      <a href="/" class="auth-brand"><span class="auth-brand-icon">❯_</span><span class="auth-brand-sep">/</span><span class="auth-brand-name">patapim</span></a>
      <div class="auth-card tv-auth-card">
        <div class="tv-label"><span class="tv-label-prompt">$</span> patapim signup <span class="tv-dim">— create your account</span></div>
        <h1 class="tv-auth-title">Create your account</h1>

        <a href={`/api/auth/google${sigParam}`} class="google-btn tv-pbtn">
          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
            <path fill="#4285F4" d="M17.64 9.205c0-.639-.057-1.252-.164-1.841H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/>
            <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
            <path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.997 8.997 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/>
            <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.581C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/>
          </svg>
          Sign up with Google
        </a>

        <div class="tv-divider">or sign up with email</div>

        <form id="signup-form" novalidate>
          <label class="field">
            <span class="tv-form-label">Name <em>(optional)</em></span>
            <input class="tv-input" type="text" name="name" autocomplete="name" maxlength="80" />
          </label>

          <label class="field">
            <span class="tv-form-label">Email</span>
            <input class="tv-input" type="email" name="email" autocomplete="email" required />
          </label>

          <label class="field">
            <span class="tv-form-label">Password</span>
            <input class="tv-input" type="password" name="password" autocomplete="new-password" required minlength="10" />
            <small class="hint">At least 10 characters.</small>
          </label>

          <button type="submit" class="tv-pbtn tv-pbtn-accent">Create account</button>
          <p id="signup-error" class="form-error" hidden></p>
        </form>

        <p class="signup-prompt">Already have an account? <a href={`/signin${sigParam}`}>Sign in</a></p>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
    background: var(--bg-deep);
  }
  .auth-wrap { width: 100%; max-width: 400px; }
  .auth-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
    margin: 0 0 14px 2px;
  }
  .auth-brand:hover .auth-brand-name { color: var(--text-primary); }
  .auth-brand-icon {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .auth-brand-sep { color: var(--text-muted); }
  .auth-brand-name { letter-spacing: 0.05em; transition: color 120ms; }

  .google-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    margin-top: 4px;
  }
  .google-btn svg { flex-shrink: 0; }

  .field { display: block; }
  .field em { color: var(--text-muted); font-style: normal; text-transform: none; letter-spacing: 0; }
  .hint { display: block; color: var(--text-muted); font-size: 11px; margin-top: 6px; }

  button.tv-pbtn { width: 100%; margin-top: 18px; }
  button.tv-pbtn:disabled { opacity: 0.6; cursor: wait; }

  .form-error { color: var(--error); font-size: 12px; margin: 10px 0 0; }

  .signup-prompt {
    text-align: center;
    color: var(--text-tertiary);
    font-size: 12.5px;
    margin-top: 20px;
  }
  .signup-prompt a { color: var(--text-primary); text-decoration: underline; }
  .signup-prompt a:hover { color: var(--cy); }
</style>

<script>
  const form = document.getElementById('signup-form') as HTMLFormElement | null;
  const errEl = document.getElementById('signup-error') as HTMLParagraphElement | null;
  if (form && errEl) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errEl.hidden = true;
      errEl.textContent = '';
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;

      const data = new FormData(form);
      const payload = {
        email: String(data.get('email') || '').trim(),
        password: String(data.get('password') || ''),
        name: String(data.get('name') || '').trim(),
      };

      try {
        const res = await fetch('/api/auth/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify(payload),
        });
        const body = await res.json().catch(() => ({}));
        if (res.ok && body.ok) {
          const sp = new URLSearchParams(window.location.search);
          const rt = sp.get('returnTo') || '';
          const safeRt = rt.startsWith('/') ? rt : '';
          window.location.href = body.paired ? '/go?paired=1' : (safeRt || '/go');
          return;
        }
        if (res.status === 429) {
          errEl.textContent = `Too many attempts. Try again in ${body.retryAfter || 60}s.`;
        } else if (body.error === 'email_in_use') {
          errEl.textContent = body.hint === 'google_only'
            ? "An account with this email already exists via Google. Sign in with Google instead."
            : "An account with this email already exists. Try signing in.";
        } else if (body.error === 'invalid_password' && Array.isArray(body.details)) {
          errEl.textContent = body.details[0] || 'Password too weak.';
        } else if (body.error === 'invalid_email') {
          errEl.textContent = 'Please enter a valid email.';
        } else {
          errEl.textContent = "Something went wrong. Please try again.";
        }
        errEl.hidden = false;
      } catch {
        errEl.textContent = 'Network error. Please try again.';
        errEl.hidden = false;
      } finally {
        btn.disabled = false;
      }
    });
  }
</script>
