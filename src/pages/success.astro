---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, t, getLocalePath } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);

const scriptI18n = {
  planPro: t(locale, 'dashboard.planPro'),
  planLifetime: t(locale, 'dashboard.planLifetime'),
};
---

<BaseLayout title={t(locale, 'meta.successTitle')} description={t(locale, 'meta.successDescription')}>
  <Navbar />

  <main class="success-page">
    <div class="container">
      <div class="success-card" id="success-card" data-i18n={JSON.stringify(scriptI18n)}>
        <div class="tv-label success-label"><span class="tv-label-prompt">$</span> patapim checkout <span class="tv-dim">— thank you</span></div>

        <!-- Loading state -->
        <div class="success-loading" id="success-loading">
          <div class="spinner"></div>
          <p>{t(locale, 'success.loading')}</p>
        </div>

        <!-- Success state (hidden until data loads) -->
        <div class="success-content" id="success-content" style="display:none;">
          <div class="success-check">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <h1 class="success-title">{t(locale, 'success.title')}</h1>
          <span class="plan-badge" id="plan-badge"></span>
          <p class="success-email" id="success-email"></p>
          <p class="success-desc" set:html={t(locale, 'success.message').replace('\n', '<br/>')} />
          <div class="success-cta">
            <a href={lp('/go')} class="tv-pbtn tv-pbtn-accent success-btn">{t(locale, 'common.goToDashboard')}</a>
            <a href={lp('/download')} class="success-link">{t(locale, 'success.downloadPatapim')}</a>
          </div>
        </div>

        <!-- Error state -->
        <div class="success-error" id="success-error" style="display:none;">
          <div class="success-check error-icon">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h1 class="success-title">{t(locale, 'success.processingTitle')}</h1>
          <p class="success-desc" set:html={t(locale, 'success.processingMessage').replace('\n', '<br/>')} />
          <div class="success-cta">
            <button class="tv-pbtn tv-pbtn-accent success-btn" onclick="location.reload()">{t(locale, 'common.refresh')}</button>
            <a href={lp('/go')} class="success-link">{t(locale, 'common.goToDashboard')}</a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .success-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 0 80px;
  }

  .success-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 480px;
    width: 90%;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-3xl) var(--space-4xl);
    background: linear-gradient(180deg, #0b0b0e 0%, #070708 100%);
    border: 1px solid rgba(255, 255, 255, 0.09);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.55), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .success-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #c26bf0, #8b7cf8, #22d3ee);
    opacity: 0.7;
  }

  .success-label {
    align-self: flex-start;
    margin-bottom: 26px;
  }

  /* Loading */
  .success-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    padding: var(--space-2xl) 0;
  }

  .success-loading p {
    font-size: 13px;
    color: var(--text-tertiary);
  }

  .spinner {
    width: 32px;
    height: 32px;
    border: 2px solid var(--border-default);
    border-top-color: var(--cy);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Success content */
  .success-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .success-check {
    color: var(--success);
    margin-bottom: var(--space-xl);
    filter: drop-shadow(0 0 14px rgba(74, 222, 128, 0.35));
  }

  .error-icon {
    color: var(--warning);
    filter: drop-shadow(0 0 14px rgba(216, 180, 90, 0.25));
  }

  .success-title {
    font-size: 24px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-lg);
  }

  .plan-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 0;
    margin-bottom: var(--space-lg);
  }

  .plan-badge.plan-pro {
    background: linear-gradient(90deg, #c26bf0, #8b7cf8, #22d3ee);
    color: #000;
  }

  .plan-badge.plan-lifetime {
    background: rgba(34, 211, 238, 0.12);
    border: 1px solid rgba(34, 211, 238, 0.35);
    color: var(--cy);
  }

  .success-email {
    font-size: 12.5px;
    color: var(--text-tertiary);
    margin-bottom: var(--space-xl);
  }

  .success-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-3xl);
  }

  .success-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .success-btn {
    min-width: 220px;
  }

  button.success-btn {
    width: 100%;
  }

  .success-link {
    font-size: 12.5px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .success-link:hover {
    color: var(--cy);
  }

  .success-error {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (max-width: 480px) {
    .success-card {
      padding: var(--space-2xl) var(--space-xl);
    }
    .success-title {
      font-size: 20px;
    }
  }
</style>

<script>
  const params = new URLSearchParams(window.location.search);
  const sessionId = params.get('session_id');

  const i18nEl = document.getElementById('success-card');
  const i18n = i18nEl ? JSON.parse(i18nEl.dataset.i18n || '{}') : {};

  if (sessionId) {
    (async () => {
      const delays = [1000, 2000, 4000];
      for (let attempt = 0; attempt <= delays.length; attempt++) {
        try {
          const res = await fetch('/api/stripe/session-info', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sessionId }),
          });
          const data = await res.json();
          if (data.found) {
            // Show success
            document.getElementById('success-loading')!.style.display = 'none';

            const badge = document.getElementById('plan-badge')!;
            if (data.plan === 'lifetime') {
              badge.textContent = i18n.planLifetime || 'Lifetime';
              badge.classList.add('plan-lifetime');
            } else {
              badge.textContent = i18n.planPro || 'Pro';
              badge.classList.add('plan-pro');
            }

            document.getElementById('success-email')!.textContent = data.email;
            document.getElementById('success-content')!.style.display = 'flex';
            return;
          }
        } catch {}
        if (attempt < delays.length) {
          await new Promise(r => setTimeout(r, delays[attempt]));
        }
      }
      // Fallback: license not found yet
      document.getElementById('success-loading')!.style.display = 'none';
      document.getElementById('success-error')!.style.display = 'flex';
    })();
  } else {
    // No session_id — redirect to home
    window.location.href = '/';
  }
</script>
