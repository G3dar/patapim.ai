---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import SessionBar from '../components/SessionBar.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, t, getLocalePath } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);
---

<BaseLayout title="Release Notes — PATAPIM" description="Full changelog and release notes for every PATAPIM version.">
  <Navbar />
  <SessionBar />

  <main class="releases-page">
    <div class="releases-container">
      <div class="releases-head">
        <div class="tv-label"><span class="tv-label-prompt">$</span> git log --releases <span class="tv-dim">— changelog</span></div>
        <h1 class="tv-heading releases-title">RELEASE NOTES</h1>
        <p class="tv-heading-sub">Every update, feature, and fix — from day one.</p>
      </div>

      <div class="releases-content" id="releases-content">
        <div class="releases-loading">
          <div class="spinner"></div>
          <p>Loading releases...</p>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  async function loadReleases() {
    const container = document.getElementById('releases-content');
    if (!container) return;

    try {
      const res = await fetch('https://api.github.com/repos/G3dar/patapim-releases/releases?per_page=100');
      if (!res.ok) throw new Error(`GitHub API ${res.status}`);
      const releases = await res.json();

      // Filter out version-bump-only releases (no user-facing changes)
      const meaningful = releases.filter(r => {
        const body = (r.body || '').trim();
        return body && !body.includes('version bump only');
      });

      if (!meaningful.length) {
        container.innerHTML = '<p class="releases-empty">No releases found.</p>';
        return;
      }

      container.innerHTML = meaningful.map(r => {
        const date = new Date(r.published_at).toLocaleDateString('en-US', {
          year: 'numeric', month: 'long', day: 'numeric'
        });
        const version = r.tag_name.replace(/^v/, '');
        const body = renderMarkdown(r.body || '');

        return `
          <article class="release-card" id="${r.tag_name}">
            <div class="release-header">
              <div class="release-version">
                <span class="version-badge">${version}</span>
                <time class="release-date" datetime="${r.published_at}">${date}</time>
              </div>
              <a href="#${r.tag_name}" class="release-anchor">#</a>
            </div>
            <div class="release-body">${body}</div>
          </article>
        `;
      }).join('');
    } catch (err) {
      container.innerHTML = `
        <div class="releases-error">
          <p>Could not load releases. Please try again later.</p>
        </div>
      `;
    }
  }

  function renderMarkdown(md) {
    // Lightweight markdown: headers, bold, lists, links, paragraphs
    let html = md
      .replace(/### (.+)/g, '<h3>$1</h3>')
      .replace(/## (.+)/g, '<h2>$1</h2>')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_, text, url) => {
        if (url.includes('github.com')) return text;
        return `<a href="${url}" target="_blank" rel="noopener">${text}</a>`;
      });

    // Convert lines starting with - into <ul><li>
    const lines = html.split('\n');
    const out = [];
    let inList = false;
    for (const line of lines) {
      const trimmed = line.trim();
      if (trimmed.startsWith('- ')) {
        if (!inList) { out.push('<ul>'); inList = true; }
        out.push(`<li>${trimmed.slice(2)}</li>`);
      } else {
        if (inList) { out.push('</ul>'); inList = false; }
        if (trimmed && !trimmed.startsWith('<h')) {
          out.push(trimmed.startsWith('<') ? trimmed : `<p>${trimmed}</p>`);
        } else {
          out.push(trimmed);
        }
      }
    }
    if (inList) out.push('</ul>');
    return out.join('\n');
  }

  loadReleases();
</script>

<style is:global>
  .releases-page {
    min-height: 100vh;
    padding-bottom: 48px;
    font-family: var(--font-mono);
    background: var(--bg-deep);
  }

  .releases-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .releases-head {
    padding-top: 120px;
    margin-bottom: 24px;
  }

  .releases-title {
    margin-top: 26px;
    font-size: clamp(17px, 2.4vw, 22px);
  }

  .releases-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 24px 0;
  }

  /* Loading */
  .releases-loading {
    text-align: center;
    padding: 48px 0;
    color: var(--text-muted);
    font-size: 13px;
  }
  .spinner {
    width: 28px;
    height: 28px;
    border: 2px solid var(--border-subtle);
    border-top-color: var(--cy);
    border-radius: 50%;
    margin: 0 auto 12px;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Error / empty */
  .releases-error, .releases-empty {
    text-align: center;
    padding: 32px 0;
    color: var(--text-muted);
    font-size: 13px;
  }
  .releases-error a { color: var(--text-secondary); }

  /* Release card — quiet terminal panel */
  .release-card {
    background: linear-gradient(180deg, #0b0b0e 0%, #070708 100%);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 0;
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.55), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    padding: 20px 22px;
    margin-bottom: 18px;
    transition: border-color 0.2s;
  }
  .release-card:first-child {
    border-color: rgba(139, 124, 248, 0.45);
    box-shadow:
      0 0 0 1px rgba(139, 124, 248, 0.22),
      0 0 28px rgba(139, 124, 248, 0.14),
      0 18px 48px rgba(0, 0, 0, 0.55);
  }

  .release-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
    gap: 8px;
    flex-wrap: wrap;
  }

  .release-version {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .version-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.04em;
    background: linear-gradient(120deg, #c26bf0, #8b7cf8, #22d3ee);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .version-badge::before {
    content: 'v';
  }

  .release-date {
    color: var(--text-muted);
    font-size: 12px;
  }

  .release-anchor {
    color: var(--text-muted);
    font-size: 14px;
    text-decoration: none;
    opacity: 0.4;
    transition: opacity 0.2s, color 0.2s;
    font-family: var(--font-mono);
  }
  .release-anchor:hover { opacity: 1; color: var(--cy); }

  /* Release body (rendered markdown) */
  .release-body h2 {
    font-size: 14px;
    color: var(--text-primary);
    letter-spacing: 0.04em;
    margin: 12px 0 4px;
  }
  .release-body h3 {
    font-size: 11px;
    font-weight: 700;
    color: var(--text-tertiary);
    margin: 12px 0 4px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .release-body h3::before {
    content: '$ ';
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .release-body p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 4px;
  }
  .release-body ul {
    list-style: none;
    padding: 0;
    margin: 0 0 8px;
  }
  .release-body li {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.75;
    padding-left: 16px;
    position: relative;
  }
  .release-body li::before {
    content: '·';
    position: absolute;
    left: 2px;
    color: var(--cy);
  }
  .release-body strong {
    color: var(--text-primary);
  }
  .release-body a {
    color: var(--text-secondary);
    text-decoration: underline;
  }
  .release-body a:hover { color: var(--cy); }

  @media (max-width: 640px) {
    .releases-content {
      padding-left: 12px;
      padding-right: 12px;
    }
    .release-card {
      padding: 14px 16px;
    }
  }
</style>
