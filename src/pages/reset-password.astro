---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';

const url = new URL(Astro.request.url);
const token = url.searchParams.get('token') || '';
const hasToken = !!token;
---
<BaseLayout title="Reset password — PATAPIM" description="Reset your PATAPIM password.">
  <main class="auth-page">
    <div class="auth-card">
      <a href="/" class="brand">PATAPIM</a>

      {hasToken ? (
        <>
          <h1>Set a new password</h1>
          <p class="lead">Pick a new password for your PATAPIM account. Once you confirm, you'll be signed in.</p>

          <form id="confirm-form" novalidate>
            <input type="hidden" name="token" value={token} />
            <label>
              <span>New password</span>
              <input type="password" name="newPassword" autocomplete="new-password" required minlength="10" />
              <small class="hint">At least 10 characters.</small>
            </label>

            <button type="submit" class="btn primary">Set new password</button>
            <p id="confirm-msg" class="form-msg" hidden></p>
          </form>
        </>
      ) : (
        <>
          <h1>Reset your password</h1>
          <p class="lead">Enter your email and we'll send you a link to choose a new password.</p>

          <form id="request-form" novalidate>
            <label>
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>

            <button type="submit" class="btn primary">Send reset link</button>
            <p id="request-msg" class="form-msg" hidden></p>
          </form>

          <p class="signup-prompt"><a href="/signin">Back to sign in</a></p>
        </>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .auth-page {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    padding: 32px 16px;
    background:
      radial-gradient(circle at 20% 10%, rgba(212,165,116,0.06), transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(120,165,212,0.04), transparent 40%),
      var(--bg-deep);
  }
  .auth-card {
    width: 100%; max-width: 400px;
    background: var(--bg-primary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    padding: 36px 32px;
    box-shadow: var(--shadow-lg);
  }
  .brand {
    display: block; font-family: var(--font-sans); font-weight: 700;
    color: var(--text-secondary); letter-spacing: 1.5px; text-decoration: none;
    font-size: 13px; margin-bottom: 24px;
  }
  .brand:hover { color: var(--accent-primary); }
  h1 {
    font-family: var(--font-sans); color: var(--text-primary);
    font-size: 24px; font-weight: 600; margin: 0 0 14px;
  }
  .lead { color: var(--text-secondary); font-size: 14px; line-height: 1.5; margin-bottom: 20px; }
  form { display: flex; flex-direction: column; gap: 14px; }
  label { display: flex; flex-direction: column; gap: 6px; }
  label > span {
    color: var(--text-secondary); font-size: 12px; font-weight: 500;
    letter-spacing: 0.3px; text-transform: uppercase;
  }
  input {
    background: var(--bg-secondary); border: 1px solid var(--border-default);
    border-radius: var(--radius-md); color: var(--text-primary);
    padding: 11px 14px; font-size: 15px; font-family: var(--font-sans);
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }
  input:focus { outline: none; border-color: var(--accent-primary); background: var(--bg-tertiary); }
  .hint { color: var(--text-tertiary); font-size: 12px; }
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    padding: 12px 16px; border-radius: var(--radius-md);
    font-size: 15px; font-weight: 600; font-family: var(--font-sans);
    cursor: pointer; border: 1px solid transparent; text-decoration: none;
    transition: all var(--transition-fast);
  }
  .btn.primary { background: var(--accent-primary); color: var(--bg-deep); margin-top: 6px; }
  .btn.primary:hover { background: var(--accent-secondary); }
  .btn.primary:disabled { opacity: 0.6; cursor: wait; }
  .form-msg {
    padding: 10px 12px; border-radius: var(--radius-md);
    font-size: 13px; margin: 4px 0 0;
  }
  .form-msg.success { background: var(--success-subtle); color: var(--success); border: 1px solid var(--success); }
  .form-msg.error { background: var(--error-subtle); color: var(--error); border: 1px solid var(--error); }
  .signup-prompt { text-align: center; margin-top: 18px; }
  .signup-prompt a { color: var(--text-tertiary); text-decoration: none; font-size: 14px; }
  .signup-prompt a:hover { color: var(--accent-primary); }
</style>

<script>
  const reqForm = document.getElementById('request-form') as HTMLFormElement | null;
  const reqMsg = document.getElementById('request-msg') as HTMLParagraphElement | null;
  if (reqForm && reqMsg) {
    reqForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      reqMsg.hidden = true;
      reqMsg.className = 'form-msg';
      const btn = reqForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      const email = String((new FormData(reqForm)).get('email') || '').trim();
      try {
        const res = await fetch('/api/auth/request-password-reset', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ email }),
        });
        if (res.ok) {
          reqMsg.classList.add('success');
          reqMsg.textContent = "If an account exists for that email, we've sent a reset link. Check your inbox.";
        } else {
          reqMsg.classList.add('error');
          reqMsg.textContent = 'Please enter a valid email.';
        }
        reqMsg.hidden = false;
      } catch {
        reqMsg.classList.add('error');
        reqMsg.textContent = 'Network error. Please try again.';
        reqMsg.hidden = false;
      } finally {
        btn.disabled = false;
      }
    });
  }

  const confForm = document.getElementById('confirm-form') as HTMLFormElement | null;
  const confMsg = document.getElementById('confirm-msg') as HTMLParagraphElement | null;
  if (confForm && confMsg) {
    confForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      confMsg.hidden = true;
      confMsg.className = 'form-msg';
      const btn = confForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      const data = new FormData(confForm);
      const payload = {
        token: String(data.get('token') || ''),
        newPassword: String(data.get('newPassword') || ''),
      };
      try {
        const res = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify(payload),
        });
        const body = await res.json().catch(() => ({}));
        if (res.ok && body.ok) {
          window.location.href = '/go';
          return;
        }
        confMsg.classList.add('error');
        if (body.error === 'invalid_or_expired_token') {
          confMsg.textContent = 'This reset link is invalid or has expired. Request a new one.';
        } else if (body.error === 'invalid_password' && Array.isArray(body.details)) {
          confMsg.textContent = body.details[0] || 'Password too weak.';
        } else {
          confMsg.textContent = 'Something went wrong. Please try again.';
        }
        confMsg.hidden = false;
      } catch {
        confMsg.classList.add('error');
        confMsg.textContent = 'Network error. Please try again.';
        confMsg.hidden = false;
      } finally {
        btn.disabled = false;
      }
    });
  }
</script>
