---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';

const url = new URL(Astro.request.url);
const token = url.searchParams.get('token') || '';
const hasToken = !!token;
---
<BaseLayout title="Reset password — PATAPIM" description="Reset your PATAPIM password.">
  <main class="auth-page">
    <div class="auth-wrap">
      <a href="/" class="auth-brand"><span class="auth-brand-icon">❯_</span><span class="auth-brand-sep">/</span><span class="auth-brand-name">patapim</span></a>
      <div class="auth-card tv-auth-card">
        <div class="tv-label"><span class="tv-label-prompt">$</span> patapim reset <span class="tv-dim">— --password</span></div>

        {hasToken ? (
          <>
            <h1 class="tv-auth-title">Set a new password</h1>
            <p class="tv-auth-sub">Pick a new password for your PATAPIM account. Once you confirm, you'll be signed in.</p>

            <form id="confirm-form" novalidate>
              <input type="hidden" name="token" value={token} />
              <label class="field">
                <span class="tv-form-label">New password</span>
                <input class="tv-input" type="password" name="newPassword" autocomplete="new-password" required minlength="10" />
                <small class="hint">At least 10 characters.</small>
              </label>

              <button type="submit" class="tv-pbtn tv-pbtn-accent">Set new password</button>
              <p id="confirm-msg" class="form-msg" hidden></p>
            </form>
          </>
        ) : (
          <>
            <h1 class="tv-auth-title">Reset your password</h1>
            <p class="tv-auth-sub">Enter your email and we'll send you a link to choose a new password.</p>

            <form id="request-form" novalidate>
              <label class="field">
                <span class="tv-form-label">Email</span>
                <input class="tv-input" type="email" name="email" autocomplete="email" required />
              </label>

              <button type="submit" class="tv-pbtn tv-pbtn-accent">Send reset link</button>
              <p id="request-msg" class="form-msg" hidden></p>
            </form>

            <p class="signup-prompt"><a href="/signin">Back to sign in</a></p>
          </>
        )}
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
    background: var(--bg-deep);
  }
  .auth-wrap { width: 100%; max-width: 400px; }
  .auth-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
    margin: 0 0 14px 2px;
  }
  .auth-brand:hover .auth-brand-name { color: var(--text-primary); }
  .auth-brand-icon {
    background: var(--p-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .auth-brand-sep { color: var(--text-muted); }
  .auth-brand-name { letter-spacing: 0.05em; transition: color 120ms; }

  .field { display: block; }
  .hint { display: block; color: var(--text-muted); font-size: 11px; margin-top: 6px; }

  button.tv-pbtn { width: 100%; margin-top: 18px; }
  button.tv-pbtn:disabled { opacity: 0.6; cursor: wait; }

  .form-msg { font-size: 12px; margin: 10px 0 0; }
  .form-msg.success { color: var(--success); }
  .form-msg.error { color: var(--error); }

  .signup-prompt { text-align: center; margin-top: 20px; }
  .signup-prompt a { color: var(--text-tertiary); text-decoration: none; font-size: 12.5px; }
  .signup-prompt a:hover { color: var(--cy); }
</style>

<script>
  const reqForm = document.getElementById('request-form') as HTMLFormElement | null;
  const reqMsg = document.getElementById('request-msg') as HTMLParagraphElement | null;
  if (reqForm && reqMsg) {
    reqForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      reqMsg.hidden = true;
      reqMsg.className = 'form-msg';
      const btn = reqForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      const email = String((new FormData(reqForm)).get('email') || '').trim();
      try {
        const res = await fetch('/api/auth/request-password-reset', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ email }),
        });
        if (res.ok) {
          reqMsg.classList.add('success');
          reqMsg.textContent = "If an account exists for that email, we've sent a reset link. Check your inbox.";
        } else {
          reqMsg.classList.add('error');
          reqMsg.textContent = 'Please enter a valid email.';
        }
        reqMsg.hidden = false;
      } catch {
        reqMsg.classList.add('error');
        reqMsg.textContent = 'Network error. Please try again.';
        reqMsg.hidden = false;
      } finally {
        btn.disabled = false;
      }
    });
  }

  const confForm = document.getElementById('confirm-form') as HTMLFormElement | null;
  const confMsg = document.getElementById('confirm-msg') as HTMLParagraphElement | null;
  if (confForm && confMsg) {
    confForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      confMsg.hidden = true;
      confMsg.className = 'form-msg';
      const btn = confForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      const data = new FormData(confForm);
      const payload = {
        token: String(data.get('token') || ''),
        newPassword: String(data.get('newPassword') || ''),
      };
      try {
        const res = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify(payload),
        });
        const body = await res.json().catch(() => ({}));
        if (res.ok && body.ok) {
          window.location.href = '/go';
          return;
        }
        confMsg.classList.add('error');
        if (body.error === 'invalid_or_expired_token') {
          confMsg.textContent = 'This reset link is invalid or has expired. Request a new one.';
        } else if (body.error === 'invalid_password' && Array.isArray(body.details)) {
          confMsg.textContent = body.details[0] || 'Password too weak.';
        } else {
          confMsg.textContent = 'Something went wrong. Please try again.';
        }
        confMsg.hidden = false;
      } catch {
        confMsg.classList.add('error');
        confMsg.textContent = 'Network error. Please try again.';
        confMsg.hidden = false;
      } finally {
        btn.disabled = false;
      }
    });
  }
</script>
