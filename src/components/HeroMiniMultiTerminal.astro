---
import { getLocaleFromUrl, t } from '../i18n';
import en from '../i18n/translations/en';
import ja from '../i18n/translations/ja';

const locale = getLocaleFromUrl(Astro.url);
const translations = locale === 'ja' ? ja : en;
const dm = translations.demos.multiTerminal;

const scriptI18n = {
  projectNames: dm.projectNames,
};
---

<div class="hm-mt" data-hm-mt data-i18n={JSON.stringify(scriptI18n)}>
  <div class="hm-chrome">
    <div class="hm-dots">
      <span class="hm-dot hm-dot-r"></span>
      <span class="hm-dot hm-dot-y"></span>
      <span class="hm-dot hm-dot-g"></span>
    </div>
    <span class="hm-title">{t(locale, 'demos.multiTerminal.windowTitle')}</span>
  </div>
  <div class="hm-body">
    <!-- Left: folder tree -->
    <div class="hm-tree">
      <div class="hm-tree-header">~/projects</div>
      <div class="hm-folder" data-folder="0">
        <div class="hm-folder-row">
          <svg class="hm-folder-icon" viewBox="0 0 20 18" fill="none">
            <path d="M2 3h5l2 2h9a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" fill="currentColor"/>
          </svg>
          <span class="hm-folder-name">{dm.projectNames[0]}</span>
          <span class="hm-folder-badge">12</span>
        </div>
      </div>
      <div class="hm-folder" data-folder="1">
        <div class="hm-folder-row">
          <svg class="hm-folder-icon" viewBox="0 0 20 18" fill="none">
            <path d="M2 3h5l2 2h9a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" fill="currentColor"/>
          </svg>
          <span class="hm-folder-name">{dm.projectNames[1]}</span>
          <span class="hm-folder-badge">8</span>
        </div>
      </div>
      <div class="hm-folder" data-folder="2">
        <div class="hm-folder-row">
          <svg class="hm-folder-icon" viewBox="0 0 20 18" fill="none">
            <path d="M2 3h5l2 2h9a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" fill="currentColor"/>
          </svg>
          <span class="hm-folder-name">{dm.projectNames[2]}</span>
          <span class="hm-folder-badge">3</span>
        </div>
      </div>
    </div>
    <!-- Right: folder contents + terminal -->
    <div class="hm-content">
      <div class="hm-files" data-hm-files>
        <!-- file items injected by script -->
      </div>
      <div class="hm-prompt-area">
        <div class="hm-path" data-hm-path></div>
        <div class="hm-cmd" data-hm-cmd></div>
        <div class="hm-result" data-hm-result></div>
      </div>
    </div>
  </div>
</div>

<style>
  .hm-mt {
    width: 340px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: var(--bg-deep);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .hm-chrome {
    background: var(--bg-tertiary);
    padding: 5px 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border-default);
  }
  .hm-dots { display: flex; gap: 4px; }
  .hm-dot { width: 6px; height: 6px; border-radius: 50%; }
  .hm-dot-r { background: #ff5f57; }
  .hm-dot-y { background: #febc2e; }
  .hm-dot-g { background: #28c840; }
  .hm-title {
    font-family: var(--font-mono);
    font-size: 8px;
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
  }

  .hm-body {
    display: flex;
    height: 180px;
  }

  /* --- Folder tree (left) --- */
  .hm-tree {
    width: 38%;
    flex-shrink: 0;
    border-right: 1px solid var(--border-default);
    background: rgba(255,255,255,0.015);
    padding: 7px 0 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .hm-tree-header {
    font-family: var(--font-mono);
    font-size: 7px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    padding: 0 8px 4px;
    text-transform: none;
  }

  .hm-folder {
    padding: 0 4px;
  }
  .hm-folder-row {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px 6px;
    border-radius: 4px;
    cursor: default;
    transition: background 0.25s ease, color 0.25s ease;
    border-left: 2px solid transparent;
  }
  .hm-folder.hm-f-active .hm-folder-row {
    background: rgba(212,165,116,0.12);
    border-left-color: var(--accent-primary);
  }
  .hm-folder-icon {
    width: 8px;
    height: 8px;
    flex-shrink: 0;
    color: var(--text-muted);
    transition: color 0.25s ease;
  }
  .hm-folder.hm-f-active .hm-folder-icon {
    color: var(--accent-primary);
  }
  .hm-folder-name {
    font-family: var(--font-mono);
    font-size: 7px;
    color: var(--text-secondary);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.25s ease;
  }
  .hm-folder.hm-f-active .hm-folder-name {
    color: var(--text-primary);
  }
  .hm-folder-badge {
    font-family: var(--font-mono);
    font-size: 6.5px;
    background: rgba(255,255,255,0.07);
    color: var(--text-muted);
    padding: 0 4px;
    border-radius: 3px;
    min-width: 12px;
    text-align: center;
    line-height: 1.5;
  }

  /* click flash effect */
  .hm-folder.hm-f-click .hm-folder-row {
    background: rgba(212,165,116,0.25);
    transition: none;
  }

  /* --- Right content panel --- */
  .hm-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
  }

  .hm-files {
    flex: 1;
    padding: 6px 8px 3px;
    display: flex;
    flex-direction: column;
    gap: 1px;
    overflow: hidden;
  }

  .hm-file-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 6.5px;
    color: var(--text-secondary);
    opacity: 0;
    transform: translateX(4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    white-space: nowrap;
    line-height: 1.3;
  }
  .hm-file-item.hm-fv {
    opacity: 1;
    transform: translateX(0);
  }

  .hm-file-dot {
    width: 3px;
    height: 3px;
    border-radius: 1px;
    flex-shrink: 0;
  }
  .hm-file-dot.hm-fd-dir { background: var(--accent-primary); border-radius: 50%; }
  .hm-file-dot.hm-fd-file { background: var(--text-muted); }
  .hm-file-dot.hm-fd-config { background: var(--success); }
  .hm-file-dot.hm-fd-special { background: var(--warning); }

  /* --- Prompt area at bottom --- */
  .hm-prompt-area {
    border-top: 1px solid var(--border-default);
    padding: 4px 8px 5px;
    background: rgba(0,0,0,0.15);
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-height: 38px;
  }
  .hm-path {
    font-family: var(--font-mono);
    font-size: 6.5px;
    color: var(--accent-primary);
    white-space: nowrap;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .hm-path.hm-vis { opacity: 1; }
  .hm-path .hm-dollar {
    color: var(--text-muted);
  }

  .hm-cmd {
    font-family: var(--font-mono);
    font-size: 6.5px;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    min-height: 9px;
  }
  .hm-cmd .hm-cursor {
    display: inline-block;
    width: 4px;
    height: 8px;
    background: var(--accent-primary);
    vertical-align: middle;
    margin-left: 1px;
    animation: hm-blink 0.8s step-end infinite;
  }

  .hm-result {
    font-family: var(--font-mono);
    font-size: 6.5px;
    color: var(--success);
    white-space: nowrap;
    overflow: hidden;
    min-height: 9px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .hm-result.hm-vis { opacity: 1; }

  @keyframes hm-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (max-width: 768px) {
    .hm-mt { width: 100%; max-width: 340px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hm-file-item { opacity: 1; transform: none; }
    .hm-path, .hm-result { opacity: 1; }
    .hm-cmd .hm-cursor { animation: none; }
  }
</style>

<script>
  (function() {
    const root = document.querySelector('[data-hm-mt]') as HTMLElement;
    if (!root) return;

    const i18n = JSON.parse(root.dataset.i18n || '{}');
    const names = i18n.projectNames || ['my-app', 'api-server', 'docs'];

    const folders = root.querySelectorAll('[data-folder]');
    const filesEl = root.querySelector('[data-hm-files]') as HTMLElement;
    const pathEl = root.querySelector('[data-hm-path]') as HTMLElement;
    const cmdEl = root.querySelector('[data-hm-cmd]') as HTMLElement;
    const resultEl = root.querySelector('[data-hm-result]') as HTMLElement;

    interface FolderData {
      files: { name: string; type: 'dir' | 'file' | 'config' | 'special' }[];
      cmd: string;
      result: string;
    }

    const data: Record<string, FolderData> = {
      '0': {
        files: [
          { name: 'src/', type: 'dir' },
          { name: 'package.json', type: 'config' },
          { name: 'CLAUDE.md', type: 'special' },
          { name: '.env', type: 'config' },
          { name: 'tsconfig.json', type: 'file' },
        ],
        cmd: 'claude "fix auth"',
        result: '\u2713 3 files updated',
      },
      '1': {
        files: [
          { name: 'routes/', type: 'dir' },
          { name: 'server.ts', type: 'file' },
          { name: 'config.yaml', type: 'config' },
          { name: 'middleware/', type: 'dir' },
        ],
        cmd: 'claude "add endpoint"',
        result: '\u2713 routes/users.ts created',
      },
      '2': {
        files: [
          { name: 'README.md', type: 'file' },
          { name: 'guide.md', type: 'file' },
          { name: 'api.md', type: 'file' },
        ],
        cmd: 'claude "update docs"',
        result: '\u2713 2 files updated',
      },
    };

    const typeClass: Record<string, string> = {
      dir: 'hm-fd-dir',
      file: 'hm-fd-file',
      config: 'hm-fd-config',
      special: 'hm-fd-special',
    };

    function setActiveFolder(idx: string) {
      folders.forEach(f => f.classList.remove('hm-f-active'));
      root.querySelector(`[data-folder="${idx}"]`)?.classList.add('hm-f-active');
    }

    function flashFolder(idx: string) {
      const f = root.querySelector(`[data-folder="${idx}"]`);
      f?.classList.add('hm-f-click');
      setTimeout(() => f?.classList.remove('hm-f-click'), 150);
    }

    function showFiles(idx: string): Promise<void> {
      const d = data[idx];
      filesEl.innerHTML = '';
      const items: HTMLElement[] = [];
      d.files.forEach(file => {
        const div = document.createElement('div');
        div.className = 'hm-file-item';
        const dot = document.createElement('span');
        dot.className = 'hm-file-dot ' + (typeClass[file.type] || 'hm-fd-file');
        div.appendChild(dot);
        const span = document.createElement('span');
        span.textContent = file.name;
        div.appendChild(span);
        filesEl.appendChild(div);
        items.push(div);
      });
      return new Promise(resolve => {
        items.forEach((item, i) => {
          setTimeout(() => {
            item.classList.add('hm-fv');
            if (i === items.length - 1) setTimeout(resolve, 80);
          }, i * 70);
        });
        if (items.length === 0) resolve();
      });
    }

    function showPath(idx: string) {
      const name = names[Number(idx)] || 'project';
      pathEl.innerHTML = '~/projects/' + name + ' <span class="hm-dollar">$</span>';
      pathEl.classList.add('hm-vis');
    }

    function clearPrompt() {
      pathEl.classList.remove('hm-vis');
      pathEl.innerHTML = '';
      cmdEl.innerHTML = '';
      resultEl.innerHTML = '';
      resultEl.classList.remove('hm-vis');
    }

    function typeCmd(text: string): Promise<void> {
      return new Promise(resolve => {
        let i = 0;
        cmdEl.innerHTML = '<span class="hm-cursor"></span>';
        const iv = setInterval(() => {
          if (!running) { clearInterval(iv); resolve(); return; }
          i++;
          if (i <= text.length) {
            cmdEl.innerHTML = text.slice(0, i) + '<span class="hm-cursor"></span>';
          } else {
            clearInterval(iv);
            cmdEl.textContent = text;
            resolve();
          }
        }, 45);
      });
    }

    function showResult(text: string) {
      resultEl.textContent = text;
      resultEl.classList.add('hm-vis');
    }

    function resetState() {
      setActiveFolder('0');
      filesEl.innerHTML = '';
      clearPrompt();
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      setActiveFolder('0');
      showFiles('0');
      showPath('0');
      cmdEl.textContent = data['0'].cmd;
      resultEl.textContent = data['0'].result;
      resultEl.classList.add('hm-vis');
      pathEl.classList.add('hm-vis');
      return;
    }

    let running = false;
    let animId: ReturnType<typeof setTimeout> | null = null;

    function wait(ms: number): Promise<void> {
      return new Promise(resolve => { animId = setTimeout(resolve, ms); });
    }

    async function startLoop() {
      while (running) {
        // 0-1s: Show my-app
        resetState();
        setActiveFolder('0');
        showPath('0');
        await showFiles('0');
        await wait(600);
        if (!running) break;

        // 1-3s: Type command, show result
        await typeCmd(data['0'].cmd);
        if (!running) break;
        await wait(300);
        if (!running) break;
        showResult(data['0'].result);
        await wait(1200);
        if (!running) break;

        // 3-4s: Switch to api-server
        flashFolder('1');
        await wait(150);
        if (!running) break;
        setActiveFolder('1');
        clearPrompt();
        filesEl.querySelectorAll('.hm-file-item').forEach(el => {
          (el as HTMLElement).style.opacity = '0';
        });
        await wait(250);
        if (!running) break;

        // 4-5.5s: Show api-server files + command
        showPath('1');
        await showFiles('1');
        await wait(400);
        if (!running) break;
        await typeCmd(data['1'].cmd);
        if (!running) break;
        await wait(300);
        if (!running) break;
        showResult(data['1'].result);
        await wait(1200);
        if (!running) break;

        // 7-8s: Switch to docs
        flashFolder('2');
        await wait(150);
        if (!running) break;
        setActiveFolder('2');
        clearPrompt();
        filesEl.querySelectorAll('.hm-file-item').forEach(el => {
          (el as HTMLElement).style.opacity = '0';
        });
        await wait(250);
        if (!running) break;

        // 8-9s: Show docs files
        showPath('2');
        await showFiles('2');
        await wait(400);
        if (!running) break;
        await typeCmd(data['2'].cmd);
        if (!running) break;
        await wait(300);
        if (!running) break;
        showResult(data['2'].result);
        await wait(1400);
        if (!running) break;

        // Fade & loop
        root.style.opacity = '0';
        root.style.transition = 'opacity 0.4s ease';
        await wait(400);
        if (!running) break;
        root.style.opacity = '1';
      }
    }

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting && !running) {
          running = true;
          startLoop();
        } else if (!e.isIntersecting && running) {
          running = false;
          if (animId) { clearTimeout(animId); animId = null; }
          resetState();
          root.style.opacity = '1';
        }
      });
    }, { threshold: 0.3 });
    obs.observe(root);
  })();
</script>
