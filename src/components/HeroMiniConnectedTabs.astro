---
import { getLocaleFromUrl, t } from '../i18n';
import en from '../i18n/translations/en';
import ja from '../i18n/translations/ja';

const locale = getLocaleFromUrl(Astro.url);
const translations = locale === 'ja' ? ja : en;
const dm = translations.demos.miniConnectedTabs;

const scriptI18n = {
  tabA: dm.tabA,
  tabB: dm.tabB,
  tabC: dm.tabC,
  paneALines: dm.paneALines,
  paneBLines: dm.paneBLines,
  synced: dm.synced,
};
---

<div class="hm-ct" data-hm-ct data-i18n={JSON.stringify(scriptI18n)}>
  <div class="hm-chrome">
    <div class="hm-dots">
      <span class="hm-dot hm-dot-r"></span>
      <span class="hm-dot hm-dot-y"></span>
      <span class="hm-dot hm-dot-g"></span>
    </div>
    <span class="hm-title">{t(locale, 'demos.miniConnectedTabs.windowTitle')}</span>
  </div>
  <div class="hm-ct-body">
    <!-- Tab strip -->
    <div class="hm-ct-tabstrip">
      <span class="hm-ct-tab hm-ct-tab-a hm-ct-tab-active" data-ct-tab="a">{dm.tabA}</span>
      <span class="hm-ct-tab hm-ct-tab-b" data-ct-tab="b">{dm.tabB}</span>
      <span class="hm-ct-tab hm-ct-tab-c" data-ct-tab="c">{dm.tabC}</span>
    </div>
    <!-- Sync bar -->
    <div class="hm-ct-syncbar">
      <div class="hm-ct-pulse" data-ct-pulse></div>
    </div>
    <!-- Split panes -->
    <div class="hm-ct-panes">
      <div class="hm-ct-pane hm-ct-pane-a">
        <div class="hm-ct-pane-header">
          <span class="hm-ct-pane-name">{dm.tabA}</span>
          <span class="hm-ct-status" data-ct-status-a></span>
        </div>
        <div class="hm-ct-pane-lines">
          <div class="hm-ct-line" data-ct-line-a="0"></div>
          <div class="hm-ct-line" data-ct-line-a="1"></div>
          <div class="hm-ct-line" data-ct-line-a="2"></div>
        </div>
      </div>
      <div class="hm-ct-divider"></div>
      <div class="hm-ct-pane hm-ct-pane-b">
        <div class="hm-ct-pane-header">
          <span class="hm-ct-pane-name">{dm.tabB}</span>
          <span class="hm-ct-status" data-ct-status-b></span>
        </div>
        <div class="hm-ct-pane-lines">
          <div class="hm-ct-line" data-ct-line-b="0"></div>
          <div class="hm-ct-line" data-ct-line-b="1"></div>
          <div class="hm-ct-line" data-ct-line-b="2"></div>
        </div>
      </div>
    </div>
    <!-- SYNCED badge -->
    <div class="hm-ct-badge" data-ct-badge>{dm.synced}</div>
  </div>
</div>

<style>
  .hm-ct {
    width: 340px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: var(--bg-deep);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .hm-chrome {
    background: var(--bg-tertiary);
    padding: 5px 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border-default);
  }
  .hm-dots { display: flex; gap: 4px; }
  .hm-dot { width: 6px; height: 6px; border-radius: 50%; }
  .hm-dot-r { background: #ff5f57; }
  .hm-dot-y { background: #febc2e; }
  .hm-dot-g { background: #28c840; }
  .hm-title {
    font-family: var(--font-mono);
    font-size: 8px;
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
  }

  .hm-ct-body {
    height: 180px;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* Tab strip */
  .hm-ct-tabstrip {
    display: flex;
    align-items: center;
    gap: 1px;
    padding: 0 4px;
    background: rgba(255,255,255,0.02);
    border-bottom: 1px solid var(--border-default);
  }
  .hm-ct-tab {
    font-family: var(--font-mono);
    font-size: 7.5px;
    color: var(--text-muted);
    padding: 4px 8px;
    cursor: default;
    border-left: 2px solid transparent;
    transition: all var(--transition-normal) ease;
    position: relative;
  }
  .hm-ct-tab-a { border-left-color: var(--success); }
  .hm-ct-tab-b { border-left-color: #6ba4d4; }
  .hm-ct-tab-c { border-left-color: var(--accent-primary); }
  .hm-ct-tab.hm-ct-tab-active {
    color: var(--text-primary);
    background: rgba(255,255,255,0.04);
  }
  .hm-ct-tab.hm-ct-tab-glow {
    box-shadow: 0 0 8px rgba(212,165,116,0.4);
  }

  /* Sync bar */
  .hm-ct-syncbar {
    height: 2px;
    background: var(--border-default);
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }
  .hm-ct-pulse {
    position: absolute;
    top: 0;
    left: 0;
    width: 25%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--accent-primary), transparent);
    opacity: 0;
    transform: translateX(-100%);
  }
  .hm-ct-pulse.hm-ct-pulse-active {
    opacity: 1;
    animation: hm-ct-pulse-slide 0.8s ease-in-out forwards;
  }

  @keyframes hm-ct-pulse-slide {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(400%); }
  }

  /* Split panes */
  .hm-ct-panes {
    flex: 1;
    display: flex;
    min-height: 0;
  }
  .hm-ct-pane {
    flex: 1;
    padding: 6px 7px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .hm-ct-divider {
    width: 1px;
    background: var(--border-default);
    flex-shrink: 0;
  }
  .hm-ct-pane-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3px;
  }
  .hm-ct-pane-name {
    font-family: var(--font-mono);
    font-size: 7px;
    color: var(--text-tertiary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Status dots */
  .hm-ct-status {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--text-muted);
    flex-shrink: 0;
    transition: background var(--transition-normal) ease;
  }
  .hm-ct-status.hm-ct-status-running {
    background: var(--warning);
    animation: hm-ct-dot-pulse 1.2s ease-in-out infinite;
  }
  .hm-ct-status.hm-ct-status-done {
    background: var(--success);
    animation: none;
  }

  @keyframes hm-ct-dot-pulse {
    0%, 100% { opacity: 0.4; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  /* Terminal lines */
  .hm-ct-line {
    font-family: var(--font-mono);
    font-size: 7px;
    line-height: 1.6;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .hm-ct-line.hm-vis { opacity: 1; }

  /* SYNCED badge */
  .hm-ct-badge {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%) scale(0.85);
    font-family: var(--font-mono);
    font-size: 7px;
    letter-spacing: 0.1em;
    color: var(--success);
    background: rgba(124,179,130,0.12);
    border: 1px solid var(--success);
    padding: 2px 8px;
    border-radius: 8px;
    opacity: 0;
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }
  .hm-ct-badge.hm-ct-badge-show {
    opacity: 1;
    transform: translateX(-50%) scale(1);
  }

  @media (max-width: 768px) {
    .hm-ct { width: 100%; max-width: 340px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hm-ct-line { opacity: 1; }
    .hm-ct-status { animation: none !important; }
    .hm-ct-pulse { animation: none !important; }
    .hm-ct-badge { opacity: 1; transform: translateX(-50%) scale(1); }
  }
</style>

<script>
  (function() {
    const root = document.querySelector('[data-hm-ct]') as HTMLElement;
    if (!root) return;

    const i18n = JSON.parse(root.dataset.i18n || '{}');

    const paneALines = root.querySelectorAll('[data-ct-line-a]');
    const paneBLines = root.querySelectorAll('[data-ct-line-b]');
    const statusA = root.querySelector('[data-ct-status-a]') as HTMLElement;
    const statusB = root.querySelector('[data-ct-status-b]') as HTMLElement;
    const pulse = root.querySelector('[data-ct-pulse]') as HTMLElement;
    const badge = root.querySelector('[data-ct-badge]') as HTMLElement;
    const tabB = root.querySelector('[data-ct-tab="b"]') as HTMLElement;
    const tabC = root.querySelector('[data-ct-tab="c"]') as HTMLElement;

    const aLines = i18n.paneALines || ['> fix auth middleware', '+ Added token refresh', '\u2713 Done. 3 files changed'];
    const bLines = i18n.paneBLines || ['Context from Tab A', 'Auth module updated', '\u2713 Dependencies resolved'];

    // Set line content
    paneALines.forEach((el, i) => { (el as HTMLElement).textContent = aLines[i] || ''; });
    paneBLines.forEach((el, i) => { (el as HTMLElement).textContent = bLines[i] || ''; });

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      paneALines.forEach(el => el.classList.add('hm-vis'));
      paneBLines.forEach(el => el.classList.add('hm-vis'));
      statusA?.classList.add('hm-ct-status-done');
      statusB?.classList.add('hm-ct-status-done');
      badge?.classList.add('hm-ct-badge-show');
      return;
    }

    let running = false;
    let animId: ReturnType<typeof setTimeout> | null = null;

    function wait(ms: number): Promise<void> {
      return new Promise(resolve => { animId = setTimeout(resolve, ms); });
    }

    function resetState() {
      paneALines.forEach(el => el.classList.remove('hm-vis'));
      paneBLines.forEach(el => el.classList.remove('hm-vis'));
      statusA?.classList.remove('hm-ct-status-running', 'hm-ct-status-done');
      statusB?.classList.remove('hm-ct-status-running', 'hm-ct-status-done');
      pulse?.classList.remove('hm-ct-pulse-active');
      badge?.classList.remove('hm-ct-badge-show');
      tabB?.classList.remove('hm-ct-tab-glow');
      tabC?.classList.remove('hm-ct-tab-glow');
    }

    function showLinesStaggered(lines: NodeListOf<Element>, delay = 300) {
      lines.forEach((el, i) => {
        setTimeout(() => { if (running) el.classList.add('hm-vis'); }, i * delay);
      });
    }

    function firePulse(): Promise<void> {
      return new Promise(resolve => {
        pulse?.classList.remove('hm-ct-pulse-active');
        // Force reflow to restart animation
        void pulse?.offsetWidth;
        pulse?.classList.add('hm-ct-pulse-active');
        animId = setTimeout(() => {
          pulse?.classList.remove('hm-ct-pulse-active');
          resolve();
        }, 850);
      });
    }

    async function startLoop() {
      while (running) {
        // Phase 1 (0-1.5s): Reset. Tab A active. Pane A lines appear staggered. Status-A = pulsing amber.
        resetState();
        statusA?.classList.add('hm-ct-status-running');
        showLinesStaggered(paneALines, 350);
        await wait(1500);
        if (!running) break;

        // Phase 2 (1.5-3s): Pane A final line visible, status-A turns green.
        statusA?.classList.remove('hm-ct-status-running');
        statusA?.classList.add('hm-ct-status-done');
        await wait(1500);
        if (!running) break;

        // Phase 3 (3-4s): Sync pulse slides left->right. Tab B glows. Status-B pulsing amber briefly.
        statusB?.classList.add('hm-ct-status-running');
        tabB?.classList.add('hm-ct-tab-glow');
        await firePulse();
        if (!running) break;
        await wait(150);
        if (!running) break;
        tabB?.classList.remove('hm-ct-tab-glow');

        // Phase 4 (4-5.5s): Pane B lines appear staggered. Status-B turns green. Badge fades in.
        showLinesStaggered(paneBLines, 350);
        await wait(1000);
        if (!running) break;
        statusB?.classList.remove('hm-ct-status-running');
        statusB?.classList.add('hm-ct-status-done');
        badge?.classList.add('hm-ct-badge-show');
        await wait(500);
        if (!running) break;

        // Phase 5 (5.5-6.5s): Second sync pulse. Tab C glows.
        tabC?.classList.add('hm-ct-tab-glow');
        await firePulse();
        if (!running) break;
        await wait(150);
        if (!running) break;
        tabC?.classList.remove('hm-ct-tab-glow');

        // Phase 6 (6.5-8s): Hold for readability.
        await wait(1500);
        if (!running) break;

        // Phase 7 (8-8.5s): Badge fades out. Opacity fade to 0.
        badge?.classList.remove('hm-ct-badge-show');
        await wait(300);
        if (!running) break;
        root.style.opacity = '0';
        root.style.transition = 'opacity 0.4s ease';
        await wait(500);
        if (!running) break;

        // Loop restart
        root.style.opacity = '1';
      }
    }

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting && !running) {
          running = true;
          startLoop();
        } else if (!e.isIntersecting && running) {
          running = false;
          if (animId) { clearTimeout(animId); animId = null; }
          resetState();
          root.style.opacity = '1';
        }
      });
    }, { threshold: 0.3 });
    obs.observe(root);
  })();
</script>
