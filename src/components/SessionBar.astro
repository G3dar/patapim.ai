---
/**
 * SessionBar — shows active remote devices below the navbar for signed-in users.
 * Entirely client-side: works on prerendered pages, hidden for anonymous users.
 */
---

<div class="session-bar" id="session-bar" style="display:none;">
  <div class="session-bar-inner container">
    <div class="session-devices" id="session-devices"></div>
    <a href="/go" class="session-dashboard-link">Dashboard &rarr;</a>
  </div>
</div>

<script>
  (async () => {
    const bar = document.getElementById('session-bar');
    const container = document.getElementById('session-devices');
    if (!bar || !container) return;

    // Check auth
    let authenticated = false;
    try {
      const res = await fetch('/api/auth/session');
      const data = await res.json();
      authenticated = data.authenticated;
    } catch { return; }
    if (!authenticated) return;

    // Fetch devices
    let devices = [];
    try {
      const res = await fetch('/api/device/list');
      const data = await res.json();
      devices = (data.devices || []).filter((d: any) => d.status === 'online');
    } catch { return; }
    if (devices.length === 0) return;

    // Render device pills
    container.innerHTML = devices.map((d: any) => {
      const badges = renderBadges(d.terminalCounts);
      const totalTerminals = d.terminalCounts
        ? (d.terminalCounts.attention + d.terminalCounts.busy + d.terminalCounts.planMode + d.terminalCounts.idle)
        : d.terminalCount || 0;
      const location = [d.city, d.country].filter(Boolean).join(', ');
      const meta = [
        totalTerminals > 0 ? totalTerminals + ' terminal' + (totalTerminals > 1 ? 's' : '') : '',
        location
      ].filter(Boolean).join(' · ');

      const terminalLine = totalTerminals > 0
        ? totalTerminals + ' terminal' + (totalTerminals > 1 ? 's' : '')
        : 'Online';

      return `<button class="session-device" data-token="${esc(d.token)}">
        <span class="session-icon">${deviceIcon(d.platform)}</span>
        <div class="session-info">
          <span class="session-name">${esc(d.deviceName)}</span>
          ${location ? '<span class="session-location">' + esc(location) + '</span>' : ''}
          <span class="session-terminals">${esc(terminalLine)}${badges ? ' ' + badges : ''}</span>
        </div>
      </button>`;
    }).join('');

    // Show bar + adjust page padding
    bar.style.display = '';
    document.documentElement.style.setProperty('--session-bar-height', '80px');

    // Click to connect
    container.addEventListener('click', async (e: Event) => {
      const btn = (e.target as Element).closest('.session-device') as HTMLElement | null;
      if (!btn || btn.classList.contains('connecting')) return;
      btn.classList.add('connecting');
      btn.style.opacity = '0.5';
      try {
        const res = await fetch('/api/device/connect-token', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ deviceToken: btn.dataset.token }),
        });
        const result = await res.json();
        if (result.connectToken && result.tunnelUrl) {
          window.location.href =
            '/remote?t=' + encodeURIComponent(result.connectToken) +
            '&url=' + encodeURIComponent(result.tunnelUrl) +
            '&d=' + encodeURIComponent(btn.dataset.token || '') +
            '&v=' + Date.now();
          return;
        }
      } catch {}
      btn.classList.remove('connecting');
      btn.style.opacity = '';
    });

    function deviceIcon(platform: string) {
      const p = (platform || '').toLowerCase();
      if (p === 'darwin') {
        return '<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>';
      }
      if (p === 'linux') {
        return '<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.368 1.884 1.43.868.065 1.157-.49 1.291-1.07.134-.49.139-1.17.064-2.202a9.37 9.37 0 00-.109-.634c-.061-.294-.158-.653-.326-1.07-.299-.726-.694-1.35-.991-1.727a6.11 6.11 0 00-.412-.49c.044-.167.088-.335.122-.49.217-.993.104-1.996-.261-2.886-.36-.876-.972-1.608-1.544-2.21-.233-.246-.454-.468-.641-.67-.192-.21-.334-.392-.429-.561a3.464 3.464 0 01-.108-.251c-.142-.409-.24-.848-.313-1.476-.066-.61-.097-1.382-.201-2.372-.142-1.344-.564-2.564-1.3-3.38C14.328.383 13.46 0 12.504 0z"/></svg>';
      }
      // Windows/default
      return '<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M3 12V6.75l6-1.32v6.48L3 12zm6.98.09l.02 6.63 6 1.32V12.13l-6.02-.04zM10 5.28L16 4v7.88l-6-.05V5.28zM16.98 12.08L17 20l7-1.12V12.1l-7.02-.02zM17 4.5L24 3.42v8.52l-7 .06V4.5z"/></svg>';
    }

    function renderBadges(tc: any) {
      if (!tc) return '';
      let html = '';
      if (tc.attention > 0) html += `<span class="sb-badge sb-attention" title="${tc.attention} finished">${tc.attention}</span>`;
      if (tc.busy > 0) html += `<span class="sb-badge sb-busy" title="${tc.busy} processing">${tc.busy}</span>`;
      if (tc.planMode > 0) html += `<span class="sb-badge sb-plan" title="${tc.planMode} plan mode">${tc.planMode}</span>`;
      if (tc.idle > 0) html += `<span class="sb-badge sb-idle" title="${tc.idle} idle">${tc.idle}</span>`;
      return html;
    }

    function esc(s: string) {
      if (!s) return '';
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
  })();
</script>

<style is:global>
  :root {
    --session-bar-height: 0px;
  }

  .session-bar {
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    z-index: 999;
    background: rgba(10, 10, 12, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
    height: 80px;
  }

  .session-bar-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 12px;
  }

  .session-devices {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    overflow-x: auto;
  }

  .session-device {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 22px;
    border-radius: 14px;
    border: 1px solid rgba(34, 197, 94, 0.25);
    background: rgba(34, 197, 94, 0.06);
    color: var(--text-primary);
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
    flex-shrink: 0;
  }
  .session-device:hover {
    background: rgba(34, 197, 94, 0.12);
    border-color: rgba(34, 197, 94, 0.5);
    box-shadow: 0 0 12px rgba(34, 197, 94, 0.15);
  }
  .session-device.connecting {
    pointer-events: none;
  }

  .session-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.4);
  }

  .session-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 9px;
    background: rgba(34, 197, 94, 0.12);
    color: #22c55e;
    flex-shrink: 0;
    transition: color 0.15s, background 0.15s;
  }
  .session-device:hover .session-icon {
    color: #4ade80;
    background: rgba(34, 197, 94, 0.2);
  }
  .session-icon svg {
    width: 17px;
    height: 17px;
  }

  .session-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .session-name {
    font-family: 'Inter', 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 1.3;
    color: #f1f5f9;
    letter-spacing: -0.01em;
  }

  .session-location {
    font-size: 12.5px;
    color: #94a3b8;
    line-height: 1.3;
  }

  .session-terminals {
    font-size: 12px;
    color: #4ade80;
    line-height: 1.3;
    font-weight: 500;
  }

  /* Terminal count badges — same colors as go.astro */
  .sb-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 9px;
    font-size: 11px;
    font-weight: 600;
    line-height: 1;
  }
  .sb-attention { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
  .sb-busy { background: rgba(239, 68, 68, 0.15); color: #ef4444; animation: sb-pulse 2s ease-in-out infinite; }
  .sb-plan { background: rgba(17, 168, 205, 0.15); color: #11a8cd; }
  .sb-idle { background: rgba(255, 255, 255, 0.08); color: var(--text-muted); }

  @keyframes sb-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .session-dashboard-link {
    color: var(--text-muted);
    font-size: 12px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .session-dashboard-link:hover {
    color: var(--accent-primary);
  }

  /* Push page content down when session bar is visible */
  main, .hero, .legal-page, .releases-page {
    padding-top: calc(var(--session-bar-height));
  }

  @media (max-width: 640px) {
    .session-bar-inner {
      padding: 0 12px;
    }
    .session-device {
      padding: 5px 10px;
    }
    .session-name {
      font-size: 12px;
    }
    .session-meta {
      font-size: 10px;
    }
    .session-dashboard-link {
      font-size: 11px;
    }
  }
</style>
