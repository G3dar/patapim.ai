---
import { getLocaleFromUrl, t } from '../i18n';
import en from '../i18n/translations/en';
import ja from '../i18n/translations/ja';

const locale = getLocaleFromUrl(Astro.url);
const translations = locale === 'ja' ? ja : en;

const boolData = [
  { patapim: true, vscode: false, cursor: false, terminal: true },
  { patapim: true, vscode: false, cursor: false, terminal: false },
  { patapim: true, vscode: false, cursor: false, terminal: true },
  { patapim: true, vscode: false, cursor: false, terminal: false },
  { patapim: true, vscode: false, cursor: false, terminal: false },
  { patapim: true, vscode: false, cursor: false, terminal: false },
  { patapim: true, vscode: false, cursor: false, terminal: false },
  { patapim: true, vscode: true, cursor: true, terminal: false },
  { patapim: true, vscode: true, cursor: true, terminal: false },
  { patapim: true, vscode: true, cursor: true, terminal: false },
  { patapim: true, vscode: true, cursor: true, terminal: false },
  { patapim: true, vscode: true, cursor: true, terminal: true },
  { patapim: true, vscode: false, cursor: false, terminal: false },
  { patapim: true, vscode: false, cursor: false, terminal: false },
  { patapim: true, vscode: true, cursor: false, terminal: true },
];

const rows = translations.comparisonTable.features.map((feature, i) => ({
  feature,
  ...boolData[i],
}));
---

<section class="section comparison-section" id="comparison">
  <div class="container">
    <div class="section-header">
      <span class="section-label">{t(locale, 'comparisonTable.label')}</span>
      <h2 class="section-title">{t(locale, 'comparisonTable.title')}</h2>
      <p class="section-subtitle">{t(locale, 'comparisonTable.subtitle')}</p>
    </div>

    <div class="table-wrapper">
      <table class="comparison-table">
        <thead>
          <tr>
            <th class="feature-col">{t(locale, 'comparisonTable.headerFeature')}</th>
            <th class="tool-col highlight">{t(locale, 'comparisonTable.headerPatapim')}</th>
            <th class="tool-col">{t(locale, 'comparisonTable.headerVscode')}</th>
            <th class="tool-col">{t(locale, 'comparisonTable.headerCursor')}</th>
            <th class="tool-col">{t(locale, 'comparisonTable.headerTerminal')}</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <td class="feature-col">{row.feature}</td>
              <td class={`tool-col highlight ${row.patapim ? 'yes' : 'no'}`}>
                {row.patapim ? <span class="check-mark">&#x2714;</span> : <span class="x-mark">&#x2014;</span>}
              </td>
              <td class={`tool-col ${row.vscode ? 'yes' : 'no'}`}>
                {row.vscode ? <span class="check-mark dim">&#x2714;</span> : <span class="x-mark">&#x2014;</span>}
              </td>
              <td class={`tool-col ${row.cursor ? 'yes' : 'no'}`}>
                {row.cursor ? <span class="check-mark dim">&#x2714;</span> : <span class="x-mark">&#x2014;</span>}
              </td>
              <td class={`tool-col ${row.terminal ? 'yes' : 'no'}`}>
                {row.terminal ? <span class="check-mark dim">&#x2714;</span> : <span class="x-mark">&#x2014;</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison-section {
    background: var(--bg-primary);
    border-top: 1px solid var(--border-subtle);
  }

  .table-wrapper {
    overflow-x: auto;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-default);
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  thead {
    background: var(--bg-secondary);
  }

  th {
    padding: 16px 20px;
    text-align: center;
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border-default);
  }

  th.feature-col {
    text-align: left;
  }

  th.highlight {
    color: var(--accent-primary);
    background: var(--accent-subtle);
  }

  td {
    padding: 14px 20px;
    text-align: center;
    border-bottom: 1px solid var(--border-subtle);
    color: var(--text-secondary);
  }

  td.feature-col {
    text-align: left;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
  }

  td.highlight {
    background: rgba(212, 165, 116, 0.04);
  }

  tr:last-child td {
    border-bottom: none;
  }

  tr:hover td {
    background: var(--bg-tertiary);
  }
  tr:hover td.highlight {
    background: rgba(212, 165, 116, 0.08);
  }

  .check-mark {
    color: var(--success);
    font-size: 16px;
  }
  .check-mark.dim {
    opacity: 0.6;
  }

  .x-mark {
    color: var(--text-muted);
    font-size: 14px;
  }

  @media (max-width: 768px) {
    td.feature-col {
      white-space: normal;
      font-size: 13px;
    }
    th, td {
      padding: 10px 12px;
    }
  }
</style>
