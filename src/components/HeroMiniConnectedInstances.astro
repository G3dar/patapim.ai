---
import { getLocaleFromUrl, t } from '../i18n';
import en from '../i18n/translations/en';
import ja from '../i18n/translations/ja';

const locale = getLocaleFromUrl(Astro.url);
const translations = locale === 'ja' ? ja : en;
const dm = translations.demos.miniConnectedInstances;
---

<div class="hm-ci" data-hm-ci>
  <div class="hm-chrome">
    <div class="hm-dots">
      <span class="hm-dot hm-dot-r"></span>
      <span class="hm-dot hm-dot-y"></span>
      <span class="hm-dot hm-dot-g"></span>
    </div>
    <span class="hm-title">{t(locale, 'demos.miniConnectedInstances.windowTitle')}</span>
  </div>

  <div class="hm-ci-body">
    <!-- Laptop (invokes) -->
    <div class="hm-ci-dev hm-ci-laptop" data-ci-dev="laptop">
      <div class="hm-ci-dev-header">
        <svg class="hm-ci-dev-icon" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="12" rx="1"/><path d="M2 20h20"/>
        </svg>
        <span class="hm-ci-dev-name">{dm.laptopLabel}</span>
        <span class="hm-ci-dot" data-ci-dot="laptop"></span>
      </div>
      <div class="hm-ci-dev-body">
        <div class="hm-ci-ln" data-ci-laptop="invoke"><span class="hm-ci-pr">$</span>{dm.invoke}</div>
        <div class="hm-ci-ln" data-ci-laptop="received"><span class="hm-ci-ok">&#x2713;</span>{dm.received}</div>
      </div>
    </div>

    <!-- Connection link -->
    <div class="hm-ci-link">
      <div class="hm-ci-wire"></div>
      <div class="hm-ci-beam" data-ci-beam></div>
    </div>

    <!-- Home computer (runs with its own context) -->
    <div class="hm-ci-dev hm-ci-home" data-ci-dev="home">
      <div class="hm-ci-dev-header">
        <svg class="hm-ci-dev-icon" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/>
        </svg>
        <span class="hm-ci-dev-name">{dm.homeLabel}</span>
        <span class="hm-ci-dot" data-ci-dot="home"></span>
      </div>
      <div class="hm-ci-dev-body">
        <div class="hm-ci-ln hm-ci-context">{dm.context}</div>
        <div class="hm-ci-ln" data-ci-home="0"><span class="hm-ci-run">&#x25B7;</span>{dm.homeLines[0]}</div>
        <div class="hm-ci-ln" data-ci-home="1"><span class="hm-ci-run">&#x25B7;</span>{dm.homeLines[1]}</div>
        <div class="hm-ci-ln" data-ci-home="2"><span class="hm-ci-ok">&#x2713;</span>{dm.homeLines[2]}</div>
      </div>
    </div>
  </div>
</div>

<style>
  .hm-ci {
    width: 340px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: var(--bg-deep);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .hm-chrome {
    background: var(--bg-tertiary);
    padding: 5px 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border-default);
  }
  .hm-dots { display: flex; gap: 4px; }
  .hm-dot { width: 6px; height: 6px; border-radius: 50%; }
  .hm-dot-r { background: #ff5f57; }
  .hm-dot-y { background: #febc2e; }
  .hm-dot-g { background: #28c840; }
  .hm-title {
    font-family: var(--font-mono);
    font-size: 8px;
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
  }

  .hm-ci-body {
    height: 180px;
    display: flex;
    align-items: stretch;
    gap: 0;
    padding: 14px 12px;
  }

  /* Device window */
  .hm-ci-dev {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-default);
    border-radius: 6px;
    background: rgba(255,255,255,0.02);
    overflow: hidden;
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .hm-ci-dev.hm-ci-active {
    border-color: var(--accent-primary);
    box-shadow: 0 0 10px rgba(212,165,116,0.22);
  }

  .hm-ci-dev-header {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px 6px;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--border-default);
  }
  .hm-ci-dev-icon { color: var(--text-tertiary); flex-shrink: 0; }
  .hm-ci-dev-name {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 7px;
    color: var(--text-tertiary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .hm-ci-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--text-muted);
    flex-shrink: 0;
    transition: background 0.3s ease;
  }
  .hm-ci-dot.hm-ci-run {
    background: var(--warning);
    animation: hm-ci-dot-pulse 1.1s ease-in-out infinite;
  }
  .hm-ci-dot.hm-ci-done { background: var(--success); animation: none; }
  @keyframes hm-ci-dot-pulse {
    0%, 100% { opacity: 0.4; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  .hm-ci-dev-body {
    flex: 1;
    min-height: 0;
    padding: 6px 7px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hm-ci-ln {
    font-family: var(--font-mono);
    font-size: 7.5px;
    line-height: 1.55;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    opacity: 0;
    transform: translateY(2px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .hm-ci-ln.hm-vis { opacity: 1; transform: none; }
  /* Persistent dim context line — present on the home box from the start */
  .hm-ci-context {
    opacity: 0.45;
    transform: none;
    margin-bottom: 2px;
  }
  .hm-ci-pr { color: var(--accent-primary); margin-right: 4px; }
  .hm-ci-ok { color: var(--success); margin-right: 4px; }
  .hm-ci-run { color: var(--warning); margin-right: 4px; }

  /* Connection link */
  .hm-ci-link {
    width: 30px;
    flex-shrink: 0;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hm-ci-wire {
    position: absolute;
    top: 50%;
    left: 1px;
    right: 1px;
    height: 1px;
    background: var(--border-strong);
    transform: translateY(-50%);
  }
  .hm-ci-beam {
    position: absolute;
    top: 50%;
    left: 0;
    width: 12px;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg, transparent, var(--accent-primary), transparent);
    transform: translate(-50%, -50%);
    opacity: 0;
    box-shadow: 0 0 6px rgba(212,165,116,0.5);
  }
  .hm-ci-beam.hm-ci-go { animation: hm-ci-beam-fwd 0.8s ease-in-out forwards; }
  .hm-ci-beam.hm-ci-back { animation: hm-ci-beam-back 0.8s ease-in-out forwards; }
  @keyframes hm-ci-beam-fwd {
    0% { left: 0; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }
  @keyframes hm-ci-beam-back {
    0% { left: 100%; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { left: 0; opacity: 0; }
  }

  @media (max-width: 768px) {
    .hm-ci { width: 100%; max-width: 340px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hm-ci-ln { opacity: 1; transform: none; }
    .hm-ci-context { opacity: 0.45; }
    .hm-ci-dot { animation: none !important; }
    .hm-ci-beam { animation: none !important; opacity: 0; }
  }
</style>

<script>
  (function() {
    const root = document.querySelector('[data-hm-ci]') as HTMLElement;
    if (!root) return;

    const laptop = root.querySelector('[data-ci-dev="laptop"]') as HTMLElement;
    const home = root.querySelector('[data-ci-dev="home"]') as HTMLElement;
    const dotLaptop = root.querySelector('[data-ci-dot="laptop"]') as HTMLElement;
    const dotHome = root.querySelector('[data-ci-dot="home"]') as HTMLElement;
    const lnInvoke = root.querySelector('[data-ci-laptop="invoke"]') as HTMLElement;
    const lnReceived = root.querySelector('[data-ci-laptop="received"]') as HTMLElement;
    const homeLines = Array.from(root.querySelectorAll('[data-ci-home]')) as HTMLElement[];
    const beam = root.querySelector('[data-ci-beam]') as HTMLElement;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      lnInvoke.classList.add('hm-vis');
      lnReceived.classList.add('hm-vis');
      homeLines.forEach(l => l.classList.add('hm-vis'));
      dotLaptop.classList.add('hm-ci-done');
      dotHome.classList.add('hm-ci-done');
      return;
    }

    let running = false;
    let animId: ReturnType<typeof setTimeout> | null = null;

    function wait(ms: number): Promise<void> {
      return new Promise(resolve => { animId = setTimeout(resolve, ms); });
    }

    function resetState() {
      lnInvoke.classList.remove('hm-vis');
      lnReceived.classList.remove('hm-vis');
      homeLines.forEach(l => l.classList.remove('hm-vis'));
      laptop.classList.remove('hm-ci-active');
      home.classList.remove('hm-ci-active');
      dotLaptop.classList.remove('hm-ci-run', 'hm-ci-done');
      dotHome.classList.remove('hm-ci-run', 'hm-ci-done');
      beam.classList.remove('hm-ci-go', 'hm-ci-back');
      root.style.opacity = '1';
      root.style.transition = '';
    }

    function fireBeam(dir: 'hm-ci-go' | 'hm-ci-back'): Promise<void> {
      return new Promise(resolve => {
        beam.classList.remove('hm-ci-go', 'hm-ci-back');
        void beam.offsetWidth; // restart animation
        beam.classList.add(dir);
        animId = setTimeout(() => {
          beam.classList.remove(dir);
          resolve();
        }, 820);
      });
    }

    async function startLoop() {
      while (running) {
        resetState();

        // 1. Laptop issues the remote invocation
        laptop.classList.add('hm-ci-active');
        dotLaptop.classList.add('hm-ci-run');
        await wait(500);
        if (!running) break;
        lnInvoke.classList.add('hm-vis');
        await wait(700);
        if (!running) break;

        // 2. Command travels to the home computer
        await fireBeam('hm-ci-go');
        if (!running) break;
        dotLaptop.classList.remove('hm-ci-run');
        home.classList.add('hm-ci-active');
        dotHome.classList.add('hm-ci-run');
        await wait(250);
        if (!running) break;

        // 3. Home runs with its own context, then finishes
        for (let i = 0; i < homeLines.length; i++) {
          homeLines[i].classList.add('hm-vis');
          await wait(600);
          if (!running) break;
        }
        if (!running) break;
        dotHome.classList.remove('hm-ci-run');
        dotHome.classList.add('hm-ci-done');
        await wait(400);
        if (!running) break;

        // 4. Polished result returns to the laptop
        await fireBeam('hm-ci-back');
        if (!running) break;
        lnReceived.classList.add('hm-vis');
        dotLaptop.classList.add('hm-ci-done');
        home.classList.remove('hm-ci-active');
        await wait(2000);
        if (!running) break;

        // 5. Fade out & loop
        root.style.transition = 'opacity 0.4s ease';
        root.style.opacity = '0';
        await wait(500);
        if (!running) break;
      }
    }

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting && !running) {
          running = true;
          startLoop();
        } else if (!e.isIntersecting && running) {
          running = false;
          if (animId) { clearTimeout(animId); animId = null; }
          resetState();
        }
      });
    }, { threshold: 0.3 });
    obs.observe(root);
  })();
</script>
