---
import { getLocaleFromUrl, t, getLocalePath } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);
const year = new Date().getFullYear();
const copyright = t(locale, 'footer.copyright').replace('{year}', String(year));
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="brand-icon">&#x276F;_</span>
          <span class="brand-text">patapim</span>
        </div>
        <p class="footer-tagline">{t(locale, 'footer.tagline')}</p>
        <a href="mailto:info@patapim.ai" class="footer-email">info@patapim.ai</a>
      </div>

      <div class="footer-col">
        <h4>{t(locale, 'footer.product')}</h4>
        <a href={`${lp('/')}#multi-terminal`}>{t(locale, 'footer.multiTerminal')}</a>
        <a href={`${lp('/')}#voice-dictation`}>{t(locale, 'footer.voiceDictation')}</a>
        <a href={`${lp('/')}#remote-access`}>{t(locale, 'footer.remoteAccess')}</a>
        <a href={lp('/pricing')}>{t(locale, 'common.pricing')}</a>
        <a href={lp('/download')}>{t(locale, 'common.download')}</a>
        <a href={lp('/releases')}>Release Notes</a>
      </div>

      <div class="footer-col">
        <h4>{t(locale, 'footer.documentation')}</h4>
        <a href={lp('/docs/getting-started/installation')}>{t(locale, 'footer.installation')}</a>
        <a href={lp('/docs/getting-started/quick-start')}>{t(locale, 'footer.quickStart')}</a>
        <a href={lp('/docs/features/multi-terminal')}>{t(locale, 'footer.multiTerminal')}</a>
        <a href={lp('/docs/features/remote-access')}>{t(locale, 'footer.remoteAccess')}</a>
      </div>

      <div class="footer-col">
        <h4>{t(locale, 'footer.community')}</h4>
        <a href="https://github.com/G3dar/patapim" target="_blank" rel="noopener">{t(locale, 'footer.github')}</a>
        <a href="https://github.com/G3dar/patapim/issues" target="_blank" rel="noopener">{t(locale, 'footer.issues')}</a>
        <a href="https://github.com/G3dar/patapim/discussions" target="_blank" rel="noopener">{t(locale, 'footer.discussions')}</a>
      </div>

      <div class="footer-col">
        <h4>{t(locale, 'footer.legal')}</h4>
        <a href={lp('/terms')}>{t(locale, 'footer.termsOfUse')}</a>
        <a href={lp('/privacy')}>{t(locale, 'footer.privacyPolicy')}</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p set:html={copyright} />
      <div class="footer-legal-links">
        <a href={lp('/terms')}>{t(locale, 'footer.terms')}</a>
        <span class="footer-dot">&middot;</span>
        <a href={lp('/privacy')}>{t(locale, 'footer.privacy')}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-primary);
    border-top: 1px solid var(--border-default);
    padding: var(--space-4xl) 0 var(--space-2xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: var(--space-4xl);
    margin-bottom: var(--space-4xl);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 18px;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .brand-icon {
    font-family: var(--font-mono);
    color: var(--accent-primary);
    font-size: 14px;
    background: var(--accent-subtle);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
  }

  .brand-text {
    font-variant: small-caps;
    letter-spacing: 0.5px;
  }

  .footer-tagline {
    color: var(--text-tertiary);
    font-size: 14px;
    max-width: 280px;
    line-height: 1.6;
  }

  .footer-email {
    color: var(--text-tertiary);
    font-size: 13px;
    text-decoration: none;
    margin-top: var(--space-sm);
    display: inline-block;
    transition: color var(--transition-fast);
  }
  .footer-email:hover {
    color: var(--accent-primary);
  }

  .footer-col h4 {
    color: var(--text-primary);
    font-size: 14px;
    font-weight: 600;
    margin-bottom: var(--space-lg);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-col a {
    color: var(--text-tertiary);
    font-size: 14px;
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .footer-col a:hover {
    color: var(--text-secondary);
  }

  .footer-bottom {
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-xl);
    text-align: center;
  }
  .footer-bottom p {
    color: var(--text-muted);
    font-size: 13px;
  }

  .footer-legal-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }
  .footer-legal-links a {
    color: var(--text-muted);
    font-size: 12px;
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .footer-legal-links a:hover {
    color: var(--text-secondary);
  }
  .footer-dot {
    color: var(--text-muted);
    font-size: 12px;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
