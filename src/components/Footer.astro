---
import { getLocaleFromUrl, t, getLocalePath } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);
const year = new Date().getFullYear();
const copyright = t(locale, 'footer.copyright').replace('{year}', String(year));

// terminal home anchors for EN; the interim ja home keeps the classic ids
const ja = locale === 'ja';
const aMulti = ja ? `${lp('/')}#multi-terminal` : `${lp('/')}#demo-multi-terminal`;
const aVoice = ja ? `${lp('/')}#voice-dictation` : `${lp('/')}#demo-voice-dictation`;
const aRemote = ja ? `${lp('/')}#remote-access` : `${lp('/')}#demo-remote-access`;
---

<footer class="tvf-footer">
  <div class="tvf-inner">
    <div class="tvf-grid">
      <div class="tvf-brand">
        <div class="tvf-brandrow">
          <span class="tv-brand-icon">&#x276F;_</span>
          <span class="tv-brand-sep">/</span>
          <span class="tv-brand-name">{t(locale, 'nav.brand')}</span>
        </div>
        <p class="tvf-tagline">{t(locale, 'footer.tagline')}</p>
        <a href="mailto:info@patapim.ai" class="tvf-email">info@patapim.ai</a>
      </div>

      <div class="tvf-col">
        <h4>{t(locale, 'footer.product')}</h4>
        <a href={aMulti}>{t(locale, 'footer.multiTerminal')}</a>
        <a href={aVoice}>{t(locale, 'footer.voiceDictation')}</a>
        <a href={aRemote}>{t(locale, 'footer.remoteAccess')}</a>
        <a href={lp('/download')}>{t(locale, 'common.download')}</a>
        <a href={lp('/pricing')}>Pricing</a>
        <a href={lp('/docs/releases')}>Release Notes</a>
      </div>

      <div class="tvf-col">
        <h4>{t(locale, 'footer.documentation')}</h4>
        <a href={lp('/docs/getting-started/installation')}>{t(locale, 'footer.installation')}</a>
        <a href={lp('/docs/getting-started/quick-start')}>{t(locale, 'footer.quickStart')}</a>
        <a href={lp('/docs/features/multi-terminal')}>{t(locale, 'footer.multiTerminal')}</a>
        <a href={lp('/docs/features/remote-access')}>{t(locale, 'footer.remoteAccess')}</a>
      </div>

      <div class="tvf-col">
        <h4>{t(locale, 'footer.legal')}</h4>
        <a href={lp('/terms')}>{t(locale, 'footer.termsOfUse')}</a>
        <a href={lp('/privacy')}>{t(locale, 'footer.privacyPolicy')}</a>
        <a href={lp('/about')}>About Us</a>
      </div>
    </div>

    <div class="tvf-bottom">
      <p set:html={copyright} />
      <div>
        <a href={lp('/terms')}>{t(locale, 'footer.terms')}</a>
        <span> · </span>
        <a href={lp('/privacy')}>{t(locale, 'footer.privacy')}</a>
      </div>
    </div>
  </div>
</footer>
