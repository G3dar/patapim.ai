---
// v2 mini demo: multi-terminal, folder-oriented. The sidebar (projects with
// their sub-terminals) is the protagonist; the terminal output on the right
// stays small. Everything is authored in markup and toggled by class, so
// Astro's scoped styles always apply (no runtime-created unstyled nodes).

const PROJECTS = [
  {
    name: 'convoy', badge: 2,
    terms: [{ n: 'api — claude' }, { n: 'tests' }],
    out: [
      { c: 'u', t: 'claude "fix the auth flow"' },
      { c: 'r', t: '▷ editing middleware…' },
      { c: 'k', t: '✓ 3 files updated' },
    ],
  },
  {
    name: 'eggscape', badge: 2,
    terms: [{ n: 'ui — codex' }, { n: 'scraper' }],
    out: [
      { c: 'u', t: 'codex "polish the lobby"' },
      { c: 'r', t: '▷ tweaking layout…' },
      { c: 'k', t: '✓ lobby updated' },
    ],
  },
  {
    name: 'dashboard', badge: 1,
    terms: [{ n: 'charts — gemini' }],
    out: [
      { c: 'u', t: 'gemini "fix the render bug"' },
      { c: 'r', t: '▷ profiling…' },
      { c: 'k', t: '✓ render fixed' },
    ],
  },
];
---

<div class="v2mt" data-v2mt>
  <div class="v2mt-chrome">
    <div class="v2mt-dots"><span class="d-r"></span><span class="d-y"></span><span class="d-g"></span></div>
    <span class="v2mt-title">PATAPIM — ~/projects</span>
  </div>
  <div class="v2mt-body">
    <!-- the star: projects with their sub-terminals -->
    <div class="v2mt-tree">
      {PROJECTS.map((p, pi) => (
        <div class="v2mt-proj" data-proj={pi}>
          <div class="v2mt-proj-row">
            <span class="v2mt-caret">▸</span>
            <span class="v2mt-proj-name">{p.name}</span>
            <span class="v2mt-badge">{p.badge}</span>
          </div>
          <div class="v2mt-terms">
            {p.terms.map((t, ti) => (
              <div class="v2mt-term" data-term={`${pi}-${ti}`}>
                <span class="v2mt-term-name">· {t.n}</span>
                <span class="v2mt-tdot"></span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
    <!-- quiet, small terminal output -->
    <div class="v2mt-out">
      {PROJECTS.map((p, pi) => (
        <div class="v2mt-sess" data-sess={pi}>
          <div class="v2mt-path">~/projects/{p.name} <span class="v2mt-dollar">$</span></div>
          {p.out.map((l, li) => (
            <div class={`v2mt-line v2mt-${l.c}`} data-line={`${pi}-${li}`}>{l.t}</div>
          ))}
          <div class="v2mt-cursor">█</div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .v2mt {
    width: 340px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: var(--bg-deep);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    font-family: var(--font-mono);
  }
  .v2mt-chrome {
    background: var(--bg-tertiary);
    padding: 5px 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border-default);
  }
  .v2mt-dots { display: flex; gap: 4px; }
  .v2mt-dots span { width: 6px; height: 6px; border-radius: 50%; }
  .d-r { background: #ff5f57; }
  .d-y { background: #febc2e; }
  .d-g { background: #28c840; }
  .v2mt-title { font-size: 8px; color: var(--text-tertiary); letter-spacing: 0.05em; }

  .v2mt-body { display: flex; height: 180px; }

  /* ===== projects + sub-terminals (the protagonist) ===== */
  .v2mt-tree {
    width: 56%;
    flex-shrink: 0;
    border-right: 1px solid var(--border-default);
    background: rgba(255, 255, 255, 0.015);
    padding: 8px 0 6px;
    overflow: hidden;
  }
  .v2mt-proj { padding: 0 5px; margin-bottom: 2px; }
  .v2mt-proj-row {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 4px 7px;
    border-radius: 4px;
    border-left: 2px solid transparent;
    transition: background 0.25s ease;
  }
  .v2mt-proj.on .v2mt-proj-row {
    background: var(--accent-subtle);
    border-left-color: var(--accent-primary);
  }
  .v2mt-caret { font-size: 8px; color: var(--text-muted); transition: transform 0.25s; }
  .v2mt-proj.on .v2mt-caret { transform: rotate(90deg); color: var(--accent-primary); }
  .v2mt-proj-name {
    font-size: 9px;
    font-weight: 600;
    color: var(--text-secondary);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.25s;
  }
  .v2mt-proj.on .v2mt-proj-name { color: var(--text-primary); }
  .v2mt-badge {
    font-size: 7px;
    background: rgba(255, 255, 255, 0.07);
    color: var(--text-muted);
    padding: 0 4px;
    border-radius: 3px;
    min-width: 12px;
    text-align: center;
    line-height: 1.6;
  }

  .v2mt-terms {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .v2mt-proj.on .v2mt-terms { max-height: 48px; }
  .v2mt-term {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2px 8px 2px 22px;
  }
  .v2mt-term-name {
    font-size: 7.5px;
    color: var(--text-tertiary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .v2mt-tdot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: transparent;
    flex-shrink: 0;
    transition: background 0.25s;
  }
  .v2mt-term.busy .v2mt-tdot { background: #f26d6d; animation: v2mt-busy 1.1s ease-in-out infinite; }
  .v2mt-term.done .v2mt-tdot { background: #4ade80; }
  @keyframes v2mt-busy { 50% { opacity: 0.35; } }

  /* ===== small terminal output ===== */
  .v2mt-out { flex: 1; min-width: 0; position: relative; }
  .v2mt-sess {
    position: absolute;
    inset: 0;
    padding: 8px 9px;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }
  .v2mt-sess.on { opacity: 1; }
  .v2mt-path {
    font-size: 7px;
    color: var(--accent-primary);
    white-space: nowrap;
    overflow: hidden;
    margin-bottom: 3px;
  }
  .v2mt-dollar { color: var(--text-muted); }
  .v2mt-line {
    font-size: 7px;
    line-height: 1.7;
    white-space: nowrap;
    overflow: hidden;
    opacity: 0;
    transform: translateX(4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .v2mt-line.vis { opacity: 1; transform: none; }
  .v2mt-u { color: var(--text-primary); }
  .v2mt-u::before { content: '❯ '; color: var(--accent-primary); }
  .v2mt-r { color: var(--text-tertiary); }
  .v2mt-k { color: #4ade80; }
  .v2mt-cursor {
    font-size: 7px;
    color: var(--accent-primary);
    animation: v2mt-blink 1s steps(1, end) infinite;
  }
  @keyframes v2mt-blink { 50% { opacity: 0; } }

  @media (max-width: 768px) {
    .v2mt { width: 100%; max-width: 340px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .v2mt-line { opacity: 1; transform: none; }
    .v2mt-cursor, .v2mt-term.busy .v2mt-tdot { animation: none; }
  }
</style>

<script>
  (function () {
    const root = document.querySelector('[data-v2mt]') as HTMLElement | null;
    if (!root) return;

    const projs = root.querySelectorAll('[data-proj]');
    const sesss = root.querySelectorAll('[data-sess]');
    const termsOf = (pi: number) => root.querySelectorAll(`[data-term^="${pi}-"]`);
    const linesOf = (pi: number) => root.querySelectorAll(`[data-line^="${pi}-"]`);

    let running = false;
    let timer: ReturnType<typeof setTimeout> | null = null;
    const wait = (ms: number) => new Promise<void>(r => { timer = setTimeout(r, ms); });

    function clearAll() {
      projs.forEach(p => p.classList.remove('on'));
      sesss.forEach(s => s.classList.remove('on'));
      root.querySelectorAll('[data-term]').forEach(t => t.classList.remove('busy', 'done'));
      root.querySelectorAll('[data-line]').forEach(l => l.classList.remove('vis'));
    }

    async function playProject(pi: number) {
      projs.forEach((p, i) => p.classList.toggle('on', i === pi));
      sesss.forEach((s, i) => s.classList.toggle('on', i === pi));
      const terms = termsOf(pi);
      const lines = linesOf(pi);
      terms.forEach(t => { t.classList.remove('done'); t.classList.add('busy'); });
      await wait(350);
      if (!running) return;
      for (let i = 0; i < lines.length; i++) {
        lines[i].classList.add('vis');
        await wait(i === lines.length - 1 ? 200 : 550);
        if (!running) return;
      }
      // work lands: terminals flip busy → done, one by one
      for (let i = 0; i < terms.length; i++) {
        terms[i].classList.remove('busy');
        terms[i].classList.add('done');
        await wait(300);
        if (!running) return;
      }
      await wait(1100);
    }

    async function loop() {
      while (running) {
        clearAll();
        for (let pi = 0; pi < projs.length; pi++) {
          await playProject(pi);
          if (!running) return;
          linesOf(pi).forEach(l => l.classList.remove('vis'));
          termsOf(pi).forEach(t => t.classList.remove('busy'));
        }
      }
    }

    if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
      projs[0]?.classList.add('on');
      sesss[0]?.classList.add('on');
      linesOf(0).forEach(l => l.classList.add('vis'));
      termsOf(0).forEach(t => t.classList.add('done'));
      return;
    }

    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting && !running) {
          running = true;
          loop();
        } else if (!e.isIntersecting && running) {
          running = false;
          if (timer) clearTimeout(timer);
          clearAll();
        }
      });
    }, { threshold: 0.3 });
    obs.observe(root);
  })();
</script>
