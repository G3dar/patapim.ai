---
import { getLocaleFromUrl, t } from '../i18n';
import en from '../i18n/translations/en';
import ja from '../i18n/translations/ja';

const locale = getLocaleFromUrl(Astro.url);
const translations = locale === 'ja' ? ja : en;
const dm = translations.demos.miniMultiAi;

const scriptI18n = {
  agents: dm.agents,
  task: dm.task,
  responses: dm.responses,
  comparing: dm.comparing,
  best: dm.best,
};
---

<div class="hm-mai" data-hm-mai data-i18n={JSON.stringify(scriptI18n)}>
  <div class="hm-chrome">
    <div class="hm-dots">
      <span class="hm-dot hm-dot-r"></span>
      <span class="hm-dot hm-dot-y"></span>
      <span class="hm-dot hm-dot-g"></span>
    </div>
    <span class="hm-title">{t(locale, 'demos.miniMultiAi.windowTitle')}</span>
  </div>
  <div class="hm-mai-body">
    <!-- Task bar -->
    <div class="hm-mai-task" data-mai-task>
      <svg class="hm-mai-broadcast" viewBox="0 0 16 16" fill="none">
        <path d="M8 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" fill="currentColor"/>
        <path d="M5.17 11.83a4.5 4.5 0 0 1 0-6.36" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M10.83 5.47a4.5 4.5 0 0 1 0 6.36" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M3.05 13.95a7.5 7.5 0 0 1 0-10.6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M12.95 3.35a7.5 7.5 0 0 1 0 10.6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <span class="hm-mai-task-text" data-mai-task-text></span>
    </div>
    <!-- Agent columns -->
    <div class="hm-mai-agents">
      <div class="hm-mai-agent" data-mai-agent="0">
        <div class="hm-mai-agent-border" style="background: #a78bfa;"></div>
        <div class="hm-mai-agent-header">
          <span class="hm-mai-dot" style="background: #a78bfa;" data-mai-dot="0"></span>
          <span class="hm-mai-agent-name">{dm.agents[0]}</span>
          <span class="hm-mai-check" data-mai-check="0"></span>
        </div>
        <div class="hm-mai-agent-response" data-mai-response="0"></div>
      </div>
      <div class="hm-mai-agent" data-mai-agent="1">
        <div class="hm-mai-agent-border" style="background: #60a5fa;"></div>
        <div class="hm-mai-agent-header">
          <span class="hm-mai-dot" style="background: #60a5fa;" data-mai-dot="1"></span>
          <span class="hm-mai-agent-name">{dm.agents[1]}</span>
          <span class="hm-mai-check" data-mai-check="1"></span>
        </div>
        <div class="hm-mai-agent-response" data-mai-response="1"></div>
      </div>
      <div class="hm-mai-agent" data-mai-agent="2">
        <div class="hm-mai-agent-border" style="background: #34d399;"></div>
        <div class="hm-mai-agent-header">
          <span class="hm-mai-dot" style="background: #34d399;" data-mai-dot="2"></span>
          <span class="hm-mai-agent-name">{dm.agents[2]}</span>
          <span class="hm-mai-check" data-mai-check="2"></span>
        </div>
        <div class="hm-mai-agent-response" data-mai-response="2"></div>
      </div>
    </div>
    <!-- Status line -->
    <div class="hm-mai-status" data-mai-status></div>
  </div>
</div>

<style>
  .hm-mai {
    width: 340px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: var(--bg-deep);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .hm-chrome {
    background: var(--bg-tertiary);
    padding: 5px 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border-default);
  }
  .hm-dots { display: flex; gap: 4px; }
  .hm-dot { width: 6px; height: 6px; border-radius: 50%; }
  .hm-dot-r { background: #ff5f57; }
  .hm-dot-y { background: #febc2e; }
  .hm-dot-g { background: #28c840; }
  .hm-title {
    font-family: var(--font-mono);
    font-size: 8px;
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
  }

  .hm-mai-body {
    height: 180px;
    display: flex;
    flex-direction: column;
    padding: 0;
  }

  /* --- Task bar --- */
  .hm-mai-task {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 6px 10px;
    border-bottom: 1px solid var(--border-default);
    background: rgba(255,255,255,0.02);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .hm-mai-task.hm-mai-vis { opacity: 1; }
  .hm-mai-broadcast {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    color: var(--accent-primary);
  }
  .hm-mai-task-text {
    font-family: var(--font-mono);
    font-size: 7.5px;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* --- Agent columns --- */
  .hm-mai-agents {
    flex: 1;
    display: flex;
    gap: 4px;
    padding: 6px 6px 4px;
    overflow: hidden;
  }

  .hm-mai-agent {
    flex: 1;
    min-width: 0;
    background: var(--bg-secondary);
    border-radius: 5px;
    border: 1px solid var(--border-default);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transition: opacity 0.3s ease, box-shadow 0.4s ease;
  }
  .hm-mai-agent.hm-mai-vis { opacity: 1; }
  .hm-mai-agent.hm-mai-glow {
    box-shadow: 0 0 8px rgba(212,165,116,0.25);
    border-color: rgba(212,165,116,0.35);
  }
  .hm-mai-agent.hm-mai-highlight {
    box-shadow: 0 0 12px rgba(124,179,130,0.3);
    border-color: rgba(124,179,130,0.4);
  }

  .hm-mai-agent-border {
    height: 2px;
    flex-shrink: 0;
  }

  .hm-mai-agent-header {
    display: flex;
    align-items: center;
    gap: 3px;
    padding: 4px 5px 2px;
  }
  .hm-mai-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
    opacity: 0.4;
    transition: opacity 0.2s ease;
  }
  .hm-mai-dot.hm-mai-pulse {
    opacity: 1;
    animation: hm-mai-pulse 0.6s ease-in-out infinite alternate;
  }
  .hm-mai-dot.hm-mai-done {
    opacity: 1;
    animation: none;
  }
  .hm-mai-agent-name {
    font-family: var(--font-mono);
    font-size: 7px;
    font-weight: 700;
    color: var(--text-secondary);
    white-space: nowrap;
    flex: 1;
  }
  .hm-mai-check {
    font-size: 7px;
    color: var(--success);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .hm-mai-check.hm-mai-vis { opacity: 1; }

  .hm-mai-agent-response {
    padding: 0 5px 5px;
    font-family: var(--font-mono);
    font-size: 6.5px;
    line-height: 1.45;
    color: var(--text-muted);
    word-break: break-word;
    overflow: hidden;
    flex: 1;
  }

  /* --- Status line --- */
  .hm-mai-status {
    padding: 4px 10px 6px;
    border-top: 1px solid var(--border-default);
    font-family: var(--font-mono);
    font-size: 7px;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    min-height: 18px;
    display: flex;
    align-items: center;
    background: rgba(0,0,0,0.12);
    opacity: 0;
    transition: opacity 0.3s ease, color 0.3s ease;
  }
  .hm-mai-status.hm-mai-vis { opacity: 1; }
  .hm-mai-status.hm-mai-success { color: var(--success); }

  /* --- Connecting glow line --- */
  .hm-mai-agents.hm-mai-connected {
    position: relative;
  }
  .hm-mai-agents.hm-mai-connected::after {
    content: '';
    position: absolute;
    left: 10px;
    right: 10px;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, #a78bfa, #60a5fa, #34d399);
    opacity: 0.5;
    animation: hm-mai-line-glow 1.5s ease-in-out infinite alternate;
    pointer-events: none;
  }

  @keyframes hm-mai-pulse {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(1.4); opacity: 1; }
  }
  @keyframes hm-mai-line-glow {
    0% { opacity: 0.3; }
    100% { opacity: 0.7; }
  }

  @media (max-width: 768px) {
    .hm-mai { width: 100%; max-width: 340px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hm-mai-task,
    .hm-mai-agent,
    .hm-mai-status,
    .hm-mai-check { opacity: 1; }
    .hm-mai-dot { opacity: 1; animation: none; }
    .hm-mai-agents::after { animation: none; }
  }
</style>

<script>
  (function() {
    const root = document.querySelector('[data-hm-mai]') as HTMLElement;
    if (!root) return;

    const i18n = JSON.parse(root.dataset.i18n || '{}');
    const agents = i18n.agents || ['Claude', 'Gemini', 'Codex'];
    const taskText = i18n.task || 'Optimize database queries';
    const responses = i18n.responses || [
      'Use connection pooling + index on user_id',
      'Batch queries, add Redis cache layer',
      'Rewrite as single JOIN, add composite index',
    ];
    const comparingText = i18n.comparing || 'Comparing approaches...';
    const bestText = i18n.best || '\u2713 Best: Combined strategy applied';

    const taskEl = root.querySelector('[data-mai-task]') as HTMLElement;
    const taskTextEl = root.querySelector('[data-mai-task-text]') as HTMLElement;
    const agentsContainer = root.querySelector('.hm-mai-agents') as HTMLElement;
    const agentEls = [0, 1, 2].map(i => root.querySelector(`[data-mai-agent="${i}"]`) as HTMLElement);
    const dotEls = [0, 1, 2].map(i => root.querySelector(`[data-mai-dot="${i}"]`) as HTMLElement);
    const checkEls = [0, 1, 2].map(i => root.querySelector(`[data-mai-check="${i}"]`) as HTMLElement);
    const responseEls = [0, 1, 2].map(i => root.querySelector(`[data-mai-response="${i}"]`) as HTMLElement);
    const statusEl = root.querySelector('[data-mai-status]') as HTMLElement;

    function resetState() {
      taskEl.classList.remove('hm-mai-vis');
      taskTextEl.textContent = '';
      agentEls.forEach(el => {
        el.classList.remove('hm-mai-vis', 'hm-mai-glow', 'hm-mai-highlight');
      });
      dotEls.forEach(el => {
        el.classList.remove('hm-mai-pulse', 'hm-mai-done');
      });
      checkEls.forEach(el => {
        el.classList.remove('hm-mai-vis');
        el.textContent = '';
      });
      responseEls.forEach(el => { el.textContent = ''; });
      agentsContainer.classList.remove('hm-mai-connected');
      statusEl.classList.remove('hm-mai-vis', 'hm-mai-success');
      statusEl.textContent = '';
    }

    // Reduced motion: show static final state
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      taskTextEl.textContent = taskText;
      taskEl.classList.add('hm-mai-vis');
      agentEls.forEach(el => el.classList.add('hm-mai-vis'));
      dotEls.forEach(el => el.classList.add('hm-mai-done'));
      checkEls.forEach(el => {
        el.textContent = '\u2713';
        el.classList.add('hm-mai-vis');
      });
      responseEls.forEach((el, i) => { el.textContent = responses[i]; });
      statusEl.textContent = bestText;
      statusEl.classList.add('hm-mai-vis', 'hm-mai-success');
      return;
    }

    let running = false;
    let animId: ReturnType<typeof setTimeout> | null = null;

    function wait(ms: number): Promise<void> {
      return new Promise(resolve => { animId = setTimeout(resolve, ms); });
    }

    async function typeText(el: HTMLElement, text: string) {
      for (let i = 0; i < text.length; i++) {
        if (!running) return;
        el.textContent += text[i];
        await wait(25 + Math.random() * 15);
      }
    }

    async function animateAgent(idx: number) {
      if (!running) return;
      // Start pulsing
      dotEls[idx].classList.add('hm-mai-pulse');
      await wait(300);
      if (!running) return;

      // Type response
      await typeText(responseEls[idx], responses[idx]);
      if (!running) return;

      // Done
      dotEls[idx].classList.remove('hm-mai-pulse');
      dotEls[idx].classList.add('hm-mai-done');
      checkEls[idx].textContent = '\u2713';
      checkEls[idx].classList.add('hm-mai-vis');
    }

    async function startLoop() {
      while (running) {
        // 0-1s: Reset. Task bar appears, agent cards visible but empty.
        resetState();
        await wait(200);
        if (!running) break;

        taskTextEl.textContent = taskText;
        taskEl.classList.add('hm-mai-vis');
        await wait(300);
        if (!running) break;

        // Show agent cards
        for (let i = 0; i < 3; i++) {
          agentEls[i].classList.add('hm-mai-vis');
          await wait(120);
          if (!running) break;
        }
        if (!running) break;
        await wait(300);
        if (!running) break;

        // 1-2.5s: Claude responds
        await animateAgent(0);
        if (!running) break;
        await wait(200);
        if (!running) break;

        // 2.5-4s: Gemini responds
        await animateAgent(1);
        if (!running) break;
        await wait(200);
        if (!running) break;

        // 4-5.5s: Codex responds
        await animateAgent(2);
        if (!running) break;
        await wait(400);
        if (!running) break;

        // 5.5-7s: Connecting glow + comparing status
        agentsContainer.classList.add('hm-mai-connected');
        agentEls.forEach(el => el.classList.add('hm-mai-glow'));
        statusEl.textContent = comparingText;
        statusEl.classList.add('hm-mai-vis');
        await wait(1500);
        if (!running) break;

        // 7-8.5s: Best result
        agentsContainer.classList.remove('hm-mai-connected');
        agentEls.forEach(el => {
          el.classList.remove('hm-mai-glow');
          el.classList.add('hm-mai-highlight');
        });
        statusEl.textContent = bestText;
        statusEl.classList.add('hm-mai-success');
        await wait(1500);
        if (!running) break;

        // 8.5-10s: Hold
        await wait(1500);
        if (!running) break;

        // 10-10.5s: Fade out, loop
        root.style.opacity = '0';
        root.style.transition = 'opacity 0.4s ease';
        await wait(500);
        if (!running) break;
        root.style.opacity = '1';
      }
    }

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting && !running) {
          running = true;
          startLoop();
        } else if (!e.isIntersecting && running) {
          running = false;
          if (animId) { clearTimeout(animId); animId = null; }
          resetState();
          root.style.opacity = '1';
        }
      });
    }, { threshold: 0.3 });
    obs.observe(root);
  })();
</script>
