---
import { getLocaleFromUrl, t, getLocalePath } from '../i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);
---

<nav class="navbar">
  <div class="navbar-inner container">
    <a href={lp('/')} class="navbar-brand">
      <span class="brand-icon">&#x276F;_</span>
      <span class="brand-text">{t(locale, 'nav.brand')}</span>
    </a>

    <div class="navbar-links">
      <a href={`${lp('/')}#why-patapim`} class="nav-link">{t(locale, 'nav.features')}</a>
      <a href={lp('/docs/getting-started/installation')} class="nav-link">{t(locale, 'nav.docs')}</a>
      <a href={lp('/pricing')} class="nav-link">{t(locale, 'nav.pricing')}</a>
      <a href={lp('/download')} class="nav-link">{t(locale, 'nav.download')}</a>
    </div>

    <div class="navbar-actions">
      <LanguageSwitcher />
      <a href="/api/auth/google" class="nav-signin" id="nav-signin" style="display:none;">{t(locale, 'nav.signIn')}</a>
      <a href={lp('/go')} class="btn btn-primary btn-nav">{t(locale, 'nav.dashboard')}</a>
    </div>

    <a href={lp('/go')} class="btn btn-primary btn-mobile-dash">{t(locale, 'nav.dashboard')}</a>
    <button class="mobile-toggle" aria-label="Toggle menu" id="mobile-toggle">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-lang-row"><LanguageSwitcher /></div>
    <a href={`${lp('/')}#why-patapim`}>{t(locale, 'nav.features')}</a>
    <a href={lp('/docs/getting-started/installation')}>{t(locale, 'nav.docs')}</a>
    <a href={lp('/pricing')}>{t(locale, 'nav.pricing')}</a>
    <a href={lp('/download')}>{t(locale, 'nav.download')}</a>
    <a href="/api/auth/google" class="mobile-signin" id="mobile-signin" style="display:none;">{t(locale, 'nav.signIn')}</a>
    <a href={lp('/go')} class="btn btn-primary" style="margin-top: 8px; justify-content: center;">{t(locale, 'nav.dashboard')}</a>
  </div>

</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(15, 15, 16, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .navbar-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 600;
    font-size: 18px;
  }

  .brand-icon {
    font-family: var(--font-mono);
    color: var(--accent-primary);
    font-size: 16px;
    background: var(--accent-subtle);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    animation: logo-icon-enter 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .brand-text {
    font-variant: small-caps;
    letter-spacing: 0.5px;
    opacity: 0;
    clip-path: inset(0 100% 0 0);
    animation: logo-text-enter 1.5s ease-out 0.3s both;
  }

  @keyframes logo-icon-enter {
    0%   { transform: scale(0); opacity: 0; }
    40%  { transform: scale(1.3); opacity: 1; }
    65%  { transform: scale(0.9); opacity: 1; }
    85%  { transform: scale(1.05); opacity: 1; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes logo-text-enter {
    0%   { opacity: 1; clip-path: inset(0 100% 0 0); text-shadow: 0 0 0px var(--accent-primary); }
    50%  { clip-path: inset(0 30% 0 0); text-shadow: 0 0 15px var(--accent-primary); }
    80%  { clip-path: inset(0 0% 0 0); text-shadow: 0 0 8px var(--accent-primary); }
    100% { opacity: 1; clip-path: inset(0 0 0 0); text-shadow: 0 0 0px transparent; }
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color var(--transition-fast);
  }
  .nav-link:hover {
    color: var(--text-primary);
  }

  .btn-nav {
    padding: 8px 20px;
    font-size: 14px;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 2px;
    transition: all var(--transition-fast);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 16px 24px 24px;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-default);
  }
  .mobile-menu a {
    display: flex;
    padding: 12px 0;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 15px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .mobile-menu a:last-child {
    border: none;
  }

  .mobile-lang-row {
    display: flex;
    justify-content: flex-end;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-subtle);
    margin-bottom: 4px;
  }

  .navbar-actions {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .nav-signin {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color var(--transition-fast);
  }
  .nav-signin:hover {
    color: var(--text-primary);
  }

  .mobile-signin {
    color: var(--text-secondary) !important;
  }

  .btn-mobile-dash {
    display: none;
  }

  @media (max-width: 768px) {
    .navbar-links, .navbar-actions { display: none; }
    .mobile-toggle { display: flex; }
    .btn-mobile-dash {
      display: inline-flex;
      padding: 6px 14px;
      font-size: 12px;
    }
    .mobile-menu.open { display: flex; }

  }
</style>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('open');
  });

  // Auth state check
  (async () => {
    try {
      const res = await fetch('/api/auth/session');
      const data = await res.json();
      if (!data.authenticated) {
        document.getElementById('nav-signin')?.style.setProperty('display', '');
        document.getElementById('mobile-signin')?.style.setProperty('display', '');
      }
    } catch {
      document.getElementById('nav-signin')?.style.setProperty('display', '');
      document.getElementById('mobile-signin')?.style.setProperty('display', '');
    }
  })();

</script>
