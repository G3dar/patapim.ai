---
import { getLocaleFromUrl, t, getLocalePath } from '../i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);

// the terminal home uses #demos; the (interim) ja home keeps the classic anchor
const featuresHref = locale === 'ja' ? `${lp('/')}#why-patapim` : `${lp('/')}#demos`;
---

<nav class="tv-nav">
  <div class="tv-nav-inner">
    <a href={lp('/')} class="tv-brand">
      <span class="tv-brand-icon">&#x276F;_</span>
      <span class="tv-brand-sep">/</span>
      <span class="tv-brand-name">{t(locale, 'nav.brand')}</span>
    </a>

    <div class="tv-nav-links">
      <a href={featuresHref}>{t(locale, 'nav.features')}</a>
      <a href={lp('/download')}>{t(locale, 'nav.download')}</a>
      <a href={lp('/docs/releases')}>{t(locale, 'nav.docs')}</a>
      <a href={lp('/about')}>{t(locale, 'nav.about')}</a>
    </div>

    <div class="tv-nav-actions">
      <LanguageSwitcher />
      <a href="/signin" class="tv-nav-signin" id="nav-signin">{t(locale, 'nav.signIn')}</a>
      <a href={lp('/go')} class="tv-nav-cta">[ {t(locale, 'nav.dashboard')} ]</a>
    </div>

    <button class="tv-nav-toggle" aria-label="Toggle menu" id="mobile-toggle">≡</button>
  </div>

  <div class="tv-nav-mobile" id="mobile-menu">
    <div class="tv-nav-lang-row"><LanguageSwitcher /></div>
    <a href={featuresHref}>{t(locale, 'nav.features')}</a>
    <a href={lp('/download')}>{t(locale, 'nav.download')}</a>
    <a href={lp('/docs/releases')}>{t(locale, 'nav.docs')}</a>
    <a href={lp('/about')}>{t(locale, 'nav.about')}</a>
    <a href="/signin" id="mobile-signin">{t(locale, 'nav.signIn')}</a>
    <a href={lp('/go')} class="tv-nav-cta">[ {t(locale, 'nav.dashboard')} ]</a>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('open');
  });

  // Auth reconcile — the header renders Sign In from the pre-paint cached
  // state (html.tv-authed, set in BaseLayout head), so it never pops in and
  // reflows the nav. This fetch only corrects the cache when the server
  // disagrees (login/logout since last visit) — a one-time self-heal.
  (async () => {
    let authed = false;
    try {
      const res = await fetch('/api/auth/session');
      authed = !!(await res.json()).authenticated;
    } catch { /* treat as anonymous */ }
    try { localStorage.setItem('ptpm-authed', authed ? '1' : '0'); } catch {}
    document.documentElement.classList.toggle('tv-authed', authed);
  })();
</script>
