---
import { getLocaleFromUrl, t } from '../i18n';
import en from '../i18n/translations/en';
import ja from '../i18n/translations/ja';

const locale = getLocaleFromUrl(Astro.url);
const translations = locale === 'ja' ? ja : en;

const icons = [
  '&#x2630;', '&#x1F310;', '&#x1F399;', '&#x2611;', '&#x1F4CB;',
  '&#x1F9E9;', '&#x1F5A5;', '&#x270F;', '&#x1F4C1;', '&#x1F504;',
  '&#x1F4BE;', '&#x1F4DD;', '&#x1F511;', '&#x2B06;', '&#x2328;',
];

const features = translations.featureGrid.features.map((f, i) => ({
  icon: icons[i],
  title: f.title,
  desc: f.desc,
  tag: f.tag,
}));
---

<section class="section feature-grid-section" id="features">
  <div class="container">
    <div class="section-header">
      <span class="section-label">{t(locale, 'featureGrid.label')}</span>
      <h2 class="section-title">{t(locale, 'featureGrid.title')}</h2>
      <p class="section-subtitle" set:html={t(locale, 'featureGrid.subtitle')} />
    </div>

    <div class="feature-grid">
      {features.map((f) => (
        <div class="feature-card glow-card">
          <div class="feature-top">
            <span class="feature-icon" set:html={f.icon} />
            <span class={`feature-tag tag-${f.tag.toLowerCase()}`}>{f.tag}</span>
          </div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc" set:html={f.desc} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .feature-card {
    padding: var(--space-xl);
  }

  .feature-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
  }

  .feature-icon {
    font-size: 28px;
    line-height: 1;
  }

  .feature-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 100px;
    font-weight: 500;
  }
  .tag-core {
    background: var(--accent-subtle);
    color: var(--accent-primary);
  }
  .tag-pro {
    background: rgba(120, 165, 212, 0.15);
    color: var(--info);
  }
  .tag-free {
    background: var(--success-subtle);
    color: var(--success);
  }

  .feature-title {
    font-size: 17px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }

  .feature-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
