---
import RemoteAccessDemo from './RemoteAccessDemo.astro';
import MultiTerminalDemo from './MultiTerminalDemo.astro';
import { getLocaleFromUrl, t } from '../i18n';
import en from '../i18n/translations/en';
import ja from '../i18n/translations/ja';

const locale = getLocaleFromUrl(Astro.url);
const translations = locale === 'ja' ? ja : en;

const contextFileIcons = ['&#x1F4C4;', '&#x1F4CA;', '&#x1F4DD;', '&#x2611;'];
---

<section class="section deep-dive">
  <div class="container">

    <!-- Deep Dive: Remote Access -->
    <div class="dive-block">
      <div class="dive-content">
        <span class="section-label">{t(locale, 'featureDeepDive.remoteLabel')}</span>
        <h2 class="dive-title">{t(locale, 'featureDeepDive.remoteTitle')}</h2>
        <p class="dive-desc">{t(locale, 'featureDeepDive.remoteDesc')}</p>
        <ul class="dive-list">
          {translations.featureDeepDive.remoteItems.map((item) => (
            <li><span class="check">&#x2714;</span> {item}</li>
          ))}
        </ul>
      </div>
      <div class="dive-visual">
        <RemoteAccessDemo />
      </div>
    </div>

    <!-- Deep Dive: Multi-Terminal + Dictation -->
    <div class="dive-block reverse">
      <div class="dive-content">
        <span class="section-label">{t(locale, 'featureDeepDive.multiVoiceLabel')}</span>
        <h2 class="dive-title">{t(locale, 'featureDeepDive.multiVoiceTitle')}</h2>
        <p class="dive-desc">{t(locale, 'featureDeepDive.multiVoiceDesc')}</p>
        <ul class="dive-list">
          {translations.featureDeepDive.multiVoiceItems.map((item) => (
            <li><span class="check">&#x2714;</span> {item}</li>
          ))}
        </ul>
      </div>
      <div class="dive-visual">
        <MultiTerminalDemo />
      </div>
    </div>

    <!-- Deep Dive: Context Preservation -->
    <div class="dive-block">
      <div class="dive-content">
        <span class="section-label">{t(locale, 'featureDeepDive.contextLabel')}</span>
        <h2 class="dive-title">{t(locale, 'featureDeepDive.contextTitle')}</h2>
        <p class="dive-desc">{t(locale, 'featureDeepDive.contextDesc')}</p>
      </div>
      <div class="dive-visual">
        <div class="files-mock">
          {translations.featureDeepDive.contextFiles.map((file, i) => (
            <div class="file-item">
              <span class="file-icon" set:html={contextFileIcons[i]} />
              <div class="file-info">
                <span class="file-name">{file.name}</span>
                <span class="file-desc">{file.desc}</span>
              </div>
              <span class="file-badge">{file.badge}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .deep-dive {
    background: var(--bg-deep);
  }

  .dive-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
    margin-bottom: var(--space-5xl);
  }
  .dive-block:last-child {
    margin-bottom: 0;
  }
  .dive-block.reverse {
    direction: rtl;
  }
  .dive-block.reverse > * {
    direction: ltr;
  }

  .dive-title {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    margin-bottom: var(--space-lg);
    line-height: 1.2;
  }

  .dive-desc {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .dive-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .dive-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .dive-list .check {
    color: var(--success);
    font-size: 14px;
    margin-top: 2px;
    flex-shrink: 0;
  }
  .dive-list code {
    font-size: 13px;
  }

  /* Files mock */
  .files-mock {
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-xl);
    padding: var(--space-lg);
    box-shadow: var(--shadow-lg);
  }
  .file-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: var(--bg-tertiary);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-default);
  }
  .file-icon {
    font-size: 24px;
    flex-shrink: 0;
  }
  .file-info {
    flex: 1;
  }
  .file-name {
    display: block;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--text-primary);
    font-weight: 500;
  }
  .file-desc {
    display: block;
    font-size: 12px;
    color: var(--text-tertiary);
  }
  .file-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--accent-primary);
    background: var(--accent-subtle);
    padding: 3px 8px;
    border-radius: 100px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .dive-block, .dive-block.reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }
    .dive-visual {
      order: -1;
    }
  }
</style>
