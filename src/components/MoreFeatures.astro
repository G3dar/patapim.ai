---
import { getLocaleFromUrl, t } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);

const features = [
  { icon: '&#x1F4DD;', title: t(locale, 'moreFeatures.contextPreservation'), desc: t(locale, 'moreFeatures.contextPreservationDesc') },
  { icon: '&#x1F4BE;', title: t(locale, 'moreFeatures.sessionPersistence'), desc: t(locale, 'moreFeatures.sessionPersistenceDesc') },
  { icon: '&#x2611;', title: t(locale, 'moreFeatures.taskManagement'), desc: t(locale, 'moreFeatures.taskManagementDesc') },
  { icon: '&#x1F4CB;', title: t(locale, 'moreFeatures.githubIntegration'), desc: t(locale, 'moreFeatures.githubIntegrationDesc') },
  { icon: '&#x1F9E9;', title: t(locale, 'moreFeatures.pluginSystem'), desc: t(locale, 'moreFeatures.pluginSystemDesc') },
  { icon: '&#x270F;', title: t(locale, 'moreFeatures.fileEditor'), desc: t(locale, 'moreFeatures.fileEditorDesc') },
  { icon: '&#x2328;', title: t(locale, 'moreFeatures.keyboardFirst'), desc: t(locale, 'moreFeatures.keyboardFirstDesc') },
];
---

<section class="section more-features" id="more-features">
  <div class="container">
    <div class="section-header">
      <span class="section-label">{t(locale, 'moreFeatures.label')}</span>
      <h2 class="section-title">{t(locale, 'moreFeatures.title')}</h2>
    </div>

    <div class="mf-grid">
      {features.map((f) => (
        <div class="mf-item">
          <span class="mf-icon" set:html={f.icon} />
          <span class="mf-title">{f.title}</span>
          <span class="mf-sep">&mdash;</span>
          <span class="mf-desc" set:html={f.desc} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .more-features {
    background: var(--bg-deep);
    scroll-margin-top: 120px;
  }

  .mf-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .mf-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 14px;
    line-height: 1.4;
  }
  .mf-item:nth-last-child(-n+2) {
    border-bottom: none;
  }

  .mf-icon {
    font-size: 18px;
    flex-shrink: 0;
    width: 24px;
    text-align: center;
  }

  .mf-title {
    color: var(--text-primary);
    font-weight: 500;
    white-space: nowrap;
  }

  .mf-sep {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .mf-desc {
    color: var(--text-secondary);
    font-size: 13px;
  }

  @media (max-width: 768px) {
    .mf-grid {
      grid-template-columns: 1fr;
    }
    .mf-item:last-child {
      border-bottom: none;
    }
    .mf-item:nth-last-child(2) {
      border-bottom: 1px solid var(--border-subtle);
    }
  }

  @media (max-width: 480px) {
    .mf-item {
      flex-wrap: wrap;
    }
    .mf-sep { display: none; }
    .mf-desc {
      flex-basis: 100%;
      padding-left: 34px;
      margin-top: -4px;
    }
  }
</style>
