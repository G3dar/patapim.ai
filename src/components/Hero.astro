---
import HeroMiniMultiTerminal from './HeroMiniMultiTerminal.astro';
import HeroMiniVoiceDictation from './HeroMiniVoiceDictation.astro';
import HeroMiniRemoteAccess from './HeroMiniRemoteAccess.astro';
import HeroMiniConnectedTabs from './HeroMiniConnectedTabs.astro';
import HeroMiniConnectedInstances from './HeroMiniConnectedInstances.astro';
import HeroMiniIntegratedBrowser from './HeroMiniIntegratedBrowser.astro';
import HeroMiniSessionRestore from './HeroMiniSessionRestore.astro';
import HeroMiniWhatsappGmail from './HeroMiniWhatsappGmail.astro';
import HeroMiniFocusMode from './HeroMiniFocusMode.astro';
import { getLocaleFromUrl, t, getLocalePath } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalePath(locale, path);
---

<section class="hero">
  <div class="hero-bg-grid"></div>
  <div class="container hero-inner">

    <!-- New main headline -->
    <h1 class="hero-title">
      {t(locale, 'hero.titleLine1')} <span class="hero-title-mid">{t(locale, 'hero.titleMid')}</span><br/>
      <span class="hero-brainrot-accent">{t(locale, 'hero.titleAccent')}</span>
    </h1>

    <p class="hero-subtitle" set:html={t(locale, 'hero.subtitle')} />

    <!-- Brain Rot Demo Video -->
    <div class="hero-video-wrapper">
      <video class="hero-video" muted loop playsinline autoplay preload="metadata" src="/hero-brainrot.mp4"></video>
    </div>

    <!-- Prominent download CTA that echoes the video's green/amber palette -->
    <div class="hero-download-wrapper">
      <a href={lp('/download')} class="hero-download-btn" aria-label={t(locale, 'nav.download')}>
        <span class="hdl-glow" aria-hidden="true"></span>
        <span class="hdl-content">
          <svg class="hdl-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M10 2.5v10m0 0l-4-4m4 4l4-4M3.75 16.25h12.5" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="hdl-text">{t(locale, 'nav.download')}</span>
        </span>
        <span class="hdl-shimmer" aria-hidden="true"></span>
      </a>
    </div>

    <!-- Three mini-demo animations -->
    <div class="hero-features">
      <div class="hero-feature-item">
        <HeroMiniMultiTerminal />
        <div class="hf-text">
          <span class="hf-label">{t(locale, 'hero.multiProject')}</span>
          <p class="hf-desc">{t(locale, 'hero.multiProjectDesc')}</p>
        </div>
      </div>
      <div class="hero-feature-item">
        <HeroMiniVoiceDictation />
        <div class="hf-text">
          <span class="hf-label">{t(locale, 'hero.voiceDictation')}</span>
          <p class="hf-desc">{t(locale, 'hero.voiceDictationDesc')}</p>
        </div>
      </div>
      <div class="hero-feature-item">
        <HeroMiniRemoteAccess />
        <div class="hf-text">
          <span class="hf-label">{t(locale, 'hero.remoteControl')}</span>
          <p class="hf-desc">{t(locale, 'hero.remoteControlDesc')}</p>
        </div>
      </div>
      <div class="hero-feature-item">
        <HeroMiniConnectedTabs />
        <div class="hf-text">
          <span class="hf-label">{t(locale, 'hero.connectedTabs')}</span>
          <p class="hf-desc">{t(locale, 'hero.connectedTabsDesc')}</p>
        </div>
      </div>
      <div class="hero-feature-item">
        <HeroMiniConnectedInstances />
        <div class="hf-text">
          <span class="hf-label">{t(locale, 'hero.connectedInstances')}</span>
          <p class="hf-desc">{t(locale, 'hero.connectedInstancesDesc')}</p>
        </div>
      </div>
      <div class="hero-feature-item">
        <HeroMiniIntegratedBrowser />
        <div class="hf-text">
          <span class="hf-label">{t(locale, 'hero.integratedBrowser')}</span>
          <p class="hf-desc">{t(locale, 'hero.integratedBrowserDesc')}</p>
        </div>
      </div>
      <div class="hero-feature-item">
        <HeroMiniSessionRestore />
        <div class="hf-text">
          <span class="hf-label">{t(locale, 'hero.sessionRestore')}</span>
          <p class="hf-desc">{t(locale, 'hero.sessionRestoreDesc')}</p>
        </div>
      </div>
      <div class="hero-feature-item">
        <HeroMiniWhatsappGmail />
        <div class="hf-text">
          <span class="hf-label">{t(locale, 'hero.whatsappGmail')}</span>
          <p class="hf-desc">{t(locale, 'hero.whatsappGmailDesc')}</p>
        </div>
      </div>
      <div class="hero-feature-item">
        <HeroMiniFocusMode />
        <div class="hf-text">
          <span class="hf-label">{t(locale, 'hero.focusMode')}</span>
          <p class="hf-desc">{t(locale, 'hero.focusModeDesc')}</p>
        </div>
      </div>
    </div>

    <div class="hero-install-section">
      <div class="hero-install">
        <div class="hero-install-tabs">
          <button class="hi-tab active" data-hero-tab="cmd">{t(locale, 'hero.tabCmd')}</button>
          <button class="hi-tab" data-hero-tab="ps">{t(locale, 'hero.tabPowerShell')}</button>
          <button class="hi-tab" data-hero-tab="mac">{t(locale, 'hero.tabMacOS')}</button>
        </div>
        <div class="hero-install-panels">
          <div class="hi-panel active" data-hero-panel="cmd">
            <div class="hi-line" data-hero-copy='curl -fsSL https://raw.githubusercontent.com/G3dar/patapim-releases/main/install.cmd -o "%TEMP%\patapim-install.cmd" && "%TEMP%\patapim-install.cmd"'>
              <span class="hi-prompt">C:\&gt;</span>
              <code>curl -fsSL https://raw.githubusercontent.com/G3dar/patapim-releases/main/install.cmd -o "%TEMP%\patapim-install.cmd" &amp;&amp; "%TEMP%\patapim-install.cmd"</code>
              <button class="hi-copy-btn" aria-label={t(locale, 'common.copyToClipboard')}>
                <svg class="hi-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="hi-check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
          </div>
          <div class="hi-panel" data-hero-panel="ps">
            <div class="hi-line" data-hero-copy="irm https://raw.githubusercontent.com/G3dar/patapim-releases/main/install.ps1 | iex">
              <span class="hi-prompt">PS&gt;</span>
              <code>irm https://raw.githubusercontent.com/G3dar/patapim-releases/main/install.ps1 | iex</code>
              <button class="hi-copy-btn" aria-label={t(locale, 'common.copyToClipboard')}>
                <svg class="hi-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="hi-check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
          </div>
          <div class="hi-panel" data-hero-panel="mac">
            <div class="hi-line" data-hero-copy="curl -fsSL https://raw.githubusercontent.com/G3dar/patapim-releases/main/install-mac.sh | bash">
              <span class="hi-prompt">$</span>
              <code>curl -fsSL https://raw.githubusercontent.com/G3dar/patapim-releases/main/install-mac.sh | bash</code>
              <button class="hi-copy-btn" aria-label={t(locale, 'common.copyToClipboard')}>
                <svg class="hi-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="hi-check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
          </div>
        </div>
        <div class="hero-install-meta">
          <span>{t(locale, 'hero.metaWindows')}</span>
          <span class="meta-dot">&#x2022;</span>
          <span>{t(locale, 'hero.metaMacOS')}</span>
          <span class="meta-dot">&#x2022;</span>
          <a href={lp('/download')} class="meta-link">{t(locale, 'hero.metaDownloadPage')}</a>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 140px 0 80px;
    overflow: hidden;
    min-height: 90vh;
    display: flex;
    align-items: center;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(212, 165, 116, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 165, 116, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 60% 50% at 50% 40%, black, transparent);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 40%, black, transparent);
  }

  .hero-inner {
    position: relative;
    text-align: center;
  }

  .hero-title {
    font-size: clamp(40px, 7vw, 80px);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-xl);
    letter-spacing: -2px;
  }

  .hero-title-mid {
    font-size: clamp(18px, 3vw, 34px);
    font-weight: 400;
    letter-spacing: -0.5px;
    color: var(--text-tertiary);
  }

  .hero-brainrot-accent {
    font-size: clamp(52px, 9vw, 110px);
    background: linear-gradient(135deg, #d4a574, #8bb04a, #d4a574);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 100%;
    animation: brainrot-shimmer 3s ease-in-out infinite;
    letter-spacing: -3px;
    font-weight: 800;
  }

  @keyframes brainrot-shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .hero-subtitle {
    font-size: clamp(16px, 2vw, 20px);
    color: var(--text-secondary);
    max-width: 620px;
    margin: 0 auto var(--space-2xl);
    line-height: 1.7;
  }

  /* Brain rot demo video */
  .hero-video-wrapper {
    position: relative;
    max-width: 600px;
    margin: 0 auto var(--space-3xl);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border-default);
    cursor: pointer;
  }

  .hero-video {
    display: block;
    width: 100%;
    border-radius: 16px;
  }

  /* Prominent download CTA — echoes the jungle-green + CRT-amber palette of the hero video */
  .hero-download-wrapper {
    display: flex;
    justify-content: center;
    margin: calc(var(--space-2xl) * -1 + 4px) auto var(--space-3xl);
    position: relative;
    z-index: 2;
  }

  .hero-download-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 15px 34px;
    border-radius: 999px;
    text-decoration: none;
    color: #1a1208;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.01em;
    background-image: linear-gradient(115deg, #e8a971 0%, #d4a574 30%, #b5bd5e 55%, #8bb04a 80%, #a8bd5a 100%);
    background-size: 180% 100%;
    background-position: 20% 50%;
    border: 1px solid rgba(255, 220, 180, 0.4);
    box-shadow:
      0 0 0 1px rgba(212, 165, 116, 0.18),
      0 14px 34px -8px rgba(212, 165, 116, 0.5),
      0 8px 18px -4px rgba(139, 176, 74, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.35);
    overflow: hidden;
    isolation: isolate;
    transition: transform 260ms cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 260ms ease;
    animation: hdl-breathe 3.2s ease-in-out infinite, hdl-drift 7s ease-in-out infinite;
  }

  .hero-download-btn:hover {
    transform: translateY(-2px);
    box-shadow:
      0 0 0 1px rgba(212, 165, 116, 0.3),
      0 20px 46px -8px rgba(224, 150, 96, 0.65),
      0 12px 26px -6px rgba(139, 176, 74, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.45);
  }

  .hero-download-btn:active {
    transform: translateY(0);
  }

  .hdl-content {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .hdl-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    animation: hdl-bounce 2.2s cubic-bezier(0.34, 1.56, 0.64, 1) infinite;
  }

  .hero-download-btn:hover .hdl-icon {
    animation-duration: 1s;
  }

  .hdl-text {
    line-height: 1;
  }

  /* Soft conic glow sitting behind the button */
  .hdl-glow {
    position: absolute;
    inset: -40%;
    z-index: 0;
    background: conic-gradient(from 0deg, rgba(224, 150, 96, 0.55), rgba(139, 176, 74, 0.5), rgba(224, 150, 96, 0.55));
    filter: blur(22px);
    opacity: 0.55;
    animation: hdl-spin 8s linear infinite;
    pointer-events: none;
  }

  /* Specular shimmer that sweeps across on hover and periodically */
  .hdl-shimmer {
    position: absolute;
    top: 0;
    left: -40%;
    width: 40%;
    height: 100%;
    z-index: 1;
    background: linear-gradient(100deg, transparent 20%, rgba(255, 255, 255, 0.45) 50%, transparent 80%);
    transform: skewX(-20deg);
    animation: hdl-shimmer 4.5s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes hdl-drift {
    0%, 100% { background-position: 20% 50%; }
    50% { background-position: 80% 50%; }
  }

  @keyframes hdl-breathe {
    0%, 100% {
      box-shadow:
        0 0 0 1px rgba(212, 165, 116, 0.15),
        0 12px 32px -8px rgba(212, 165, 116, 0.45),
        0 6px 16px -4px rgba(139, 176, 74, 0.35),
        inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }
    50% {
      box-shadow:
        0 0 0 1px rgba(212, 165, 116, 0.25),
        0 16px 38px -6px rgba(224, 150, 96, 0.55),
        0 8px 20px -4px rgba(139, 176, 74, 0.5),
        inset 0 1px 0 rgba(255, 255, 255, 0.35);
    }
  }

  @keyframes hdl-bounce {
    0%, 75%, 100% { transform: translateY(0); }
    10% { transform: translateY(-2px); }
    25% { transform: translateY(3px); }
    40% { transform: translateY(0); }
  }

  @keyframes hdl-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes hdl-shimmer {
    0%, 40% { left: -40%; }
    70%, 100% { left: 120%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-download-btn,
    .hdl-icon,
    .hdl-glow,
    .hdl-shimmer {
      animation: none;
    }
  }


  /* Install section */
  .hero-install-section {
    margin-top: var(--space-4xl);
    padding-top: var(--space-3xl);
    border-top: 1px solid var(--border-default);
  }

  /* Install command block */
  .hero-install {
    max-width: 680px;
    margin: 0 auto;
  }

  .hero-install-tabs {
    display: flex;
    gap: 2px;
    justify-content: center;
    margin-bottom: 0;
  }

  .hi-tab {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-default);
    border-bottom: none;
    padding: 6px 18px;
    border-radius: 6px 6px 0 0;
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .hi-tab:hover { color: var(--text-secondary); }
  .hi-tab.active {
    color: var(--text-primary);
    background: var(--bg-deep);
    border-color: var(--border-strong);
  }

  .hero-install-panels {
    background: var(--bg-deep);
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    overflow: hidden;
  }

  .hi-panel { display: none; }
  .hi-panel.active { display: block; }

  .hi-line {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 18px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-secondary);
    cursor: pointer;
    transition: border-color 0.3s ease;
    word-break: break-all;
    line-height: 1.6;
  }
  .hi-line:hover { background: rgba(212, 165, 116, 0.03); }
  .hi-line.copied {
    border-color: var(--success);
    box-shadow: inset 0 0 0 1px var(--success);
  }

  .hi-prompt {
    color: var(--accent-primary);
    flex-shrink: 0;
    font-weight: 500;
  }

  .hi-line code {
    flex: 1;
    min-width: 0;
    color: var(--text-secondary);
  }

  .hi-copy-btn {
    flex-shrink: 0;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-default);
    border-radius: 4px;
    padding: 5px;
    cursor: pointer;
    color: var(--text-muted);
    transition: all var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hi-copy-btn:hover {
    color: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .hi-check-icon { display: none; }
  .hi-copy-btn.copied .hi-copy-icon { display: none; }
  .hi-copy-btn.copied .hi-check-icon { display: block; }
  .hi-copy-btn.copied {
    color: var(--success);
    border-color: var(--success);
  }

  .hero-install-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 12px;
    font-size: 13px;
    color: var(--text-muted);
  }
  .meta-dot { font-size: 8px; }
  .meta-link {
    color: var(--accent-primary);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }
  .meta-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  /* Feature mini demos */
  .hero-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    justify-items: center;
    gap: var(--space-3xl) var(--space-2xl);
    margin-top: var(--space-4xl);
    max-width: 1140px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    max-width: 340px;
  }

  .hf-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .hf-label {
    font-family: var(--font-mono);
    font-size: 15px;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    font-weight: 600;
  }

  .hf-desc {
    font-size: 13px;
    color: var(--text-tertiary);
    line-height: 1.5;
    text-align: center;
    max-width: 300px;
    margin: 0;
  }

  @media (max-width: 768px) {
    .hero { padding: 120px 0 60px; min-height: auto; }
    .hero-install { max-width: 100%; }
    .hi-line { font-size: 11px; padding: 12px 14px; }
    .hi-tab { font-size: 11px; padding: 5px 14px; }
    .hero-features { grid-template-columns: repeat(2, 1fr); gap: var(--space-xl); }
    .hf-label { font-size: 13px; }
    .hf-desc { font-size: 12px; max-width: 280px; }
    .hero-video-wrapper { max-width: 100%; }
    .hero-install-section { margin-top: var(--space-3xl); padding-top: var(--space-2xl); }
  }

  @media (max-width: 480px) {
    .hi-line { font-size: 10px; padding: 10px 12px; }
    .hi-prompt { display: none; }
    .hero-video-wrapper { border-radius: 12px; }
    .hero-video { border-radius: 12px; }
    .hero-video-overlay { border-radius: 12px; }
    .hero-features { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Install tabs
  const heroTabs = document.querySelectorAll('[data-hero-tab]');
  const heroPanels = document.querySelectorAll('[data-hero-panel]');

  function activateHeroTab(tabId: string) {
    heroTabs.forEach(t => t.classList.remove('active'));
    heroPanels.forEach(p => p.classList.remove('active'));
    const tab = document.querySelector(`[data-hero-tab="${tabId}"]`);
    const panel = document.querySelector(`[data-hero-panel="${tabId}"]`);
    tab?.classList.add('active');
    panel?.classList.add('active');
  }

  heroTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.heroTab;
      if (target) activateHeroTab(target);
    });
  });

  // Auto-detect platform: show macOS tab for Mac users
  if (/Mac|iPhone|iPad/.test(navigator.userAgent)) {
    activateHeroTab('mac');
  }

  // Copy to clipboard
  function heroCopyText(text: string): Promise<void> {
    if (navigator.clipboard?.writeText) {
      return navigator.clipboard.writeText(text);
    }
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed';
    ta.style.opacity = '0';
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    return Promise.resolve();
  }

  document.querySelectorAll('.hi-line[data-hero-copy]').forEach(line => {
    const handleCopy = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      const el = line as HTMLElement;
      const text = el.dataset.heroCopy;
      const btn = el.querySelector('.hi-copy-btn');
      if (text) {
        heroCopyText(text).then(() => {
          el.classList.add('copied');
          btn?.classList.add('copied');
          setTimeout(() => {
            el.classList.remove('copied');
            btn?.classList.remove('copied');
          }, 1500);
        }).catch(() => {
          el.classList.add('copied');
          btn?.classList.add('copied');
          setTimeout(() => {
            el.classList.remove('copied');
            btn?.classList.remove('copied');
          }, 1500);
        });
      }
    };
    line.addEventListener('click', handleCopy);
  });
</script>
